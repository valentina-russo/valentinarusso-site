# Grav locale — plugin non deployati (già installati su Aruba)
grav-site/user/plugins/*
# Eccezione: plugin custom non installabile via Grav admin, va in git
!grav-site/user/plugins/valentina-admin
grav-site/user/data/
grav-site/user/cache/
# Pagine: gestite SOLO da Grav Admin sul server, mai da git
# Usa /* (non /) per permettere eccezioni su sottocartelle specifiche
grav-site/user/pages/*
# Eccezione: pagina workshop (landing B2B statica, deployata via FTP)
!grav-site/user/pages/workshop-proposta
# Eccezione: tool HD Relazionale (pagina + template deployati via FTP)
!grav-site/user/pages/hd-relazionale
# Eccezioni: nuovi articoli bozza privati (deployati via FTP, dentro /blog/articoli)
!grav-site/user/pages/04.blog
grav-site/user/pages/04.blog/*
!grav-site/user/pages/04.blog/articoli
grav-site/user/pages/04.blog/articoli/*
