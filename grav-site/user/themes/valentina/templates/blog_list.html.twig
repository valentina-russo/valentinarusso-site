{% extends 'partials/base.html.twig' %}

{% block title %}{{ page.title }} | Valentina Russo{% endblock %}

{% block content %}
<main class="section-padding">
    <div class="container">
        <h1 class="text-center" style="margin-bottom: 0.5rem;" data-animate>{{ page.title }}</h1>
        {% if page.header.description is defined %}
        <p class="text-center serif italic" style="color: var(--primary-color); margin-bottom: var(--space-lg);" data-animate>
            {{ page.header.description }}
        </p>
        {% endif %}

        {% set collection = page.collection() %}

        {% if collection is empty %}
        <p class="text-center" style="color: var(--text-muted, #777); margin-top: 3rem;">Nessun articolo disponibile al momento.</p>
        {% else %}
        <div class="blog-grid" id="blog-grid">
            {% for article in collection %}
            <article class="blog-card" data-category="{{ page.header.category ?? 'privati' }}">
                {% set card_img = '' %}
                {# 1. featured_image filename semplice (no slash) → lookup diretto nei media della pagina #}
                {% if article.header.featured_image is defined and article.header.featured_image and '/' not in article.header.featured_image %}
                  {% set _fm = article.media[article.header.featured_image] %}
                  {% if _fm %}{% set card_img = _fm.url %}{% endif %}
                {% endif %}
                {# 2. Prima immagine dai page media — usa filtro built-in Grav (solo immagini, esclude audio/file) #}
                {% if not card_img %}
                  {% set _imgs = article.media.images %}
                  {% if _imgs|length %}{% set card_img = _imgs|first.url %}{% endif %}
                {% endif %}
                {# 3. featured_image percorso assoluto legacy (es. /user/images/blog/...) — MAI /user/pages/ che non è un URL pubblico #}
                {% if not card_img and article.header.featured_image is defined and article.header.featured_image %}
                  {% set _fi = article.header.featured_image %}
                  {% if '/' in _fi and 'placeholder' not in _fi and '/user/pages/' not in _fi %}
                    {% set card_img = _fi %}
                  {% endif %}
                {% endif %}
                {# 4. Nessuna immagine trovata: non mostrare nulla (no fallback ingannevole) #}
                {% if card_img %}
                <div class="blog-card-image">
                    <img src="{{ card_img }}"
                         alt="{{ article.header.image_alt ?? article.title }}"
                         loading="lazy">
                </div>
                {% endif %}
                <div class="blog-card-content">
                    {% if article.header.tags is defined and article.header.tags %}
                    <div style="margin-bottom: 0.5rem;">
                        {% for tag in (article.header.tags is iterable ? article.header.tags : article.header.tags|split(',')) %}
                        <span class="article-tag">{{ tag|trim }}</span>
                        {% endfor %}
                    </div>
                    {% endif %}
                    <h3>{{ article.title }}</h3>
                    {% if article.header.description is defined %}
                    <p class="text-small" style="color: var(--text-muted, #777); line-height: 1.6;">
                        {{ article.header.description|slice(0, 120) }}{% if article.header.description|length > 120 %}...{% endif %}
                    </p>
                    {% endif %}
                    <div style="margin-top: 0.5rem; font-size: 0.75rem; color: #aaa;">
                        {{ article.date|date("d M Y") }}
                        {% if article.header.author is defined %}&mdash; {{ article.header.author }}{% endif %}
                    </div>
                    <a href="{{ article.url }}" class="btn-blog-link" style="margin-top: 1rem;">Leggi &rarr;</a>
                </div>
            </article>
            {% endfor %}
        </div>

        {# Grav Pagination #}
        {% if config.plugins.pagination.enabled and collection is defined %}
            {% include 'partials/pagination.html.twig' %}
        {% endif %}
        {% endif %}
    </div>
</main>
{% endblock %}
