async function calcolaConnessione(){
  const dateVal=document.getElementById('gcb-b-date').value;
  const timeVal=document.getElementById('gcb-b-time').value;
  const dateParts=dateVal?dateVal.split('-'):[];
  const timeParts=timeVal?timeVal.split(':'):[];
  const y=dateParts[0]?parseInt(dateParts[0]):NaN;
  const m=dateParts[1]?parseInt(dateParts[1]):NaN;
  const d=dateParts[2]?parseInt(dateParts[2]):NaN;
  const h=timeParts[0]!==undefined?parseInt(timeParts[0]):NaN;
  const min=timeParts[1]!==undefined?parseInt(timeParts[1]):NaN;
  const tz=document.getElementById('gcb-b-tz').value,nome=document.getElementById('gcb-b-nome').value.trim(),city=document.getElementById('gcb-b-city').value.trim();
  if(!city){mostraErroreB('Inserisci il luogo di nascita della seconda persona.');document.getElementById('gcb-b-city').focus();return;}
  if(!d||!m||!y||isNaN(h)||isNaN(min)){mostraErroreB('Compila data, ora e luogo di nascita della seconda persona.');return;}
  if(y<1900||y>2050){mostraErroreB('Anno non valido.');return;}
  if(!_lastChartA){mostraErroreB('Prima calcola la carta della Persona A.');return;}
  document.getElementById('gcb-error-b').style.display='none';
  document.getElementById('gcb-results').style.display='none';
  document.getElementById('gcb-loading-b').style.display='block';
  document.getElementById('gcb-calcola-b-btn').disabled=true;
  try{
    const localDt=new Date(y,m-1,d,h,min);
    const tzDate=new Date(localDt.toLocaleString('en-US',{timeZone:tz}));
    const utcDate=new Date(localDt.toLocaleString('en-US',{timeZone:'UTC'}));
    const tzOffset=(tzDate-utcDate)/3600000;
    const dataRaw=await calculateHDChart(y,m,d,h,min,tzOffset);
    if(dataRaw.environment_name){dataRaw.environment=dataRaw.environment_name;delete dataRaw.environment_name;}
    const dataB=normalizzaRisposta(dataRaw);if(!dataB)throw new Error('Formato risposta non riconosciuto.');
    _lastChartB=dataB;_lastNomeB=nome;
    await renderConnectionChart(_lastChartA,dataB,_lastCartaNome||'Persona A',nome||'Persona B');
  }catch(e){mostraErroreB(e.message||'Errore nel calcolo. Riprova.');}
  finally{document.getElementById('gcb-loading-b').style.display='none';document.getElementById('gcb-calcola-b-btn').disabled=false;}
}

async function renderConnectionChart(chartA,chartB,nomeA,nomeB){
  const activeA=new Set(Object.keys(chartA.gate_colors).map(Number));
  const activeB=new Set(Object.keys(chartB.gate_colors).map(Number));
  const allActive=new Set([...activeA,...activeB]);
  const emGates=new Set(),emChannels=[],dominanzaChannels=[],compromessoGates=[];
  for(const [g1,g2] of HD_CHANNELS){
    const a1=activeA.has(g1),a2=activeA.has(g2),b1=activeB.has(g1),b2=activeB.has(g2);
    if((a1&&!a2&&!b1&&b2)||(!a1&&a2&&b1&&!b2)){emGates.add(g1);emGates.add(g2);emChannels.push({gates:[g1,g2]});}
    const aFull=a1&&a2,bFull=b1&&b2,aNone=!a1&&!a2,bNone=!b1&&!b2;
    if(aFull&&bNone)dominanzaChannels.push({gates:[g1,g2],dominant:'A'});
    if(bFull&&aNone)dominanzaChannels.push({gates:[g1,g2],dominant:'B'});
    // Compromesso: una persona ha il canale completo, l'altra ha solo UNA delle due porte
    if(aFull&&!bFull&&(b1||b2))compromessoGates.push({gates:[g1,g2],dominant:'A',disadvantaged:'B',disadvantagedGate:b1?g1:g2});
    if(bFull&&!aFull&&(a1||a2))compromessoGates.push({gates:[g1,g2],dominant:'B',disadvantaged:'A',disadvantagedGate:a1?g1:g2});
  }
  const compositeGateColors={};
  for(const g of allActive){const inA=activeA.has(g),inB=activeB.has(g);if(inA&&inB)compositeGateColors[String(g)]='AB';else if(emGates.has(g))compositeGateColors[String(g)]='EM';else if(inA)compositeGateColors[String(g)]='A';else compositeGateColors[String(g)]='B';}
  const compDefChan=hdGetDefinedChannels(allActive).map(([a,b])=>{const ch=CHANNELS.find(([c1,c2])=>(c1===a&&c2===b)||(c1===b&&c2===a));return ch||[a,b,HD_GATE_CENTER[a]||'',HD_GATE_CENTER[b]||''];});
  const compDefCenters=hdGetDefinedCenters(allActive);
  _gcbRendered.a=false;_gcbRendered.b=false;_gcbRendered.conn=false;
  const legA=document.getElementById('gcb-legend-a'),legB=document.getElementById('gcb-legend-b');if(legA)legA.textContent=nomeA;if(legB)legB.textContent=nomeB;
  const lblA=document.getElementById('gcb-label-a'),lblB=document.getElementById('gcb-label-b');if(lblA)lblA.textContent=nomeA;if(lblB)lblB.textContent=nomeB;
  const tabA=document.getElementById('gcb-tab-a'),tabB=document.getElementById('gcb-tab-b');if(tabA)tabA.textContent=nomeA;if(tabB)tabB.textContent=nomeB;
  const title=document.getElementById('gcb-conn-title'),sub=document.getElementById('gcb-conn-subtitle');
  if(title)title.textContent=`${nomeA} & ${nomeB}`;
  if(sub)sub.textContent=`${emChannels.length} canali EM · ${dominanzaChannels.length} dominanza · ${compromessoGates.length} compromesso`;
  await loadAndRenderBodygraph(compositeGateColors,compDefChan,compDefCenters,null,null,null,'gcb-bg-conn',true);
  _gcbRendered.conn=true;
  const z2el=document.getElementById('gcb-zone-2');
  if(z2el){z2el.classList.add('gcb-zone-2--has-results');z2el.style.display='block';requestAnimationFrame(()=>requestAnimationFrame(()=>{z2el.classList.add('gcb-zone-2--visible');}));}
  document.getElementById('gcb-results').style.display='block';
  gcbSetTab('conn');
  setTimeout(()=>{document.getElementById('gcb-results')?.scrollIntoView({behavior:'smooth',block:'start'});},60);
  renderEmAnalysis(emChannels,dominanzaChannels,compromessoGates,nomeA,nomeB);
  renderBodygraphA();
  renderBodygraphB();
}

function renderEmAnalysis(emChannels,dominanzaChannels,compromessoGates,nomeA,nomeB){
  const el=document.getElementById('gcb-em-analysis');if(!el)return;
  let html='';
  if(emChannels.length>0)html+=`<div class="gcb-em-card"><div class="gcb-em-card-title"><span class="gcb-em-dot gcb-em-dot--em"></span>Canali Elettromagnetici<span class="gcb-em-count-badge">${emChannels.length}</span></div><div class="gcb-em-card-body"><p>${escHtml(nomeA)} e ${escHtml(nomeB)} si completano su questi canali — uno ha un gate, l'altro ha quello opposto. La connessione EM attiva qualcosa che nessuno dei due possiede da solo.</p><ul>${emChannels.map(c=>`<li>Canale ${c.gates[0]}–${c.gates[1]}</li>`).join('')}</ul></div></div>`;
  if(dominanzaChannels.length>0){const dA=dominanzaChannels.filter(c=>c.dominant==='A'),dB=dominanzaChannels.filter(c=>c.dominant==='B');html+=`<div class="gcb-em-card"><div class="gcb-em-card-title"><span class="gcb-em-dot gcb-em-dot--a"></span>Canali di Dominanza<span class="gcb-em-count-badge">${dominanzaChannels.length}</span></div><div class="gcb-em-card-body"><p>Un partner ha il canale completo, l'altro non attiva nessuno dei due gate. Chi ha il canale porta quella frequenza nella relazione.</p>${dA.length?`<p><strong>${escHtml(nomeA)}:</strong> ${dA.map(c=>c.gates.join('–')).join(', ')}</p>`:''}${dB.length?`<p><strong>${escHtml(nomeB)}:</strong> ${dB.map(c=>c.gates.join('–')).join(', ')}</p>`:''}</div></div>`;}
  if(compromessoGates.length>0){
    const rows=compromessoGates.map(c=>{
      const domName=c.dominant==='A'?escHtml(nomeA):escHtml(nomeB);
      const disName=c.disadvantaged==='A'?escHtml(nomeA):escHtml(nomeB);
      return`<li>Canale ${c.gates[0]}–${c.gates[1]} — ${domName} ha il canale completo, ${disName} porta solo la porta ${c.disadvantagedGate}: non viene riconosciuta da ${domName} perché quel canale è già presente nel suo disegno.</li>`;
    }).join('');
    html+=`<div class="gcb-em-card"><div class="gcb-em-card-title"><span class="gcb-em-dot gcb-em-dot--ab"></span>Canali di Compromesso<span class="gcb-em-count-badge">${compromessoGates.length}</span></div><div class="gcb-em-card-body"><p>Una persona ha il canale completo, l'altra porta solo una delle due porte. Chi ha il canale intero non riesce a vedere né a riconoscere nell'altra la porta che porta.</p><ul>${rows}</ul></div></div>`;
  }
  if(!html)html=`<div class="gcb-em-card"><div class="gcb-em-card-body"><p>Nessun canale condiviso o elettromagnetico tra ${escHtml(nomeA)} e ${escHtml(nomeB)}. Le due carte sono energeticamente indipendenti.</p></div></div>`;
  el.innerHTML=html;el.style.display='block';
}

document.addEventListener('keydown',e=>{if(e.key==='Enter'){const ae=document.activeElement;if(ae&&ae.id&&(ae.id.startsWith('cf-')||ae.closest('#gcb-zone-1')))calcolaCarta();}});

// ─── Touch swipe carousel ─────────────────────────────────────────────────────
(function(){
  let _ts=null;
  const wrap=document.querySelector('.gcb-panels-grid');
  if(!wrap)return;
  wrap.addEventListener('touchstart',e=>{_ts=e.touches[0].clientX;},{passive:true});
  wrap.addEventListener('touchend',e=>{
    if(_ts===null)return;
    const dx=e.changedTouches[0].clientX-_ts;
    _ts=null;
    if(Math.abs(dx)<45)return;
    const tabs=['a','conn','b'];
    const curIdx=tabs.indexOf(_gcbCurrentTab);
    if(dx<0&&curIdx<2)gcbSetTab(tabs[curIdx+1]);
    else if(dx>0&&curIdx>0)gcbSetTab(tabs[curIdx-1]);
  },{passive:true});
})();

{% if page.header.hd_account_enabled %}
// ─── Salva Carta ──────────────────────────────────────────────────────────────
const HD_BASE='https://valentinarussobg5.com';

// ─── Account chart picker ──────────────────────────────────────────────────────
let _gcbPickerTarget=null,_gcbPickerCharts=null;
async function gcbPickerOpen(target){
  _gcbPickerTarget=target;
  const overlay=document.getElementById('gcb-picker-overlay'),listEl=document.getElementById('gcb-picker-list');
  if(!overlay||!listEl)return;
  listEl.innerHTML='<div style="text-align:center;padding:2rem;color:#888;font-size:0.9rem;">Caricamento…</div>';
  overlay.classList.add('gcb-picker-overlay--open');
  try{
    if(!_gcbPickerCharts){
      const r=await fetch(HD_BASE+'/hd-charts.php?action=list',{credentials:'include'}),j=await r.json();
      if(!j.ok)throw new Error(j.error||'Non autenticato');
      _gcbPickerCharts=j.data||[];
    }
    if(_gcbPickerCharts.length===0){
      listEl.innerHTML='<div style="text-align:center;padding:2rem;color:#888;font-size:0.88rem;">Nessuna carta salvata ancora.<br>Calcola e salva una carta per usarla qui.</div>';
    } else {
      listEl.innerHTML=_gcbPickerCharts.map((c,i)=>{
        const d=c.birth_day&&c.birth_month&&c.birth_year?`${c.birth_day}/${c.birth_month}/${c.birth_year}`:'';
        return`<div class="gcb-picker-item" onclick="gcbPickerSelect(${i})"><div class="gcb-picker-item-name">${escHtml(c.chart_name)}</div>${d||c.birth_city?`<div class="gcb-picker-item-meta">${d}${d&&c.birth_city?' · ':''}${escHtml(c.birth_city||'')}</div>`:''}</div>`;
      }).join('');
    }
  }catch(e){listEl.innerHTML=`<div style="text-align:center;padding:2rem;color:#c0392b;font-size:0.88rem;">Errore nel caricamento.<br><small>Effettua l'accesso per usare le tue carte.</small></div>`;}
}
function gcbPickerClose(){document.getElementById('gcb-picker-overlay')?.classList.remove('gcb-picker-overlay--open');}
function gcbPickerSelect(idx){
  const c=_gcbPickerCharts?.[idx];if(!c)return;
  const pfx=_gcbPickerTarget==='b'?'gcb-b-':'cf-';
  const sv=(id,v)=>{const el=document.getElementById(id);if(el&&v!==undefined&&v!==null)el.value=v;};
  sv(pfx+'nome',c.chart_name);
  // Populate native date input (YYYY-MM-DD)
  const d2=c.birth_day?String(c.birth_day).padStart(2,'0'):'';
  const mo=c.birth_month?String(c.birth_month).padStart(2,'0'):'';
  const yr=c.birth_year||'';
  if(yr&&mo&&d2)sv(pfx+'date',yr+'-'+mo+'-'+d2);
  // Populate native time input (HH:MM)
  const hr=c.birth_hour!==undefined?String(c.birth_hour).padStart(2,'0'):'00';
  const mn=c.birth_min!==undefined?String(c.birth_min).padStart(2,'0'):'00';
  sv(pfx+'time',hr+':'+mn);
  sv(pfx+'city',c.birth_city||'');
  if(c.birth_tz){const ts=document.getElementById(pfx+'tz');if(ts)ts.value=c.birth_tz;}
  gcbPickerClose();
}
function hdSaveMsg(text,type){const el=document.getElementById('hd-save-msg');if(!el)return;el.style.display='block';el.textContent=text;el.style.background=type==='ok'?'rgba(50,200,100,0.2)':'rgba(220,50,50,0.2)';el.style.border=type==='ok'?'1px solid rgba(50,200,100,0.4)':'1px solid rgba(220,50,50,0.4)';el.style.color=type==='ok'?'#b6f5c8':'#ffb3b3';}
async function hdSaveOpen(){
  if(!_lastCartaData)return;
  const panel=document.getElementById('hd-save-panel');if(!panel)return;
  panel.style.display='block';document.getElementById('hd-save-msg').style.display='none';
  try{const r=await fetch(HD_BASE+'/hd-auth.php?action=me',{credentials:'include'}),j=await r.json();
    if(j.ok&&j.data){document.getElementById('hd-save-form').style.display='block';document.getElementById('hd-save-login').style.display='none';const ni=document.getElementById('hd-save-name');if(ni&&!ni.value&&_lastCartaNome)ni.value=_lastCartaNome;}
    else{document.getElementById('hd-save-form').style.display='none';document.getElementById('hd-save-login').style.display='block';}
  }catch(e){document.getElementById('hd-save-form').style.display='none';document.getElementById('hd-save-login').style.display='block';}
}
function hdSaveClose(){const p=document.getElementById('hd-save-panel');if(p)p.style.display='none';}
async function hdSaveConfirm(){
  if(!_lastCartaData)return;
  const ni=document.getElementById('hd-save-name'),name=ni?ni.value.trim():'';if(!name){hdSaveMsg('Inserisci un nome per la carta.','err');return;}
  const d=_lastCartaData;
  const _dv=document.getElementById('cf-date')?.value||'',_dp=_dv.split('-');
  const _tv=document.getElementById('cf-time')?.value||'',_tp=_tv.split(':');
  const day=parseInt(_dp[2]||'0',10),month=parseInt(_dp[1]||'0',10),year=parseInt(_dp[0]||'0',10);
  const hour=parseInt(_tp[0]||'0',10),min=parseInt(_tp[1]||'0',10);
  const city=document.getElementById('cf-city')?.value||'',tz=document.getElementById('cf-tz')?.value||'Europe/Rome';
  try{
    const csrfR=await fetch(HD_BASE+'/hd-auth.php?action=csrf&for=save_chart',{credentials:'include'}),csrfJ=await csrfR.json();
    if(!csrfJ.ok){hdSaveMsg('Sessione scaduta. Ricarica la pagina.','err');return;}
    const svgEl=document.querySelector('#carta-bodygraph-wrap svg');
    const saveData=Object.assign({},d,{svg_preview:svgEl?svgEl.outerHTML:''});
    const body={action:'save',chart_name:name,birth_day:day,birth_month:month,birth_year:year,birth_hour:hour,birth_min:min,birth_city:city,birth_tz:tz,chart_json:JSON.stringify(saveData),csrf:csrfJ.data.token};
    const r=await fetch(HD_BASE+'/hd-charts.php',{method:'POST',credentials:'include',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)}),j=await r.json();
    if(j.ok){hdSaveMsg('Carta salvata! Trovala in "Le mie Carte".','ok');setTimeout(()=>hdSaveClose(),2500);}
    else hdSaveMsg(j.error||'Errore durante il salvataggio.','err');
  }catch(e){hdSaveMsg('Errore di rete. Riprova.','err');}
}
(function(){
  const stored=sessionStorage.getItem('hd_load_chart');if(!stored)return;
  sessionStorage.removeItem('hd_load_chart');
  try{
    const chart=JSON.parse(stored);
    const sv=(id,v)=>{const el=document.getElementById(id);if(el&&v!==undefined)el.value=v;};
    // Populate native date/time inputs from stored chart data
    const d2=chart.birth_day?String(chart.birth_day).padStart(2,'0'):'';
    const mo=chart.birth_month?String(chart.birth_month).padStart(2,'0'):'';
    const yr=chart.birth_year||'';
    const hr=chart.birth_hour!==undefined?String(chart.birth_hour).padStart(2,'0'):'00';
    const mn=chart.birth_min!==undefined?String(chart.birth_min).padStart(2,'0'):'00';
    if(yr&&mo&&d2)sv('cf-date',yr+'-'+mo+'-'+d2);
    sv('cf-time',hr+':'+mn);
    sv('cf-city',chart.birth_city);
    if(chart.birth_tz){const ts=document.getElementById('cf-tz');if(ts)ts.value=chart.birth_tz;}
    if(chart.chart_data)document.addEventListener('DOMContentLoaded',()=>{renderRisultati(chart.chart_data,chart.chart_name||'');});
  }catch(e){}
})();
