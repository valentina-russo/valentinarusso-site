{% extends 'partials/base.html.twig' %}

{% block title %}{{ page.header.seo_title }}{% endblock %}

{% block extra_css %}
<style>
  .carta-wrap {
    max-width: 860px;
    margin: 0 auto;
    padding: var(--space-lg) var(--space-md);
  }
  .carta-intro { text-align: center; margin-bottom: 2.5rem; }
  .carta-intro h1 { font-size: clamp(1.6rem, 4vw, 2.2rem); margin-bottom: 0.75rem; }
  .carta-intro p { color: var(--text-muted, #666); font-size: 1rem; max-width: 560px; margin: 0 auto; line-height: 1.6; }

  /* Form */
  .carta-form-card { background: #fff; border-radius: 16px; box-shadow: 0 4px 24px rgba(0,0,0,0.07); padding: 2rem; margin-bottom: 2rem; }
  .cf-row { display: grid; gap: 1rem; margin-bottom: 1rem; }
  .cf-row.cols-3 { grid-template-columns: 1fr 1fr 1.5fr; }
  .cf-row.cols-2 { grid-template-columns: 1fr 1fr; }
  .cf-row.cols-1 { grid-template-columns: 1fr; }
  .cf-field label { display: block; font-size: 0.78rem; font-weight: 700; color: var(--primary-color); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.35rem; }
  .cf-field input, .cf-field select { width: 100%; border: 1.5px solid #e0dbd7; border-radius: 8px; padding: 0.65rem 0.85rem; font-family: inherit; font-size: 0.95rem; color: #333; background: #faf9f8; box-sizing: border-box; transition: border-color 0.2s; }
  .cf-field input:focus, .cf-field select:focus { outline: none; border-color: var(--primary-color); background: #fff; }
  .cf-hint { font-size: 0.73rem; color: #aaa; margin-top: 0.25rem; }
  .carta-btn { width: 100%; padding: 0.9rem 1.5rem; background: var(--primary-color); color: #fff; border: none; border-radius: 10px; font-family: inherit; font-size: 1rem; font-weight: 700; cursor: pointer; margin-top: 0.5rem; transition: opacity 0.2s, transform 0.1s; }
  .carta-btn:hover:not(:disabled) { opacity: 0.88; }
  .carta-btn:active:not(:disabled) { transform: scale(0.99); }
  .carta-btn:disabled { opacity: 0.5; cursor: not-allowed; }

  /* Loading */
  .carta-loading { display: none; text-align: center; padding: 2.5rem; color: var(--primary-color); }
  .carta-loading-dots span { display: inline-block; width: 8px; height: 8px; background: var(--primary-color); border-radius: 50%; margin: 0 3px; animation: dotPulse 1.2s ease-in-out infinite; }
  .carta-loading-dots span:nth-child(2) { animation-delay: 0.2s; }
  .carta-loading-dots span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes dotPulse { 0%,80%,100%{opacity:0.2;transform:scale(0.8)} 40%{opacity:1;transform:scale(1)} }

  /* Error */
  .carta-error { display: none; background: #fff0f0; border: 1.5px solid #ffcccc; border-radius: 10px; padding: 1rem 1.25rem; color: #c0392b; font-size: 0.9rem; margin-bottom: 1rem; }

  /* Results */
  .carta-results { display: none; }
  .carta-name-header { text-align: center; margin-bottom: 1.5rem; }
  .carta-name-header h2 { font-size: 1.4rem; color: var(--primary-color); margin: 0 0 0.2rem; }
  .carta-name-header p { color: #888; font-size: 0.85rem; margin: 0; }

  /* Core cards */
  .carta-core { display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 0.6rem; margin-bottom: 1.5rem; }
  .core-card { background: #fff; border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); padding: 1rem 0.9rem; text-align: center; }
  .core-card-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; color: var(--primary-color); margin-bottom: 0.3rem; }
  .core-card-value { font-size: 0.95rem; font-weight: 700; color: #2c2c2c; line-height: 1.3; }

  /* Bodygraph */
  .carta-bodygraph-wrap { display: flex; justify-content: center; margin-bottom: 2rem; }
  .carta-bodygraph-wrap svg { max-width: 100%; height: auto; }

  /* Planet table */
  .carta-planets { background: #fff; border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); padding: 1.25rem; margin-bottom: 2rem; overflow-x: auto; }
  .carta-planets h3 { font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--primary-color); margin: 0 0 1rem; }
  .planets-table { width: 100%; border-collapse: collapse; font-size: 0.78rem; }
  .planets-table th { text-align: left; padding: 0.25rem 0.4rem; font-weight: 700; font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.04em; color: #999; border-bottom: 1.5px solid #f0ece8; }
  .planets-table td { padding: 0.25rem 0.4rem; border-bottom: 1px solid #f5f2ef; color: #444; line-height: 1.2; }
  .planets-table tr:last-child td { border-bottom: none; }
  .gate-black { color: #1a1a2e; font-weight: 700; }
  .gate-red { color: #c0392b; font-weight: 700; }
  .planet-bg5 { font-weight: 600; color: #333; font-size: 0.78rem; }
  .planet-name { font-size: 0.65rem; color: #aaa; margin-left: 0.3rem; }

  /* Desktop 2-col layout */
  .carta-desktop-layout { display: flex; flex-direction: column; gap: 1.5rem; }
  @media (min-width: 900px) {
    .carta-desktop-layout { flex-direction: row; gap: 2rem; align-items: flex-start; }
    .carta-col-left { flex: 0 0 45%; max-width: 45%; position: sticky; top: 1rem; }
    .carta-col-right { flex: 1; min-width: 0; }
  }

  /* PDF button */
  .carta-pdf-btn { display: block; width: 100%; padding: 0.85rem 1.5rem; margin-top: 2rem; background: var(--primary-color); color: #fff; border: none; border-radius: 10px; font-weight: 700; font-size: 0.95rem; cursor: pointer; transition: opacity 0.2s; }
  .carta-pdf-btn:hover { opacity: 0.88; }

  /* CTA */
  .carta-cta { background: #f5f0f8; border-radius: 16px; padding: 2rem; text-align: center; margin-top: 2.5rem; }
  .carta-cta p { color: #555; font-size: 0.95rem; margin-bottom: 1.25rem; line-height: 1.6; }
  .carta-cta a { display: inline-block; padding: 0.9rem 2rem; background: var(--primary-color); color: #fff; border-radius: 10px; font-weight: 700; font-size: 1rem; text-decoration: none; transition: opacity 0.2s; }
  .carta-cta a:hover { opacity: 0.88; }

  /* City autocomplete */
  .cf-autocomplete-wrap { position: relative; }
  .cf-autocomplete-list { position: absolute; top: calc(100% + 2px); left: 0; right: 0; background: #fff; border: 1.5px solid var(--primary-color); border-radius: 8px; box-shadow: 0 6px 20px rgba(0,0,0,0.12); z-index: 200; max-height: 220px; overflow-y: auto; display: none; }
  .cf-autocomplete-list li { padding: 0.6rem 0.85rem; cursor: pointer; font-size: 0.9rem; color: #333; border-bottom: 1px solid #f5f2ef; list-style: none; }
  .cf-autocomplete-list li:last-child { border-bottom: none; }
  .cf-autocomplete-list li:hover { background: #f8f4ff; }
  .cf-tz-detected { font-size: 0.73rem; color: #7c5cbf; margin-top: 0.25rem; display: none; }

  @media (max-width: 600px) {
    .cf-row.cols-3 { grid-template-columns: 1fr 1fr; }
    .cf-row.cols-2 { grid-template-columns: 1fr; }
    .carta-core { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 601px) and (max-width: 899px) {
    .carta-core { grid-template-columns: repeat(4, 1fr); }
  }

  /* PDF Layout */
  #pdf-layout { display: none; font-family: 'Outfit', Arial, sans-serif; color: #222; }
  #pdf-layout .pdf-header { display: flex; justify-content: space-between; align-items: baseline; border-bottom: 2.5px solid #b8913e; padding-bottom: 8px; margin-bottom: 12px; }
  #pdf-layout .pdf-header-right { font-size: 10pt; color: #444; text-align: right; }
  #pdf-layout .pdf-brand { font-size: 15pt; font-weight: 800; color: #1a1a2e; }
  #pdf-layout .pdf-brand-sub { font-size: 9pt; color: #8b7355; }
  #pdf-layout .pdf-body { display: flex; gap: 14px; margin-bottom: 12px; }
  #pdf-layout .pdf-col-left { flex: 0 0 290px; }
  #pdf-layout .pdf-col-left img, #pdf-layout .pdf-col-left svg { width: 290px !important; height: auto !important; max-width: 290px !important; }
  #pdf-layout .pdf-col-right { flex: 1; display: flex; flex-direction: column; gap: 5px; }
  #pdf-layout .pdf-card { border: 1px solid #e5e0da; border-radius: 4px; padding: 5px 10px; }
  #pdf-layout .pdf-card-label { font-size: 6.5pt; text-transform: uppercase; letter-spacing: 0.5px; color: #8b7355; font-weight: 600; margin-bottom: 1px; }
  #pdf-layout .pdf-card-value { font-size: 10pt; font-weight: 700; color: #1a1a2e; }
  #pdf-layout .pdf-card-desc { font-size: 7pt; color: #555; line-height: 1.3; margin-top: 2px; }
  #pdf-layout .pdf-planets { margin-bottom: 10px; }
  #pdf-layout .pdf-planets table { width: 100%; border-collapse: collapse; font-size: 8pt; }
  #pdf-layout .pdf-planets th { background: #f5f2ef; font-size: 6.5pt; text-transform: uppercase; color: #8b7355; padding: 3px 5px; text-align: left; border-bottom: 1px solid #ddd; }
  #pdf-layout .pdf-planets td { padding: 2px 5px; border-bottom: 1px solid #f0ece8; }
  #pdf-layout .pdf-planets td:nth-child(2) { font-weight: 600; color: #1a1a2e; }
  #pdf-layout .pdf-planets td:nth-child(3) { font-weight: 600; color: #c0392b; }
  #pdf-layout .pdf-cta { background: linear-gradient(135deg, #1a1a2e 0%, #2d2a4a 100%); border: none; border-radius: 10px; padding: 16px 20px; position: relative; overflow: hidden; }
  #pdf-layout .pdf-cta::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, #b8913e, #d4a843, #b8913e); }
  #pdf-layout .pdf-cta-inner { display: flex; align-items: center; gap: 16px; }
  #pdf-layout .pdf-cta-photo { width: 80px; height: 80px; border-radius: 50%; object-fit: cover; border: 3px solid #b8913e; flex-shrink: 0; }
  #pdf-layout .pdf-cta-content { flex: 1; }
  #pdf-layout .pdf-cta-badge { font-size: 6pt; text-transform: uppercase; letter-spacing: 2px; color: #b8913e; font-weight: 700; margin-bottom: 4px; }
  #pdf-layout .pdf-cta-title { font-size: 12pt; font-weight: 800; color: #fff; margin-bottom: 4px; line-height: 1.25; }
  #pdf-layout .pdf-cta-text { font-size: 8pt; color: #c8c2bc; margin-bottom: 6px; line-height: 1.35; }
  #pdf-layout .pdf-cta-button { display: inline-block; background: linear-gradient(135deg, #b8913e, #d4a843); color: #1a1a2e; font-size: 9pt; font-weight: 800; padding: 5px 22px; border-radius: 5px; margin-bottom: 5px; }
  #pdf-layout .pdf-cta-links { font-size: 7.5pt; color: #8b8178; }
  #pdf-layout .pdf-cta-links span { margin: 0 5px; }
  #pdf-layout .pdf-footer { font-size: 5.5pt; color: #999; text-align: center; padding-top: 4px; margin-top: 4px; }

  /* ── Gradient page styling ── */
  body { background: linear-gradient(160deg, #B68397 0%, #8A6FA8 45%, #3A5A8A 80%, #1E3A5F 100%) !important; background-attachment: fixed !important; min-height: 100vh; }
  body header { background: rgba(255,255,255,0.12) !important; backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border-bottom: 1px solid rgba(255,255,255,0.2) !important; position: sticky; top: 0; z-index: 1000; }
  body header .brand-name, body header .brand-tagline, body header #main-nav a { color: #fff !important; }
  body header #main-nav a:hover { color: rgba(255,255,255,0.7) !important; }
  body header .menu-toggle { color: #fff !important; }
  body footer { background: rgba(255,255,255,0.08) !important; backdrop-filter: blur(12px); border-top: 1px solid rgba(255,255,255,0.15) !important; }
  body footer a, body footer div { color: rgba(255,255,255,0.75) !important; }
  body footer a:hover { color: #fff !important; }
  .carta-intro h1 { color: #fff !important; }
  .carta-intro .carta-tagline { font-style: italic; font-family: var(--font-serif, 'Playfair Display', serif); font-size: 1.15rem; color: rgba(255,255,255,0.88); max-width: 600px; margin: 0 auto; line-height: 1.6; }

  /* Tips bar */
  .gc-tips-bar { display: flex; gap: 1rem; margin-bottom: 1.5rem; background: rgba(255,255,255,0.15); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.25); border-radius: 16px; padding: 1.25rem 1.5rem; flex-wrap: wrap; }
  .gc-tips-item { display: flex; align-items: flex-start; gap: 0.5rem; flex: 1; min-width: 160px; }
  .gc-tips-num { background: rgba(255,255,255,0.3); color: #fff; font-weight: 700; font-size: 0.72rem; width: 20px; height: 20px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 1px; }
  .gc-tips-text { color: rgba(255,255,255,0.88); font-size: 0.82rem; line-height: 1.45; }
  .gc-tips-text strong { color: #fff; display: block; }

  .carta-cta { background: rgba(255,255,255,0.15) !important; backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.25) !important; border-radius: 30px !important; }
  .carta-cta p { color: rgba(255,255,255,0.88) !important; }
  .carta-cta a { background: #fff !important; color: var(--primary-color) !important; }
  .carta-cta a:hover { opacity: 0.9 !important; }

  /* ── Progress nav ── */
  .gcb-progress { display: none; align-items: center; gap: 0.75rem; padding: 1rem 0; margin-bottom: 2rem; }
  .gcb-progress.gcb-progress--show { display: flex; }
  .gcb-step { display: flex; align-items: center; gap: 0.5rem; font-size: 0.8rem; font-weight: 700; color: rgba(255,255,255,0.45); }
  .gcb-step.gcb-step--done { color: #fff; }
  .gcb-step-dot { width: 10px; height: 10px; border-radius: 50%; background: rgba(255,255,255,0.25); flex-shrink: 0; }
  .gcb-step--done .gcb-step-dot { background: #fff; }
  .gcb-step-line { flex: 1; height: 1.5px; background: rgba(255,255,255,0.2); }

  /* ── Connect CTA (shown after zone 1 calc) ── */
  .gcb-connect-cta { display: none; background: rgba(255,255,255,0.12); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.25); border-radius: 20px; padding: 2rem; text-align: center; margin-top: 2rem; }
  .gcb-connect-cta h3 { font-family: var(--font-serif, 'Playfair Display', serif); font-size: 1.25rem; color: #fff; margin: 0 0 0.5rem; }
  .gcb-connect-cta p { color: rgba(255,255,255,0.78); font-size: 0.9rem; margin: 0 0 1.5rem; line-height: 1.6; max-width: 420px; margin-inline: auto; margin-bottom: 1.5rem; }
  .gcb-connect-btn { display: inline-block; padding: 0.9rem 2.5rem; background: #fff; color: var(--primary-color); border: none; border-radius: 50px; font-family: inherit; font-size: 1rem; font-weight: 700; cursor: pointer; transition: opacity 0.2s, transform 0.1s; }
  .gcb-connect-btn:hover { opacity: 0.9; }
  .gcb-connect-btn:active { transform: scale(0.98); }

  /* ── Zone 2 ── */
  .gcb-zone-2 { display: none; opacity: 0; transform: translateY(20px); transition: opacity 0.4s ease, transform 0.4s ease; padding-top: 0; border-top: none; margin-top: 0; }
  .gcb-zone-2.gcb-zone-2--has-results { padding-top: 3rem; border-top: 1.5px solid rgba(255,255,255,0.15); margin-top: 2rem; }
  .gcb-zone-2.gcb-zone-2--visible { opacity: 1; transform: translateY(0); }
  .gcb-zone-header { text-align: center; margin-bottom: 2rem; }
  .gcb-zone-header h2 { font-size: clamp(1.4rem, 3.5vw, 1.9rem); color: #fff; margin: 0 0 0.5rem; }
  .gcb-zone-header p { color: rgba(255,255,255,0.75); font-size: 0.95rem; margin: 0; }
  .gcb-persona-b-badge { display: inline-flex; align-items: center; gap: 0.4rem; background: rgba(61,122,138,0.25); color: #a8dce8; font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; padding: 0.3rem 0.8rem; border-radius: 20px; margin-bottom: 1rem; }

  /* ── Tabs ── */
  .gcb-tabs-bar { display: flex; border-bottom: 2px solid rgba(255,255,255,0.2); margin-bottom: 1.5rem; }
  .gcb-tab-btn { flex: 1; padding: 0.75rem 0.5rem; border: none; background: none; cursor: pointer; font-family: inherit; font-size: 0.82rem; font-weight: 700; color: rgba(255,255,255,0.45); text-align: center; border-bottom: 2.5px solid transparent; margin-bottom: -2px; transition: color 0.2s, border-color 0.2s; min-height: 44px; }
  .gcb-tab-btn[aria-selected="true"] { color: #fff; border-bottom-color: #fff; }
  /* Carousel mobile */
  .gcb-panels-grid { overflow: hidden; }
  .gcb-carousel-track { display: flex; width: 300%; transition: transform 0.38s cubic-bezier(0.4,0,0.2,1); will-change: transform; }
  .gcb-panel { width: calc(100% / 3); flex-shrink: 0; min-width: 0; }
  .gcb-panel-label { text-align: center; font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: rgba(255,255,255,0.5); margin-bottom: 0.75rem; }

  @media (min-width: 900px) {
    .gcb-tabs-bar { display: none; }
    .gcb-panels-grid { overflow: visible; }
    .gcb-carousel-track { display: grid; grid-template-columns: 1fr 1.2fr 1fr; gap: 1rem; width: 100%; transform: none !important; transition: none; }
    .gcb-panel { width: auto; flex-shrink: unset; }
  }

  /* Composite legend */
  .gcb-legend { display: flex; flex-wrap: wrap; gap: 0.4rem 1rem; padding: 0.75rem 1rem; background: rgba(255,255,255,0.1); border-radius: 10px; margin-bottom: 1rem; font-size: 0.75rem; }
  .gcb-legend-item { display: flex; align-items: center; gap: 0.35rem; color: rgba(255,255,255,0.85); }
  .gcb-legend-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }

  /* EM Analysis cards */
  .gcb-em-section { display: none; margin-top: 1.5rem; }
  .gcb-em-card { background: rgba(255,255,255,0.1); backdrop-filter: blur(8px); border: 1px solid rgba(255,255,255,0.18); border-radius: 14px; padding: 1.25rem; margin-bottom: 1rem; }
  .gcb-em-card-title { display: flex; align-items: center; gap: 0.5rem; font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: rgba(255,255,255,0.9); margin-bottom: 0.75rem; }
  .gcb-em-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
  .gcb-em-dot--em { background: #E6A756; }
  .gcb-em-dot--a { background: #7a5c6e; }
  .gcb-em-dot--b { background: #3d7a8a; }
  .gcb-em-dot--ab { background: #5a8a6e; }
  .gcb-em-card-body { font-size: 0.88rem; color: rgba(255,255,255,0.78); line-height: 1.6; }
  .gcb-em-card-body p { margin: 0 0 0.5rem; }
  .gcb-em-card-body ul { margin: 0.25rem 0 0; padding-left: 1.25rem; }
  .gcb-em-card-body li { margin-bottom: 0.2rem; }
  .gcb-em-count-badge { display: inline-block; background: rgba(255,255,255,0.15); color: #fff; font-size: 0.7rem; font-weight: 700; padding: 0.1rem 0.45rem; border-radius: 10px; margin-left: 0.3rem; }

  /* Zone 2 results mini header */
  .gcb-conn-names { text-align: center; margin-bottom: 1.5rem; }
  .gcb-conn-names h3 { color: #fff; font-size: 1.1rem; margin: 0; }
  .gcb-conn-names p { color: rgba(255,255,255,0.65); font-size: 0.82rem; margin: 0.25rem 0 0; }

  /* ── Forms row (1-col single / 2-col couple) ── */
  .gcb-forms-row { display: grid; grid-template-columns: 1fr; }
  #gcb-form-col-b { display: none; }
  .gcb-form-col-label { display: none; font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: rgba(255,255,255,0.6); margin-bottom: 0.5rem; padding: 0 0.25rem; }
  /* Couple active */
  .gcb-forms-couple { grid-template-columns: 1fr 1fr; gap: 1rem; }
  .gcb-forms-couple .gcb-form-col-label { display: block; }
  .gcb-forms-couple .carta-form-card { padding: 1.25rem 1rem; }
  .gcb-forms-couple .cf-field input, .gcb-forms-couple .cf-field select { font-size: 0.85rem; padding: 0.48rem 0.65rem; }
  .gcb-forms-couple .cf-row { gap: 0.45rem; }
  .gcb-forms-couple .cf-field label { font-size: 0.7rem; }
  .gcb-forms-couple .carta-btn { padding: 0.72rem 1rem; font-size: 0.88rem; }
  /* Hide intro/tips in couple mode */
  .gcb-single-only { transition: opacity 0.25s; }
  .gcb-single-only.gcb-hidden { display: none; }
  /* Mobile: stack couple forms */
  @media (max-width: 640px) {
    .gcb-forms-couple { grid-template-columns: 1fr; }
  }

  /* ── Wizard: lock overlay form B ── */
  #gcb-form-col-b { position: relative; }
  .gcb-step2-lock { position: absolute; inset: 2.2rem 0 0 0; border-radius: 16px; background: rgba(15,10,35,0.75); backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px); display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 2rem 1.5rem; z-index: 5; transition: opacity 0.4s, visibility 0.4s; opacity: 0; visibility: hidden; }
  .gcb-step2-lock--visible { opacity: 1; visibility: visible; }
  .gcb-step2-lock-icon { font-size: 1.7rem; margin-bottom: 0.65rem; opacity: 0.75; }
  .gcb-step2-lock-title { color: #fff; font-size: 0.88rem; font-weight: 700; margin: 0 0 0.3rem; }
  .gcb-step2-lock-sub { color: rgba(255,255,255,0.58); font-size: 0.75rem; margin: 0; line-height: 1.45; }
  /* Form A done bar (couple mode, after calculation) */
  .gcb-form-done-bar { display: none; align-items: center; justify-content: space-between; padding: 0.6rem 0 0.8rem; border-bottom: 1px solid rgba(107,79,168,0.15); margin-bottom: 0.5rem; }
  .gcb-form-done-bar-text { color: #5a3e8a; font-size: 0.82rem; font-weight: 700; }
  .gcb-form-edit-btn { background: none; border: none; color: rgba(90,62,138,0.55); font-size: 0.72rem; cursor: pointer; text-decoration: underline; padding: 0; font-family: inherit; }
  .gcb-form-card--collapsed .gcb-form-done-bar { display: flex; }
  .gcb-form-card--collapsed .cf-row,
  .gcb-form-card--collapsed .cf-city-wrap,
  .gcb-form-card--collapsed .cf-tz-row,
  .gcb-form-card--collapsed #hd-account-picker-btn { display: none !important; }
  .gcb-form-card--collapsed .carta-btn { display: none !important; }
  .gcb-form-card--collapsed .gcb-pick-btn { display: none !important; }
  /* Carousel swipe dots (mobile only) */
  .gcb-swipe-dots { display: none; justify-content: center; gap: 7px; margin-top: 0.65rem; }
  .gcb-swipe-dot { width: 7px; height: 7px; border-radius: 50%; background: rgba(255,255,255,0.22); transition: background 0.25s; }
  .gcb-swipe-dot--active { background: rgba(255,255,255,0.85); }
  @media (max-width: 899px) { .gcb-swipe-dots { display: flex; } }
  #gcb-form-card-b.gcb-form-locked { opacity: 0.18; pointer-events: none; filter: blur(2px); user-select: none; transition: opacity 0.4s, filter 0.4s; }
  #gcb-form-card-b { transition: opacity 0.4s, filter 0.4s; }
  /* Form B pulse on unlock */
  @keyframes gcbFormBPulse {
    0%   { box-shadow: 0 0 0 0 rgba(255,255,255,0.45); }
    60%  { box-shadow: 0 0 0 14px rgba(255,255,255,0); }
    100% { box-shadow: 0 0 0 0 rgba(255,255,255,0); }
  }
  .gcb-form-b-pulse { animation: gcbFormBPulse 0.75s ease-out; }
  /* Bodygraph panels — adequate height on mobile */
  @media (max-width: 899px) {
    .gcb-panel .carta-bodygraph-wrap { min-height: 300px; display: flex; align-items: center; justify-content: center; }
    .gcb-panel .carta-bodygraph-wrap svg { width: 100%; max-width: 340px; height: auto; }
  }
  /* Couple mode compact header */
  #gcb-couple-header { display: none; text-align: center; margin-bottom: 1.5rem; }
  #gcb-couple-header h1 { font-size: clamp(1.3rem,4vw,1.8rem); color: #fff; margin: 0 0 0.3rem; }
  #gcb-couple-header p { color: rgba(255,255,255,0.72); font-size: 0.88rem; margin: 0; }
  /* Form A done state */
  .gcb-btn-done { background: rgba(55,155,95,0.85) !important; }
  .gcb-btn-done:hover:not(:disabled) { opacity: 1 !important; background: rgba(55,155,95,0.85) !important; }

  /* ── Date/time row ── */
  .cf-row-datetime { display: flex; gap: 0.75rem; align-items: flex-start; flex-wrap: wrap; }
  .cf-field-date { flex: 1.6; min-width: 160px; }
  .cf-field-time { flex: 1; min-width: 110px; }
  /* Native date/time inputs — on white card background */
  input[type="date"], input[type="time"] {
    display: block;
    width: 100%;
    min-width: 0;
    min-height: 2.9rem;
    line-height: 1.4;
    padding: 0.7rem 0.9rem;
    border-radius: 10px;
    border: 1.5px solid rgba(107,79,168,0.35);
    background: #f7f5fc;
    color: #3a2560;
    font-family: inherit;
    font-size: 0.95rem;
    font-weight: 500;
    cursor: pointer;
    box-sizing: border-box;
  }
  input[type="date"]:focus, input[type="time"]:focus {
    outline: none;
    border-color: #6b4fa8;
    background: #f0eaf8;
  }
  /* Clip iOS native chrome overflow inside container */
  .cf-field-date, .cf-field-time { overflow: hidden; min-width: 0; }
  .cf-row-datetime { overflow: hidden; }
  /* Mobile compact form */
  @media (max-width: 640px) {
    .carta-form-card { padding: 1rem 0.9rem 1.1rem; }
    .cf-field label { font-size: 0.7rem; margin-bottom: 0.18rem; }
    .cf-field input, .cf-field select { padding: 0.55rem 0.75rem; font-size: 0.88rem; }
    input[type="date"], input[type="time"] { padding: 0.55rem 0.75rem; font-size: 0.88rem; }
    .cf-row { gap: 0.5rem; margin-bottom: 0.5rem; }
    .cf-row-datetime { gap: 0.5rem; }
    .cf-hint { font-size: 0.68rem; margin-top: 0.2rem; }
    .carta-btn { padding: 0.8rem 1.2rem; font-size: 0.95rem; margin-top: 0.5rem; }
    .gcb-form-col-label { font-size: 0.78rem; margin-bottom: 0.4rem; }
  }

  /* ── Mode selector ── */
  .gcb-mode-sel { display: flex; gap: 0.75rem; margin-bottom: 2rem; }
  .gcb-mode-card { flex: 1; padding: 1rem 0.75rem; border-radius: 14px; border: 2px solid rgba(255,255,255,0.2); background: rgba(255,255,255,0.07); cursor: pointer; text-align: center; transition: border-color 0.2s, background 0.2s; }
  .gcb-mode-card--active { border-color: rgba(255,255,255,0.8); background: rgba(255,255,255,0.15); }
  .gcb-mode-card-icon { font-size: 1.3rem; margin-bottom: 0.3rem; }
  .gcb-mode-card-title { font-size: 0.85rem; font-weight: 700; color: #fff; margin-bottom: 0.15rem; }
  .gcb-mode-card-desc { font-size: 0.72rem; color: rgba(255,255,255,0.55); line-height: 1.35; }

  /* ── Account chart picker ── */
  .gcb-pick-btn { display: inline-flex; align-items: center; gap: 0.35rem; padding: 0.4rem 0.85rem; background: rgba(107,79,168,0.08); border: 1px solid rgba(107,79,168,0.3); border-radius: 20px; color: #6b4fa8; font-size: 0.77rem; font-weight: 600; cursor: pointer; margin-bottom: 0.6rem; transition: background 0.15s; font-family: inherit; }
  .gcb-pick-btn:hover { background: rgba(107,79,168,0.15); }
  @media (max-width: 640px) {
    .gcb-pick-btn { width: 100%; justify-content: center; border-radius: 10px; padding: 0.6rem 1rem; font-size: 0.85rem; }
    .cf-row-datetime { flex-direction: column; }
    .cf-field-date, .cf-field-time { min-width: 0; flex: none; width: 100%; }
  }
  .gcb-picker-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1000; align-items: flex-end; justify-content: center; }
  .gcb-picker-overlay--open { display: flex; }
  .gcb-picker-sheet { background: #fff; border-radius: 20px 20px 0 0; width: 100%; max-width: 520px; max-height: 65vh; overflow-y: auto; padding: 1.25rem 1.25rem 2.5rem; }
  .gcb-picker-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.85rem; }
  .gcb-picker-header-title { font-weight: 700; color: #333; font-size: 0.97rem; }
  .gcb-picker-close { background: none; border: none; font-size: 1.6rem; cursor: pointer; color: #aaa; line-height: 1; padding: 0; }
  .gcb-picker-item { padding: 0.85rem 0.5rem; border-radius: 10px; cursor: pointer; transition: background 0.15s; border-bottom: 1px solid #f0ece8; }
  .gcb-picker-item:last-child { border-bottom: none; }
  .gcb-picker-item:hover { background: #f5f3f1; }
  .gcb-picker-item-name { font-weight: 700; color: var(--primary-color, #5b3a6b); font-size: 0.92rem; }
  .gcb-picker-item-meta { font-size: 0.77rem; color: #888; margin-top: 0.15rem; }

  @media print {
    @page { size: A4; margin: 0.4cm 0.7cm; }
    body { background: #fff !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    header, footer, nav, .carta-intro, .carta-form, .carta-cta, .carta-results,
    .carta-pdf-btn, .cf-autocomplete-list, .carta-wrap > *:not(#pdf-layout),
    .carta-name-header, .carta-core, .carta-desktop-layout, .carta-error,
    .carta-form-wrap, .gcb-progress, .gcb-connect-cta, .gcb-zone-2 { display: none !important; }
    #pdf-layout { display: block !important; }
  }
</style>
{% endblock %}

{% block content %}
<div class="carta-wrap">

  <!-- Mode selector -->
  <div class="gcb-mode-sel">
    <div class="gcb-mode-card gcb-mode-card--active" id="gcb-mode-single" onclick="gcbSetMode('single')">
      <div class="gcb-mode-card-icon">◉</div>
      <div class="gcb-mode-card-title">La mia carta</div>
      <div class="gcb-mode-card-desc">Calcola la tua carta Human Design</div>
    </div>
    <div class="gcb-mode-card" id="gcb-mode-couple" onclick="gcbSetMode('couple')">
      <div class="gcb-mode-card-icon">⊕</div>
      <div class="gcb-mode-card-title">Carta di coppia</div>
      <div class="gcb-mode-card-desc">Confronta due persone insieme</div>
    </div>
  </div>

  <!-- Progress nav -->
  <div class="gcb-progress" id="gcb-progress">
    <div class="gcb-step gcb-step--done" id="gcb-step-1">
      <span class="gcb-step-dot"></span>
      <span>La Tua Carta</span>
    </div>
    <div class="gcb-step-line"></div>
    <div class="gcb-step" id="gcb-step-2">
      <span class="gcb-step-dot"></span>
      <span>Carta di Coppia</span>
    </div>
  </div>

  <!-- ═══ ZONE 1: Carta Individuale ═══ -->
  <div id="gcb-zone-1">
    <div class="carta-intro gcb-single-only">
      <h1>{{ page.header.title }}</h1>
      <p class="carta-tagline">Il primo passo verso la consapevolezza del tuo disegno unico.</p>
    </div>

    <div class="gc-tips-bar gcb-single-only">
      <div class="gc-tips-item">
        <div class="gc-tips-num">1</div>
        <div class="gc-tips-text"><strong>Data di nascita</strong>Giorno, mese e anno completi.</div>
      </div>
      <div class="gc-tips-item">
        <div class="gc-tips-num">2</div>
        <div class="gc-tips-text"><strong>Ora esatta</strong>Anche pochi minuti cambiano il risultato. Cercala sull'estratto di nascita integrale.</div>
      </div>
      <div class="gc-tips-item">
        <div class="gc-tips-num">3</div>
        <div class="gc-tips-text"><strong>Luogo di nascita</strong>Inserisci la città — il fuso orario viene rilevato automaticamente.</div>
      </div>
    </div>

    <!-- ── Forms row: 1-col in single mode, 2-col in couple mode ── -->
    <div class="gcb-forms-row" id="gcb-forms-row">

    <!-- Colonna A -->
    <div class="gcb-form-col" id="gcb-form-col-a">
    <div class="gcb-form-col-label">Persona A</div>
    <div class="carta-form-card" id="gcb-form-card-a">
      <div class="gcb-form-done-bar" id="gcb-form-done-bar">
        <span class="gcb-form-done-bar-text" id="gcb-form-done-text"></span>
        <button class="gcb-form-edit-btn" onclick="gcbEditFormA()">Modifica</button>
      </div>
      <div class="cf-row cols-1">
        <div class="cf-field">
          <label>Nome (opzionale)</label>
          <input type="text" id="cf-nome" placeholder="Il tuo nome">
        </div>
      </div>
      {% if page.header.hd_account_enabled %}
      <button type="button" class="gcb-pick-btn" onclick="gcbPickerOpen('a')">📂 Scegli una carta salvata</button>
      {% endif %}
      <div class="cf-row cf-row-datetime">
        <div class="cf-field cf-field-date">
          <label>📅 Data di nascita</label>
          <input type="date" id="cf-date" min="1900-01-01" max="2050-12-31">
        </div>
        <div class="cf-field cf-field-time">
          <label>🕐 Ora di nascita</label>
          <input type="time" id="cf-time">
        </div>
      </div>
      <div class="cf-row cols-1">
        <div class="cf-field">
          <label>📍 Luogo di nascita *</label>
          <div class="cf-autocomplete-wrap">
            <input type="text" id="cf-city" placeholder="Es: Milano, Roma, Napoli…" autocomplete="off" required>
            <ul class="cf-autocomplete-list" id="cf-city-list"></ul>
          </div>
          <div class="cf-hint">Inserisci la città — il fuso orario verrà rilevato automaticamente</div>
        </div>
      </div>
      <div class="cf-row cols-1">
        <div class="cf-field">
          <label>Fuso orario</label>
          <select id="cf-tz">
            <option value="Europe/Rome" selected>Italia (Europe/Rome)</option>
            <option value="Europe/London">Regno Unito (Europe/London)</option>
            <option value="Europe/Paris">Francia / Belgio (Europe/Paris)</option>
            <option value="Europe/Berlin">Germania / Austria (Europe/Berlin)</option>
            <option value="Europe/Madrid">Spagna (Europe/Madrid)</option>
            <option value="Europe/Zurich">Svizzera (Europe/Zurich)</option>
            <option value="America/New_York">USA Est (America/New_York)</option>
            <option value="America/Chicago">USA Centrale (America/Chicago)</option>
            <option value="America/Los_Angeles">USA Ovest (America/Los_Angeles)</option>
            <option value="America/Argentina/Buenos_Aires">Argentina</option>
            <option value="America/Sao_Paulo">Brasile (America/Sao_Paulo)</option>
            <option value="Asia/Dubai">Emirati Arabi (Asia/Dubai)</option>
            <option value="Asia/Kolkata">India (Asia/Kolkata)</option>
            <option value="Asia/Tokyo">Giappone (Asia/Tokyo)</option>
            <option value="Australia/Sydney">Australia (Australia/Sydney)</option>
          </select>
          <div class="cf-hint">Selezionato automaticamente dalla città</div>
          <div class="cf-tz-detected" id="cf-tz-detected"></div>
        </div>
      </div>
      <button class="carta-btn" id="carta-calcola-btn" onclick="calcolaCarta()">Calcola la mia Carta</button>
    </div>
    </div><!-- /gcb-form-col-a -->

    <!-- Colonna B (visibile solo in couple mode) -->
    <div class="gcb-form-col" id="gcb-form-col-b">
    <div class="gcb-form-col-label">Persona B</div>
    <div class="gcb-step2-lock" id="gcb-step2-lock">
      <div class="gcb-step2-lock-icon">🔒</div>
      <p class="gcb-step2-lock-title">Prima completa la tua carta</p>
      <p class="gcb-step2-lock-sub">Inserisci i tuoi dati e premi "Continua"</p>
    </div>
    <div class="carta-form-card gcb-form-locked" id="gcb-form-card-b">
      <div class="cf-row cols-1">
        <div class="cf-field">
          <label>Nome (opzionale)</label>
          <input type="text" id="gcb-b-nome" placeholder="Nome della seconda persona">
        </div>
      </div>
      {% if page.header.hd_account_enabled %}
      <button type="button" class="gcb-pick-btn" onclick="gcbPickerOpen('b')">📂 Scegli una carta salvata</button>
      {% endif %}
      <div class="cf-row cf-row-datetime">
        <div class="cf-field cf-field-date">
          <label>📅 Data di nascita</label>
          <input type="date" id="gcb-b-date" min="1900-01-01" max="2050-12-31">
        </div>
        <div class="cf-field cf-field-time">
          <label>🕐 Ora di nascita</label>
          <input type="time" id="gcb-b-time">
        </div>
      </div>
      <div class="cf-row cols-1">
        <div class="cf-field">
          <label>📍 Luogo di nascita *</label>
          <div class="cf-autocomplete-wrap">
            <input type="text" id="gcb-b-city" placeholder="Es: Milano, Roma, Napoli…" autocomplete="off">
            <ul class="cf-autocomplete-list" id="gcb-b-city-list"></ul>
          </div>
          <div class="cf-hint">Inserisci la città — fuso orario automatico</div>
        </div>
      </div>
      <div class="cf-row cols-1">
        <div class="cf-field">
          <label>Fuso orario</label>
          <select id="gcb-b-tz">
            <option value="Europe/Rome" selected>Italia (Europe/Rome)</option>
            <option value="Europe/London">Regno Unito</option>
            <option value="Europe/Paris">Francia / Belgio</option>
            <option value="Europe/Berlin">Germania / Austria</option>
            <option value="Europe/Madrid">Spagna</option>
            <option value="Europe/Zurich">Svizzera</option>
            <option value="America/New_York">USA Est</option>
            <option value="America/Chicago">USA Centrale</option>
            <option value="America/Los_Angeles">USA Ovest</option>
            <option value="America/Argentina/Buenos_Aires">Argentina</option>
            <option value="America/Sao_Paulo">Brasile</option>
            <option value="Asia/Dubai">Emirati Arabi</option>
            <option value="Asia/Kolkata">India</option>
            <option value="Asia/Tokyo">Giappone</option>
            <option value="Australia/Sydney">Australia</option>
          </select>
          <div class="cf-hint">Selezionato automaticamente dalla città</div>
          <div class="cf-tz-detected" id="gcb-b-tz-detected"></div>
        </div>
      </div>
      <button class="carta-btn" id="gcb-calcola-b-btn" onclick="calcolaConnessione()">Calcola la Connessione</button>
    </div>
    <div class="carta-loading" id="gcb-loading-b">
      <div class="carta-loading-dots"><span></span><span></span><span></span></div>
      <p style="margin-top:0.75rem;color:#888;font-size:0.9rem;">Calcolo connessione…</p>
    </div>
    <div class="carta-error" id="gcb-error-b"></div>
    </div><!-- /gcb-form-col-b -->

    </div><!-- /gcb-forms-row -->

    <div class="carta-loading" id="carta-loading">
      <div class="carta-loading-dots"><span></span><span></span><span></span></div>
      <p style="margin-top:0.75rem;color:#888;font-size:0.9rem;">Calcolo in corso…</p>
    </div>
    <div class="carta-error" id="carta-error"></div>

    <div class="carta-results" id="carta-results">
      <div class="carta-name-header" id="carta-name-header"></div>
      <div class="carta-core" id="carta-core"></div>
      <div class="carta-desktop-layout">
        <div class="carta-col-left">
          <div class="carta-bodygraph-wrap" id="carta-bodygraph-wrap"></div>
        </div>
        <div class="carta-col-right">
          <div class="carta-planets" id="carta-planets"></div>
          {% if page.header.hd_account_enabled %}
          <div style="display:flex; gap:0.75rem; flex-wrap:wrap; margin-top: 1rem;">
            <button class="carta-pdf-btn" id="carta-pdf-btn" onclick="scaricaPDF()" style="margin-top:0; flex:1; min-width:140px;">Scarica PDF</button>
            <button class="carta-pdf-btn" id="carta-save-btn" onclick="hdSaveOpen()" style="margin-top:0; flex:1; min-width:140px; background:#fff; color:var(--primary-color);">Salva Carta</button>
          </div>
          <div id="hd-save-panel" style="display:none; margin-top:1rem; background:rgba(255,255,255,0.12); border:1px solid rgba(255,255,255,0.25); border-radius:16px; padding:1.25rem;">
            <div id="hd-save-msg" style="display:none; padding:0.65rem 0.9rem; border-radius:10px; font-size:0.88rem; margin-bottom:0.9rem;"></div>
            <div id="hd-save-form">
              <label style="display:block; font-size:0.8rem; font-weight:600; text-transform:uppercase; letter-spacing:0.05em; color:rgba(255,255,255,0.7); margin-bottom:0.4rem;">Nome della carta</label>
              <input type="text" id="hd-save-name" maxlength="100" placeholder="Es. Marco, La mia carta…" style="width:100%; padding:0.65rem 0.9rem; border-radius:10px; border:1px solid rgba(255,255,255,0.3); background:rgba(255,255,255,0.1); color:#fff; font-size:0.95rem; box-sizing:border-box; margin-bottom:0.9rem;">
              <div style="display:flex; gap:0.65rem; flex-wrap:wrap;">
                <button onclick="hdSaveConfirm()" style="flex:1; min-width:120px; padding:0.55rem 1rem; background:#FDE8B0; color:#1E3A5F; font-weight:700; border:none; border-radius:50px; cursor:pointer; font-size:0.88rem;">Salva</button>
                <button onclick="hdSaveClose()" style="flex:1; min-width:80px; padding:0.55rem 1rem; background:transparent; border:1px solid rgba(255,255,255,0.35); color:#fff; border-radius:50px; cursor:pointer; font-size:0.88rem;">Annulla</button>
              </div>
            </div>
            <div id="hd-save-login" style="display:none; text-align:center;">
              <p style="color:rgba(255,255,255,0.85); font-size:0.9rem; margin-bottom:0.9rem;">Crea un account gratuito per salvare le tue carte.</p>
              <div style="display:flex; gap:0.65rem; justify-content:center; flex-wrap:wrap;">
                <a href="{{ grav.base_url }}/account" style="padding:0.55rem 1.2rem; background:#FDE8B0; color:#1E3A5F; font-weight:700; border-radius:50px; text-decoration:none; font-size:0.88rem;">Accedi o Registrati</a>
                <button onclick="hdSaveClose()" style="padding:0.55rem 1rem; background:transparent; border:1px solid rgba(255,255,255,0.35); color:#fff; border-radius:50px; cursor:pointer; font-size:0.88rem;">Annulla</button>
              </div>
            </div>
          </div>
          {% else %}
          <button class="carta-pdf-btn" id="carta-pdf-btn" onclick="scaricaPDF()">Scarica PDF</button>
          {% endif %}
        </div>
      </div>
      <div class="carta-cta">
        <p>La tua carta mostra la struttura energetica di base. Una lettura professionale con Valentina trasforma questi dati in indicazioni concrete per le tue relazioni, il lavoro e le decisioni di tutti i giorni.</p>
        <a href="/contatti">Prenota una Prima Lettura</a>
      </div>
    </div>

    <!-- Connect CTA (shown after Zone 1 calc) -->
    <div class="gcb-connect-cta" id="gcb-connect-cta">
      <h3>Scopri come sei in relazione</h3>
      <p>Calcola la Carta di Coppia per vedere come la tua energia si intreccia con quella di un'altra persona.</p>
      <button class="gcb-connect-btn" onclick="gcbAttivaZona2()">Confrontati con qualcuno</button>
