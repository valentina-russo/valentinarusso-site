const C_PRIMARY='#7a5c9e',C_RED='#c0392b',C_BLACK='#1a1a2e',C_UNDEF='#f0ece8',C_UNDEF_STROKE='#d5cfc9';
const CENTER_GEO={HEAD:{cx:210,cy:35,type:'tri-up',pts:[[168,62],[252,62],[210,8]]},AJNA:{cx:210,cy:94,type:'tri-dn',pts:[[168,68],[252,68],[210,120]]},THROAT:{cx:210,cy:154,type:'rect',rx:168,ry:138,rw:84,rh:32},G:{cx:210,cy:238,type:'diamond',pts:[[210,197],[256,238],[210,279],[164,238]]},HEART:{cx:290,cy:215,type:'tri-dn',pts:[[265,195],[315,195],[290,240]]},SPLEEN:{cx:83,cy:335,type:'tri-rt',pts:[[58,306],[58,364],[108,335]]},SOLAR:{cx:337,cy:335,type:'tri-lt',pts:[[362,306],[362,364],[312,335]]},SACRAL:{cx:210,cy:364,type:'rect',rx:168,ry:350,rw:84,rh:28},ROOT:{cx:210,cy:462,type:'rect',rx:168,ry:448,rw:84,rh:28}};
const CHANNEL_PATHS={'HEAD-AJNA':[[210,62],[210,68]],'AJNA-THROAT':[[210,120],[210,138]],'THROAT-G':[[210,170],[210,197]],'THROAT-HEART':[[252,154],[265,210]],'THROAT-SPLEEN':[[168,154],[108,335]],'THROAT-SOLAR':[[252,154],[312,335]],'THROAT-SACRAL':[[210,170],[210,350]],'G-HEART':[[256,238],[265,220]],'G-SACRAL':[[210,279],[210,350]],'HEART-SPLEEN':[[265,232],[108,320]],'HEART-SOLAR':[[315,232],[312,320]],'SACRAL-SPLEEN':[[168,364],[108,345]],'SACRAL-SOLAR':[[252,364],[312,345]],'SACRAL-ROOT':[[210,378],[210,448]],'SPLEEN-ROOT':[[73,364],[185,448]],'SOLAR-ROOT':[[347,364],[235,448]]};
function cpKey(c1,c2){const o=['HEAD','AJNA','THROAT','G','HEART','SPLEEN','SOLAR','SACRAL','ROOT'];return o.indexOf(c1)<o.indexOf(c2)?`${c1}-${c2}`:`${c2}-${c1}`;}
function buildBodygraph(blackGates,redGates,definedChannels,definedCenterSet){
  let svg=`<svg viewBox="0 0 420 510" width="420" height="510" xmlns="http://www.w3.org/2000/svg">`;
  const activePairs=new Set();
  definedChannels.forEach(([g1,g2,c1,c2])=>{const key=cpKey(c1,c2);if(!activePairs.has(key)&&CHANNEL_PATHS[key]){activePairs.add(key);const[[x1,y1],[x2,y2]]=CHANNEL_PATHS[key];const g1b=blackGates.has(g1),g1r=redGates.has(g1),g2b=blackGates.has(g2),g2r=redGates.has(g2);const color=(g1b&&!g1r&&g2b&&!g2r)?C_BLACK:(!g1b&&g1r&&!g2b&&g2r)?C_RED:C_PRIMARY;svg+=`<line x1="${x1}" y1="${y1}" x2="${x2}" y2="${y2}" stroke="${color}" stroke-width="4" stroke-linecap="round"/>`;} });
  for(const [key,[[x1,y1],[x2,y2]]] of Object.entries(CHANNEL_PATHS)){if(!activePairs.has(key))svg+=`<line x1="${x1}" y1="${y1}" x2="${x2}" y2="${y2}" stroke="${C_UNDEF_STROKE}" stroke-width="2" stroke-linecap="round"/>`;}
  for(const [name,geo] of Object.entries(CENTER_GEO)){const isDef=definedCenterSet.has(name),fill=isDef?C_PRIMARY:C_UNDEF,stroke=isDef?C_PRIMARY:C_UNDEF_STROKE,tc=isDef?'#fff':'#aaa';if(geo.type==='rect')svg+=`<rect x="${geo.rx}" y="${geo.ry}" width="${geo.rw}" height="${geo.rh}" rx="5" fill="${fill}" stroke="${stroke}" stroke-width="1.5"/>`;else{const pts=geo.pts.map(p=>p.join(',')).join(' ');svg+=`<polygon points="${pts}" fill="${fill}" stroke="${stroke}" stroke-width="1.5"/>`;}svg+=`<text x="${geo.cx}" y="${geo.cy+5}" text-anchor="middle" fill="${tc}" font-size="9" font-weight="700">${CENTER_IT[name].toUpperCase()}</text>`;}
  return svg+'</svg>';
}

