// ─── Swiss Ephemeris init ─────────────────────────────────────────────────────
let _sweMod = null, _sweCalc = null, _sweJulday = null;
async function initSwe() {
  if (_sweMod) return;
  const SweClass = window.SwissEphemeris;
  if (!SweClass) throw new Error('SwissEphemeris non caricato');
  const inst = new SweClass();
  await inst.init();
  try { await inst.loadStandardEphemeris(); } catch(e) {}
  _sweMod = inst.module;
  try {
    const CDN = 'https://cdn.jsdelivr.net/gh/aloistr/swisseph/ephe';
    try { _sweMod.FS.mkdir('/ephe'); } catch(e) {}
    const files = ['sepl_18.se1', 'semo_18.se1'];
    await Promise.all(files.map(async f => {
      const resp = await fetch(`${CDN}/${f}`);
      if (resp.ok) _sweMod.FS.writeFile(`/ephe/${f}`, new Uint8Array(await resp.arrayBuffer()));
    }));
    _sweMod.cwrap('swe_set_ephe_path_wrap', null, ['string'])('/ephe');
  } catch(e) {
    _sweMod.cwrap('swe_set_ephe_path_wrap', null, ['string'])('');
  }
  _sweCalc = (jd, planet, flags) => {
    const ptr = _sweMod.ccall('swe_calc_ut_wrap', 'number', ['number','number','number'], [jd, planet, flags]);
    return _sweMod.getValue(ptr, 'double');
  };
  _sweJulday = _sweMod.cwrap('swe_julday_wrap', 'number', ['number','number','number','number','number']);
}

const HD_GATE_WHEEL = [41,19,13,49,30,55,37,63,22,36,25,17,21,51,42,3,27,24,2,23,8,20,16,35,45,12,15,52,39,53,62,56,31,33,7,4,29,59,40,64,47,6,46,18,48,57,32,50,28,44,1,43,14,34,9,5,26,11,10,58,38,54,61,60];
const HD_RAVE_OFFSET = 58.0;

const HD_CHANNELS = [
  [64,47],[61,24],[63,4],[17,62],[43,23],[11,56],[16,48],[20,57],
  [31,7],[8,1],[33,13],[10,20],[45,21],[35,36],[12,22],[20,34],
  [10,34],[10,57],[26,44],[51,25],[40,37],[2,14],[5,15],[29,46],[27,50],[34,57],
  [59,6],[3,60],[9,52],[42,53],[18,58],[28,38],[32,54],[30,41],[39,55],[19,49]
];

const HD_GATE_CENTER = {};
[64,61,63].forEach(g=>HD_GATE_CENTER[g]='HEAD');
[47,24,4,17,43,11].forEach(g=>HD_GATE_CENTER[g]='AJNA');
[62,23,56,16,31,8,33,45,35,12,20].forEach(g=>HD_GATE_CENTER[g]='THROAT');
[7,13,1,10,25,15,2,46].forEach(g=>HD_GATE_CENTER[g]='G');
[21,51,26,40].forEach(g=>HD_GATE_CENTER[g]='HEART');
[48,57,44,50,32,28,18].forEach(g=>HD_GATE_CENTER[g]='SPLEEN');
[36,22,37,6,30,55,49].forEach(g=>HD_GATE_CENTER[g]='SOLAR');
[34,5,14,29,3,42,9,27,59].forEach(g=>HD_GATE_CENTER[g]='SACRAL');
[53,60,52,54,58,38,41,39,19].forEach(g=>HD_GATE_CENTER[g]='ROOT');

const HD_PLANETS = [
  {id:0,it:'Sole',en:'Sun'},{id:-2,it:'Terra',en:'Earth'},{id:1,it:'Luna',en:'Moon'},
  {id:11,it:'Nodo Nord',en:'North Node'},{id:-1,it:'Nodo Sud',en:'South Node'},
  {id:2,it:'Mercurio',en:'Mercury'},{id:3,it:'Venere',en:'Venus'},{id:4,it:'Marte',en:'Mars'},
  {id:5,it:'Giove',en:'Jupiter'},{id:6,it:'Saturno',en:'Saturn'},{id:7,it:'Urano',en:'Uranus'},
  {id:8,it:'Nettuno',en:'Neptune'},{id:9,it:'Plutone',en:'Pluto'},
];
const HD_PHS = {1:{name:'Appetito',a:'Consecutivo',b:'Alternato'},2:{name:'Gusto',a:'Aperto',b:'Chiuso'},3:{name:'Sete',a:'Caldo',b:'Freddo'},4:{name:'Tatto',a:'Calmo',b:'Nervoso'},5:{name:'Suono',a:'Alto',b:'Basso'},6:{name:'Luce',a:'Diretta',b:'Indiretta'}};
const HD_ENV = {1:{name:'Grotte',a:'Selettivo',b:'Aperto'},2:{name:'Mercati',a:'Interno',b:'Esterno'},3:{name:'Cucine',a:'Umido',b:'Secco'},4:{name:'Montagne',a:'Attivo',b:'Passivo'},5:{name:'Valli',a:'Stretto',b:'Largo'},6:{name:'Rive',a:'Naturale',b:'Artificiale'}};
function phsLabel(c,t){const p=HD_PHS[c];if(!p)return'?';return`${p.name} (${t<=3?p.a:p.b})`;}
function envLabel(c,t){const e=HD_ENV[c];if(!e)return'?';return`${e.name} (${t<=3?e.a:e.b})`;}

function hdDegreesToGateLineColor(deg) {
  const angle=((deg+HD_RAVE_OFFSET)%360+360)%360, pct=angle/360;
  const gate=HD_GATE_WHEEL[Math.min(Math.floor(pct*64),63)];
  const line=Math.floor((pct*64*6)%6)+1, color=Math.floor((pct*64*6*6)%6)+1, tone=Math.floor((pct*64*6*6*6)%6)+1;
  return {gate,line,color,tone};
}
function dateToJD(y,m,d,h,min,tzOffset){return _sweJulday(y,m,d,h+min/60-tzOffset,1);}
async function calcPlanets(jd) {
  await initSwe();
  const results=[]; let nnLon=null, sunLon=null; const SWIEPH=2;
  for(const p of HD_PLANETS) {
    let lon;
    if(p.id===-1){lon=nnLon!==null?(nnLon+180)%360:0;}
    else if(p.id===-2){lon=sunLon!==null?(sunLon+180)%360:0;}
    else{lon=_sweCalc(jd,p.id,SWIEPH);if(p.id===0)sunLon=lon;if(p.id===11)nnLon=lon;}
    const glc=hdDegreesToGateLineColor(lon);
    results.push({planet_it:p.it,planet_en:p.en,gate:glc.gate,line:glc.line,color:glc.color,tone:glc.tone,degrees:Math.round(lon*10000)/10000});
  }
  return results;
}
function hdGetDefinedChannels(activeGates){return HD_CHANNELS.filter(([g1,g2])=>activeGates.has(g1)&&activeGates.has(g2));}
function hdGetDefinedCenters(activeGates){
  const def=new Set();
  for(const [g1,g2] of HD_CHANNELS){if(activeGates.has(g1)&&activeGates.has(g2)){if(HD_GATE_CENTER[g1])def.add(HD_GATE_CENTER[g1]);if(HD_GATE_CENTER[g2])def.add(HD_GATE_CENTER[g2]);}}
  return def;
}
function hdCalcType(defCenters,defChannels){
  const motors=new Set(['SACRAL','HEART','SOLAR','ROOT']);
  if(!defCenters.size)return'Reflector';
  function motorToThroat(start,visited=new Set()){
    if(visited.has(start))return false;visited.add(start);if(start==='THROAT')return true;
    const adj=new Set();
    for(const [g1,g2] of defChannels){const c1=HD_GATE_CENTER[g1]||'',c2=HD_GATE_CENTER[g2]||'';if(c1===start)adj.add(c2);else if(c2===start)adj.add(c1);}
    return[...adj].some(c=>motorToThroat(c,new Set(visited)));
  }
  const hasSacral=defCenters.has('SACRAL');
  const anyMotorToThroat=[...motors].filter(m=>defCenters.has(m)).some(m=>motorToThroat(m));
  if(hasSacral)return anyMotorToThroat?'Manifesting Generator':'Generator';
  return anyMotorToThroat?'Manifestor':'Projector';
}
function hdCalcProfile(pers,des){const sP=pers.find(p=>p.planet_en==='Sun'),sD=des.find(p=>p.planet_en==='Sun');if(!sP||!sD)return'?/?';return`${sP.line}/${sD.line}`;}
function hdCalcAuthority(defCenters){
  const order=[['SOLAR','Emotional'],['SACRAL','Sacral'],['SPLEEN','Splenic'],['HEART','Ego Manifested'],['G','Self Projected']];
  for(const [c,auth] of order){if(defCenters.has(c))return auth;}
  return defCenters.size?'Mental Projector':'Lunar';
}
function hdCalcDefinition(defCenters,defChannels){
  if(!defCenters.size)return'No Definition';
  const adj={};for(const c of defCenters)adj[c]=new Set();
  for(const [g1,g2] of defChannels){const c1=HD_GATE_CENTER[g1]||'',c2=HD_GATE_CENTER[g2]||'';if(adj[c1]&&adj[c2]){adj[c1].add(c2);adj[c2].add(c1);}}
  const visited=new Set();let components=0;
  for(const c of defCenters){if(visited.has(c))continue;components++;const stack=[c];while(stack.length){const n=stack.pop();if(visited.has(n))continue;visited.add(n);for(const nb of(adj[n]||[])){if(!visited.has(nb))stack.push(nb);}}}
  return{1:'Single Definition',2:'Split Definition',3:'Triple Split',4:'Quadruple Split'}[components]||'Quadruple Split';
}
async function calculateHDChart(y,m,d,h,min,tzOffset){
  await initSwe();
  const jdBirth=dateToJD(y,m,d,h,min,tzOffset);
  const SWIEPH2=2,natalSunLon=_sweCalc(jdBirth,0,SWIEPH2),targetLon=((natalSunLon-88)%360+360)%360;
  let lo=jdBirth-95,hi=jdBirth-80;
  for(let i=0;i<50;i++){const mid=(lo+hi)/2,midLon=_sweCalc(mid,0,SWIEPH2);let diff=(midLon-targetLon+180)%360-180;if(Math.abs(diff)<1e-6){lo=hi=mid;break;}if(diff<0)lo=mid;else hi=mid;}
  const jdDesign=(lo+hi)/2,personality=await calcPlanets(jdBirth),design=await calcPlanets(jdDesign);
  const activeGates=new Set();[...personality,...design].forEach(p=>activeGates.add(p.gate));
  const defChannels=hdGetDefinedChannels(activeGates),defCenters=hdGetDefinedCenters(activeGates);
  const type=hdCalcType(defCenters,defChannels),profile=hdCalcProfile(personality,design);
  const authority=hdCalcAuthority(defCenters),definition=hdCalcDefinition(defCenters,defChannels);
  const pGates=new Set(personality.map(p=>p.gate)),dGates=new Set(design.map(p=>p.gate));
  const gate_colors={};
  for(const g of new Set([...pGates,...dGates])){gate_colors[String(g)]=(pGates.has(g)&&dGates.has(g))?'PD':pGates.has(g)?'P':'D';}
  const pSun=personality.find(p=>p.planet_en==='Sun')||{},dSun=design.find(p=>p.planet_en==='Sun')||{};
  const arrowSun=t=>t<=3?'left':'right';
  const dNode=design.find(p=>p.planet_en==='North Node')||{},pNode=personality.find(p=>p.planet_en==='North Node')||{};
  return{type,profile,authority,definition,defined_centers:[...defCenters].sort(),defined_channels:defChannels.map(([a,b])=>[a,b]),gate_colors,personality,design,variables:{digestion:arrowSun(dSun.tone||1),environment:arrowSun(dNode.tone||1),perspective:arrowSun(pSun.tone||1),awareness:arrowSun(pNode.tone||1)},dietary_regime:phsLabel(dSun.color||1,dSun.tone||1),environment_name:envLabel(dNode.color||1,dNode.tone||1)};
}

// ─── City autocomplete (reusable) ────────────────────────────────────────────
function initCityAutocomplete(cityInputId,cityListId,tzSelectId,tzDetectedId){
  const cityInput=document.getElementById(cityInputId),cityList=document.getElementById(cityListId),tzSelect=document.getElementById(tzSelectId),tzDetected=document.getElementById(tzDetectedId);
  if(!cityInput||!cityList||!tzSelect)return;
  let debounce=null;
  cityInput.addEventListener('input',()=>{clearTimeout(debounce);const q=cityInput.value.trim();if(q.length<3){cityList.style.display='none';return;}debounce=setTimeout(()=>fetchCities(q),350);});
  cityInput.addEventListener('blur',()=>{setTimeout(()=>{cityList.style.display='none';},200);});
  async function fetchCities(q){try{const url=`https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(q)}&format=json&limit=6&addressdetails=1&featuretype=city`;const res=await fetch(url,{headers:{'Accept-Language':'it'}});const data=await res.json();showSuggestions(data);}catch(e){cityList.style.display='none';}}
  function showSuggestions(places){cityList.innerHTML='';if(!places.length){cityList.style.display='none';return;}places.forEach(p=>{const li=document.createElement('li');const parts=[p.display_name.split(',')[0].trim()];if(p.address){if(p.address.state)parts.push(p.address.state);if(p.address.country)parts.push(p.address.country);}li.textContent=parts.join(', ');li.addEventListener('click',()=>selectCity(p,li.textContent));cityList.appendChild(li);});cityList.style.display='block';}
  async function selectCity(place,label){cityInput.value=label;cityList.style.display='none';const lat=parseFloat(place.lat),lng=parseFloat(place.lon);try{const tzRes=await fetch(`https://timeapi.io/api/timezone/coordinate?latitude=${lat}&longitude=${lng}`);const tzData=await tzRes.json();const tz=tzData.timeZone;if(tz){let found=false;for(const opt of tzSelect.options){if(opt.value===tz){tzSelect.value=tz;found=true;break;}}if(!found){const opt=document.createElement('option');opt.value=tz;opt.textContent=tz;tzSelect.appendChild(opt);tzSelect.value=tz;}if(tzDetected){tzDetected.textContent=`✓ Fuso orario rilevato: ${tz}`;tzDetected.style.display='block';}}}catch(e){}}
}

document.addEventListener('DOMContentLoaded',()=>{
  initCityAutocomplete('cf-city','cf-city-list','cf-tz','cf-tz-detected');
  initCityAutocomplete('gcb-b-city','gcb-b-city-list','gcb-b-tz','gcb-b-tz-detected');
});

