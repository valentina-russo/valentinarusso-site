  if(d.personality&&d.personality.length>0){const pSun=d.personality.find(p=>p.planet_en==='Sun');if(pSun){const cross=getIncarnationCross(pSun.gate,d.profile);const el=document.getElementById('pdf-croce');if(el){el.querySelector('.pdf-card-value').textContent=cross;const de=el.querySelector('.pdf-card-desc');if(de){const qi=HD_GATE_WHEEL.indexOf(pSun.gate),q=qi<16?'Mente':qi<32?'Forma':qi<48?'Relazioni':'Trasformazione';de.textContent={'Mente':'Il tuo scopo emerge attraverso la mente e l\'ispirazione.','Forma':'Il tuo scopo si realizza attraverso il corpo e la forma materiale.','Relazioni':'Il tuo scopo si esprime attraverso le relazioni.','Trasformazione':'Il tuo scopo è legato alla trasformazione.'}[q]||'';}}}}
