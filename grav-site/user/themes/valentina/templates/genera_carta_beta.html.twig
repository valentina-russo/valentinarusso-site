  for(const pk of PLANET_ORDER){const pp=(d.personality||[]).find(p=>p.planet_en===pk),dp=(d.design||[]).find(p=>p.planet_en===pk);tbl+=`<tr><td>${PLANET_BG5[pk]||PLANET_IT[pk]||pk}</td><td>${pp?pp.gate+'.'+pp.line:'-'}</td><td>${dp?dp.gate+'.'+dp.line:'-'}</td></tr>`;}
