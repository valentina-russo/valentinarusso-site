  const srcSvg=document.querySelector('#carta-bodygraph-wrap svg'),pdfBg=document.getElementById('pdf-bodygraph');
  pdfBg.innerHTML='';
  if(srcSvg){
    const clone=srcSvg.cloneNode(true);
    const pat=clone.querySelector('#splitGatePattern');if(pat){pat.querySelectorAll('rect').forEach(r=>{const f=r.getAttribute('fill');if(f&&f.includes('--color-personality'))r.setAttribute('fill','#1a1a2e');if(f&&f.includes('--color-design'))r.setAttribute('fill','#c0392b');});}
