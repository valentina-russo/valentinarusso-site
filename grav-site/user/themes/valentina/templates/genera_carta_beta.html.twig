function getIncarnationCross(pSunGate,profileStr){
  const cross=CROSS_BG5[pSunGate]||{P:'?',T:'?',S:'?'};
  const idx=GATE_WHEEL.indexOf(pSunGate);
  let quarter;if(idx>=2&&idx<=17)quarter=1;else if(idx>=18&&idx<=33)quarter=2;else if(idx>=34&&idx<=49)quarter=3;else quarter=4;
  const[l1,l2]=profileStr.split('/').map(Number);
  let focusKey,focusLabel;
  if(l1===4&&l2===1){focusKey='S';focusLabel='Focus Fisso';}else if(l1>=5){focusKey='T';focusLabel='Focus Transpersonale';}else{focusKey='P';focusLabel='Focus Personale';}
  return`${cross[focusKey]||cross.P}, ${focusLabel}, ${QUARTER_NAMES[quarter]}`;
}

// ─── Zone 1: calcolaCarta ─────────────────────────────────────────────────────
async function calcolaCarta(){
  const dateVal=document.getElementById('cf-date').value;
  const timeVal=document.getElementById('cf-time').value;
  const dateParts=dateVal?dateVal.split('-'):[];
  const timeParts=timeVal?timeVal.split(':'):[];
  const y=dateParts[0]?parseInt(dateParts[0]):NaN;
  const m=dateParts[1]?parseInt(dateParts[1]):NaN;
  const d=dateParts[2]?parseInt(dateParts[2]):NaN;
  const h=timeParts[0]!==undefined?parseInt(timeParts[0]):NaN;
  const min=timeParts[1]!==undefined?parseInt(timeParts[1]):NaN;
  const tz=document.getElementById('cf-tz').value,nome=document.getElementById('cf-nome').value.trim(),city=document.getElementById('cf-city').value.trim();
  if(!city){mostraErrore('Inserisci il luogo di nascita per continuare.');document.getElementById('cf-city').focus();return;}
  if(!d||!m||!y||isNaN(h)||isNaN(min)){mostraErrore('Compila data, ora e luogo di nascita.');return;}
  if(y<1900||y>2050){mostraErrore('Anno tra il 1900 e il 2050.');return;}
  document.getElementById('carta-error').style.display='none';
  document.getElementById('carta-results').style.display='none';
  document.getElementById('carta-loading').style.display='block';
  document.getElementById('carta-calcola-btn').disabled=true;
  try{
    const localDt=new Date(y,m-1,d,h,min);
    const tzDate=new Date(localDt.toLocaleString('en-US',{timeZone:tz}));
    const utcDate=new Date(localDt.toLocaleString('en-US',{timeZone:'UTC'}));
    const tzOffset=(tzDate-utcDate)/3600000;
    const data=await calculateHDChart(y,m,d,h,min,tzOffset);
    if(data.environment_name){data.environment=data.environment_name;delete data.environment_name;}
    await renderRisultati(data,nome);
  }catch(e){mostraErrore(e.message||'Si è verificato un errore. Riprova.');}
  finally{document.getElementById('carta-loading').style.display='none';document.getElementById('carta-calcola-btn').disabled=false;}
}

function mostraErrore(msg){document.getElementById('carta-loading').style.display='none';document.getElementById('carta-calcola-btn').disabled=false;const el=document.getElementById('carta-error');el.textContent=msg;el.style.display='block';}
function mostraErroreB(msg){document.getElementById('gcb-loading-b').style.display='none';document.getElementById('gcb-calcola-b-btn').disabled=false;const el=document.getElementById('gcb-error-b');el.textContent=msg;el.style.display='block';}

function normalizzaRisposta(data){
  if(data.gate_colors){data.type=TIPO_IT[data.type]||data.type;data.authority=AUTH_IT[data.authority]||data.authority;data.definition=DEF_IT[data.definition]||data.definition;return data;}
  const core=data.result&&data.result.Core,acts=data.result&&data.result.Activations;
  if(!core||!acts)return null;
  const pArr=Object.entries(acts.Personality).map(([en,v])=>({planet_en:en,planet_it:PLANET_IT[en]||en,gate:v.Gate,line:v.Line,degrees:0}));
  const dArr=Object.entries(acts.Design).map(([en,v])=>({planet_en:en,planet_it:PLANET_IT[en]||en,gate:v.Gate,line:v.Line,degrees:0}));
  const blackGates=new Set(pArr.map(p=>p.gate)),redGates=new Set(dArr.map(p=>p.gate)),allActive=new Set([...blackGates,...redGates]);
  const gate_colors={};allActive.forEach(g=>{const inP=blackGates.has(g),inD=redGates.has(g);gate_colors[String(g)]=(inP&&inD)?'PD':inP?'P':'D';});
  const defined_channels=CHANNELS.filter(([g1,g2])=>allActive.has(g1)&&allActive.has(g2)).map(([g1,g2])=>[g1,g2]);
  const defined_centers=[];defined_channels.forEach(([g1,g2])=>{const c1=GATE_TO_CENTER[g1],c2=GATE_TO_CENTER[g2];if(c1&&!defined_centers.includes(c1))defined_centers.push(c1);if(c2&&!defined_centers.includes(c2))defined_centers.push(c2);});
  return{type:TIPO_IT[core.Type]||core.Type,profile:core.Profile,authority:AUTH_IT[core.Authority]||core.Authority,definition:DEF_IT[core.Definition]||core.Definition,gate_colors,defined_channels,defined_centers,personality:pArr,design:dArr};
}

let _lastCartaData=null,_lastCartaNome=null,_lastChartA=null,_lastChartB=null,_lastNomeB=null;

function escHtml(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}

async function renderRisultati(data,nome){
  const d=normalizzaRisposta(data);
  if(!d){mostraErrore('Formato risposta non riconosciuto.');return;}
  _lastCartaData=d;_lastCartaNome=nome;_lastChartA=d;
  const nh=document.getElementById('carta-name-header');
  if(nome){nh.innerHTML=`<h2>${escHtml(nome)}</h2><p>Carta Human Design</p>`;nh.style.display='block';}else{nh.style.display='none';}
  const coreItems=[{label:'Tipo di Carriera',value:d.type},{label:'Profilo',value:d.profile},{label:'Autorità',value:d.authority},{label:'Definizione',value:d.definition}];
  if(d.personality&&d.personality.length>0){const pS=d.personality.find(p=>p.planet_en==='Sun');if(pS)coreItems.push({label:'Tema di Vita',value:getIncarnationCross(pS.gate,d.profile)});}
  if(d.variables){const dS=d.variables.digestion==='left'?'L':'R',dN=d.variables.environment==='left'?'L':'R',pS=d.variables.perspective==='left'?'L':'R',pN=d.variables.awareness==='left'?'L':'R';coreItems.push({label:'Variabile',value:`P${pS}${pN} D${dS}${dN}`});}
  if(d.dietary_regime)coreItems.push({label:'Regime Alimentare',value:d.dietary_regime});
  if(d.environment)coreItems.push({label:'Ambiente',value:d.environment});
  document.getElementById('carta-core').innerHTML=coreItems.map(i=>`<div class="core-card"><div class="core-card-label">${i.label}</div><div class="core-card-value">${escHtml(i.value)}</div></div>`).join('');
  const blackGates=new Set(),redGates=new Set();
  for(const [g,c] of Object.entries(d.gate_colors)){const gn=parseInt(g);if(c==='P'||c==='PD')blackGates.add(gn);if(c==='D'||c==='PD')redGates.add(gn);}
  const definedCenterSet=new Set(d.defined_centers);
  const definedChannels=d.defined_channels.map(([g1,g2])=>{const ch=CHANNELS.find(([c1,c2])=>(c1===g1&&c2===g2)||(c1===g2&&c2===g1));return ch||[g1,g2,GATE_TO_CENTER[g1]||'',GATE_TO_CENTER[g2]||''];});
  await loadAndRenderBodygraph(d.gate_colors,definedChannels,definedCenterSet,blackGates,redGates,d.variables,'carta-bodygraph-wrap',false);
  renderPlaneti(d.personality,d.design);
  const prog=document.getElementById('gcb-progress');if(prog)prog.classList.add('gcb-progress--show');
  if(_gcbMode==='couple'){
    gcbUnlockFormB(nome);
  } else {
    document.getElementById('carta-results').style.display='block';
    document.getElementById('carta-results').scrollIntoView({behavior:'smooth',block:'start'});
    const cta=document.getElementById('gcb-connect-cta');
    if(cta){if(nome){const btn=cta.querySelector('.gcb-connect-btn');if(btn)btn.textContent=`Confronta ${nome} con qualcuno`;}cta.style.display='block';}
  }
}

// ─── Bodygraph renderer ───────────────────────────────────────────────────────
async function loadAndRenderBodygraph(gateColors,definedChannels,definedCenterSet,blackGates,redGates,variables,targetId,compositeMode){
  const wrap=document.getElementById(targetId||'carta-bodygraph-wrap');if(!wrap)return;
  const ns='http://www.w3.org/2000/svg';
  const CTR_ID={HEAD:'Head',AJNA:'Ajna',THROAT:'Throat',G:'G',HEART:'Heart',SPLEEN:'Splenic_Center',SACRAL:'Sacral',SOLAR:'Solar_Plexus',ROOT:'Root'};
  const CTR_COL={HEAD:'#b4cfe8',AJNA:'#52a363',THROAT:'#b8913e',G:'#d9b82a',HEART:'#b83838',SPLEEN:'#957040',SOLAR:'#d47a2e',SACRAL:'#c94e4e',ROOT:'#8a7868'};
  const COL_P='#1a1a2e',COL_D='#c0392b',COL_EMPTY='#c8c2bc';
  const COL_A='#7a5c6e',COL_B='#3d7a8a',COL_EM='#E6A756',COL_AB='#5a8a6e';
  function gcFill(col){if(!compositeMode)return col==='P'?COL_P:col==='D'?COL_D:'url(#splitGatePattern)';return col==='A'?COL_A:col==='B'?COL_B:col==='EM'?COL_EM:COL_AB;}
  try{
    const resp=await fetch('/chart.svg',{cache:'no-cache'});if(!resp.ok)throw new Error('SVG non trovato');
    const svgEl=(new DOMParser()).parseFromString(await resp.text(),'image/svg+xml').documentElement;
    svgEl.setAttribute('style','max-width:520px;width:100%;height:auto;display:block;margin:0 auto');
    svgEl.removeAttribute('class');
    const rules=[];
    rules.push(`:root{--color-personality:${COL_P};--color-design:${COL_D};--color-empty:${COL_EMPTY};}`);
    for(let g=1;g<=64;g++){const col=gateColors[g]||gateColors[String(g)];if(!col)continue;rules.push(`#Gate${g}{fill:${gcFill(col)}!important;}`);}
    const intIds=[10,20,34,57];
    for(const ig of intIds){const col=gateColors[ig]||gateColors[String(ig)];if(col)rules.push(`#GateConnect${ig}{fill:${gcFill(col)}!important;}`);}
    if(intIds.some(g=>gateColors[g]||gateColors[String(g)])){const col20=gateColors[20]||gateColors['20'];rules.push(`#GateSpan{fill:${col20?gcFill(col20):COL_EMPTY}!important;}`);}
    for(const c of definedCenterSet){const svgId=CTR_ID[c],col=CTR_COL[c];if(svgId&&col)rules.push(`#${svgId} path{fill:${col}!important;}`);}
    const activeGates=new Set(Object.keys(gateColors).map(Number));
    for(let g=1;g<=64;g++){if(activeGates.has(g)){rules.push(`#GateText${g}{fill:#fff!important;font-weight:bold!important;opacity:1!important;}`);rules.push(`#GateTextBg${g} path,#GateTextBg${g} circle{fill:#1a1a2e!important;}`);}else{rules.push(`#GateText${g}{fill:#fff!important;opacity:0.4!important;}`);}}
    let defs=svgEl.querySelector('defs');if(!defs){defs=document.createElementNS(ns,'defs');svgEl.insertBefore(defs,svgEl.firstChild);}
    const styleEl=document.createElementNS(ns,'style');styleEl.textContent=rules.join('\n');defs.appendChild(styleEl);
    const gg=svgEl.querySelector('#Gates');if(gg)gg.removeAttribute('class');
    if(variables&&!compositeMode){
      const toArrow=dir=>dir==='left'?'\u25C4':'\u25BA';
      const hc=426,ay=30,ag=35,ao=80;
      const mkA=(x,y,t,col)=>{const el=document.createElementNS(ns,'text');el.setAttribute('x',String(x));el.setAttribute('y',String(y));el.setAttribute('text-anchor','middle');el.setAttribute('font-size','28');el.setAttribute('fill',col);el.setAttribute('font-weight','bold');el.textContent=t;return el;};
      const grp=document.createElementNS(ns,'g');grp.setAttribute('id','hd-variables');
      grp.appendChild(mkA(hc-ao,ay,toArrow(variables.digestion),'#c0392b'));
      grp.appendChild(mkA(hc-ao,ay+ag,toArrow(variables.environment),'#c0392b'));
      grp.appendChild(mkA(hc+ao,ay,toArrow(variables.perspective),'#1a1a2e'));
      grp.appendChild(mkA(hc+ao,ay+ag,toArrow(variables.awareness),'#1a1a2e'));
      svgEl.appendChild(grp);
    }
    wrap.innerHTML='';wrap.appendChild(svgEl);
  }catch(e){
    const bg=blackGates||new Set(),rg=redGates||new Set();
    wrap.innerHTML=buildBodygraph(bg,rg,definedChannels,definedCenterSet);
  }
}

