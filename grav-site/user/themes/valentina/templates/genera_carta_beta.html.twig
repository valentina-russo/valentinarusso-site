const GATE_TO_CENTER={};
const CENTER_GATES={HEAD:[64,61,63],AJNA:[47,24,4,17,43,11],THROAT:[62,23,56,35,12,45,33,8,31,20,16],G:[1,13,25,46,10,15,2,7],HEART:[51,21,40,26],SPLEEN:[48,57,44,50,32,28,18],SOLAR:[36,22,37,6,49,55,30],SACRAL:[5,14,29,27,34,9,3,42,59],ROOT:[38,54,53,60,52,19,39,41,58]};
