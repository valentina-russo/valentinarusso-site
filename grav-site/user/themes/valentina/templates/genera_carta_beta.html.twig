const CHANNELS=[[64,47,'HEAD','AJNA'],[61,24,'HEAD','AJNA'],[63,4,'HEAD','AJNA'],[17,62,'AJNA','THROAT'],[43,23,'AJNA','THROAT'],[11,56,'AJNA','THROAT'],[16,48,'THROAT','SPLEEN'],[20,57,'THROAT','SPLEEN'],[31,7,'THROAT','G'],[8,1,'THROAT','G'],[33,13,'THROAT','G'],[10,20,'THROAT','G'],[45,21,'THROAT','HEART'],[35,36,'THROAT','SOLAR'],[12,22,'THROAT','SOLAR'],[20,34,'THROAT','SACRAL'],[26,44,'HEART','SPLEEN'],[51,25,'HEART','G'],[40,37,'HEART','SOLAR'],[10,34,'G','SACRAL'],[2,14,'G','SACRAL'],[5,15,'G','SACRAL'],[29,46,'G','SACRAL'],[27,50,'SACRAL','SPLEEN'],[34,57,'SACRAL','SPLEEN'],[59,6,'SACRAL','SOLAR'],[3,60,'SACRAL','ROOT'],[9,52,'SACRAL','ROOT'],[42,53,'SACRAL','ROOT'],[18,58,'SPLEEN','ROOT'],[28,38,'SPLEEN','ROOT'],[32,54,'SPLEEN','ROOT'],[30,41,'SOLAR','ROOT'],[39,55,'SOLAR','ROOT'],[19,49,'SOLAR','ROOT']];
