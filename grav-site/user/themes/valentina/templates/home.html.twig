{% extends 'partials/base.html.twig' %}

{% block title %}Valentina Russo | Consulente BG5&reg; &amp; Human Design{% endblock %}

{% block schema %}
{{ parent() }}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": "{{ grav.base_url_absolute }}/#webpage",
  "url": "{{ grav.base_url_absolute }}/",
  "name": "Valentina Russo | Consulente BG5® & Human Design",
  "description": "Consulente BG5® e Human Design per carriera, relazioni e amor proprio. Analisi del tuo tipo energetico, strategia e autorità interna.",
  "inLanguage": "it",
  "datePublished": "2024-01-01",
  "dateModified": "{{ page.modified|date('c') }}",
  "isPartOf": {
    "@type": "WebSite",
    "url": "{{ grav.base_url_absolute }}"
  },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "{{ grav.base_url_absolute }}/"
      }
    ]
  }
}
</script>
{% endblock %}

{% block extra_css %}
<link rel="stylesheet" href="{{ theme_url }}/css/hero-privati.css?v=20260311">
{% endblock %}

{% block content %}
<main>
    <!-- NEW HERO V2 -->
    <section class="hero-v2">
      <div class="hero-text">
        <p class="eyebrow">A mete eccelse, per anguste vie</p>
        <h1 class="headline">
          Ri-conosci<br>
          e <em>ama</em><br>
          te stesso
        </h1>
        <p class="subline">
          Valentina Russo &mdash; Guida Mentale 2/4<br>
          Ti aiuto a leggere chi sei davvero attraverso la logica della tua energia.
        </p>
        <div class="cta-group">
          <a href="{{ grav.base_url }}/servizi#percorso" class="btn-primary-v2">Inizia il tuo viaggio &rarr;</a>
          <a href="{{ grav.base_url }}/genera-carta" class="btn-secondary-v2">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10" />
              <polygon points="10 8 16 12 10 16 10 8" />
            </svg>
            <span style="font-size:.78rem;">Analizza la tua carta qui</span>
          </a>
        </div>
        <div class="social-proof">
          <a href="https://bg5businessinstitute.com/professionals?id=399d41b3-612b-48d1-88b9-7bc26ed71418" target="_blank" rel="noopener noreferrer" style="display:inline-flex;align-items:center;gap:0.5rem;text-decoration:none;color:inherit;">
            <img src="{{ theme_url }}/images/bg5-certified.png" alt="BG5 Certified Career &amp; Business Professional" style="height: 48px; width: auto; object-fit: contain;">
            <strong>Analista certificata BG5&reg; &middot; Human Design</strong>
          </a>
        </div>
      </div>

      <div class="hero-visual">
        <div class="image-wrapper">
          <div class="dot-grid"></div>
          <div class="star">&#10022;</div>
          <img src="{{ grav.base_url }}/user/pages/assets/valentina.jpg" alt="Valentina Russo" class="photo-blob" />
          <div class="photo-ribbon">
            <span>&#10022; Guida Mentale 2/4</span>
          </div>
          <div class="vertical-tag">valentinarussobg5.com</div>
        </div>
      </div>
    </section>

    <!-- Quote Section -->
    <section class="quote-section">
      <div class="container text-center">
        <div class="quote-text serif italic" data-animate>
          &ldquo;Tutto cambia quando capisci che la tua versione migliore non &egrave; una versione futura, ma una scelta quotidiana.&rdquo;
        </div>
      </div>
    </section>

    <!-- Il Tuo Funzionamento Naturale -->
    <section class="section-padding">
      <div class="container">
        <div class="text-center" style="margin-bottom: var(--space-lg); max-width: 800px; margin-inline: auto;">
          <h2 data-animate style="margin-bottom: 1rem;">Il Tuo Funzionamento Naturale</h2>
          <p data-animate class="serif italic" style="font-size: 1.25rem; color: var(--primary-color); margin-bottom: 1.5rem;">
            Il sistema nervoso ha un perimetro esatto. Quando la mente cerca di forzare la forma, il corpo registra il colpo. La resistenza si accumula nei muscoli, le relazioni si complicano, i soldi si bloccano.
          </p>
          <p data-animate style="margin-bottom: 2rem;">
            Io leggo il codice sorgente del tuo veicolo attraverso lo Human Design e il sistema BG5&reg;. Ti fornisco i dati meccanici per far funzionare la tua vita e la tua carriera. Scegli la tua porta d&rsquo;accesso.
          </p>
        </div>

        <div class="footer-grid" style="grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));">
          <div class="blog-card" style="box-shadow: 0 4px 6px rgba(0,0,0,0.05);" data-animate>
            <div class="blog-card-content text-center">
              <h3 style="color: var(--primary-color);">1. Filtro d&rsquo;Ingresso</h3>
              <p class="text-small">Il passaggio obbligato per comprendere come sei progettato. Ottieni la tua mappa di base.</p>
              <a href="{{ grav.base_url }}/servizi" style="display: block; margin-top: 1rem; color: var(--primary-color); font-weight: 600;">Scopri di pi&ugrave; &rarr;</a>
            </div>
          </div>
          <div class="blog-card" style="box-shadow: 0 4px 6px rgba(0,0,0,0.05);" data-animate>
            <div class="blog-card-content text-center">
              <h3 style="color: var(--accent-color);">2. Vita e Relazioni</h3>
              <p class="text-small">Ripulisci la quotidianit&agrave; dai condizionamenti, supera i blocchi inconsci e comprendi chi hai accanto.</p>
              <a href="{{ grav.base_url }}/servizi" style="display: block; margin-top: 1rem; color: var(--accent-color); font-weight: 600;">Scopri di pi&ugrave; &rarr;</a>
            </div>
          </div>
          <div class="blog-card" style="box-shadow: 0 4px 6px rgba(0,0,0,0.05);" data-animate>
            <div class="blog-card-content text-center">
              <h3 style="color: var(--secondary-color);">3. Individuo - Business</h3>
              <p class="text-small">Applica la tua meccanica al mercato. Ottimizza la tua operativit&agrave; e le relazioni professionali.</p>
              <a href="{{ grav.base_url }}/servizi" style="display: block; margin-top: 1rem; color: var(--secondary-color); font-weight: 600;">Scopri di pi&ugrave; &rarr;</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Human Design Deep Dive -->
    <section class="container">
      <div class="hd-section">
        <div class="hd-content" data-animate>
          <h2>Il Tuo Disegno Unico</h2>
          <p style="margin: 1.5rem 0;">Il Human Design e il BG5&reg; non sono sistemi di credenze, ma strumenti di analisi logica della tua energia. Attraverso la tua carta, possiamo vedere i talenti che hai ricevuto alla nascita e le aree dove sei pi&ugrave; vulnerabile al condizionamento esterno.</p>
          <div style="display: flex; gap: 1rem; justify-content: flex-start;">
            <a href="{{ grav.base_url }}/genera-carta" class="btn btn-outline">Fai la tua Carta</a>
            <a href="{{ grav.base_url }}/chi-sono" class="btn btn-primary">Chi sono</a>
          </div>
        </div>
        <div class="hd-visual" data-animate>
          <img src="{{ grav.base_url }}/user/pages/assets/bodygraph.png" alt="Human Design Bodygraph">
        </div>
      </div>
    </section>

    <!-- Consulente BG5 per città — Internal Links SEO -->
    <section class="section-padding" style="background: var(--bg-light, #f8f8f8); padding-top: 3rem; padding-bottom: 3rem;">
      <div class="container text-center">
        <h2 data-animate style="margin-bottom: 0.75rem; font-size: 1.4rem;">Consulente BG5&reg; &mdash; Dove opero</h2>
        <p data-animate style="margin-bottom: 1.5rem; color: var(--text-muted, #666);">Sessioni online e in presenza. Seleziona la tua città.</p>
        <nav aria-label="Città disponibili" style="display: flex; flex-wrap: wrap; gap: 0.5rem; justify-content: center;">
          <a href="{{ grav.base_url }}/consulente-bg5-torino" class="btn btn-outline" style="font-size: 0.85rem; padding: 0.4rem 1rem;">Torino</a>
          <a href="{{ grav.base_url }}/consulente-bg5-milano" class="btn btn-outline" style="font-size: 0.85rem; padding: 0.4rem 1rem;">Milano</a>
          <a href="{{ grav.base_url }}/consulente-bg5-roma" class="btn btn-outline" style="font-size: 0.85rem; padding: 0.4rem 1rem;">Roma</a>
          <a href="{{ grav.base_url }}/consulente-bg5-firenze" class="btn btn-outline" style="font-size: 0.85rem; padding: 0.4rem 1rem;">Firenze</a>
          <a href="{{ grav.base_url }}/consulente-bg5-bologna" class="btn btn-outline" style="font-size: 0.85rem; padding: 0.4rem 1rem;">Bologna</a>
          <a href="{{ grav.base_url }}/consulente-bg5-napoli" class="btn btn-outline" style="font-size: 0.85rem; padding: 0.4rem 1rem;">Napoli</a>
          <a href="{{ grav.base_url }}/consulente-bg5-venezia" class="btn btn-outline" style="font-size: 0.85rem; padding: 0.4rem 1rem;">Venezia</a>
          <a href="{{ grav.base_url }}/consulente-bg5-bari" class="btn btn-outline" style="font-size: 0.85rem; padding: 0.4rem 1rem;">Bari</a>
          <a href="{{ grav.base_url }}/consulente-bg5-palermo" class="btn btn-outline" style="font-size: 0.85rem; padding: 0.4rem 1rem;">Palermo</a>
          <a href="{{ grav.base_url }}/consulente-bg5-verona" class="btn btn-outline" style="font-size: 0.85rem; padding: 0.4rem 1rem;">Verona</a>
          <a href="{{ grav.base_url }}/consulente-bg5-italia" class="btn btn-outline" style="font-size: 0.85rem; padding: 0.4rem 1rem;">Tutta Italia</a>
        </nav>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="section-padding text-center hero-cta-band" style="color: var(--white); margin-top: 0;">
      <div class="container">
        <h2 style="margin-bottom: var(--space-md);" data-animate>Cominciamo il tuo percorso?</h2>
        <p style="margin-bottom: var(--space-lg);" data-animate>Prenota un colloquio conoscitivo gratuito di 15 minuti per capire come posso aiutarti.</p>
        <a href="{{ grav.base_url }}/contatti" class="btn btn-outline" style="border-color: var(--white); color: var(--white);" data-animate>Contattami ora</a>
      </div>
    </section>
</main>
{% endblock %}
