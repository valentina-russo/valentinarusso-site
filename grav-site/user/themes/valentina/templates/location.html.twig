{% extends 'partials/base.html.twig' %}

{% set city = page.header.city ?? 'Italia' %}
{% set region = page.header.region ?? 'Italia' %}

{% block title %}{{ page.header.seo_title ?? page.title }} | Valentina Russo{% endblock %}

{% block schema %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "ProfessionalService"],
  "name": "Valentina Russo — Consulente BG5® e Human Design",
  "url": "{{ grav.base_url_absolute }}",
  "image": "{{ grav.base_url_absolute }}/user/pages/assets/valentina.png",
  "description": "{{ page.header.seo_desc|e('js') }}",
  "priceRange": "€€",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "{{ city }}",
    "addressRegion": "{{ region }}",
    "addressCountry": "IT"
  },
  "areaServed": [
    { "@type": "AdministrativeArea", "name": "{{ region }}" },
    { "@type": "Country", "name": "Italia" }
  ],
  "knowsAbout": ["BG5 System", "Human Design", "Career Consulting", "Business Strategy"],
  "hasCredential": {
    "@type": "EducationalOccupationalCredential",
    "name": "BG5® Business Institute Certified",
    "credentialCategory": "Professional Certification",
    "url": "https://www.humandesignbusiness.com/"
  },
  "sameAs": [
    "https://www.instagram.com/valentinarussobg5/",
    "https://www.humandesignbusiness.com/"
  ],
  "serviceType": ["BG5 Consulting", "Human Design Analysis", "Career Consulting", "Business Consulting"],
  "servesCuisine": null
}
</script>
{% endblock %}

{% block content %}
<main>

  {# Hero #}
  <section class="section-padding" style="background: linear-gradient(135deg, var(--bg-color) 0%, #f5f0eb 100%); border-bottom: 1px solid var(--soft-gray);">
    <div class="container" style="max-width: 900px; text-align: center;">
      <p class="text-uppercase" style="color: var(--primary-color); font-weight: 700; letter-spacing: 2px; font-size: 0.8rem; margin-bottom: 1rem;" data-animate>
        BG5® Certified Consultant
      </p>
      <h1 style="margin-bottom: 1.25rem;" data-animate>{{ page.title }}</h1>
      <p class="serif italic" style="font-size: 1.2rem; color: var(--primary-color); margin-bottom: 2rem; max-width: 700px; margin-inline: auto;" data-animate>
        {{ page.header.subtitle ?? 'Consulenze individuali BG5® e Human Design per carriera, relazioni e business.' }}
      </p>
      <a href="{{ grav.base_url }}/contatti" class="btn btn-primary" style="font-size: 1.1rem; padding: 0.9rem 2rem;" data-animate>
        Prenota una consulenza
      </a>
    </div>
  </section>

  {# Main content #}
  <section class="section-padding">
    <div class="container" style="max-width: 900px;">

      <div class="location-content" data-animate>
        {{ page.content|raw }}
      </div>

      {# Servizi #}
      <div style="margin-top: 4rem;" data-animate>
        <h2 style="color: var(--primary-color); margin-bottom: 0.5rem; text-align: center;">Consulenze disponibili</h2>
        <p style="text-align: center; opacity: 0.7; margin-bottom: 2.5rem;">Sessioni online — accessibili da {{ city }} e da tutta Italia</p>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.5rem;">

          <div class="card" style="background: var(--white); border: 1px solid var(--soft-gray); border-top: 4px solid var(--primary-color); border-radius: 12px; padding: 1.5rem;">
            <h3 style="margin-bottom: 0.75rem; font-size: 1.1rem;">Prima Lettura Human Design</h3>
            <p style="font-size: 0.9rem; margin-bottom: 1rem; opacity: 0.85;">Sessione di 2 ore. Tipo Energetico, Strategia, Autorità Decisionale. La mappa del tuo funzionamento naturale.</p>
            <p style="font-weight: 700; color: var(--primary-color);">210 €</p>
          </div>

          <div class="card" style="background: var(--white); border: 1px solid var(--soft-gray); border-top: 4px solid var(--accent-color); border-radius: 12px; padding: 1.5rem;">
            <h3 style="margin-bottom: 0.75rem; font-size: 1.1rem;">Panoramica BG5® Carriera</h3>
            <p style="font-size: 0.9rem; margin-bottom: 1rem; opacity: 0.85;">90 minuti. Disegno di Carriera, Tipo di Carriera, Strategia e Autorità in chiave professionale. Certificato BG5®.</p>
            <p style="font-weight: 700; color: var(--accent-color);">350 €</p>
          </div>

          <div class="card" style="background: var(--white); border: 1px solid var(--soft-gray); border-top: 4px solid var(--secondary-color); border-radius: 12px; padding: 1.5rem;">
            <h3 style="margin-bottom: 0.75rem; font-size: 1.1rem;">Percorso BG5® Business Blueprint</h3>
            <p style="font-size: 0.9rem; margin-bottom: 1rem; opacity: 0.85;">15 sessioni per professionisti indipendenti e imprenditori. Strategia, posizionamento, partnership.</p>
            <p style="font-weight: 700; color: var(--secondary-color);">1.800 €</p>
          </div>

        </div>
      </div>

      {# Chi sono #}
      <div style="margin-top: 4rem; display: grid; grid-template-columns: auto 1fr; gap: 2rem; align-items: center; background: var(--white); border: 1px solid var(--soft-gray); border-radius: 16px; padding: 2rem;" data-animate>
        <img src="{{ grav.base_url }}/user/pages/assets/valentina.png"
             alt="Valentina Russo, Consulente BG5® e Human Design"
             style="width: 100px; height: 100px; border-radius: 50%; object-fit: cover; flex-shrink: 0;">
        <div>
          <h3 style="margin-bottom: 0.5rem;">Valentina Russo</h3>
          <p style="font-size: 0.9rem; opacity: 0.8; margin-bottom: 0.75rem;">BG5® Business Institute Certified Consultant · Human Design Analyst · Guida Mentale 2/4</p>
          <p style="font-size: 0.9rem; line-height: 1.7;">Consulente certificata BG5® con clienti in tutta Italia. Le sessioni si svolgono online in videochiamata — stessa qualità e profondità di una consulenza in presenza.</p>
        </div>
      </div>

      {# CTA finale #}
      <div style="margin-top: 4rem; text-align: center; padding: 3rem 2rem; background: linear-gradient(135deg, #f5f0eb, #ede8e3); border-radius: 16px;" data-animate>
        <h2 style="margin-bottom: 1rem;">Pronta a partire?</h2>
        <p style="max-width: 550px; margin: 0 auto 2rem; opacity: 0.8;">Scrivi da {{ city }} o da qualsiasi città italiana — rispondo entro 24 ore e concordiamo il primo appuntamento.</p>
        <a href="{{ grav.base_url }}/contatti" class="btn btn-primary" style="font-size: 1.1rem; padding: 0.9rem 2.2rem;">Contattami ora</a>
      </div>

    </div>
  </section>

</main>
{% endblock %}
