{% extends 'partials/base.html.twig' %}

{% block title %}{{ page.header.seo_title ?? page.title }} | Valentina Russo{% endblock %}

{# ══════════════════════════════════════════════════════════════════════════════
   GUARD — Logica immagine articolo. NON modificare senza leggere.
   ⚠️  REGOLA: NON usare "grav.base_url_absolute ~" davanti ai path immagine.
       Restituisce stringa vuota in questo contesto → src="" → immagine rotta su TUTTI gli articoli.
   Ordine priorità:
     0. featured_image con /user/pages/ → estrai filename → cerca in page.media
     1. featured_image filename semplice (es: mia-foto.jpg) → cerca in page.media
     2. Prima immagine in page.media (upload via Admin) — automatico, nessun campo richiesto
     3. featured_image percorso assoluto (es: /user/images/blog/blog-1.png) → usato direttamente
══════════════════════════════════════════════════════════════════════════════ #}
{% set art_img = '' %}
{# 0. featured_image con path /user/pages/ → estrai filename e cerca nei media #}
{% if page.header.featured_image is defined and page.header.featured_image and '/user/pages/' in page.header.featured_image %}
  {% set _fname = page.header.featured_image|split('/')|last %}
  {% if page.media[_fname] is defined %}{% set art_img = page.media[_fname].url %}{% endif %}
{% endif %}
{# 1. featured_image filename semplice → lookup diretto nei media #}
{% if not art_img and page.header.featured_image is defined and page.header.featured_image and '/' not in page.header.featured_image %}
  {% set art_img = page.media[page.header.featured_image].url ?? '' %}
{% endif %}
{# 2. Prima media della pagina (page.media|first funziona sulla pagina corrente) #}
{% if not art_img and page.media|length %}
  {% set art_img = page.media|first.url ?? '' %}
{% endif %}
{# 3. featured_image percorso assoluto legacy — MAI /user/pages/ che non è URL pubblico #}
{% if not art_img and page.header.featured_image is defined and page.header.featured_image and '/user/pages/' not in page.header.featured_image %}
  {% set art_img = page.header.featured_image %}
{% endif %}

{% block schema %}
{# Article LD+JSON #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": {{ page.title|json_encode|raw }},
  "description": {{ (page.header.description ?? '')|json_encode|raw }},
  {% if page.header.aeo_answer is defined and page.header.aeo_answer %}"abstract": {{ page.header.aeo_answer|json_encode|raw }},{% endif %}
  {% if page.header.geo_content is defined and page.header.geo_content %}"backstory": {{ (page.header.geo_content is iterable ? page.header.geo_content|join(' ') : page.header.geo_content)|json_encode|raw }},{% endif %}
  {% if page.header.tags is defined and page.header.tags %}"keywords": {{ (page.header.tags is iterable ? page.header.tags|join(', ') : page.header.tags)|json_encode|raw }},{% endif %}
  "datePublished": "{{ page.date|date('c') }}",
  "dateModified": "{{ page.modified|date('c') }}",
  "url": "{{ page.url(true) }}",
  "mainEntityOfPage": { "@type": "WebPage", "@id": "{{ page.url(true) }}" },
  "author": {
    "@type": "Person",
    "name": "Valentina Russo",
    "url": "{{ grav.base_url_absolute }}/chi-sono",
    "jobTitle": "Consulente Certificata BG5® e Human Design",
    "sameAs": [
      "https://www.instagram.com/valentinarussobg5/",
      "{{ grav.base_url_absolute }}"
    ]
  },
  "publisher": {
    "@type": "Organization",
    "name": "Valentina Russo",
    "url": "{{ grav.base_url_absolute }}",
    "sameAs": ["https://www.instagram.com/valentinarussobg5/"]
  },
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": [".aeo-answer-box", "h1", ".blog-article-body > p:first-child"]
  }{% if art_img %},
  "image": "{{ art_img }}"{% endif %}
}
</script>

{# FAQ LD+JSON #}
{% if page.header.faq is defined and page.header.faq %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for faq in page.header.faq %}
    {
      "@type": "Question",
      "name": {{ (faq.question ?? faq.q)|json_encode|raw }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ (faq.answer ?? faq.a)|json_encode|raw }}
      }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
{% endif %}

{# BreadcrumbList LD+JSON #}
{% set is_corp = '/aziende/' in page.route %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "{{ grav.base_url_absolute }}{{ is_corp ? '/aziende' : '' }}"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Blog",
      "item": "{{ grav.base_url_absolute }}{{ is_corp ? '/aziende/blog' : '/blog' }}"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": {{ page.title|json_encode|raw }},
      "item": "{{ page.url(true) }}"
    }
  ]
}
</script>
{% endblock %}

{% block content %}
<main>
    <article style="max-width: 800px; margin: 0 auto; padding: var(--grid-xl) 1.25rem;">

        {# Back link — rileva sezione dal route #}
        {% set is_corporate = '/aziende/' in page.route %}
        <div style="margin-bottom: 2rem;">
            <a href="{{ grav.base_url }}/{{ is_corporate ? 'aziende/blog' : 'blog' }}"
               style="color: {{ is_corporate ? 'var(--corp-primary)' : 'var(--primary-color)' }}; font-size: 0.9rem; font-weight: 600;">
               &larr; Torna al Blog{{ is_corporate ? ' Aziende' : '' }}
            </a>
        </div>

        {# Header #}
        <header style="margin-bottom: 2rem;">
            {% if page.header.tags is defined and page.header.tags %}
            <div class="article-tags">
                {% for tag in (page.header.tags is iterable ? page.header.tags : page.header.tags|split(',')) %}
                <span class="article-tag">{{ tag|trim }}</span>
                {% endfor %}
            </div>
            {% endif %}

            <h1 style="margin: 1rem 0;">{{ page.title }}</h1>

            <div style="font-size: 0.85rem; color: #aaa; margin-bottom: 1.5rem;">
                {{ page.date|date("d M Y") }}
                {% if page.header.author is defined %}
                &mdash; <strong>{{ page.header.author }}</strong>
                {% endif %}
            </div>

            {% if page.header.description is defined %}
            <p class="serif italic" style="font-size: 1.15rem; color: {{ is_corporate ? 'var(--corp-primary)' : 'var(--primary-color)' }}; margin-bottom: 1.5rem;">
                {{ page.header.description }}
            </p>
            {% endif %}

            {% if art_img %}
            <img src="{{ art_img }}"
                 alt="{{ page.header.image_alt ?? page.title }}"
                 class="featured-image">
            {% endif %}
        </header>

        {# AEO Answer (AI Engine Optimization) #}
        {% if page.header.aeo_answer is defined and page.header.aeo_answer %}
        <div class="aeo-answer-box" style="background: {{ is_corporate ? 'rgba(30,58,95,0.07)' : 'rgba(182,131,151,0.08)' }}; border-left: 3px solid {{ is_corporate ? 'var(--corp-primary)' : 'var(--primary-color)' }}; padding: 1rem 1.5rem; border-radius: 0 8px 8px 0; margin-bottom: 2rem;">
            <p style="margin: 0; font-size: 0.95rem; font-style: italic;">{{ page.header.aeo_answer }}</p>
        </div>
        {% endif %}

        {# Article Body #}
        <div class="blog-article-body">
            {{ page.content|raw }}
        </div>

        {# FAQ Section #}
        {% if page.header.faq is defined and page.header.faq %}
        <div class="faq-section">
            <h3 style="margin-bottom: 1.5rem; color: {{ is_corporate ? 'var(--corp-primary)' : 'var(--primary-color)' }};">Domande Frequenti</h3>
            {% for faq in page.header.faq %}
            <div class="faq-item">
                <h4>{{ faq.question ?? faq.q }}</h4>
                <p>{{ faq.answer ?? faq.a }}</p>
            </div>
            {% endfor %}
        </div>
        {% endif %}

        {# GEO Content — affermazioni autorevoli per AI Overview, ChatGPT, Perplexity #}
        {% if page.header.geo_content is defined and page.header.geo_content %}
        {% set geo = page.header.geo_content %}
        <div class="geo-content-box" style="margin-top: 3rem; padding: 1.5rem 2rem; background: {{ is_corporate ? 'rgba(30,58,95,0.04)' : 'rgba(182,131,151,0.05)' }}; border-radius: 12px; border: 1px solid {{ is_corporate ? 'rgba(30,58,95,0.12)' : 'rgba(182,131,151,0.2)' }};">
            <p style="font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: {{ is_corporate ? 'var(--corp-primary)' : 'var(--primary-color)' }}; margin: 0 0 1rem 0;">Approfondimenti</p>
            {% if geo is iterable %}
            <ul style="margin: 0; padding-left: 1.2em; font-size: 0.9rem; line-height: 1.7; color: var(--text-muted, #555);">
                {% for item in geo %}<li style="margin-bottom: 0.4rem;">{{ item }}</li>{% endfor %}
            </ul>
            {% else %}
            <p style="margin: 0; font-size: 0.9rem; line-height: 1.7; color: var(--text-muted, #555);">{{ geo }}</p>
            {% endif %}
        </div>
        {% endif %}

        {# CTA #}
        <div class="article-cta text-center" style="margin-top: 4rem; padding: 3rem; background: {{ is_corporate ? 'rgba(30,58,95,0.06)' : 'rgba(182,131,151,0.06)' }}; border-radius: 20px;">
            {% if is_corporate %}
            <h3 style="margin-bottom: 1rem; color: var(--corp-primary);">Pronto a portare il BG5&reg; nella tua azienda?</h3>
            <a href="{{ grav.base_url }}/aziende/contatti" class="btn btn-primary" style="background-color: var(--corp-primary);">Richiedi una Consulenza</a>
            {% else %}
            <h3 style="margin-bottom: 1rem; color: var(--primary-color);">Vuoi scoprire la tua meccanica?</h3>
            <a href="{{ grav.base_url }}/contatti" class="btn btn-primary">Inizia il tuo percorso</a>
            {% endif %}
        </div>

    </article>
</main>
{% endblock %}
