{% extends 'partials/base.html.twig' %}

{% block title %}Servizi Corporate | Valentina Russo{% endblock %}

{% block content %}
<main>
    <div class="corp-page-header" style="padding: 6rem 0 4rem; text-align: center;">
        <div class="container">
            <h1 class="serif" style="font-size: clamp(2.5rem, 8vw, 4rem); margin-bottom: 2rem;">Percorsi &amp; Consulenze</h1>
            <p style="font-size: 1.25rem; max-width: 800px; margin: 0 auto; opacity: 0.9; line-height: 1.6;">Soluzioni BG5&reg; per professionisti, partnership strategiche e organizzazioni complesse.</p>
        </div>
    </div>

    <section class="section-padding" style="background: transparent; padding-top: 0;">
        <div class="container-full">

            <!-- Area individuale -->
            <div class="area-individuale" id="leadership">
                <div class="container" style="position: relative; z-index: 1;">
                    <div class="area-icon-box" style="background: white; color: var(--corp-secondary); box-shadow: 0 10px 20px rgba(49,130,206,0.1);">&#128100;</div>
                    <h2 class="text-center" style="margin-bottom: 4rem; color: var(--primary-color); font-size: 2.2rem;">Per l&rsquo;imprenditore - CEO - Persona Individuale</h2>
                    <div class="blog-grid aziende-grid-fix">

                        <div class="card" style="background: white; padding: 2.5rem; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); border-top: 4px solid var(--accent-color);" data-animate>
                            <h3 style="color: var(--primary-color); margin-bottom: 1rem;">BG5 Business Blueprint</h3>
                            <p style="margin-bottom: 1.5rem;">Per liberi professionisti, consulenti e imprenditori indipendenti che desiderano lavorare in allineamento al proprio modo naturale di operare.</p>
                            <ul style="margin-bottom: 2rem; padding-left: 1.2rem; list-style: disc; font-size: 0.95rem;">
                                <li>Il tuo modo naturale di contribuire.</li>
                                <li>Segnali meccanici di corretto allineamento.</li>
                                <li>Ambiente di lavoro ideale e processamento info.</li>
                                <li>Individuazione e rimozione dei condizionamenti.</li>
                                <li>Il tuo ruolo nei gruppi e nel collettivo.</li>
                            </ul>
                            <div style="background: #f8fafc; padding: 1rem; border-radius: 10px; font-size: 0.9rem;">
                                <strong>Dettagli:</strong> 15 sessioni (90 min) + PDF + Registrazioni<br>
                                <strong>Investimento:</strong> Euro 1.800
                            </div>
                        </div>

                        <div class="card" style="background: white; padding: 2.5rem; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); border-top: 4px solid var(--secondary-color);" data-animate>
                            <h3 style="color: var(--primary-color); margin-bottom: 1rem;">BG5 Partnership Dynamics</h3>
                            <p style="margin-bottom: 1.5rem;">Percorso per soci e co-fondatori. Comprendere le meccaniche individuali e di relazione previene gli attriti, rende le decisioni chiare.</p>
                            <ul style="margin-bottom: 2rem; padding-left: 1.2rem; list-style: disc; font-size: 0.95rem;">
                                <li>Dinamiche naturali che emergono nella coppia.</li>
                                <li>Competenze e talenti portati da ciascun socio.</li>
                                <li>Connessioni dei ruoli pubblici e comunicazione.</li>
                                <li>Mappatura di compromessi e aree di affinit&agrave;.</li>
                                <li>Analisi delle connessioni elettromagnetiche.</li>
                            </ul>
                            <div style="background: #f8fafc; padding: 1rem; border-radius: 10px; font-size: 0.9rem;">
                                <strong>Dettagli:</strong> Analisi intensiva delle dinamiche soci<br>
                                <strong>Investimento:</strong> Euro 2.200
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Area aziendale -->
            <div class="area-aziendale" id="team">
                <div class="container" style="position: relative; z-index: 1;">
                    <div class="area-icon-box" style="background: var(--corp-primary); color: white; box-shadow: 0 10px 20px rgba(30,58,95,0.2);">&#127970;</div>
                    <h2 class="text-center" style="margin-bottom: 4rem; color: var(--primary-color); font-size: 2.2rem;">Per l&rsquo;azienda</h2>
                    <div class="blog-grid aziende-grid-fix">

                        <div class="card" style="background: white; padding: 2.5rem; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); border-top: 4px solid var(--primary-color);" data-animate>
                            <h3 style="color: var(--primary-color); margin-bottom: 1rem;">BG5 Corporate Analysis</h3>
                            <p style="margin-bottom: 1.5rem;">Ottimizzazione di performance, leadership e dinamiche interne. Ogni persona diventa una nota essenziale nell&rsquo;orchestra aziendale.</p>
                            <ul style="margin-bottom: 2rem; padding-left: 1.2rem; list-style: disc; font-size: 0.95rem;">
                                <li><strong>Disegno di Carriera:</strong> talenti operativi innati.</li>
                                <li><strong>Team Engineering:</strong> progettazione team e Penta.</li>
                                <li><strong>Analisi Gruppo Unificato:</strong> sinergia key people.</li>
                                <li><strong>Consulenze 1:1:</strong> supporto decisionale HR/Management.</li>
                            </ul>
                            <div style="background: #f8fafc; padding: 1rem; border-radius: 10px; font-size: 0.9rem;">
                                <strong>Dettagli:</strong> Progetto su misura<br>
                                <strong>Investimento:</strong> Preventivo personalizzato
                            </div>
                        </div>

                        <div class="card" style="background: white; padding: 2.5rem; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); border-top: 4px solid var(--accent-color);" data-animate>
                            <h3 style="color: var(--primary-color); margin-bottom: 1rem;">Alpha One - Personal Management</h3>
                            <p style="margin-bottom: 1.5rem;">Percorso intensivo premium per CEO e manager. Impara a guidare il team e ottenere risultati reali conoscendo il tuo design di leadership.</p>
                            <ul style="margin-bottom: 2rem; padding-left: 1.2rem; list-style: disc; font-size: 0.95rem;">
                                <li>Gestione del team minimizzando i conflitti.</li>
                                <li>Decisioni strategiche con chiarezza meccanica.</li>
                                <li>Guidare le persone verso il loro vero potenziale.</li>
                                <li>Ottimizzazione dell&rsquo;energia e del tempo.</li>
                            </ul>
                            <div style="background: #f8fafc; padding: 1rem; border-radius: 10px; font-size: 0.9rem;">
                                <strong>Dettagli:</strong> 6 ore di accompagnamento (4 sessioni x 90m)<br>
                                <strong>Investimento:</strong> Euro 1.800
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-center" style="padding: 6rem 0;" data-animate>
                <div class="container">
                    <a href="{{ grav.base_url }}/aziende/contatti" class="btn btn-primary" style="font-size: 1.2rem; padding: 1.2rem 2.5rem;">Richiedi una Consulenza Corporate</a>
                </div>
            </div>
        </div>
    </section>
</main>
{% endblock %}
