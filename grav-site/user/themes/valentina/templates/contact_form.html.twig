{% extends 'partials/base.html.twig' %}

{% block title %}{{ page.title }} | Valentina Russo{% endblock %}

{% block content %}
<main class="section-padding">
    <div class="container" style="max-width: 800px;">
        <h1 class="text-center" style="margin-bottom: var(--grid-lg);" data-animate>{{ page.title }}</h1>

        <div class="contact-form-wrapper" data-animate>

            {% if page.header.corporate is defined and page.header.corporate %}
            <p class="text-center" style="margin-bottom: 2.5rem;">Compila il form per richiedere un contatto conoscitivo e valutare le soluzioni BG5&reg; per il tuo business.</p>
            {% endif %}

            {# Grav Form Plugin #}
            {% set the_form = forms(page.header.form.name ?? page.slug) %}
            {% if the_form %}
                {% include "forms/form.html.twig" with {form: the_form} %}
            {% else %}
            {# Fallback form statico (compatibilità) #}
            <form method="POST" action="{{ page.url }}" style="display: grid; gap: 1.5rem;">

                {% if page.header.corporate is defined and page.header.corporate %}
                <div class="form-field">
                    <label>Nome o Referente *</label>
                    <input type="text" name="nome" required>
                </div>
                <div class="form-field">
                    <label>Nome Azienda *</label>
                    <input type="text" name="azienda" required>
                </div>
                {% else %}
                <div class="form-field">
                    <label>Nome Completo *</label>
                    <input type="text" name="name" required>
                </div>
                {% endif %}

                <div class="form-field">
                    <label>Email *</label>
                    <input type="email" name="email" required>
                </div>

                <div class="form-field">
                    <label>{{ page.header.corporate is defined and page.header.corporate ? 'Come posso aiutarti?' : 'Messaggio / Tipo di Consulenza' }} *</label>
                    <textarea name="message" required></textarea>
                </div>

                <button type="submit" class="btn btn-primary" style="width: 100%;">Invia Messaggio</button>
            </form>
            {% endif %}

            {# Contatti diretti #}
            <div style="margin-top: var(--grid-xl); text-align: center;" data-animate>
                <p class="text-small" style="margin-bottom: 0.5rem;">Preferisci un contatto diretto?</p>
                <p style="margin-bottom: 0.5rem;"><strong>Email:</strong> <a href="mailto:info@valentinarussobg5.com">info@valentinarussobg5.com</a></p>
                <p style="margin-bottom: 0.5rem;"><strong>Whatsapp:</strong> <a href="https://wa.me/393791037653" style="color: var(--primary-color);">+39 379 103 7653</a></p>
                <p style="margin-bottom: 0.5rem;"><strong>Instagram:</strong> <a href="https://www.instagram.com/valentinarussobg5/" target="_blank" rel="noopener" style="color: var(--primary-color);">@valentinarussobg5</a></p>
            </div>

            {# Link location — Consulente BG5 per città #}
            {% if not (page.header.corporate is defined and page.header.corporate) %}
            <div style="margin-top: 2.5rem; padding-top: 2rem; border-top: 1px solid #ece8e3; text-align: center;" data-animate>
                <p style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--primary-color); margin: 0 0 0.75rem 0;">Consulenze disponibili in tutta Italia</p>
                <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 0.4rem 0.9rem; font-size: 0.82rem;">
                    <a href="{{ grav.base_url }}/consulente-bg5-milano" style="color: var(--primary-color); text-decoration: none; font-weight: 600;">Milano</a>
                    <span style="color: #ccc;">&middot;</span>
                    <a href="{{ grav.base_url }}/consulente-bg5-torino" style="color: var(--primary-color); text-decoration: none; font-weight: 600;">Torino</a>
                    <span style="color: #ccc;">&middot;</span>
                    <a href="{{ grav.base_url }}/consulente-bg5-roma" style="color: var(--primary-color); text-decoration: none; font-weight: 600;">Roma</a>
                    <span style="color: #ccc;">&middot;</span>
                    <a href="{{ grav.base_url }}/consulente-bg5-bologna" style="color: var(--primary-color); text-decoration: none; font-weight: 600;">Bologna</a>
                    <span style="color: #ccc;">&middot;</span>
                    <a href="{{ grav.base_url }}/consulente-bg5-firenze" style="color: var(--primary-color); text-decoration: none; font-weight: 600;">Firenze</a>
                    <span style="color: #ccc;">&middot;</span>
                    <a href="{{ grav.base_url }}/consulente-bg5-napoli" style="color: var(--primary-color); text-decoration: none; font-weight: 600;">Napoli</a>
                    <span style="color: #ccc;">&middot;</span>
                    <a href="{{ grav.base_url }}/consulente-bg5-venezia" style="color: var(--primary-color); text-decoration: none; font-weight: 600;">Venezia</a>
                    <span style="color: #ccc;">&middot;</span>
                    <a href="{{ grav.base_url }}/consulente-bg5-bari" style="color: var(--primary-color); text-decoration: none; font-weight: 600;">Bari</a>
                    <span style="color: #ccc;">&middot;</span>
                    <a href="{{ grav.base_url }}/consulente-bg5-palermo" style="color: var(--primary-color); text-decoration: none; font-weight: 600;">Palermo</a>
                    <span style="color: #ccc;">&middot;</span>
                    <a href="{{ grav.base_url }}/consulente-bg5-verona" style="color: var(--primary-color); text-decoration: none; font-weight: 600;">Verona</a>
                    <span style="color: #ccc;">&middot;</span>
                    <a href="{{ grav.base_url }}/consulente-bg5-italia" style="color: var(--primary-color); text-decoration: none; font-weight: 600;">Tutta Italia &rarr;</a>
                </div>
            </div>
            {% endif %}
        </div>
    </div>
</main>
{% endblock %}
