<script>
// ── FAQ accordion ──────────────────────────────────────────────────────────
document.querySelectorAll('.bp-faq-q').forEach(function(btn) {
  btn.addEventListener('click', function() {
    var item = this.closest('.bp-faq-item');
    var isOpen = item.classList.contains('open');
    document.querySelectorAll('.bp-faq-item').forEach(function(i) {
      i.classList.remove('open');
      i.querySelector('.bp-faq-q').setAttribute('aria-expanded', 'false');
    });
    if (!isOpen) {
      item.classList.add('open');
      this.setAttribute('aria-expanded', 'true');
    }
  });
});

// ── Scroll reveal fallback (per browser senza animation-timeline) ──────────
if (!CSS.supports('animation-timeline', 'view()')) {
  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (e.isIntersecting) { e.target.classList.add('visible'); }
    });
  }, { threshold: 0.12 });
  document.querySelectorAll('.bp-reveal').forEach(function(el) { observer.observe(el); });
}

// ── GA4 tracking su click CTA ordine ──────────────────────────────────────
document.querySelectorAll('a[href*="checkout.php"]').forEach(function(a) {
  a.addEventListener('click', function() {
    var tier = this.href.includes('avanzato') ? 'avanzato' : 'base';
    if (typeof gtag !== 'undefined') {
      gtag('event', 'begin_checkout', { 'event_category': 'Libretto', 'event_label': tier });
    }
  });
});

// ── Floating particles ────────────────────────────────────────────────────
(function() {
  var hero = document.querySelector('.bp-hero');
  if (!hero) return;
  var container = document.createElement('div');
  container.className = 'bp-particles';
  container.setAttribute('aria-hidden','true');
  hero.insertBefore(container, hero.firstChild);
  for (var i = 0; i < 20; i++) {
    var p = document.createElement('div');
    p.className = 'bp-particle';
    var size = 1.5 + Math.random() * 3.5;
    var dur  = 9 + Math.random() * 14;
    var delay = -(Math.random() * dur);
    var drift = (Math.random() - 0.5) * 140;
    p.style.cssText = 'width:'+size+'px;height:'+size+'px;left:'+(Math.random()*100)+'%;animation-duration:'+dur+'s;animation-delay:'+delay+'s;--drift:'+drift+'px;opacity:'+(0.4+Math.random()*0.6);
    container.appendChild(p);
  }
})();

// ── Mouse parallax hero ───────────────────────────────────────────────────
(function() {
  if (window.matchMedia('(max-width:900px)').matches) return;
  if (window.matchMedia('(prefers-reduced-motion:reduce)').matches) return;
  var hero    = document.querySelector('.bp-hero');
  var heroImg = document.querySelector('.bp-hero__img img');
  var heroTxt = document.querySelector('.bp-hero__inner');
  var heroAmb = document.querySelector('.bp-hero__ambient');
  if (!hero || !heroImg) return;
  var ticking = false, mx = 0, my = 0;
  hero.addEventListener('mousemove', function(e) {
    var r = hero.getBoundingClientRect();
    mx = (e.clientX - r.left) / r.width  - 0.5;
    my = (e.clientY - r.top)  / r.height - 0.5;
    if (!ticking) {
      requestAnimationFrame(function() {
        heroImg.style.transform = 'translate('+( mx*20)+'px,'+(my*14)+'px)';
        if (heroTxt) heroTxt.style.transform = 'translate('+(-mx*6)+'px,'+(-my*4)+'px)';
        if (heroAmb) heroAmb.style.transform = 'translate('+( mx*30)+'px,'+(my*22)+'px) scale(1)';
        ticking = false;
      });
      ticking = true;
    }
  });
  hero.addEventListener('mouseleave', function() {
    heroImg.style.transform = '';
    if (heroTxt) heroTxt.style.transform = '';
    if (heroAmb) heroAmb.style.transform = '';
  });
})();

// ── Scroll parallax sulle immagini di sezione ─────────────────────────────
(function() {
  if (window.matchMedia('(prefers-reduced-motion:reduce)').matches) return;
  var imgs = document.querySelectorAll('.bp-section-img img, .bp-doc-mockup img');
  function tick() {
    imgs.forEach(function(img) {
      var rect = img.closest('.bp-section-img, .bp-doc-mockup').getBoundingClientRect();
      var center = rect.top + rect.height / 2 - window.innerHeight / 2;
      img.style.transform = 'translateY('+(center * -0.07)+'px)';
    });
  }
  window.addEventListener('scroll', tick, { passive: true });
  tick();
})();

// ── 3D tilt su card pricing ───────────────────────────────────────────────
(function() {
  if (window.matchMedia('(prefers-reduced-motion:reduce)').matches) return;
  document.querySelectorAll('.bp-pricing-card').forEach(function(card) {
    card.style.transition = 'transform .12s ease, box-shadow .12s ease';
    card.addEventListener('mousemove', function(e) {
      var r = card.getBoundingClientRect();
      var x = (e.clientX - r.left) / r.width  - 0.5;
      var y = (e.clientY - r.top)  / r.height - 0.5;
      card.style.transform = 'perspective(900px) rotateY('+(x*11)+'deg) rotateX('+(-y*8)+'deg) translateZ(10px)';
      card.style.boxShadow = '0 '+(28+y*20)+'px '+(64+Math.abs(x)*40)+'px rgba(26,35,50,'+(0.18+Math.abs(x)*0.08)+')';
    });
    card.addEventListener('mouseleave', function() {
      card.style.transform = '';
      card.style.boxShadow = '';
    });
  });
})();

// ── 3D tilt leggero su step cards ────────────────────────────────────────
(function() {
  if (window.matchMedia('(prefers-reduced-motion:reduce)').matches) return;
  document.querySelectorAll('.bp-step').forEach(function(card) {
    card.addEventListener('mousemove', function(e) {
      var r = card.getBoundingClientRect();
      var x = (e.clientX - r.left) / r.width  - 0.5;
      var y = (e.clientY - r.top)  / r.height - 0.5;
      card.style.transform = 'perspective(600px) rotateY('+(x*7)+'deg) rotateX('+(-y*5)+'deg) translateY(-4px)';
    });
    card.addEventListener('mouseleave', function() {
      card.style.transform = '';
    });
  });
})();
</script>
