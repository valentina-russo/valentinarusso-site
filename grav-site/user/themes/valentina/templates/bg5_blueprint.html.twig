}
.bp-form-group input:focus,
.bp-form-group select:focus {
  outline: 2px solid var(--bp-rosa);
  outline-offset: 2px;
  border-color: var(--bp-rosa);
}
.bp-form-group input::placeholder { color: rgba(245,236,240,.35); }
.bp-form-group select option { background: var(--bp-navy-deep); color: var(--bp-white); }

.bp-form-radio-group {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
}
.bp-form-radio {
  display: flex;
  align-items: center;
  gap: .6rem;
  cursor: pointer;
  font-size: .9375rem;
  color: rgba(245,236,240,.85);
  padding: .75rem 1.25rem;
  border: 1.5px solid rgba(245,236,240,.2);
  border-radius: 4px;
  transition: border-color .2s, background .2s;
  flex: 1;
  min-width: 200px;
}
.bp-form-radio:has(input:checked) {
  border-color: var(--bp-rosa);
  background: rgba(201,118,138,.12);
}
.bp-form-radio input { accent-color: var(--bp-rosa); }
.bp-form-radio strong { display: block; font-weight: 700; color: var(--bp-white); }
.bp-form-radio span { font-size: .8125rem; color: rgba(245,236,240,.55); }

.bp-form-submit {
  width: 100%;
  padding: 1.125rem;
  background: var(--bp-rosa);
  color: var(--bp-white);
  font-family: 'Outfit', sans-serif;
  font-weight: 700;
  font-size: 1.0625rem;
  border: none;
  border-radius: 4px;
  cursor: pointer;
  transition: background .2s, transform .15s;
  margin-top: .5rem;
}
.bp-form-submit:hover { background: #B5697B; transform: translateY(-1px); }
.bp-form-note {
  text-align: center;
  font-size: .8125rem;
  color: rgba(139,157,181,.8);
  margin-top: .75rem;
}
.bp-form-success {
  display: none;
  text-align: center;
  padding: 2rem;
  background: rgba(74,140,140,.15);
  border: 1.5px solid var(--bp-teal);
  border-radius: 8px;
  color: var(--bp-white);
  margin-top: 1rem;
}


/* ══════════════════════════════════════════
   8. FAQ
══════════════════════════════════════════ */
.bp-faq-wrap {
  max-width: 720px;
  margin: 3rem auto 0;
}
.bp-faq-item {
  border-bottom: 1px solid var(--bp-soft-parchment);
}
.bp-faq-item:first-child { border-top: 1px solid var(--bp-soft-parchment); }
.bp-faq-q {
  width: 100%;
  background: none;
  border: none;
  padding: 1.25rem 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  cursor: pointer;
  text-align: left;
  font-family: 'Outfit', sans-serif;
  font-size: 1.0625rem;
  font-weight: 600;
  color: var(--bp-navy);
  transition: color .2s;
}
.bp-faq-q:hover { color: var(--bp-rosa); }
.bp-faq-q:focus { outline: 2px solid var(--bp-rosa); outline-offset: 2px; }
.bp-faq-icon {
  flex-shrink: 0;
  width: 24px;
  height: 24px;
  border-radius: 50%;
  border: 1.5px solid var(--bp-soft-parchment);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1rem;
  color: var(--bp-rosa);
  transition: transform .3s;
}
.bp-faq-item.open .bp-faq-icon { transform: rotate(45deg); }
.bp-faq-a {
  max-height: 0;
  overflow: hidden;
  transition: max-height .35s ease, padding .35s ease;
}
.bp-faq-item.open .bp-faq-a { max-height: 400px; padding-bottom: 1.25rem; }
.bp-faq-a p {
  font-size: .9375rem;
  line-height: 1.7;
  color: var(--bp-text);
  margin: 0;
}


/* ══════════════════════════════════════════
   RESPONSIVE
══════════════════════════════════════════ */
@media (max-width: 900px) {
  .bp-what__grid { grid-template-columns: 1fr; }
  .bp-doc-mockup { display: none; }
  .bp-contains__grid { grid-template-columns: 1fr; }
  .bp-forchi__grid { grid-template-columns: 1fr; }
  .bp-steps__grid {
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  .bp-steps__grid::before { display: none; }
  .bp-step { text-align: left; }
  .bp-step__num { display: none; }
  .bp-step__icon { margin: 0 0 1rem; }
  .bp-pricing__grid { grid-template-columns: 1fr; }
  .bp-pricing-card--comp { order: -1; }
  .bp-section-title { font-size: 1.75rem; }
  .bp-hero__h1 { font-size: 2.25rem; }
}
@media (max-width: 600px) {
