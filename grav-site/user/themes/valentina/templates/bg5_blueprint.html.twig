/* ──── Link footer pricing — gold (era rosa) ──── */
.bp-pricing__footer a { color: var(--bp-gold) !important; }
.bp-pricing__footer a:hover { color: #A06820 !important; }

/* ──── Section dark: titolo cream puro (era blush rosa-wash) ──── */
.bp-section--dark .bp-section-title { color: #F5EFE3 !important; }
