{% extends 'partials/base.html.twig' %}

{% block title %}BG5 Business Blueprint — La tua analisi energetica professionale | Valentina Russo{% endblock %}

{% block schema %}
{{ parent() }}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "BG5 Business Blueprint",
  "description": "Report PDF personalizzato di 40-65 pagine che traduce la tua configurazione BG5/Human Design in una strategia concreta per il tuo lavoro e la tua attività.",
  "url": "{{ grav.base_url_absolute }}/bg5-blueprint",
  "provider": { "@id": "{{ grav.base_url_absolute }}/#valentina-russo" },
  "offers": [
    {
      "@type": "Offer",
      "name": "Carta Essenziale",
      "price": "90",
      "priceCurrency": "EUR",
      "availability": "https://schema.org/InStock"
    },
    {
      "@type": "Offer",
      "name": "Blueprint Completo",
      "price": "147",
      "priceCurrency": "EUR",
      "availability": "https://schema.org/InStock"
    }
  ]
}
</script>
{% endblock %}

{% block extra_css %}
<style>
/* ── BG5 Blueprint Landing — Token extra ── */
:root {
  --bp-gold:          #C48A3A;
  --bp-navy-deep:     #0F1A29;
  --bp-rosa-wash:     #F5ECF0;
  --bp-teal-wash:     #E8F4F4;
  --bp-gold-glow:     rgba(196,138,58,.30);
  --bp-rosa-glow:     rgba(201,118,138,.12);
  --bp-navy-glow:     rgba(15,26,41,.35);
  --bp-parchment:     #FAF7F5;
  --bp-soft-parchment:#EAE5E1;
  --bp-rosa:          #C9768A;
  --bp-teal:          #4A8C8C;
  --bp-navy:          #1A2332;
  --bp-text:          #2D2926;
  --bp-text-muted:    #6B6560;
  --bp-white:         #FFFFFF;
}

/* ── Reset & Base ── */
.bp-landing * { box-sizing: border-box; }
.bp-landing { font-family: 'Outfit', sans-serif; color: var(--bp-text); }
.bp-landing h1, .bp-landing h2, .bp-landing h3,
.bp-landing .bp-price { font-family: 'Playfair Display', serif; }

.bp-container {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 1.5rem;
}

/* ── Eyebrow label ── */
.bp-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: .5rem;
  font-family: 'Outfit', sans-serif;
  font-size: .8125rem;
  font-weight: 500;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: var(--bp-rosa);
  margin-bottom: 1.25rem;
}
.bp-eyebrow::before,
.bp-eyebrow::after {
  content: '';
  display: inline-block;
  width: 28px;
  height: 1px;
  background: var(--bp-rosa);
}

/* H2 con ornamento ── */
.bp-section-title {
  font-size: 2.25rem;
  font-weight: 700;
  color: var(--bp-navy);
  line-height: 1.2;
  margin-bottom: .75rem;
}
.bp-section-sub {
  font-size: 1.0625rem;
  color: var(--bp-text-muted);
  line-height: 1.65;
  max-width: 620px;
}

/* ── Sezione separatore curva ── */
.bp-section {
  position: relative;
  padding: 5rem 0;
}
.bp-section--white   { background: var(--bp-white); }
.bp-section--parchment { background: var(--bp-parchment); }
.bp-section--soft    { background: var(--bp-soft-parchment); }
.bp-section--dark    { background: var(--bp-navy-deep); }
.bp-section--gradient {
  background: linear-gradient(180deg, var(--bp-parchment) 0%, #F0EBF2 100%);
}

/* ── Scroll reveal ── */
.bp-reveal {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity .5s ease, transform .5s ease;
}
.bp-reveal.visible {
  opacity: 1;
  transform: translateY(0);
}
@supports (animation-timeline: view()) {
  .bp-reveal {
    animation: bp-fade-up linear both;
    animation-timeline: view();
    animation-range: entry 0% entry 40%;
    opacity: 1;
    transform: none;
  }
}
@keyframes bp-fade-up {
  from { opacity: 0; transform: translateY(24px); }
  to   { opacity: 1; transform: translateY(0); }
}


/* ══════════════════════════════════════════
   1. HERO
══════════════════════════════════════════ */
.bp-hero {
  min-height: min(100dvh, 820px);
  background: var(--bp-parchment);
  display: flex;
  align-items: center;
  padding: 5rem 0 4rem;
  position: relative;
  overflow: hidden;
}
.bp-hero__bg-grid {
  position: absolute;
  bottom: 0; right: 0;
  width: 520px; height: 520px;
  background-image:
    radial-gradient(circle, var(--bp-soft-parchment) 1.5px, transparent 1.5px);
  background-size: 24px 24px;
  opacity: .55;
  pointer-events: none;
}
.bp-hero__bg-glow {
  position: absolute;
  bottom: -80px; right: -80px;
  width: 420px; height: 420px;
  background: radial-gradient(circle at 60% 60%, rgba(26,35,50,.08) 0%, transparent 70%);
  pointer-events: none;
}
.bp-hero__inner {
  position: relative;
  z-index: 1;
  max-width: 700px;
}
.bp-hero__h1 {
  font-size: clamp(2.25rem, 5vw, 3.5rem);
  font-weight: 700;
  font-style: italic;
  line-height: 1.1;
  margin: 0 0 1.5rem;
  color: var(--bp-navy);
}
.bp-hero__h1 span { color: var(--bp-rosa); }
.bp-hero__sub {
  font-size: 1.25rem;
  line-height: 1.6;
  color: var(--bp-text);
  max-width: 560px;
  margin-bottom: 2.5rem;
  font-weight: 400;
}
.bp-hero__cta-group {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 1rem;
}
.bp-btn-primary {
  display: inline-block;
  background: var(--bp-rosa);
  color: var(--bp-white);
  font-family: 'Outfit', sans-serif;
  font-weight: 700;
  font-size: 1rem;
  padding: 1rem 2.5rem;
  border-radius: 4px;
  text-decoration: none;
  border: none;
  cursor: pointer;
  transition: background .2s, transform .15s;
  letter-spacing: .02em;
}
.bp-btn-primary:hover { background: #B5697B; transform: translateY(-1px); }

.bp-btn-outline {
  display: inline-block;
  color: var(--bp-rosa);
  font-family: 'Outfit', sans-serif;
  font-weight: 600;
  font-size: 1rem;
  padding: .9rem 2rem;
  border-radius: 4px;
  text-decoration: none;
  border: 2px solid var(--bp-rosa);
  cursor: pointer;
  transition: background .2s, color .2s;
}
.bp-btn-outline:hover { background: var(--bp-bp-rosa-wash); }

.bp-hero__meta {
  font-size: .8125rem;
  color: var(--bp-text-muted);
  margin-top: .75rem;
}
.bp-hero__scroll {
  position: absolute;
  bottom: 2rem;
  left: 50%;
  transform: translateX(-50%);
  animation: bp-bounce .85s ease-in-out infinite alternate;
  color: var(--bp-text-muted);
  font-size: 1.3rem;
  text-decoration: none;
}
@keyframes bp-bounce {
  from { transform: translateX(-50%) translateY(0); }
  to   { transform: translateX(-50%) translateY(6px); }
}


/* ══════════════════════════════════════════
   2. COS'È IL BLUEPRINT
══════════════════════════════════════════ */
.bp-what__grid {
  display: grid;
  grid-template-columns: 1fr 1.1fr;
  gap: 4rem;
  align-items: center;
}
.bp-what__list {
  list-style: none;
  padding: 0;
  margin: 1.75rem 0 0;
}
.bp-what__list li {
  display: flex;
  align-items: flex-start;
  gap: .875rem;
  margin-bottom: 1rem;
  font-size: 1rem;
  line-height: 1.6;
  color: var(--bp-text);
}
.bp-what__list li::before {
  content: '';
  flex-shrink: 0;
  width: 20px;
  height: 20px;
  margin-top: 2px;
  background: var(--bp-teal);
  border-radius: 50%;
  background-image: url("data:image/svg+xml,%3Csvg width='12' height='9' viewBox='0 0 12 9' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 4L4.5 7.5L11 1' stroke='white' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
  background-repeat: no-repeat;
  background-position: center;
}

/* Mockup documento */
.bp-doc-mockup {
  position: relative;
  transform: rotate(2deg);
}
.bp-doc-inner {
  background: var(--bp-white);
  border-radius: 8px;
  box-shadow: 0 20px 60px rgba(26,35,50,.18), 0 4px 16px rgba(26,35,50,.10);
  padding: 2rem 1.75rem;
  min-height: 320px;
}
.bp-doc-header {
  display: flex;
  align-items: center;
  gap: .75rem;
  margin-bottom: 1.5rem;
  padding-bottom: 1.25rem;
  border-bottom: 1.5px solid var(--bp-soft-parchment);
}
.bp-doc-header-circle {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: var(--bp-rosa-wash, #F5ECF0);
  display: flex;
  align-items: center;
  justify-content: center;
}
.bp-doc-line {
  height: 10px;
  border-radius: 5px;
  background: var(--bp-soft-parchment);
  margin-bottom: .6rem;
}
.bp-doc-line--short { width: 55%; }
.bp-doc-line--med   { width: 75%; }
.bp-doc-line--full  { width: 100%; }
.bp-doc-line--rosa  { background: rgba(201,118,138,.25); width: 45%; }
.bp-doc-line--teal  { background: rgba(74,140,140,.2); width: 60%; }
.bp-doc-badge {
  display: inline-block;
  background: var(--bp-teal-wash, #E8F4F4);
  color: var(--bp-teal);
  font-size: .7rem;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  padding: .3rem .7rem;
  border-radius: 100px;
  margin-bottom: 1rem;
}


/* ══════════════════════════════════════════
   3. COSA CONTIENE
══════════════════════════════════════════ */
.bp-contains__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2rem;
  margin-top: 3rem;
}
.bp-tier-panel {
  border-radius: 8px;
  padding: 2.5rem 2rem;
}
.bp-tier-panel--essenziale {
  background: var(--bp-rosa-wash, #F5ECF0);
  border: 1.5px solid rgba(201,118,138,.3);
}
.bp-tier-panel--completo {
  background: var(--bp-navy);
  color: var(--bp-white);
}
.bp-tier-panel__title {
  font-family: 'Outfit', sans-serif;
  font-size: .75rem;
  font-weight: 700;
  letter-spacing: .18em;
  text-transform: uppercase;
  margin-bottom: .5rem;
}
.bp-tier-panel--essenziale .bp-tier-panel__title { color: var(--bp-rosa); }
.bp-tier-panel--completo .bp-tier-panel__title { color: var(--bp-gold, #C48A3A); }

.bp-tier-panel__heading {
  font-size: 1.5rem;
  font-weight: 700;
  margin: 0 0 .3rem;
  line-height: 1.2;
}
.bp-tier-panel--essenziale .bp-tier-panel__heading { color: var(--bp-navy); }
.bp-tier-panel--completo .bp-tier-panel__heading { color: var(--bp-white); }

.bp-tier-panel__count {
  font-size: .875rem;
  margin-bottom: 1.75rem;
}
.bp-tier-panel--essenziale .bp-tier-panel__count { color: var(--bp-text-muted); }
.bp-tier-panel--completo .bp-tier-panel__count { color: rgba(245,236,240,.6); }

.bp-section-list {
  list-style: none;
  padding: 0;
  margin: 0;
}
.bp-section-list li {
  display: flex;
  align-items: baseline;
  gap: .875rem;
  padding: .5rem 0;
  border-bottom: 1px solid;
  font-size: .9rem;
  line-height: 1.5;
}
.bp-tier-panel--essenziale .bp-section-list li { border-color: rgba(201,118,138,.15); color: var(--bp-text); }
.bp-tier-panel--completo .bp-section-list li { border-color: rgba(245,236,240,.1); color: rgba(245,236,240,.85); }
.bp-tier-panel--completo .bp-section-list li:last-child { border-bottom: none; }
.bp-tier-panel--essenziale .bp-section-list li:last-child { border-bottom: none; }

.bp-section-num {
  font-family: 'Playfair Display', serif;
  font-weight: 700;
  font-size: 1.2rem;
  line-height: 1;
  flex-shrink: 0;
}
.bp-tier-panel--essenziale .bp-section-num { color: var(--bp-rosa); }
.bp-tier-panel--completo .bp-section-num { color: var(--bp-gold, #C48A3A); }

.bp-section-list li.extra {
  font-style: italic;
}
.bp-tier-panel--completo .bp-section-list li.extra { color: #C48A3A; }


/* ══════════════════════════════════════════
   4. PER CHI È
══════════════════════════════════════════ */
.bp-forchi__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
  margin-top: 3rem;
}
.bp-profile-card {
  background: var(--bp-white);
  border-radius: 8px;
  border: 1px solid var(--bp-soft-parchment);
  padding: 2rem 1.75rem 1.75rem;
  transition: box-shadow .2s;
}
.bp-profile-card:hover {
  box-shadow: 0 8px 32px var(--bp-rosa-glow);
}
.bp-profile-icon {
  width: 52px;
  height: 52px;
  border-radius: 50%;
  background: var(--bp-teal-wash, #E8F4F4);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 1.25rem;
  color: var(--bp-teal);
}
.bp-profile-card h3 {
  font-family: 'Outfit', sans-serif;
  font-size: 1.0625rem;
  font-weight: 700;
  color: var(--bp-navy);
  margin: 0 0 .75rem;
}
.bp-profile-card p {
  font-size: .9375rem;
  line-height: 1.65;
  color: var(--bp-text);
  margin: 0 0 1.25rem;
}
.bp-profile-tag {
  font-size: .8125rem;
  font-style: italic;
  color: var(--bp-rosa);
}


/* ══════════════════════════════════════════
   5. COME FUNZIONA
══════════════════════════════════════════ */
.bp-steps__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2.5rem;
  margin-top: 3rem;
  position: relative;
}
.bp-steps__grid::before {
  content: '';
  position: absolute;
  top: 32px;
  left: calc(16.66% + 1rem);
  right: calc(16.66% + 1rem);
  height: 1px;
  border-top: 2px dashed var(--bp-soft-parchment);
  z-index: 0;
}
.bp-step {
  position: relative;
  z-index: 1;
  text-align: center;
}
.bp-step__num {
  font-family: 'Playfair Display', serif;
  font-weight: 700;
  font-size: 5rem;
  line-height: 1;
  color: var(--bp-soft-parchment);
  position: absolute;
  top: -24px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 0;
  pointer-events: none;
  user-select: none;
}
.bp-step__icon {
  position: relative;
  z-index: 1;
  width: 64px;
  height: 64px;
  border-radius: 50%;
  background: var(--bp-teal-wash, #E8F4F4);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 1.25rem;
  color: var(--bp-teal);
}
.bp-step h3 {
  font-family: 'Outfit', sans-serif;
  font-size: 1.0625rem;
  font-weight: 700;
  color: var(--bp-navy);
  margin: 0 0 .625rem;
  position: relative;
  z-index: 1;
}
.bp-step p {
  font-size: .9375rem;
  line-height: 1.65;
  color: var(--bp-text);
  margin: 0;
  position: relative;
  z-index: 1;
}


/* ══════════════════════════════════════════
   6. PRICING
══════════════════════════════════════════ */
.bp-pricing__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2rem;
  align-items: end;
  max-width: 860px;
  margin: 3rem auto 0;
}
.bp-pricing-card {
  border-radius: 8px;
  position: relative;
}

/* Essenziale */
.bp-pricing-card--ess {
  background: var(--bp-white);
  border: 1.5px solid var(--bp-rosa);
  padding: 2.5rem 2rem;
  box-shadow: 0 4px 24px var(--bp-rosa-glow);
}
.bp-pricing-card--ess .bp-price {
  font-size: 3rem;
  font-weight: 700;
  font-style: italic;
  color: var(--bp-navy);
  line-height: 1;
}
.bp-pricing-card--ess .bp-price-label {
  font-size: .875rem;
  color: var(--bp-text-muted);
  margin-bottom: 1.75rem;
}
.bp-pricing-card--ess .bp-cta { margin-top: 2rem; }

/* Completo */
.bp-pricing-card--comp {
  background: var(--bp-navy-deep);
  padding: 3.5rem 2rem;
  box-shadow: 0 12px 48px var(--bp-navy-glow), 0 0 0 1px rgba(196,138,58,.3);
}
.bp-pricing-badge {
  display: block;
  text-align: center;
  position: absolute;
  top: -14px;
  left: 50%;
  transform: translateX(-50%);
  white-space: nowrap;
  background: var(--bp-gold);
  color: var(--bp-white);
  font-family: 'Outfit', sans-serif;
  font-size: .6875rem;
  font-weight: 700;
  letter-spacing: .12em;
  text-transform: uppercase;
  padding: .375rem 1.25rem;
  border-radius: 100px;
  box-shadow: 0 2px 12px var(--bp-gold-glow);
}
.bp-pricing-card--comp .bp-price {
  font-size: 3.5rem;
  font-weight: 700;
  font-style: italic;
  color: var(--bp-rosa-wash, #F5ECF0);
  line-height: 1;
}
.bp-pricing-card--comp .bp-price-label {
  font-size: .875rem;
  color: rgba(245,236,240,.55);
  margin-bottom: 1.75rem;
}
.bp-pricing-card--comp .bp-cta { margin-top: 2rem; }
.bp-pricing-card--comp .bp-btn-primary {
  background: var(--bp-rosa);
  width: 100%;
  display: block;
  text-align: center;
}

.bp-pricing-card__title {
  font-family: 'Outfit', sans-serif;
  font-size: .75rem;
  font-weight: 700;
  letter-spacing: .18em;
  text-transform: uppercase;
  margin-bottom: .5rem;
}
.bp-pricing-card--ess .bp-pricing-card__title { color: var(--bp-rosa); }
.bp-pricing-card--comp .bp-pricing-card__title { color: var(--bp-gold); }

.bp-pricing-card__name {
  font-family: 'Playfair Display', serif;
  font-size: 1.5rem;
  font-weight: 700;
  margin: 0 0 .25rem;
}
.bp-pricing-card--ess .bp-pricing-card__name { color: var(--bp-navy); }
.bp-pricing-card--comp .bp-pricing-card__name { color: var(--bp-white); }

.bp-feature-list {
  list-style: none;
  padding: 0;
  margin: 0 0 1.5rem;
}
.bp-feature-list li {
  display: flex;
  align-items: flex-start;
  gap: .75rem;
  padding: .5rem 0;
  font-size: .9375rem;
  line-height: 1.5;
  border-bottom: 1px solid;
}
.bp-feature-list li:last-child { border-bottom: none; }
.bp-pricing-card--ess .bp-feature-list li { border-color: var(--bp-soft-parchment); color: var(--bp-text); }
.bp-pricing-card--comp .bp-feature-list li { border-color: rgba(245,236,240,.1); color: rgba(245,236,240,.85); }

.bp-feature-check {
  flex-shrink: 0;
  width: 18px;
  height: 18px;
  margin-top: 1px;
  color: var(--bp-teal);
  font-size: .875rem;
}
.bp-feature-extra {
  color: var(--bp-gold);
  font-weight: 600;
  font-size: .8125rem;
}

.bp-pricing__footer {
  text-align: center;
  margin-top: 2rem;
  font-size: .875rem;
  color: var(--bp-text-muted);
}
.bp-pricing__footer a { color: var(--bp-rosa); }

.bp-btn-outline-ess {
  display: block;
  width: 100%;
  text-align: center;
  color: var(--bp-rosa);
  font-family: 'Outfit', sans-serif;
  font-weight: 700;
  font-size: 1rem;
  padding: .9rem 2rem;
  border-radius: 4px;
  text-decoration: none;
  border: 2px solid var(--bp-rosa);
  cursor: pointer;
  transition: background .2s, color .2s;
}
.bp-btn-outline-ess:hover { background: var(--bp-rosa-wash); }


/* ══════════════════════════════════════════
   7. FORM
══════════════════════════════════════════ */
.bp-form-wrap {
  max-width: 600px;
  margin: 0 auto;
}
.bp-section--dark .bp-section-title { color: var(--bp-rosa-wash, #F5ECF0); }
.bp-section--dark .bp-section-sub { color: rgba(245,236,240,.65); }
.bp-section--dark .bp-eyebrow { color: var(--bp-gold); }
.bp-section--dark .bp-eyebrow::before,
.bp-section--dark .bp-eyebrow::after { background: var(--bp-gold); }

.bp-form { margin-top: 2.5rem; }
.bp-form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
}
.bp-form-group {
  margin-bottom: 1.25rem;
}
.bp-form-group label {
  display: block;
  font-size: .875rem;
  font-weight: 600;
  color: rgba(245,236,240,.8);
  margin-bottom: .4rem;
}
.bp-form-group input,
.bp-form-group select {
  width: 100%;
  padding: .8rem 1rem;
  background: rgba(255,255,255,.08);
  border: 1.5px solid rgba(245,236,240,.2);
  border-radius: 4px;
  color: var(--bp-white);
  font-family: 'Outfit', sans-serif;
  font-size: 1rem;
