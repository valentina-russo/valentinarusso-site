{% extends 'partials/base.html.twig' %}

{% block title %}Genera la tua Carta | Valentina Russo{% endblock %}

{% block extra_css %}
<style>
    body {
        background: linear-gradient(160deg, #B68397 0%, #8A6FA8 45%, #3A5A8A 80%, #1E3A5F 100%) !important;
        background-attachment: fixed !important;
        min-height: 100vh;
    }
    body header {
        background: rgba(255,255,255,0.12) !important;
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-bottom: 1px solid rgba(255,255,255,0.2) !important;
        position: sticky;
        top: 0;
        z-index: 1000;
    }
    body header .brand-name,
    body header .brand-tagline,
    body header #main-nav a {
        color: #fff !important;
    }
    body header #main-nav a:hover {
        color: rgba(255,255,255,0.7) !important;
    }
    body header .menu-toggle {
        color: #fff !important;
    }
    body h1, body h2, body h3 {
        color: #fff !important;
    }
    body h4 {
        color: #FDE8B0 !important;
    }
    body p, body .text-small {
        color: rgba(255,255,255,0.88);
    }
    body .serif.italic {
        color: rgba(255,255,255,0.9) !important;
    }
    .gc-card {
        background: rgba(255,255,255,0.15) !important;
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255,255,255,0.25) !important;
        border-radius: 30px;
        color: rgba(255,255,255,0.9) !important;
    }
    .gc-side {
        background: rgba(255,255,255,0.15) !important;
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255,255,255,0.25) !important;
        border-radius: 20px;
    }
    .gc-cta {
        background: rgba(255,255,255,0.15) !important;
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255,255,255,0.3) !important;
        border-radius: 50px;
    }
    .btn-outline {
        border-color: rgba(255,255,255,0.7) !important;
        color: #fff !important;
    }
    .btn-outline:hover {
        background: rgba(255,255,255,0.15) !important;
        color: #fff !important;
    }
    body footer {
        background: rgba(255,255,255,0.08) !important;
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-top: 1px solid rgba(255,255,255,0.15) !important;
    }
    body footer a, body footer div {
        color: rgba(255,255,255,0.75) !important;
    }
    body footer a:hover {
        color: #fff !important;
    }

    /* ── Tipo accordion ── */
    .tipo-accordion { max-width: 720px; margin: 0 auto; display: flex; flex-direction: column; gap: 0.75rem; }
    .tipo-item { border-radius: 16px; border: 1px solid rgba(255,255,255,0.18); overflow: hidden; background: rgba(255,255,255,0.08); backdrop-filter: blur(10px); transition: border-color 0.2s; }
    .tipo-item:hover { border-color: rgba(255,255,255,0.32); }
    .tipo-item summary {
        list-style: none;
        cursor: pointer;
        padding: 1.1rem 1.4rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        user-select: none;
    }
    .tipo-item summary::-webkit-details-marker { display: none; }
    .tipo-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
    .tipo-name { font-family: 'Playfair Display', serif; font-size: 1.05rem; font-weight: 700; color: #fff; flex: 1; }
    .tipo-pct { font-size: 0.75rem; color: rgba(255,255,255,0.45); font-weight: 600; letter-spacing: 0.04em; }
    .tipo-chevron { font-size: 0.7rem; color: rgba(255,255,255,0.4); transition: transform 0.25s; margin-left: auto; }
    .tipo-item[open] .tipo-chevron { transform: rotate(180deg); }
    .tipo-body {
        padding: 0 1.4rem 1.4rem;
        border-top: 1px solid rgba(255,255,255,0.10);
        padding-top: 1.1rem;
    }
    .tipo-body p { font-size: 0.9rem; color: rgba(255,255,255,0.82); line-height: 1.7; margin-bottom: 0.7rem; }
    .tipo-body p:last-child { margin-bottom: 0; }
    .tipo-tag { display: inline-block; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; padding: 0.2rem 0.7rem; border-radius: 20px; margin-right: 0.4rem; margin-bottom: 0.6rem; }
</style>
{% endblock %}

{% block content %}
<main>
    <section class="section-padding">
        <div class="container">
            <div class="text-center" style="max-width: 800px; margin: 0 auto;" data-animate>
                <a href="{{ grav.base_url }}/human-design"
                   style="display: inline-flex; align-items: center; gap: 0.5rem; margin-bottom: 1.5rem; font-size: 0.78rem; font-weight: 600; color: rgba(255,255,255,0.65); text-decoration: none; letter-spacing: 0.04em; border-bottom: 1px solid rgba(255,255,255,0.2); padding-bottom: 0.1rem; transition: color 0.2s;">
                    ✦ Nuovo qui? Scopri prima cos&rsquo;&egrave; lo Human Design &rarr;
                </a>
                <h1 style="margin-bottom: var(--space-md);">Genera la tua Carta</h1>
                <p class="serif italic" style="font-size: 1.25rem; margin-bottom: var(--space-lg);">Il primo passo verso la consapevolezza del tuo disegno unico.</p>
            </div>

            <!-- Video Section -->
            <div class="gc-card" style="max-width: 900px; margin: 0 auto var(--space-xl); padding: 2rem;" data-animate>
                <div style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; border-radius: 15px;">
                    <iframe src="https://www.youtube.com/embed/FRZUXjTsYzU"
                        style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;" frameborder="0"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                        allowfullscreen>
                    </iframe>
                </div>
                <div style="margin-top: 2rem; text-align: center;">
                    <h3 class="serif">Guarda la video guida di Valentina</h3>
                    <p style="margin-top: 1rem;">In questo video ti spiego passo dopo passo come inserire i tuoi dati e come leggere le prime informazioni della tua carta.</p>
                </div>
            </div>

            <!-- Instructions Section -->
            <div class="footer-grid" style="align-items: flex-start; margin-bottom: var(--space-xl);">
                <div data-animate>
                    <h2 class="serif">Come procedere correttamente</h2>
                    <p style="margin: 1.5rem 0; line-height: 1.6;">Per ottenere un Bodygraph accurato, &egrave; fondamentale inserire dati precisi. Il sistema di Human Design incrocia la posizione dei pianeti al momento della tua nascita con quella di circa 88 giorni prima.</p>

                    <div style="margin-bottom: 2rem;">
                        <div style="margin-bottom: 1.5rem;">
                            <h4 class="serif">1. Data di Nascita</h4>
                            <p class="text-small">Inserisci giorno, mese e anno completi.</p>
                        </div>
                        <div style="margin-bottom: 1.5rem;">
                            <h4 class="serif">2. Ora Esatta</h4>
                            <p class="text-small">L&rsquo;ora &egrave; cruciale: anche pochi minuti di differenza possono cambiare alcuni aspetti della tua carta (come la Luna o le Linee). Se non la conosci, cercala sull&rsquo;estratto di nascita integrale.</p>
                        </div>
                        <div style="margin-bottom: 1.5rem;">
                            <h4 class="serif">3. Luogo di Nascita</h4>
                            <p class="text-small">Inserisci la citt&agrave; dove sei nat&aelig;. Il software calcoler&agrave; automaticamente il fuso orario e le coordinate geografiche necessarie.</p>
                        </div>
                    </div>

                    <a href="https://jovianarchive.com/pages/get-your-human-design-chart" target="_blank" class="btn btn-primary">Genera Gratuitamente su Jovian Archive</a>
                </div>
                <div class="gc-side" style="padding: 3rem; text-align: center;" data-animate>
                    <img src="{{ grav.base_url }}/user/pages/assets/bodygraph.png" alt="Esempio Bodygraph" style="max-height: 350px; margin: 0 auto;">
                    <p class="text-small italic" style="margin-top: 1.5rem;">La tua carta &egrave; il &ldquo;libretto delle istruzioni&rdquo; del tuo veicolo energetico.</p>
                </div>
            </div>

            <!-- Scopri il tuo Tipo -->
            <div style="margin-bottom: var(--space-xl);" data-animate>
                <div class="text-center" style="margin-bottom: 2rem;">
                    <h2 class="serif" style="margin-bottom: 0.75rem;">Hai visto la tua carta. E adesso?</h2>
                    <p style="color: rgba(255,255,255,0.7); max-width: 520px; margin: 0 auto; font-size: 0.95rem;">Trova il tuo Tipo qui sotto e scopri cosa significa in pratica — prima di qualsiasi altra cosa.</p>
                </div>

                <div class="tipo-accordion">

                    <details class="tipo-item">
                        <summary>
                            <span class="tipo-dot" style="background:#7EC8C8;"></span>
                            <span class="tipo-name">Generatore</span>
                            <span class="tipo-pct">~70% della popolazione</span>
                            <span class="tipo-chevron">▼</span>
                        </summary>
                        <div class="tipo-body">
                            <p>
                                <span class="tipo-tag" style="background:rgba(126,200,200,0.2);color:#7EC8C8;">Strategia</span>
                                <strong style="color:#fff;">Rispondere agli stimoli prima di agire.</strong> Non partire da soli — aspettare che arrivi qualcosa dall'esterno (una proposta, una domanda, una situazione) e sentire la risposta nel corpo.
                            </p>
                            <p>Hai il Centro Sacrale definito: un motore biologico che si ricarica ogni notte e produce energia lavorativa costante. Funziona solo sulle cose giuste — quelle che risuonano nel corpo, non quelle scelte dalla testa.</p>
                            <p>
                                <span class="tipo-tag" style="background:rgba(126,200,200,0.15);color:rgba(255,255,255,0.6);">Allineato</span> Soddisfazione &nbsp;·&nbsp;
                                <span class="tipo-tag" style="background:rgba(255,100,100,0.12);color:rgba(255,180,180,0.8);">Fuori meccanica</span> Frustrazione cronica
                            </p>
                        </div>
                    </details>

                    <details class="tipo-item">
                        <summary>
                            <span class="tipo-dot" style="background:#B68397;"></span>
                            <span class="tipo-name">Proiettore</span>
                            <span class="tipo-pct">~20% della popolazione</span>
                            <span class="tipo-chevron">▼</span>
                        </summary>
                        <div class="tipo-body">
                            <p>
                                <span class="tipo-tag" style="background:rgba(182,131,151,0.2);color:#B68397;">Strategia</span>
                                <strong style="color:#fff;">Aspettare l'invito specifico</strong> prima di offrire guida o direzione. Non proporsi — essere riconosciuti.
                            </p>
                            <p>Non hai il Sacrale definito: non sei fatto per il lavoro duro e continuo. Sei fatto per vedere gli altri in modo acuto e guidarli. Quando imiti i Generatori ti esaurisci rapidamente.</p>
                            <p>
                                <span class="tipo-tag" style="background:rgba(182,131,151,0.15);color:rgba(255,255,255,0.6);">Allineato</span> Successo &nbsp;·&nbsp;
                                <span class="tipo-tag" style="background:rgba(255,100,100,0.12);color:rgba(255,180,180,0.8);">Fuori meccanica</span> Amarezza
                            </p>
                        </div>
                    </details>

                    <details class="tipo-item">
                        <summary>
                            <span class="tipo-dot" style="background:#E8A96A;"></span>
                            <span class="tipo-name">Manifestatore</span>
                            <span class="tipo-pct">~9% della popolazione</span>
                            <span class="tipo-chevron">▼</span>
                        </summary>
                        <div class="tipo-body">
                            <p>
                                <span class="tipo-tag" style="background:rgba(232,169,106,0.2);color:#E8A96A;">Strategia</span>
                                <strong style="color:#fff;">Informare le persone chiave prima di agire.</strong> Non chiedere permesso — comunicare cosa stai per fare, per ridurre la resistenza degli altri.
                            </p>
                            <p>Sei l'unico Tipo che può iniziare azioni autonomamente senza aspettare. Il tuo blocco principale non è la mancanza di energia — è la resistenza che gli altri oppongono quando agisci senza avvisare.</p>
                            <p>
                                <span class="tipo-tag" style="background:rgba(232,169,106,0.15);color:rgba(255,255,255,0.6);">Allineato</span> Pace &nbsp;·&nbsp;
                                <span class="tipo-tag" style="background:rgba(255,100,100,0.12);color:rgba(255,180,180,0.8);">Fuori meccanica</span> Rabbia
                            </p>
                        </div>
                    </details>

                    <details class="tipo-item">
                        <summary>
                            <span class="tipo-dot" style="background:#A88FD4;"></span>
                            <span class="tipo-name">Riflettore</span>
                            <span class="tipo-pct">~1% della popolazione</span>
                            <span class="tipo-chevron">▼</span>
                        </summary>
                        <div class="tipo-body">
                            <p>
                                <span class="tipo-tag" style="background:rgba(168,143,212,0.2);color:#A88FD4;">Strategia</span>
                                <strong style="color:#fff;">Aspettare un ciclo lunare completo (28 giorni)</strong> per le decisioni importanti. Non affrettarsi mai.
                            </p>
                            <p>Non hai nessun centro definito. Sei uno specchio: amplifichi e rifletti l'energia dell'ambiente e delle persone intorno a te. Le condizioni esterne — luoghi, persone, comunità — influenzano profondamente come ti senti.</p>
                            <p>
                                <span class="tipo-tag" style="background:rgba(168,143,212,0.15);color:rgba(255,255,255,0.6);">Allineato</span> Sorpresa &nbsp;·&nbsp;
                                <span class="tipo-tag" style="background:rgba(255,100,100,0.12);color:rgba(255,180,180,0.8);">Fuori meccanica</span> Delusione
                            </p>
                        </div>
                    </details>

                </div>

                <p style="text-align:center; margin-top:1.75rem; font-size:0.82rem; color:rgba(255,255,255,0.4);">
                    In BG5 il Generatore si divide in Costruttore Classico e Costruttore Rapido — la meccanica di base è la stessa.
                </p>
            </div>

            <!-- Next Steps CTA -->
            <div class="gc-cta section-padding text-center" data-animate>
                <h2 class="serif">Hai gi&agrave; la tua carta?</h2>
                <p style="margin: 1.5rem 0 var(--space-md);">Una volta ottenuta la mappa, il passo successivo &egrave; decodificarla. Senza una lettura professionale, rimangono solo colori e numeri.</p>
                <div style="display: flex; gap: 1rem; justify-content: center;">
                    <a href="{{ grav.base_url }}/servizi" class="btn btn-outline">Scopri i Servizi</a>
                    <a href="{{ grav.base_url }}/contatti" class="btn btn-primary">Prenota una Lettura</a>
                </div>
            </div>
        </div>
    </section>
</main>
{% endblock %}
