<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>{% block title %}{{ page.header.seo_title ?? page.title }} | Valentina Russo{% endblock %}</title>
    <meta name="description" content="{{ page.header.seo_desc ?? page.header.description ?? 'Consulente BG5® e Human Design per carriera, relazioni e amor proprio.' }}">

    {# Favicons #}
    <link rel="icon" type="image/png" href="{{ grav.base_url }}/user/pages/assets/favicon-32x32.png" sizes="32x32">
    <link rel="apple-touch-icon" href="{{ grav.base_url }}/user/pages/assets/apple-touch-icon.png">

    {# GEO meta tags #}
    {% if page.header.geo_location is defined and page.header.geo_location %}
    <meta name="geo.placename" content="{{ page.header.geo_location }}">
    <meta name="geo.region" content="IT">
    {% endif %}

    {# Open Graph #}
    <meta property="og:title" content="{{ page.header.seo_title ?? page.title }}">
    <meta property="og:description" content="{{ page.header.seo_desc ?? page.header.description ?? '' }}">
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ page.url(true) }}">
    {% set og_image = '' %}
    {% if page.header.featured_image is defined and page.header.featured_image %}
      {% if '/' not in page.header.featured_image %}
        {% set og_image = page.media[page.header.featured_image].url ?? '' %}
      {% elseif 'placeholder' not in page.header.featured_image %}
        {% set og_image = grav.base_url_absolute ~ page.header.featured_image %}
      {% endif %}
    {% endif %}
    {% if not og_image and page.media|length %}
      {% set og_image = page.media|first.url ?? '' %}
    {% endif %}
    {% if not og_image %}
      {% set og_image = grav.base_url_absolute ~ '/user/themes/valentina/images/og-default.jpg' %}
    {% endif %}
    <meta property="og:image" content="{{ og_image }}">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:image" content="{{ og_image }}">

    {# CSS #}
    <link rel="stylesheet" href="{{ theme_url }}/css/style.css?v=20260308c">

    {# LD+JSON Website #}
    {% block schema %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Valentina Russo",
      "url": "{{ grav.base_url_absolute }}",
      "description": "Consulente BG5® e Human Design"
    }
    </script>
    {% endblock %}
</head>

{% set is_corporate_page = ('/aziende/' in page.route) or (page.header.corporate is defined and page.header.corporate) %}
<body{% if is_corporate_page %} class="corporate"{% endif %}>

    {% include 'partials/header.html.twig' %}

    {% block content %}{% endblock %}

    {% include 'partials/footer.html.twig' %}

    <script src="{{ theme_url }}/js/main.js"></script>
    {% block scripts %}{% endblock %}

</body>
</html>
