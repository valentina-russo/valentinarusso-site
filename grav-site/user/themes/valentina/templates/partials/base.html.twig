<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>{% block title %}{{ page.header.seo_title ?? page.title }} | Valentina Russo{% endblock %}</title>
    <meta name="description" content="{{ page.header.seo_desc ?? page.header.description ?? 'Consulente BG5® e Human Design per carriera, relazioni e amor proprio.' }}">
    <link rel="canonical" href="{{ page.url(true) }}">

    {# Favicons #}
    <link rel="icon" type="image/png" href="{{ grav.base_url }}/user/pages/assets/favicon-32x32.png" sizes="32x32">
    <link rel="apple-touch-icon" href="{{ grav.base_url }}/user/pages/assets/apple-touch-icon.png">

    {# Google Search Console — verifica proprietà #}
    <meta name="google-site-verification" content="hVvQ2yByWi_wqkv5-CpFa5ifdITtkTIsE1wBWU6WgOQ">

    {# Google Analytics 4 — escludi admin (localStorage) e bot/Playwright (user-agent) #}
    <script>
    if(!localStorage.getItem('vr_no_track') && !/HeadlessChrome|Playwright|Puppeteer|PhantomJS/i.test(navigator.userAgent)){
      var s=document.createElement('script');s.async=true;
      s.src='https://www.googletagmanager.com/gtag/js?id=G-GHR1HCYPY4';
      document.head.appendChild(s);
      window.dataLayer=window.dataLayer||[];
      function gtag(){dataLayer.push(arguments);}
      gtag('js',new Date());
      gtag('config','G-GHR1HCYPY4');
    }
    </script>

    {# GEO meta tags #}
    {% if page.header.geo_location is defined and page.header.geo_location %}
    <meta name="geo.placename" content="{{ page.header.geo_location }}">
    {% else %}
    <meta name="geo.placename" content="Torino, Italia">
    {% endif %}
    <meta name="geo.region" content="IT">

    {# Open Graph #}
    <meta property="og:title" content="{% block og_title %}{{ page.header.seo_title ?? page.title }}{% endblock %}">
    <meta property="og:description" content="{% block og_description %}{{ page.header.seo_desc ?? page.header.description ?? '' }}{% endblock %}">
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ page.url(true) }}">
    {% set og_image = '' %}
    {% if page.header.featured_image is defined and page.header.featured_image %}
      {% if '/' not in page.header.featured_image %}
        {% set og_image = page.media[page.header.featured_image].url ?? '' %}
      {% elseif 'placeholder' not in page.header.featured_image %}
        {% set og_image = grav.base_url_absolute ~ page.header.featured_image %}
      {% endif %}
    {% endif %}
    {% if not og_image and page.media|length %}
      {% set og_image = page.media|first.url ?? '' %}
    {% endif %}
    {% if not og_image %}
      {% set og_image = grav.base_url_absolute ~ '/user/themes/valentina/images/og-default.jpg' %}
    {% endif %}
    <meta property="og:image" content="{{ og_image }}">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:image" content="{{ og_image }}">
    <meta name="twitter:title" content="{{ page.header.seo_title ?? page.title }}">
    <meta name="twitter:description" content="{{ page.header.seo_desc ?? page.header.description ?? '' }}">
    <meta name="twitter:creator" content="@valentinarussobg5">
    <meta name="twitter:site" content="@valentinarussobg5">

    {# CSS #}
    <link rel="stylesheet" href="{{ theme_url }}/css/style.css?v=20260312_ULTRA">
    {% block extra_css %}{% endblock %}

    {# Content freshness meta #}
    <meta name="last-modified" content="{{ page.modified|date('D, d M Y H:i:s') }} GMT">

    {# LD+JSON Website #}
    {% block schema %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Valentina Russo",
      "url": "{{ grav.base_url_absolute }}",
      "description": "Consulente BG5® e Human Design",
      "dateModified": "{{ page.modified|date('c') }}"
    }
    </script>
    {% endblock %}

    {# Person schema — ESPANSO per GEO/SEO #}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "@id": "{{ grav.base_url_absolute }}/#valentina-russo",
      "name": "Valentina Russo",
      "alternateName": "Valentina Russo BG5",
      "givenName": "Valentina",
      "familyName": "Russo",
      "url": "{{ grav.base_url_absolute }}",
      "image": "{{ grav.base_url_absolute }}/user/pages/assets/valentina.jpg",
      "description": "Consulente BG5® certificata e Human Design Analyst. Tra le poche professioniste italiane con certificazione ufficiale BG5® Business Institute. Specializzata in career development, business strategy e dinamiche relazionali.",
      "jobTitle": ["BG5® Consultant", "Human Design Analyst", "Career & Business Professional"],
      "knowsAbout": ["BG5 System", "Human Design", "Career Consulting", "Business Strategy", "Personal Development", "Team Composition Analysis", "Organizational Dynamics"],
      "qualifications": [
        {
          "@type": "EducationalOccupationalCredential",
          "name": "BG5® Career & Business Professional",
          "credentialCategory": "Professional Certification",
          "recognizedBy": {
            "@type": "Organization",
            "name": "BG5® Business Institute",
            "url": "https://www.humandesignbusiness.com/"
          },
          "url": "https://bg5businessinstitute.com/professionals?id=399d41b3-612b-48d1-88b9-7bc26ed71418"
        },
        {
          "@type": "EducationalOccupationalCredential",
          "name": "Human Design Analyst",
          "credentialCategory": "Professional Certification"
        }
      ],
      "sameAs": [
        "https://www.instagram.com/valentinarussobg5/",
        "https://www.linkedin.com/in/valentina-russo-6abb6514a/",
        "https://bg5businessinstitute.com/professionals?id=399d41b3-612b-48d1-88b9-7bc26ed71418"
      ],
      "email": "consulenze@valentinarussobg5.com",
      "worksFor": {
        "@type": "Organization",
        "@id": "{{ grav.base_url_absolute }}/#organization"
      }
    }
    </script>

    {# Organization Schema — Partner e Affiliazioni #}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "@id": "{{ grav.base_url_absolute }}/#organization",
      "name": "Valentina Russo",
      "alternateName": "Valentina Russo BG5 Consultant",
      "url": "{{ grav.base_url_absolute }}",
      "logo": "{{ grav.base_url_absolute }}/user/pages/assets/logo.png",
      "description": "BG5® Business Institute Certified Consultant e Human Design Analyst specializzata in career, relazioni e business strategy.",
      "email": "consulenze@valentinarussobg5.com",
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer service",
        "email": "consulenze@valentinarussobg5.com",
        "availableLanguage": ["Italian", "English"]
      },
      "founder": {
        "@type": "Person",
        "@id": "{{ grav.base_url_absolute }}/#valentina-russo"
      },
      "sameAs": [
        "https://www.instagram.com/valentinarussobg5/",
        "https://www.linkedin.com/in/valentina-russo-6abb6514a/",
        "https://www.humandesignbusiness.com/",
        "https://bg5businessinstitute.com/professionals?id=399d41b3-612b-48d1-88b9-7bc26ed71418"
      ],
      "memberOf": [
        {
          "@type": "Organization",
          "name": "BG5® Business Institute",
          "url": "https://www.humandesignbusiness.com/"
        }
      ]
    }
    </script>

    {# Service Schema — Servizi Principali #}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Service",
      "name": "BG5® Consulting & Human Design Analysis",
      "provider": {
        "@type": "Person",
        "@id": "{{ grav.base_url_absolute }}/#valentina-russo"
      },
      "areaServed": "IT",
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Servizi BG5® e Human Design",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Prima Lettura Human Design",
              "description": "Sessione intensiva di 2 ore per decodificare Tipo Energetico, Strategia e Autorità interna."
            },
            "price": "210",
            "priceCurrency": "EUR"
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Oltre l'Ombra",
              "description": "Percorso di 3 sessioni da 90 min. Decondiciona schemi ripetitivi e frustrazioni."
            },
            "price": "500",
            "priceCurrency": "EUR"
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Ri-Conoscersi",
              "description": "Percorso individuale di 10 sessioni da 90 min. Esplora il tema generale del contributo personale."
            },
            "price": "1200",
            "priceCurrency": "EUR"
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Sinfonia a Due",
              "description": "Percorso di coppia di 9 sessioni da 90 min. Analisi connessioni elettromagnetiche tra i design."
            },
            "price": "1800",
            "priceCurrency": "EUR"
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "BG5® Business Blueprint",
              "description": "Percorso di 15 sessioni per liberi professionisti e imprenditori su career optimization e business strategy."
            },
            "price": "1800",
            "priceCurrency": "EUR"
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "BG5® Partnership Dynamics",
              "description": "Percorso per soci e co-fondatori. Compatibilità energetica e dinamiche comunicative tra partner."
            },
            "price": "2200",
            "priceCurrency": "EUR"
          }
        ]
      }
    }
    </script>

    {# LocalBusiness Schema — Consulente Italia #}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "Valentina Russo",
      "alternateName": "Valentina Russo BG5 Consultant",
      "url": "{{ grav.base_url_absolute }}",
      "image": "{{ grav.base_url_absolute }}/user/pages/assets/valentina.jpg",
      "description": "Consulente BG5® certificata specializzata in career coaching, business strategy e human design per professionisti e imprenditori italiani.",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Torino",
        "addressRegion": "Piemonte",
        "addressCountry": "IT"
      },
      "areaServed": ["IT", "Italia"],
      "serviceType": ["Career Coaching", "Business Consulting", "Human Design Analysis", "BG5 Consulting"],
      "priceRange": "€€€",
      "email": "consulenze@valentinarussobg5.com",
      "sameAs": [
        "https://www.instagram.com/valentinarussobg5/",
        "https://www.linkedin.com/in/valentina-russo-6abb6514a/",
        "https://www.humandesignbusiness.com/",
        "https://bg5businessinstitute.com/professionals?id=399d41b3-612b-48d1-88b9-7bc26ed71418"
      ],
      "knowsLanguage": ["it", "en"]
    }
    </script>

    {# FAQPage Schema — Domande frequenti per IA #}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Che cosa è il BG5®?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "BG5® è un sistema applicato al Human Design che decodifica il tuo codice genetico per il lavoro, la carriera e le dinamiche di business. Ti fornisce i dati meccanici per operare in allineamento con la tua vera natura."
          }
        },
        {
          "@type": "Question",
          "name": "Che cosa è l'Human Design?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "L'Human Design è un sistema di analisi logica della tua energia basato sulla data, ora e luogo di nascita. Non è un sistema di credenze, ma uno strumento per comprendere il tuo disegno unico e come sei progettato per operare nel mondo."
          }
        },
        {
          "@type": "Question",
          "name": "Chi è Valentina Russo?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Valentina Russo è una Consulente BG5® certificata e Human Design Analyst. Aiuta professionisti, imprenditori e individui a decodificare il loro tipo energetico, strategia decisionale e autorità interna per vivere e lavorare in allineamento con la loro vera natura."
          }
        },
        {
          "@type": "Question",
          "name": "Quali sono i servizi principali?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "I servizi includono: La Prima Lettura Human Design (mappa di base), percorsi su Vita e Relazioni, consulenze BG5® per business, e programmi per coppia e partnership. Ogni servizio è costruito per aiutarti ad incarnare il tuo disegno nella quotidianità."
          }
        },
        {
          "@type": "Question",
          "name": "Come faccio a ottenere la mia carta Human Design?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Puoi generare la tua carta gratuitamente sul sito nella sezione 'Genera la tua carta'. Avrai bisogno di data, ora e luogo di nascita. La carta ti mostra il tuo Tipo, Strategia e Autorità, i primi passi per comprendere come sei progettato."
          }
        },
        {
          "@type": "Question",
          "name": "Quanto costa una consulenza con Valentina Russo?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "La Prima Lettura Human Design costa €210 (sessione di 2 ore). I percorsi approfonditi vanno da €500 (Oltre l'Ombra, 3 sessioni) a €2.200 (BG5® Partnership Dynamics). Tutti i prezzi sono su valentinarussobg5.com/servizi."
          }
        },
        {
          "@type": "Question",
          "name": "Le consulenze di Valentina Russo si possono fare online?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sì. Tutte le sessioni sono disponibili in videochiamata per clienti in tutta Italia e all'estero. Valentina Russo ha sede a Torino e opera online in tutta Italia."
          }
        },
        {
          "@type": "Question",
          "name": "BG5® è adatto anche per le aziende e i team?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sì. BG5® nasce come sistema applicato al contesto professionale e aziendale. Valentina Russo offre servizi per team aziendali: analisi della composizione energetica del gruppo, selezione del personale, identificazione dei leader naturali e compatibilità tra soci."
          }
        },
        {
          "@type": "Question",
          "name": "Qual è la differenza tra Human Design e BG5®?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Human Design analizza la persona nella sua totalità: vita, relazioni, scopo. BG5® è l'applicazione professionale dello stesso sistema, con focus specifico su carriera, team e business. Stessa meccanica energetica, contesto applicativo diverso."
          }
        }
      ]
    }
    </script>

    {# GA4 gia' caricato in head — rimosso duplicato #}
</head>

{% set is_corporate_page = ('/aziende/' in page.route) or (page.header.corporate is defined and page.header.corporate) %}
{% set is_home = page.template == 'home' %}
{% set is_aziende_home = page.template == 'aziende_home' %}
{% set body_classes = [] %}
{% if is_corporate_page %}{% set body_classes = body_classes|merge(['corporate']) %}{% endif %}
{% if is_home %}{% set body_classes = body_classes|merge(['hero-v2-privati']) %}{% endif %}
{% if is_aziende_home %}{% set body_classes = body_classes|merge(['hero-v2-aziende']) %}{% endif %}
<body{% if body_classes %} class="{{ body_classes|join(' ') }}"{% endif %}>

    {% include 'partials/header.html.twig' %}

    {% block content %}{% endblock %}

    {% include 'partials/footer.html.twig' %}

    <script src="{{ theme_url }}/js/main.js"></script>
    {% block scripts %}{% endblock %}

</body>
</html>
