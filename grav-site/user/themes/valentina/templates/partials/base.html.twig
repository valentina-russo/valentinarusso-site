<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>{% block title %}{{ page.header.seo_title ?? page.title }} | Valentina Russo{% endblock %}</title>
    <meta name="description" content="{{ page.header.seo_desc ?? page.header.description ?? 'Consulente BG5® e Human Design per carriera, relazioni e amor proprio.' }}">
    <link rel="canonical" href="{{ page.url(true) }}">

    {# Favicons #}
    <link rel="icon" type="image/png" href="{{ grav.base_url }}/user/pages/assets/favicon-32x32.png" sizes="32x32">
    <link rel="apple-touch-icon" href="{{ grav.base_url }}/user/pages/assets/apple-touch-icon.png">

    {# GEO meta tags #}
    {% if page.header.geo_location is defined and page.header.geo_location %}
    <meta name="geo.placename" content="{{ page.header.geo_location }}">
    <meta name="geo.region" content="IT">
    {% endif %}

    {# Open Graph #}
    <meta property="og:title" content="{{ page.header.seo_title ?? page.title }}">
    <meta property="og:description" content="{{ page.header.seo_desc ?? page.header.description ?? '' }}">
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ page.url(true) }}">
    {% set og_image = '' %}
    {% if page.header.featured_image is defined and page.header.featured_image %}
      {% if '/' not in page.header.featured_image %}
        {% set og_image = page.media[page.header.featured_image].url ?? '' %}
      {% elseif 'placeholder' not in page.header.featured_image %}
        {% set og_image = grav.base_url_absolute ~ page.header.featured_image %}
      {% endif %}
    {% endif %}
    {% if not og_image and page.media|length %}
      {% set og_image = page.media|first.url ?? '' %}
    {% endif %}
    {% if not og_image %}
      {% set og_image = grav.base_url_absolute ~ '/user/themes/valentina/images/og-default.jpg' %}
    {% endif %}
    <meta property="og:image" content="{{ og_image }}">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:image" content="{{ og_image }}">
    <meta name="twitter:title" content="{{ page.header.seo_title ?? page.title }}">
    <meta name="twitter:description" content="{{ page.header.seo_desc ?? page.header.description ?? '' }}">
    <meta name="twitter:creator" content="@valentinarussobg5">
    <meta name="twitter:site" content="@valentinarussobg5">

    {# CSS #}
    <link rel="stylesheet" href="{{ theme_url }}/css/style.css?v=20260311d">
    {% block extra_css %}{% endblock %}

    {# LD+JSON Website #}
    {% block schema %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Valentina Russo",
      "url": "{{ grav.base_url_absolute }}",
      "description": "Consulente BG5® e Human Design"
    }
    </script>
    {% endblock %}

    {# Person schema — ESPANSO per GEO/SEO #}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Valentina Russo",
      "givenName": "Valentina",
      "familyName": "Russo",
      "url": "{{ grav.base_url_absolute }}",
      "image": "{{ grav.base_url_absolute }}/user/pages/assets/valentina.png",
      "description": "Consulente BG5® e Human Design per carriera, relazioni e amor proprio.",
      "jobTitle": ["BG5® Consultant", "Human Design Analyst", "Career & Business Professional"],
      "knowsAbout": ["BG5 System", "Human Design", "Career Consulting", "Business Strategy", "Personal Development"],
      "qualifications": [
        {
          "@type": "EducationalOccupationalCredential",
          "name": "BG5® Business Institute Certified",
          "credentialCategory": "Professional Certification",
          "url": "https://www.humandesignbusiness.com/",
          "credentialHasExpire": false
        },
        {
          "@type": "EducationalOccupationalCredential",
          "name": "Human Design Analyst",
          "credentialCategory": "Professional Certification"
        }
      ],
      "sameAs": [
        "https://www.instagram.com/valentinarussobg5/"
      ],
      "website": "{{ grav.base_url_absolute }}"
    }
    </script>

    {# Organization Schema — Partner e Affiliazioni #}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Valentina Russo — BG5® Consultant",
      "url": "{{ grav.base_url_absolute }}",
      "logo": "{{ grav.base_url_absolute }}/user/pages/assets/logo.png",
      "description": "BG5® Business Institute Certified Consultant e Human Design Analyst specializzata in career, relazioni e business strategy.",
      "sameAs": [
        "https://www.instagram.com/valentinarussobg5/",
        "https://www.humandesignbusiness.com/"
      ],
      "memberOf": [
        {
          "@type": "Organization",
          "name": "BG5® Business Institute",
          "url": "https://www.humandesignbusiness.com/"
        }
      ]
    }
    </script>

    {# Service Schema — Servizi Principali #}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Service",
      "name": "BG5® Consulting & Human Design Analysis",
      "provider": {
        "@type": "LocalBusiness",
        "name": "Valentina Russo",
        "url": "{{ grav.base_url_absolute }}"
      },
      "areaServed": "IT",
      "hasOfferingDetails": [
        {
          "@type": "Offering",
          "name": "Prima Lettura Human Design",
          "description": "Sessione intensiva di 2 ore per decodificare il tuo Tipo Energetico, Strategia e Autorità interna.",
          "price": "210",
          "priceCurrency": "EUR"
        },
        {
          "@type": "Offering",
          "name": "Percorsi BG5® Business",
          "description": "Consulenze per liberi professionisti e imprenditori su career optimization e business strategy.",
          "price": "1800",
          "priceCurrency": "EUR"
        },
        {
          "@type": "Offering",
          "name": "Vita e Relazioni",
          "description": "Percorsi per ripulire condizionamenti e comprendere relazioni con consapevolezza del design.",
          "price": "500",
          "priceCurrency": "EUR"
        }
      ]
    }
    </script>

    {# LocalBusiness Schema — Consulente Italia #}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Valentina Russo — BG5® Consultant & Human Design Analyst",
      "url": "{{ grav.base_url_absolute }}",
      "image": "{{ grav.base_url_absolute }}/user/pages/assets/valentina.png",
      "description": "Consulente BG5® certificata specializzata in career coaching, business strategy e human design per professionisti e imprenditori italiani.",
      "address": {
        "@type": "PostalAddress",
        "addressCountry": "IT"
      },
      "areaServed": ["IT", "Italia"],
      "serviceType": ["Career Coaching", "Business Consulting", "Human Design Analysis", "BG5 Consulting"],
      "priceRange": "€€€",
      "sameAs": [
        "https://www.instagram.com/valentinarussobg5/",
        "https://www.humandesignbusiness.com/"
      ],
      "knowsLanguage": ["it", "en"]
    }
    </script>

    {# FAQPage Schema — Domande frequenti per IA #}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Che cosa è il BG5®?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "BG5® è un sistema applicato al Human Design che decodifica il tuo codice genetico per il lavoro, la carriera e le dinamiche di business. Ti fornisce i dati meccanici per operare in allineamento con la tua vera natura."
          }
        },
        {
          "@type": "Question",
          "name": "Che cosa è l'Human Design?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "L'Human Design è un sistema di analisi logica della tua energia basato sulla data, ora e luogo di nascita. Non è un sistema di credenze, ma uno strumento per comprendere il tuo disegno unico e come sei progettato per operare nel mondo."
          }
        },
        {
          "@type": "Question",
          "name": "Chi è Valentina Russo?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Valentina Russo è una Consulente BG5® certificata e Human Design Analyst. Aiuta professionisti, imprenditori e individui a decodificare il loro tipo energetico, strategia decisionale e autorità interna per vivere e lavorare in allineamento con la loro vera natura."
          }
        },
        {
          "@type": "Question",
          "name": "Quali sono i servizi principali?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "I servizi includono: La Prima Lettura Human Design (mappa di base), percorsi su Vita e Relazioni, consulenze BG5® per business, e programmi per coppia e partnership. Ogni servizio è costruito per aiutarti ad incarnare il tuo disegno nella quotidianità."
          }
        },
        {
          "@type": "Question",
          "name": "Come faccio a ottenere la mia carta Human Design?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Puoi generare la tua carta gratuitamente sul sito nella sezione 'Genera la tua carta'. Avrai bisogno di data, ora e luogo di nascita. La carta ti mostra il tuo Tipo, Strategia e Autorità, i primi passi per comprendere come sei progettato."
          }
        }
      ]
    }
    </script>

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-GHR1HCYPY4"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-GHR1HCYPY4');
    </script>
</head>

{% set is_corporate_page = ('/aziende/' in page.route) or (page.header.corporate is defined and page.header.corporate) %}
{% set is_home = page.template == 'home' %}
{% set is_aziende_home = page.template == 'aziende_home' %}
{% set body_classes = [] %}
{% if is_corporate_page %}{% set body_classes = body_classes|merge(['corporate']) %}{% endif %}
{% if is_home %}{% set body_classes = body_classes|merge(['hero-v2-privati']) %}{% endif %}
{% if is_aziende_home %}{% set body_classes = body_classes|merge(['hero-v2-aziende']) %}{% endif %}
<body{% if body_classes %} class="{{ body_classes|join(' ') }}"{% endif %}>

    {% include 'partials/header.html.twig' %}

    {% block content %}{% endblock %}

    {% include 'partials/footer.html.twig' %}

    <script src="{{ theme_url }}/js/main.js"></script>
    {% block scripts %}{% endblock %}

</body>
</html>
