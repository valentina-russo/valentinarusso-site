{# Partial: calcolatore carta Human Design singola (pagine città + genera_carta) #}
{% set _cs_mode = mode ?? 'city' %}
<section id="carta-calculator" style="padding: 3.5rem 0 4rem;">
<style>
/* ── Contenitore ── */
#carta-calculator { font-family: 'Outfit', Arial, sans-serif; }
#carta-calculator .csingle-intro { text-align: center; margin-bottom: 2rem; }
#carta-calculator .csingle-badge { display: inline-block; background: rgba(107,79,168,0.1); color: var(--primary-color, #6b4fa8); font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; padding: 0.25rem 0.8rem; border-radius: 20px; margin-bottom: 0.85rem; }
#carta-calculator .csingle-intro h2 { font-size: clamp(1.35rem,3.5vw,1.85rem); color: var(--primary-color, #6b4fa8); margin: 0 0 0.5rem; font-family: 'Playfair Display', serif; }
#carta-calculator .csingle-intro p { color: #666; font-size: 0.95rem; margin: 0; }

/* ── Form card ── */
#carta-calculator .carta-form-card { background: #fff; border-radius: 20px; padding: 1.75rem 1.75rem 1.5rem; box-shadow: 0 4px 24px rgba(0,0,0,0.08); border: 1px solid rgba(107,79,168,0.12); }
#carta-calculator .cf-row { display: grid; grid-template-columns: 1fr; gap: 0.75rem; margin-bottom: 0.75rem; }
#carta-calculator .cf-row-datetime { display: flex; gap: 0.75rem; align-items: flex-start; flex-wrap: wrap; margin-bottom: 0.75rem; }
#carta-calculator .cf-field-date { flex: 1.6; min-width: 160px; }
#carta-calculator .cf-field-time { flex: 1; min-width: 110px; }
#carta-calculator .cf-field label { display: block; font-size: 0.78rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #6b4fa8; margin-bottom: 0.3rem; }
#carta-calculator .cf-field input, #carta-calculator .cf-field select { width: 100%; padding: 0.7rem 0.9rem; border-radius: 10px; border: 1.5px solid rgba(107,79,168,0.3); background: #f7f5fc; color: #3a2560; font-family: inherit; font-size: 0.95rem; font-weight: 500; box-sizing: border-box; }
#carta-calculator .cf-field input:focus, #carta-calculator .cf-field select:focus { outline: none; border-color: #6b4fa8; background: #f0eaf8; }
#carta-calculator .cf-hint { font-size: 0.72rem; color: #a093c0; margin-top: 0.25rem; }
#carta-calculator .cf-tz-detected { font-size: 0.72rem; color: #52a363; margin-top: 0.2rem; display: none; }
#carta-calculator .cf-autocomplete-wrap { position: relative; }
#carta-calculator .cf-autocomplete-list { position: absolute; top: 100%; left: 0; right: 0; background: #fff; border: 1px solid rgba(107,79,168,0.2); border-top: none; border-radius: 0 0 10px 10px; list-style: none; margin: 0; padding: 0; z-index: 100; display: none; box-shadow: 0 8px 24px rgba(0,0,0,0.1); }
#carta-calculator .cf-autocomplete-list li { padding: 0.65rem 0.9rem; cursor: pointer; font-size: 0.9rem; color: #3a2560; border-bottom: 1px solid #f0ece8; }
#carta-calculator .cf-autocomplete-list li:last-child { border-bottom: none; }
#carta-calculator .cf-autocomplete-list li:hover { background: #f5f0ff; }
#carta-calculator .cf-dt-wrap { position: relative; }
#carta-calculator .cf-dt-ph { position: absolute; inset: 0; padding: 0.7rem 0.9rem; color: #a093c0; font-size: 0.95rem; pointer-events: none; display: flex; align-items: center; border-radius: 10px; background: #f7f5fc; }
#carta-calculator .cf-dt-ph.cf-dt-ph--hidden { display: none; }
#carta-calculator input[type="date"], #carta-calculator input[type="time"] { -webkit-appearance: none; appearance: none; display: block; width: 100%; min-width: 0; min-height: 2.9rem; line-height: 1.4; padding: 0.7rem 0.9rem; border-radius: 10px; border: 1.5px solid rgba(107,79,168,0.35); background: #f7f5fc; color: #3a2560; font-family: inherit; font-size: 0.95rem; font-weight: 500; cursor: pointer; box-sizing: border-box; position: relative; z-index: 1; }
#carta-calculator input[type="date"]:focus, #carta-calculator input[type="time"]:focus { outline: none; border-color: #6b4fa8; background: #f0eaf8; }
#carta-calculator .carta-btn { display: block; width: 100%; padding: 1rem 1.5rem; background: linear-gradient(135deg, #6b4fa8 0%, #8a63c8 100%); color: #fff; border: none; border-radius: 50px; font-family: inherit; font-size: 1.05rem; font-weight: 700; cursor: pointer; margin-top: 1rem; transition: opacity 0.2s, transform 0.1s; }
#carta-calculator .carta-btn:hover:not(:disabled) { opacity: 0.9; }
#carta-calculator .carta-btn:active:not(:disabled) { transform: scale(0.99); }
#carta-calculator .carta-btn:disabled { opacity: 0.6; cursor: not-allowed; }

/* ── Loading ── */
#carta-calculator .carta-loading { display: none; text-align: center; padding: 2rem 0; }
#carta-calculator .carta-loading-dots { display: flex; justify-content: center; gap: 6px; }
#carta-calculator .carta-loading-dots span { width: 10px; height: 10px; border-radius: 50%; background: #6b4fa8; animation: csdots 1.2s infinite ease-in-out; }
#carta-calculator .carta-loading-dots span:nth-child(2) { animation-delay: 0.2s; }
#carta-calculator .carta-loading-dots span:nth-child(3) { animation-delay: 0.4s; }
@keyframes csdots { 0%,80%,100%{transform:scale(0);opacity:0.4} 40%{transform:scale(1);opacity:1} }
#carta-calculator .carta-error { display: none; background: #fff0f0; border: 1px solid #f5c0c0; color: #c0392b; border-radius: 12px; padding: 0.85rem 1.1rem; font-size: 0.9rem; margin-top: 1rem; }

/* ── Risultati ── */
#carta-calculator .carta-results { display: none; margin-top: 2rem; }
#carta-calculator .carta-name-header { display: none; text-align: center; margin-bottom: 1.5rem; }
#carta-calculator .carta-name-header h2 { font-size: 1.4rem; color: var(--primary-color, #6b4fa8); margin: 0 0 0.25rem; }
#carta-calculator .carta-name-header p { color: #888; font-size: 0.88rem; margin: 0; }

/* Core cards */
#carta-calculator .carta-core { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.75rem; margin-bottom: 1.5rem; }
@media (min-width: 600px) { #carta-calculator .carta-core { grid-template-columns: repeat(3, 1fr); } }
@media (min-width: 900px) { #carta-calculator .carta-core { grid-template-columns: repeat(4, 1fr); } }
#carta-calculator .core-card { background: #fff; border: 1px solid var(--soft-gray, #e8e4df); border-top: 3px solid var(--primary-color, #6b4fa8); border-radius: 10px; padding: 0.85rem 1rem; }
#carta-calculator .core-card-label { font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; color: #a093c0; margin-bottom: 0.3rem; }
#carta-calculator .core-card-value { font-size: 0.88rem; font-weight: 700; color: #1a1a2e; line-height: 1.3; }

/* Bodygraph + pianeti */
#carta-calculator .carta-desktop-layout { display: grid; grid-template-columns: 1fr; gap: 1.5rem; align-items: start; }
@media (min-width: 768px) { #carta-calculator .carta-desktop-layout { grid-template-columns: auto 1fr; align-items: stretch; } }
#carta-calculator .carta-bodygraph-wrap { display: flex; align-items: center; justify-content: center; background: #fff; border: 1px solid var(--soft-gray, #e8e4df); border-radius: 16px; padding: 1rem; }
#carta-calculator .carta-bodygraph-wrap svg { max-width: 300px; width: 100%; height: auto; display: block; }
/* Mobile: pianeti sotto il bodygraph, altezza libera */
#carta-calculator .carta-col-planets { display: flex; flex-direction: column; }
#carta-calculator .carta-planets { overflow: hidden; background: #fff; border: 1px solid var(--soft-gray, #e8e4df); border-radius: 16px; padding: 0.75rem; }
/* Desktop: stessa altezza del bodygraph, nessuno scroll */
@media (min-width: 768px) {
  #carta-calculator .carta-col-planets { overflow: hidden; }
  #carta-calculator .carta-planets { overflow: hidden; height: 100%; display: flex; flex-direction: column; padding: 0.5rem 0.65rem; }
  #carta-calculator .carta-planets h3 { font-size: 0.78rem; margin: 0 0 0.2rem; }
  #carta-calculator .planets-table { font-size: 0.65rem; line-height: 1.05; flex: 1; }
  #carta-calculator .planets-table th { padding: 0.3rem 0.35rem 0.2rem; font-size: 0.5rem; }
  #carta-calculator .planets-table td { padding: 0.04rem 0.35rem; border-bottom: 1px solid #f5f2ef; }
  #carta-calculator .planet-bg5 { display: inline; font-size: 0.58rem; font-weight: 600; }
  #carta-calculator .planet-name { display: inline; font-size: 0.5rem; color: #bbb; margin-left: 0.1rem; }
  #carta-calculator .gate-black, #carta-calculator .gate-red { font-size: 0.68rem; font-weight: 700; }
}
#carta-calculator .carta-planets h3 { font-size: 0.88rem; color: var(--primary-color, #6b4fa8); margin: 0 0 0.3rem; }
#carta-calculator .planets-table { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
#carta-calculator .planets-table th { background: #f5f0eb; color: #8b7355; font-size: 0.62rem; text-transform: uppercase; letter-spacing: 0.05em; padding: 0.3rem 0.5rem; text-align: left; border-bottom: 1px solid #e8e4df; position: sticky; top: 2rem; }
#carta-calculator .planets-table td { padding: 0.22rem 0.5rem; border-bottom: 1px solid #f0ece8; color: #333; }
#carta-calculator .planet-bg5 { font-size: 0.75rem; }
#carta-calculator .planet-name { font-size: 0.62rem; }
#carta-calculator .planet-bg5 { display: block; font-size: 0.8rem; color: #1a1a2e; font-weight: 600; }
#carta-calculator .planet-name { display: block; font-size: 0.68rem; color: #aaa; }
#carta-calculator .gate-black { color: #1a1a2e; font-weight: 700; }
#carta-calculator .gate-red { color: #c0392b; font-weight: 700; }

/* CTA */
#carta-calculator .csingle-cta { background: #fff; border: 1px solid var(--soft-gray, #e8e4df); border-radius: 16px; padding: 1.75rem 2rem; text-align: center; margin-top: 2rem; }
#carta-calculator .csingle-cta p { color: #555; font-size: 0.92rem; margin: 0 0 1.25rem; line-height: 1.65; max-width: 480px; margin-inline: auto; margin-bottom: 1.25rem; }
#carta-calculator .csingle-cta a { display: inline-block; padding: 0.9rem 2.25rem; background: var(--primary-color, #6b4fa8); color: #fff; border-radius: 50px; font-weight: 700; font-size: 1rem; text-decoration: none; transition: opacity 0.2s; }
#carta-calculator .csingle-cta a:hover { opacity: 0.88; }

@media (max-width: 640px) {
  #carta-calculator .carta-form-card { padding: 1.25rem 1rem; }
  #carta-calculator .cf-row-datetime { flex-direction: column; }
  #carta-calculator .cf-field-date, #carta-calculator .cf-field-time { flex: none; width: 100%; min-width: 0; }
  #carta-calculator .carta-core { grid-template-columns: 1fr 1fr; }
}
</style>

<div class="container" style="max-width: 720px; padding: 0 1.25rem;">

  <div class="csingle-intro">
    <span class="csingle-badge">Gratuito · nessuna registrazione</span>
    <h2>Calcola la tua Carta Human Design</h2>
    <p>Scopri il tuo Tipo Energetico, Profilo e Autorità Decisionale in pochi secondi.</p>
  </div>

  <div class="carta-form-card">
    <div class="cf-row">
      <div class="cf-field">
        <label>Nome (opzionale)</label>
        <input type="text" id="cs-nome" placeholder="Il tuo nome">
      </div>
    </div>
    <div class="cf-row-datetime">
      <div class="cf-field cf-field-date">
        <label>📅 Data di nascita</label>
        <div class="cf-dt-wrap">
          <input type="date" id="cs-date" min="1900-01-01" max="2050-12-31">
          <span class="cf-dt-ph" id="cs-date-ph" aria-hidden="true">gg / mm / aaaa</span>
        </div>
      </div>
      <div class="cf-field cf-field-time">
        <label>🕐 Ora di nascita</label>
        <div class="cf-dt-wrap">
          <input type="time" id="cs-time">
          <span class="cf-dt-ph" id="cs-time-ph" aria-hidden="true">ora : min</span>
        </div>
      </div>
    </div>
    <div class="cf-row">
      <div class="cf-field">
        <label>📍 Luogo di nascita *</label>
        <div class="cf-autocomplete-wrap">
          <input type="text" id="cs-city" placeholder="Es: Milano, Roma, Napoli…" autocomplete="off" required>
          <ul class="cf-autocomplete-list" id="cs-city-list"></ul>
        </div>
        <div class="cf-hint">Inserisci la città — il fuso orario viene rilevato automaticamente</div>
      </div>
    </div>
    <div class="cf-row">
      <div class="cf-field">
        <label>Fuso orario</label>
        <select id="cs-tz">
          <option value="Europe/Rome" selected>Italia (Europe/Rome)</option>
          <option value="Europe/London">Regno Unito (Europe/London)</option>
          <option value="Europe/Paris">Francia / Belgio (Europe/Paris)</option>
          <option value="Europe/Berlin">Germania / Austria (Europe/Berlin)</option>
          <option value="Europe/Madrid">Spagna (Europe/Madrid)</option>
          <option value="Europe/Zurich">Svizzera (Europe/Zurich)</option>
          <option value="America/New_York">USA Est (America/New_York)</option>
          <option value="America/Chicago">USA Centrale (America/Chicago)</option>
          <option value="America/Los_Angeles">USA Ovest (America/Los_Angeles)</option>
          <option value="America/Argentina/Buenos_Aires">Argentina</option>
          <option value="America/Sao_Paulo">Brasile</option>
          <option value="Asia/Dubai">Emirati Arabi</option>
          <option value="Asia/Kolkata">India</option>
          <option value="Asia/Tokyo">Giappone</option>
          <option value="Australia/Sydney">Australia</option>
        </select>
        <div class="cf-hint">Selezionato automaticamente dalla città</div>
        <div class="cf-tz-detected" id="cs-tz-detected"></div>
      </div>
    </div>
    <button class="carta-btn" id="cs-calcola-btn" onclick="csCalcola()">Calcola la mia Carta</button>
  </div>

  <div class="carta-loading" id="cs-loading">
    <div class="carta-loading-dots"><span></span><span></span><span></span></div>
    <p style="margin-top:0.75rem;color:#888;font-size:0.9rem;">Calcolo in corso…</p>
  </div>
  <div class="carta-error" id="cs-error"></div>

  <div class="carta-results" id="cs-results">
    <div class="carta-name-header" id="cs-name-header"></div>
    <div class="carta-core" id="cs-core"></div>
    <div class="carta-desktop-layout">
      <div>
        <div class="carta-bodygraph-wrap" id="cs-bodygraph-wrap"></div>
      </div>
      <div class="carta-col-planets">
        <div class="carta-planets" id="cs-planets"></div>
      </div>
    </div>
    {% if _cs_mode != 'genera' %}
    <div class="csingle-cta">
      <p>La tua carta mostra la struttura energetica di base. Una lettura con Valentina trasforma questi dati in indicazioni concrete per il lavoro, le relazioni e le decisioni di tutti i giorni.</p>
      <a href="{{ grav.base_url }}/contatti">Prenota una Prima Lettura →</a>
    </div>
    {% endif %}
  </div>

</div>

{% if _cs_mode != 'genera' %}<script src="/user/themes/valentina/js/swe-hd.js"></script>{% endif %}
<script>
// ─── Swiss Ephemeris ──────────────────────────────────────────────────────────
var _csSweMod=null,_csSweCalc=null,_csSweJulday=null;
async function _csInitSwe(){
  if(_csSweMod)return;
  var SweClass=window.SwissEphemeris;if(!SweClass)throw new Error('SwissEphemeris non caricato');
  var inst=new SweClass();await inst.init();
  try{await inst.loadStandardEphemeris();}catch(e){}
  _csSweMod=inst.module;
  try{
    var CDN='https://cdn.jsdelivr.net/gh/aloistr/swisseph/ephe';
    try{_csSweMod.FS.mkdir('/ephe');}catch(e){}
    await Promise.all(['sepl_18.se1','semo_18.se1'].map(async function(f){
      var resp=await fetch(CDN+'/'+f);
      if(resp.ok)_csSweMod.FS.writeFile('/ephe/'+f,new Uint8Array(await resp.arrayBuffer()));
    }));
    _csSweMod.cwrap('swe_set_ephe_path_wrap',null,['string'])('/ephe');
  }catch(e){_csSweMod.cwrap('swe_set_ephe_path_wrap',null,['string'])('');}
  _csSweCalc=function(jd,planet,flags){var ptr=_csSweMod.ccall('swe_calc_ut_wrap','number',['number','number','number'],[jd,planet,flags]);return _csSweMod.getValue(ptr,'double');};
  _csSweJulday=_csSweMod.cwrap('swe_julday_wrap','number',['number','number','number','number','number']);
}

// ─── HD Constants ─────────────────────────────────────────────────────────────
var CS_GATE_WHEEL=[41,19,13,49,30,55,37,63,22,36,25,17,21,51,42,3,27,24,2,23,8,20,16,35,45,12,15,52,39,53,62,56,31,33,7,4,29,59,40,64,47,6,46,18,48,57,32,50,28,44,1,43,14,34,9,5,26,11,10,58,38,54,61,60];
var CS_RAVE_OFFSET=58.0;
var CS_CHANNELS=[[64,47],[61,24],[63,4],[17,62],[43,23],[11,56],[16,48],[20,57],[31,7],[8,1],[33,13],[10,20],[45,21],[35,36],[12,22],[20,34],[10,34],[10,57],[26,44],[51,25],[40,37],[2,14],[5,15],[29,46],[27,50],[34,57],[59,6],[3,60],[9,52],[42,53],[18,58],[28,38],[32,54],[30,41],[39,55],[19,49]];
var CS_GATE_CENTER={};
[64,61,63].forEach(function(g){CS_GATE_CENTER[g]='HEAD';});
[47,24,4,17,43,11].forEach(function(g){CS_GATE_CENTER[g]='AJNA';});
[62,23,56,16,31,8,33,45,35,12,20].forEach(function(g){CS_GATE_CENTER[g]='THROAT';});
[7,13,1,10,25,15,2,46].forEach(function(g){CS_GATE_CENTER[g]='G';});
[21,51,26,40].forEach(function(g){CS_GATE_CENTER[g]='HEART';});
[48,57,44,50,32,28,18].forEach(function(g){CS_GATE_CENTER[g]='SPLEEN';});
[36,22,37,6,30,55,49].forEach(function(g){CS_GATE_CENTER[g]='SOLAR';});
[34,5,14,29,3,42,9,27,59].forEach(function(g){CS_GATE_CENTER[g]='SACRAL';});
[53,60,52,54,58,38,41,39,19].forEach(function(g){CS_GATE_CENTER[g]='ROOT';});
var CS_HD_PLANETS=[{id:0,it:'Sole',en:'Sun'},{id:-2,it:'Terra',en:'Earth'},{id:1,it:'Luna',en:'Moon'},{id:11,it:'Nodo Nord',en:'North Node'},{id:-1,it:'Nodo Sud',en:'South Node'},{id:2,it:'Mercurio',en:'Mercury'},{id:3,it:'Venere',en:'Venus'},{id:4,it:'Marte',en:'Mars'},{id:5,it:'Giove',en:'Jupiter'},{id:6,it:'Saturno',en:'Saturn'},{id:7,it:'Urano',en:'Uranus'},{id:8,it:'Nettuno',en:'Neptune'},{id:9,it:'Plutone',en:'Pluto'}];
var CS_PHS={1:{name:'Appetito',a:'Consecutivo',b:'Alternato'},2:{name:'Gusto',a:'Aperto',b:'Chiuso'},3:{name:'Sete',a:'Caldo',b:'Freddo'},4:{name:'Tatto',a:'Calmo',b:'Nervoso'},5:{name:'Suono',a:'Alto',b:'Basso'},6:{name:'Luce',a:'Diretta',b:'Indiretta'}};
var CS_ENV={1:{name:'Grotte',a:'Selettivo',b:'Aperto'},2:{name:'Mercati',a:'Interno',b:'Esterno'},3:{name:'Cucine',a:'Umido',b:'Secco'},4:{name:'Montagne',a:'Attivo',b:'Passivo'},5:{name:'Valli',a:'Stretto',b:'Largo'},6:{name:'Rive',a:'Naturale',b:'Artificiale'}};
function csPhsLabel(c,t){var p=CS_PHS[c];if(!p)return'?';return p.name+' ('+(t<=3?p.a:p.b)+')';}
function csEnvLabel(c,t){var e=CS_ENV[c];if(!e)return'?';return e.name+' ('+(t<=3?e.a:e.b)+')';}

function csDeg2GLC(deg){
  var angle=((deg+CS_RAVE_OFFSET)%360+360)%360,pct=angle/360;
  var gate=CS_GATE_WHEEL[Math.min(Math.floor(pct*64),63)];
  var line=Math.floor((pct*64*6)%6)+1,color=Math.floor((pct*64*6*6)%6)+1,tone=Math.floor((pct*64*6*6*6)%6)+1;
  return{gate:gate,line:line,color:color,tone:tone};
}
function csDateToJD(y,m,d,h,min,tzOff){return _csSweJulday(y,m,d,h+min/60-tzOff,1);}
async function csCalcPlanets(jd){
  await _csInitSwe();
  var results=[],nnLon=null,sunLon=null,SWIEPH=2;
  for(var i=0;i<CS_HD_PLANETS.length;i++){
    var p=CS_HD_PLANETS[i],lon;
    if(p.id===-1){lon=nnLon!==null?(nnLon+180)%360:0;}
    else if(p.id===-2){lon=sunLon!==null?(sunLon+180)%360:0;}
    else{lon=_csSweCalc(jd,p.id,SWIEPH);if(p.id===0)sunLon=lon;if(p.id===11)nnLon=lon;}
    var glc=csDeg2GLC(lon);
    results.push({planet_it:p.it,planet_en:p.en,gate:glc.gate,line:glc.line,color:glc.color,tone:glc.tone});
  }
  return results;
}
function csGetDefChannels(ag){return CS_CHANNELS.filter(function(c){return ag.has(c[0])&&ag.has(c[1]);});}
function csGetDefCenters(ag){
  var def=new Set();
  CS_CHANNELS.forEach(function(c){if(ag.has(c[0])&&ag.has(c[1])){if(CS_GATE_CENTER[c[0]])def.add(CS_GATE_CENTER[c[0]]);if(CS_GATE_CENTER[c[1]])def.add(CS_GATE_CENTER[c[1]]);}});
  return def;
}
function csCalcType(dc,dch){
  var motors=new Set(['SACRAL','HEART','SOLAR','ROOT']);
  if(!dc.size)return'Reflector';
  function mtt(start,vis){
    if(!vis)vis=new Set();if(vis.has(start))return false;vis.add(start);if(start==='THROAT')return true;
    var adj=new Set();
