      const toArrow=dir=>dir==='left'?'\u25C4':'\u25BA';
      const hc=426,ay=30,ag=35,ao=80;
      const mkA=(x,y,t,col)=>{const el=document.createElementNS(ns,'text');el.setAttribute('x',String(x));el.setAttribute('y',String(y));el.setAttribute('text-anchor','middle');el.setAttribute('font-size','28');el.setAttribute('fill',col);el.setAttribute('font-weight','bold');el.textContent=t;return el;};
      const grp=document.createElementNS(ns,'g');grp.setAttribute('id','hd-variables');
      grp.appendChild(mkA(hc-ao,ay,toArrow(variables.digestion),'#c0392b'));
      grp.appendChild(mkA(hc-ao,ay+ag,toArrow(variables.environment),'#c0392b'));
      grp.appendChild(mkA(hc+ao,ay,toArrow(variables.perspective),'#1a1a2e'));
      grp.appendChild(mkA(hc+ao,ay+ag,toArrow(variables.awareness),'#1a1a2e'));
      svgEl.appendChild(grp);
    }
    wrap.innerHTML='';wrap.appendChild(svgEl);
  }catch(e){
    const bg=blackGates||new Set(),rg=redGates||new Set();
    wrap.innerHTML=buildBodygraph(bg,rg,definedChannels,definedCenterSet);
  }
}

// ─── Planet table ─────────────────────────────────────────────────────────────
const PLANET_ORDER=['Sun','Earth','Moon','North Node','South Node','Mercury','Venus','Mars','Jupiter','Saturn','Uranus','Neptune','Pluto'];
function renderPlaneti(personality,design){
  const dMap={},pMap={};design.forEach(p=>{dMap[p.planet_en]=p;});personality.forEach(p=>{pMap[p.planet_en]=p;});
  let rows='';
  for(const key of PLANET_ORDER){const p=pMap[key];if(!p)continue;const d=dMap[p.planet_en]||{};rows+=`<tr><td><span class="planet-bg5">${escHtml(PLANET_BG5[p.planet_en]||p.planet_it)}</span><span class="planet-name">(${escHtml(p.planet_it)})</span></td><td class="gate-black">${p.gate}.${p.line}</td><td class="gate-red">${d.gate||'–'}.${d.line||''}</td></tr>`;}
  document.getElementById('carta-planets').innerHTML=`<h3>Attivazioni Planetarie</h3><table class="planets-table"><thead><tr><th>Funzione BG5</th><th style="color:#b4d0f5">Personalità</th><th style="color:#f5a0a0">Design</th></tr></thead><tbody>${rows}</tbody></table>`;
}

// ─── Main render ──────────────────────────────────────────────────────────────
async function csRenderRisultati(data,nome){
  const d=normalizzaRisposta(data);
  if(!d){csError('Formato risposta non riconosciuto.');return;}
  const nh=document.getElementById('carta-name-header');
  if(nome){nh.innerHTML=`<h2>${escHtml(nome)}</h2><p>Carta Human Design</p>`;nh.style.display='block';}else{nh.style.display='none';}
  const coreItems=[{label:'Tipo di Carriera',value:d.type},{label:'Profilo',value:d.profile},{label:'Autorità',value:d.authority},{label:'Definizione',value:d.definition}];
  if(d.personality&&d.personality.length>0){const pS=d.personality.find(p=>p.planet_en==='Sun');if(pS)coreItems.push({label:'Tema di Vita',value:getIncarnationCross(pS.gate,d.profile)});}
  if(d.variables){const dS=d.variables.digestion==='left'?'L':'R',dN=d.variables.environment==='left'?'L':'R',pS=d.variables.perspective==='left'?'L':'R',pN=d.variables.awareness==='left'?'L':'R';coreItems.push({label:'Variabile',value:`P${pS}${pN} D${dS}${dN}`});}
  if(d.dietary_regime)coreItems.push({label:'Regime Alimentare',value:d.dietary_regime});
  if(d.environment)coreItems.push({label:'Ambiente',value:d.environment});
  document.getElementById('carta-core').innerHTML=coreItems.map(i=>`<div class="core-card"><div class="core-card-label">${i.label}</div><div class="core-card-value">${escHtml(i.value)}</div></div>`).join('');
  const blackGates=new Set(),redGates=new Set();
  for(const[g,c] of Object.entries(d.gate_colors)){const gn=parseInt(g);if(c==='P'||c==='PD')blackGates.add(gn);if(c==='D'||c==='PD')redGates.add(gn);}
  const definedCenterSet=new Set(d.defined_centers);
  const definedChannels=d.defined_channels.map(([g1,g2])=>{const ch=CHANNELS.find(([c1,c2])=>(c1===g1&&c2===g2)||(c1===g2&&c2===g1));return ch||[g1,g2,GATE_TO_CENTER[g1]||'',GATE_TO_CENTER[g2]||''];});
  await loadAndRenderBodygraph(d.gate_colors,definedChannels,definedCenterSet,blackGates,redGates,d.variables);
  renderPlaneti(d.personality,d.design);
  document.getElementById('carta-results').style.display='block';
  document.getElementById('carta-results').scrollIntoView({behavior:'smooth',block:'start'});
}

// ─── Form submit ──────────────────────────────────────────────────────────────
async function csCalcola(){
  const dateVal=document.getElementById('cf-date').value;
  const timeVal=document.getElementById('cf-time').value;
  const dateParts=dateVal?dateVal.split('-'):[];
  const timeParts=timeVal?timeVal.split(':'):[];
  const y=dateParts[0]?parseInt(dateParts[0]):NaN;
  const m=dateParts[1]?parseInt(dateParts[1]):NaN;
  const d=dateParts[2]?parseInt(dateParts[2]):NaN;
  const h=timeParts[0]!==undefined?parseInt(timeParts[0]):NaN;
  const min=timeParts[1]!==undefined?parseInt(timeParts[1]):NaN;
  const tz=document.getElementById('cf-tz').value,nome=document.getElementById('cf-nome').value.trim(),city=document.getElementById('cf-city').value.trim();
  if(!city){csError('Inserisci il luogo di nascita per continuare.');document.getElementById('cf-city').focus();return;}
  if(!d||!m||!y||isNaN(h)||isNaN(min)){csError('Compila data, ora e luogo di nascita.');return;}
  if(y<1900||y>2050){csError('Anno tra il 1900 e il 2050.');return;}
  document.getElementById('carta-error').style.display='none';
  document.getElementById('carta-results').style.display='none';
  document.getElementById('carta-loading').style.display='block';
  document.getElementById('carta-calcola-btn').disabled=true;
  try{
    const localDt=new Date(y,m-1,d,h,min);
    const tzDate=new Date(localDt.toLocaleString('en-US',{timeZone:tz}));
    const utcDate=new Date(localDt.toLocaleString('en-US',{timeZone:'UTC'}));
    const tzOffset=(tzDate-utcDate)/3600000;
    const data=await calculateHDChart(y,m,d,h,min,tzOffset);
    if(data.environment_name){data.environment=data.environment_name;delete data.environment_name;}
    await csRenderRisultati(data,nome);
  }catch(e){csError(e.message||'Si è verificato un errore. Riprova.');}
  finally{document.getElementById('carta-loading').style.display='none';document.getElementById('carta-calcola-btn').disabled=false;}
}
// Enter key support
document.getElementById('carta-calculator')?.addEventListener('keydown',e=>{if(e.key==='Enter')csCalcola();});
})();
</script>
