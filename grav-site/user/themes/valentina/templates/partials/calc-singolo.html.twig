{# Partial: calcolatore carta Human Design singola (incluso nelle pagine città) #}
<section id="carta-calculator" style="padding: 3.5rem 0 4rem; background: linear-gradient(160deg, #B68397 0%, #8A6FA8 45%, #3A5A8A 80%, #1E3A5F 100%);">
<style>
#carta-calculator { font-family: 'Outfit', Arial, sans-serif; }
#carta-calculator .csingle-intro { text-align: center; margin-bottom: 2rem; }
#carta-calculator .csingle-intro h2 { font-size: clamp(1.35rem,3.5vw,1.85rem); color: #fff; margin: 0 0 0.5rem; font-family: 'Playfair Display', serif; }
#carta-calculator .csingle-intro p { color: rgba(255,255,255,0.8); font-size: 0.95rem; margin: 0; }
#carta-calculator .csingle-badge { display: inline-block; background: rgba(255,255,255,0.15); color: rgba(255,255,255,0.9); font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; padding: 0.25rem 0.75rem; border-radius: 20px; margin-bottom: 0.85rem; }

/* Form card */
#carta-calculator .carta-form-card { background: #fff; border-radius: 20px; padding: 1.75rem 1.75rem 1.5rem; box-shadow: 0 8px 32px rgba(0,0,0,0.18); }
#carta-calculator .cf-row { display: grid; grid-template-columns: 1fr; gap: 0.75rem; margin-bottom: 0.75rem; }
#carta-calculator .cf-row.cols-2 { grid-template-columns: 1fr 1fr; }
#carta-calculator .cf-row-datetime { display: flex; gap: 0.75rem; align-items: flex-start; flex-wrap: wrap; margin-bottom: 0.75rem; }
#carta-calculator .cf-field-date { flex: 1.6; min-width: 160px; }
#carta-calculator .cf-field-time { flex: 1; min-width: 110px; }
#carta-calculator .cf-field label { display: block; font-size: 0.78rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #6b4fa8; margin-bottom: 0.3rem; }
#carta-calculator .cf-field input, #carta-calculator .cf-field select { width: 100%; padding: 0.7rem 0.9rem; border-radius: 10px; border: 1.5px solid rgba(107,79,168,0.3); background: #f7f5fc; color: #3a2560; font-family: inherit; font-size: 0.95rem; font-weight: 500; box-sizing: border-box; }
#carta-calculator .cf-field input:focus, #carta-calculator .cf-field select:focus { outline: none; border-color: #6b4fa8; background: #f0eaf8; }
#carta-calculator .cf-hint { font-size: 0.72rem; color: #a093c0; margin-top: 0.25rem; }
#carta-calculator .cf-tz-detected { font-size: 0.72rem; color: #52a363; margin-top: 0.2rem; display: none; }
#carta-calculator .cf-autocomplete-wrap { position: relative; }
#carta-calculator .cf-autocomplete-list { position: absolute; top: 100%; left: 0; right: 0; background: #fff; border: 1px solid rgba(107,79,168,0.2); border-top: none; border-radius: 0 0 10px 10px; list-style: none; margin: 0; padding: 0; z-index: 100; display: none; box-shadow: 0 8px 24px rgba(0,0,0,0.1); }
#carta-calculator .cf-autocomplete-list li { padding: 0.65rem 0.9rem; cursor: pointer; font-size: 0.9rem; color: #3a2560; border-bottom: 1px solid #f0ece8; }
#carta-calculator .cf-autocomplete-list li:last-child { border-bottom: none; }
#carta-calculator .cf-autocomplete-list li:hover { background: #f5f0ff; }
#carta-calculator .cf-dt-wrap { position: relative; }
#carta-calculator .cf-dt-ph { position: absolute; inset: 0; padding: 0.7rem 0.9rem; color: #a093c0; font-size: 0.95rem; pointer-events: none; display: flex; align-items: center; border-radius: 10px; background: #f7f5fc; }
#carta-calculator .cf-dt-ph.cf-dt-ph--hidden { display: none; }
#carta-calculator input[type="date"], #carta-calculator input[type="time"] { -webkit-appearance: none; appearance: none; display: block; width: 100%; min-width: 0; min-height: 2.9rem; line-height: 1.4; padding: 0.7rem 0.9rem; border-radius: 10px; border: 1.5px solid rgba(107,79,168,0.35); background: #f7f5fc; color: #3a2560; font-family: inherit; font-size: 0.95rem; font-weight: 500; cursor: pointer; box-sizing: border-box; position: relative; z-index: 1; }
#carta-calculator input[type="date"]:focus, #carta-calculator input[type="time"]:focus { outline: none; border-color: #6b4fa8; background: #f0eaf8; }
#carta-calculator .carta-btn { display: block; width: 100%; padding: 1rem 1.5rem; background: linear-gradient(135deg, #6b4fa8 0%, #8a63c8 100%); color: #fff; border: none; border-radius: 50px; font-family: inherit; font-size: 1.05rem; font-weight: 700; cursor: pointer; margin-top: 1rem; transition: opacity 0.2s, transform 0.1s; }
#carta-calculator .carta-btn:hover:not(:disabled) { opacity: 0.9; }
#carta-calculator .carta-btn:active:not(:disabled) { transform: scale(0.99); }
#carta-calculator .carta-btn:disabled { opacity: 0.6; cursor: not-allowed; }

/* Loading */
#carta-calculator .carta-loading { display: none; text-align: center; padding: 2rem; }
#carta-calculator .carta-loading-dots { display: flex; justify-content: center; gap: 6px; }
#carta-calculator .carta-loading-dots span { width: 10px; height: 10px; border-radius: 50%; background: rgba(255,255,255,0.7); animation: csdots 1.2s infinite ease-in-out; }
#carta-calculator .carta-loading-dots span:nth-child(2) { animation-delay: 0.2s; }
#carta-calculator .carta-loading-dots span:nth-child(3) { animation-delay: 0.4s; }
@keyframes csdots { 0%,80%,100%{transform:scale(0);opacity:0.5} 40%{transform:scale(1);opacity:1} }
#carta-calculator .carta-error { display: none; background: rgba(255,80,80,0.18); border: 1px solid rgba(255,80,80,0.35); color: #fff; border-radius: 12px; padding: 0.85rem 1.1rem; font-size: 0.9rem; margin-top: 1rem; }

/* Results */
#carta-calculator .carta-results { display: none; margin-top: 2rem; }
#carta-calculator .carta-name-header { display: none; text-align: center; margin-bottom: 1.5rem; }
#carta-calculator .carta-name-header h2 { font-size: 1.4rem; color: #fff; margin: 0 0 0.25rem; }
#carta-calculator .carta-name-header p { color: rgba(255,255,255,0.65); font-size: 0.88rem; margin: 0; }
#carta-calculator .carta-core { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.75rem; margin-bottom: 1.5rem; }
@media (min-width: 600px) { #carta-calculator .carta-core { grid-template-columns: repeat(3, 1fr); } }
@media (min-width: 900px) { #carta-calculator .carta-core { grid-template-columns: repeat(4, 1fr); } }
#carta-calculator .core-card { background: rgba(255,255,255,0.12); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); border: 1px solid rgba(255,255,255,0.2); border-radius: 14px; padding: 0.9rem 1rem; }
#carta-calculator .core-card-label { font-size: 0.62rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; color: rgba(255,255,255,0.55); margin-bottom: 0.3rem; }
#carta-calculator .core-card-value { font-size: 0.9rem; font-weight: 700; color: #fff; line-height: 1.3; }
#carta-calculator .carta-desktop-layout { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
@media (min-width: 768px) { #carta-calculator .carta-desktop-layout { grid-template-columns: auto 1fr; align-items: start; } }
#carta-calculator .carta-bodygraph-wrap { display: flex; align-items: center; justify-content: center; min-height: 280px; }
#carta-calculator .carta-bodygraph-wrap svg { max-width: 320px; width: 100%; height: auto; display: block; }
#carta-calculator .carta-planets h3 { color: #fff; font-size: 1rem; margin: 0 0 0.75rem; }
#carta-calculator .planets-table { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
#carta-calculator .planets-table th { background: rgba(255,255,255,0.12); color: rgba(255,255,255,0.7); font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.05em; padding: 0.45rem 0.6rem; text-align: left; border-bottom: 1px solid rgba(255,255,255,0.15); }
#carta-calculator .planets-table td { padding: 0.35rem 0.6rem; border-bottom: 1px solid rgba(255,255,255,0.08); color: rgba(255,255,255,0.85); }
#carta-calculator .planet-bg5 { display: block; font-size: 0.8rem; color: #fff; font-weight: 600; }
#carta-calculator .planet-name { display: block; font-size: 0.68rem; color: rgba(255,255,255,0.5); }
#carta-calculator .gate-black { color: #b4d0f5; font-weight: 700; }
#carta-calculator .gate-red { color: #f5a0a0; font-weight: 700; }

/* CTA */
#carta-calculator .csingle-cta { background: rgba(255,255,255,0.12); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.22); border-radius: 20px; padding: 1.75rem 2rem; text-align: center; margin-top: 2rem; }
#carta-calculator .csingle-cta p { color: rgba(255,255,255,0.82); font-size: 0.92rem; margin: 0 0 1.25rem; line-height: 1.6; max-width: 420px; margin-inline: auto; margin-bottom: 1.25rem; }
#carta-calculator .csingle-cta a { display: inline-block; padding: 0.9rem 2.25rem; background: #fff; color: #6b4fa8; border-radius: 50px; font-weight: 700; font-size: 1rem; text-decoration: none; transition: opacity 0.2s; }
#carta-calculator .csingle-cta a:hover { opacity: 0.9; }

@media (max-width: 640px) {
  #carta-calculator .carta-form-card { padding: 1.25rem 1rem 1.25rem; }
  #carta-calculator .cf-row-datetime { flex-direction: column; }
  #carta-calculator .cf-field-date, #carta-calculator .cf-field-time { flex: none; width: 100%; min-width: 0; }
  #carta-calculator .carta-core { grid-template-columns: 1fr 1fr; }
}
</style>

<div class="container" style="max-width: 720px; padding: 0 1.25rem;">
  <div class="csingle-intro">
    <span class="csingle-badge">Gratuito — nessuna registrazione</span>
    <h2>Calcola la tua Carta Human Design</h2>
    <p>Scopri il tuo Tipo Energetico, Profilo e Autorità Decisionale in pochi secondi.</p>
  </div>

  <!-- Form -->
  <div class="carta-form-card">
    <div class="cf-row cols-1">
      <div class="cf-field">
        <label>Nome (opzionale)</label>
        <input type="text" id="cf-nome" placeholder="Il tuo nome">
      </div>
    </div>
    <div class="cf-row-datetime">
      <div class="cf-field cf-field-date">
        <label>📅 Data di nascita</label>
        <div class="cf-dt-wrap">
          <input type="date" id="cf-date" min="1900-01-01" max="2050-12-31">
          <span class="cf-dt-ph" id="cf-date-ph" aria-hidden="true">gg / mm / aaaa</span>
        </div>
      </div>
      <div class="cf-field cf-field-time">
        <label>🕐 Ora di nascita</label>
        <div class="cf-dt-wrap">
          <input type="time" id="cf-time">
          <span class="cf-dt-ph" id="cf-time-ph" aria-hidden="true">ora : min</span>
        </div>
      </div>
    </div>
    <div class="cf-row cols-1">
      <div class="cf-field">
        <label>📍 Luogo di nascita *</label>
        <div class="cf-autocomplete-wrap">
          <input type="text" id="cf-city" placeholder="Es: Milano, Roma, Napoli…" autocomplete="off" required>
          <ul class="cf-autocomplete-list" id="cf-city-list"></ul>
        </div>
        <div class="cf-hint">Inserisci la città — il fuso orario viene rilevato automaticamente</div>
      </div>
    </div>
    <div class="cf-row cols-1">
      <div class="cf-field">
        <label>Fuso orario</label>
        <select id="cf-tz">
          <option value="Europe/Rome" selected>Italia (Europe/Rome)</option>
          <option value="Europe/London">Regno Unito (Europe/London)</option>
          <option value="Europe/Paris">Francia / Belgio (Europe/Paris)</option>
          <option value="Europe/Berlin">Germania / Austria (Europe/Berlin)</option>
          <option value="Europe/Madrid">Spagna (Europe/Madrid)</option>
          <option value="Europe/Zurich">Svizzera (Europe/Zurich)</option>
          <option value="America/New_York">USA Est (America/New_York)</option>
          <option value="America/Chicago">USA Centrale (America/Chicago)</option>
          <option value="America/Los_Angeles">USA Ovest (America/Los_Angeles)</option>
          <option value="America/Argentina/Buenos_Aires">Argentina</option>
          <option value="America/Sao_Paulo">Brasile</option>
          <option value="Asia/Dubai">Emirati Arabi</option>
          <option value="Asia/Kolkata">India</option>
          <option value="Asia/Tokyo">Giappone</option>
          <option value="Australia/Sydney">Australia</option>
        </select>
        <div class="cf-hint">Selezionato automaticamente dalla città</div>
        <div class="cf-tz-detected" id="cf-tz-detected"></div>
      </div>
    </div>
    <button class="carta-btn" id="carta-calcola-btn" onclick="csCalcola()">Calcola la mia Carta</button>
  </div>

  <div class="carta-loading" id="carta-loading">
    <div class="carta-loading-dots"><span></span><span></span><span></span></div>
    <p style="margin-top:0.75rem;color:rgba(255,255,255,0.7);font-size:0.9rem;">Calcolo in corso…</p>
  </div>
  <div class="carta-error" id="carta-error"></div>

  <!-- Results -->
  <div class="carta-results" id="carta-results">
    <div class="carta-name-header" id="carta-name-header"></div>
    <div class="carta-core" id="carta-core"></div>
    <div class="carta-desktop-layout">
      <div class="carta-col-left">
        <div class="carta-bodygraph-wrap" id="carta-bodygraph-wrap"></div>
      </div>
      <div class="carta-col-right">
        <div class="carta-planets" id="carta-planets"></div>
      </div>
    </div>
    <div class="csingle-cta">
      <p>La tua carta mostra la struttura energetica di base. Una lettura con Valentina trasforma questi dati in indicazioni concrete per il lavoro, le relazioni e le decisioni quotidiane.</p>
      <a href="{{ grav.base_url }}/contatti">Prenota una Prima Lettura →</a>
    </div>
  </div>
</div>

<script src="/user/themes/valentina/js/swe-hd.js"></script>
<script>
(function(){
// ─── Swiss Ephemeris ──────────────────────────────────────────────────────────
let _sweMod=null,_sweCalc=null,_sweJulday=null;
async function initSwe(){
  if(_sweMod)return;
  const SweClass=window.SwissEphemeris;if(!SweClass)throw new Error('SwissEphemeris non caricato');
  const inst=new SweClass();await inst.init();
  try{await inst.loadStandardEphemeris();}catch(e){}
  _sweMod=inst.module;
  try{
    const CDN='https://cdn.jsdelivr.net/gh/aloistr/swisseph/ephe';
    try{_sweMod.FS.mkdir('/ephe');}catch(e){}
    await Promise.all(['sepl_18.se1','semo_18.se1'].map(async f=>{
      const resp=await fetch(`${CDN}/${f}`);
      if(resp.ok)_sweMod.FS.writeFile(`/ephe/${f}`,new Uint8Array(await resp.arrayBuffer()));
    }));
    _sweMod.cwrap('swe_set_ephe_path_wrap',null,['string'])('/ephe');
  }catch(e){_sweMod.cwrap('swe_set_ephe_path_wrap',null,['string'])('');}
  _sweCalc=(jd,planet,flags)=>{const ptr=_sweMod.ccall('swe_calc_ut_wrap','number',['number','number','number'],[jd,planet,flags]);return _sweMod.getValue(ptr,'double');};
  _sweJulday=_sweMod.cwrap('swe_julday_wrap','number',['number','number','number','number','number']);
}

// ─── HD Constants ─────────────────────────────────────────────────────────────
const HD_GATE_WHEEL=[41,19,13,49,30,55,37,63,22,36,25,17,21,51,42,3,27,24,2,23,8,20,16,35,45,12,15,52,39,53,62,56,31,33,7,4,29,59,40,64,47,6,46,18,48,57,32,50,28,44,1,43,14,34,9,5,26,11,10,58,38,54,61,60];
const HD_RAVE_OFFSET=58.0;
const HD_CHANNELS=[[64,47],[61,24],[63,4],[17,62],[43,23],[11,56],[16,48],[20,57],[31,7],[8,1],[33,13],[10,20],[45,21],[35,36],[12,22],[20,34],[10,34],[10,57],[26,44],[51,25],[40,37],[2,14],[5,15],[29,46],[27,50],[34,57],[59,6],[3,60],[9,52],[42,53],[18,58],[28,38],[32,54],[30,41],[39,55],[19,49]];
const HD_GATE_CENTER={};
[64,61,63].forEach(g=>HD_GATE_CENTER[g]='HEAD');
[47,24,4,17,43,11].forEach(g=>HD_GATE_CENTER[g]='AJNA');
[62,23,56,16,31,8,33,45,35,12,20].forEach(g=>HD_GATE_CENTER[g]='THROAT');
[7,13,1,10,25,15,2,46].forEach(g=>HD_GATE_CENTER[g]='G');
[21,51,26,40].forEach(g=>HD_GATE_CENTER[g]='HEART');
[48,57,44,50,32,28,18].forEach(g=>HD_GATE_CENTER[g]='SPLEEN');
[36,22,37,6,30,55,49].forEach(g=>HD_GATE_CENTER[g]='SOLAR');
[34,5,14,29,3,42,9,27,59].forEach(g=>HD_GATE_CENTER[g]='SACRAL');
[53,60,52,54,58,38,41,39,19].forEach(g=>HD_GATE_CENTER[g]='ROOT');
const HD_PLANETS=[{id:0,it:'Sole',en:'Sun'},{id:-2,it:'Terra',en:'Earth'},{id:1,it:'Luna',en:'Moon'},{id:11,it:'Nodo Nord',en:'North Node'},{id:-1,it:'Nodo Sud',en:'South Node'},{id:2,it:'Mercurio',en:'Mercury'},{id:3,it:'Venere',en:'Venus'},{id:4,it:'Marte',en:'Mars'},{id:5,it:'Giove',en:'Jupiter'},{id:6,it:'Saturno',en:'Saturn'},{id:7,it:'Urano',en:'Uranus'},{id:8,it:'Nettuno',en:'Neptune'},{id:9,it:'Plutone',en:'Pluto'}];
const HD_PHS={1:{name:'Appetito',a:'Consecutivo',b:'Alternato'},2:{name:'Gusto',a:'Aperto',b:'Chiuso'},3:{name:'Sete',a:'Caldo',b:'Freddo'},4:{name:'Tatto',a:'Calmo',b:'Nervoso'},5:{name:'Suono',a:'Alto',b:'Basso'},6:{name:'Luce',a:'Diretta',b:'Indiretta'}};
const HD_ENV={1:{name:'Grotte',a:'Selettivo',b:'Aperto'},2:{name:'Mercati',a:'Interno',b:'Esterno'},3:{name:'Cucine',a:'Umido',b:'Secco'},4:{name:'Montagne',a:'Attivo',b:'Passivo'},5:{name:'Valli',a:'Stretto',b:'Largo'},6:{name:'Rive',a:'Naturale',b:'Artificiale'}};
function phsLabel(c,t){const p=HD_PHS[c];if(!p)return'?';return`${p.name} (${t<=3?p.a:p.b})`;}
function envLabel(c,t){const e=HD_ENV[c];if(!e)return'?';return`${e.name} (${t<=3?e.a:e.b})`;}

function hdDegreesToGateLineColor(deg){
  const angle=((deg+HD_RAVE_OFFSET)%360+360)%360,pct=angle/360;
  const gate=HD_GATE_WHEEL[Math.min(Math.floor(pct*64),63)];
  const line=Math.floor((pct*64*6)%6)+1,color=Math.floor((pct*64*6*6)%6)+1,tone=Math.floor((pct*64*6*6*6)%6)+1;
  return{gate,line,color,tone};
}
function dateToJD(y,m,d,h,min,tzOffset){return _sweJulday(y,m,d,h+min/60-tzOffset,1);}
async function calcPlanets(jd){
  await initSwe();
  const results=[];let nnLon=null,sunLon=null;const SWIEPH=2;
  for(const p of HD_PLANETS){
    let lon;
    if(p.id===-1){lon=nnLon!==null?(nnLon+180)%360:0;}
    else if(p.id===-2){lon=sunLon!==null?(sunLon+180)%360:0;}
    else{lon=_sweCalc(jd,p.id,SWIEPH);if(p.id===0)sunLon=lon;if(p.id===11)nnLon=lon;}
    const glc=hdDegreesToGateLineColor(lon);
    results.push({planet_it:p.it,planet_en:p.en,gate:glc.gate,line:glc.line,color:glc.color,tone:glc.tone,degrees:Math.round(lon*10000)/10000});
  }
  return results;
}
function hdGetDefinedChannels(activeGates){return HD_CHANNELS.filter(([g1,g2])=>activeGates.has(g1)&&activeGates.has(g2));}
function hdGetDefinedCenters(activeGates){
  const def=new Set();
  for(const[g1,g2] of HD_CHANNELS){if(activeGates.has(g1)&&activeGates.has(g2)){if(HD_GATE_CENTER[g1])def.add(HD_GATE_CENTER[g1]);if(HD_GATE_CENTER[g2])def.add(HD_GATE_CENTER[g2]);}}
  return def;
}
function hdCalcType(defCenters,defChannels){
  const motors=new Set(['SACRAL','HEART','SOLAR','ROOT']);
  if(!defCenters.size)return'Reflector';
  function motorToThroat(start,visited=new Set()){
    if(visited.has(start))return false;visited.add(start);if(start==='THROAT')return true;
    const adj=new Set();
    for(const[g1,g2] of defChannels){const c1=HD_GATE_CENTER[g1]||'',c2=HD_GATE_CENTER[g2]||'';if(c1===start)adj.add(c2);else if(c2===start)adj.add(c1);}
    return[...adj].some(c=>motorToThroat(c,new Set(visited)));
  }
  const hasSacral=defCenters.has('SACRAL');
  const anyMotorToThroat=[...motors].filter(m=>defCenters.has(m)).some(m=>motorToThroat(m));
  if(hasSacral)return anyMotorToThroat?'Manifesting Generator':'Generator';
  return anyMotorToThroat?'Manifestor':'Projector';
}
function hdCalcProfile(pers,des){const sP=pers.find(p=>p.planet_en==='Sun'),sD=des.find(p=>p.planet_en==='Sun');if(!sP||!sD)return'?/?';return`${sP.line}/${sD.line}`;}
function hdCalcAuthority(defCenters){
  const order=[['SOLAR','Emotional'],['SACRAL','Sacral'],['SPLEEN','Splenic'],['HEART','Ego Manifested'],['G','Self Projected']];
  for(const[c,auth] of order){if(defCenters.has(c))return auth;}
  return defCenters.size?'Mental Projector':'Lunar';
}
function hdCalcDefinition(defCenters,defChannels){
  if(!defCenters.size)return'No Definition';
  const adj={};for(const c of defCenters)adj[c]=new Set();
  for(const[g1,g2] of defChannels){const c1=HD_GATE_CENTER[g1]||'',c2=HD_GATE_CENTER[g2]||'';if(adj[c1]&&adj[c2]){adj[c1].add(c2);adj[c2].add(c1);}}
  const visited=new Set();let components=0;
