  document.getElementById('cs-core').innerHTML=items.map(function(i){return'<div class="core-card"><div class="core-card-label">'+i.label+'</div><div class="core-card-value">'+i.value+'</div></div>';}).join('');

  var bG=new Set(),rG=new Set();
  Object.keys(d.gate_colors).forEach(function(g){var gn=parseInt(g),c=d.gate_colors[g];if(c==='P'||c==='PD')bG.add(gn);if(c==='D'||c==='PD')rG.add(gn);});
  var dcs=new Set(d.defined_centers);
  var dch=d.defined_channels.map(function(c){var g1=c[0],g2=c[1];return[g1,g2,CS_GATE_CENTER[g1]||'',CS_GATE_CENTER[g2]||''];});

  await csRenderBodygraph(d.gate_colors,dch,dcs,bG,rG,d.variables);
  csRenderPlanets(d.personality,d.design);

  document.getElementById('cs-results').style.display='block';
  setTimeout(function(){document.getElementById('cs-results').scrollIntoView({behavior:'smooth',block:'start'});},60);
  if(typeof window._csAfterRender === 'function') window._csAfterRender(d, nome);
}

// ─── City autocomplete ────────────────────────────────────────────────────────
(function(){
  var ci=document.getElementById('cs-city'),cl=document.getElementById('cs-city-list'),tz=document.getElementById('cs-tz'),tzd=document.getElementById('cs-tz-detected');
  if(!ci||!cl||!tz)return;
  var deb=null;
  ci.addEventListener('input',function(){clearTimeout(deb);var q=ci.value.trim();if(q.length<3){cl.style.display='none';return;}deb=setTimeout(function(){fetchCS(q);},350);});
  ci.addEventListener('blur',function(){setTimeout(function(){cl.style.display='none';},200);});
  function fetchCS(q){fetch('https://nominatim.openstreetmap.org/search?q='+encodeURIComponent(q)+'&format=json&limit=6&addressdetails=1&featuretype=city',{headers:{'Accept-Language':'it'}}).then(function(r){return r.json();}).then(function(data){showCS(data);}).catch(function(){cl.style.display='none';});}
  function showCS(places){cl.innerHTML='';if(!places.length){cl.style.display='none';return;}places.forEach(function(p){var li=document.createElement('li');var parts=[p.display_name.split(',')[0].trim()];if(p.address){if(p.address.state)parts.push(p.address.state);if(p.address.country)parts.push(p.address.country);}li.textContent=parts.join(', ');li.addEventListener('click',function(){selCS(p,li.textContent);});cl.appendChild(li);});cl.style.display='block';}
  function selCS(place,label){ci.value=label;cl.style.display='none';var lat=parseFloat(place.lat),lng=parseFloat(place.lon);fetch('https://timeapi.io/api/timezone/coordinate?latitude='+lat+'&longitude='+lng).then(function(r){return r.json();}).then(function(data){var tzv=data.timeZone;if(tzv){var found=false;for(var i=0;i<tz.options.length;i++){if(tz.options[i].value===tzv){tz.value=tzv;found=true;break;}}if(!found){var opt=document.createElement('option');opt.value=tzv;opt.textContent=tzv;tz.appendChild(opt);tz.value=tzv;}if(tzd){tzd.textContent='✓ Fuso orario: '+tzv;tzd.style.display='block';}}}).catch(function(){});}
})();

// ─── Date/time placeholder ────────────────────────────────────────────────────
['cs-date','cs-time'].forEach(function(id){
  var inp=document.getElementById(id),ph=document.getElementById(id+'-ph');
  if(!inp||!ph)return;
  function upd(){ph.classList.toggle('cf-dt-ph--hidden',!!inp.value);}
  inp.addEventListener('focus',function(){ph.classList.add('cf-dt-ph--hidden');});
  inp.addEventListener('blur',upd);inp.addEventListener('change',upd);upd();
});

// ─── Calcola (funzione globale) ───────────────────────────────────────────────
window.csCalcola = async function(){
  var dateVal=document.getElementById('cs-date').value;
  var timeVal=document.getElementById('cs-time').value;
  var dp=dateVal?dateVal.split('-'):[];
  var tp=timeVal?timeVal.split(':'):[];
  var y=dp[0]?parseInt(dp[0]):NaN,m=dp[1]?parseInt(dp[1]):NaN,d=dp[2]?parseInt(dp[2]):NaN;
  var h=tp[0]!==undefined?parseInt(tp[0]):NaN,min=tp[1]!==undefined?parseInt(tp[1]):NaN;
  var tz=document.getElementById('cs-tz').value;
  var nome=document.getElementById('cs-nome').value.trim();
  var city=document.getElementById('cs-city').value.trim();
  var errEl=document.getElementById('cs-error');
  function showErr(msg){document.getElementById('cs-loading').style.display='none';document.getElementById('cs-calcola-btn').disabled=false;errEl.textContent=msg;errEl.style.display='block';}
  if(!city){showErr('Inserisci il luogo di nascita per continuare.');document.getElementById('cs-city').focus();return;}
  if(!d||!m||!y||isNaN(h)||isNaN(min)){showErr('Compila data, ora e luogo di nascita.');return;}
  if(y<1900||y>2050){showErr('Anno tra il 1900 e il 2050.');return;}
  errEl.style.display='none';
  document.getElementById('cs-results').style.display='none';
  document.getElementById('cs-loading').style.display='block';
  document.getElementById('cs-calcola-btn').disabled=true;
  try{
    var localDt=new Date(y,m-1,d,h,min);
    var tzDate=new Date(localDt.toLocaleString('en-US',{timeZone:tz}));
    var utcDate=new Date(localDt.toLocaleString('en-US',{timeZone:'UTC'}));
    var tzOff=(tzDate-utcDate)/3600000;
    var data=await csCalcHD(y,m,d,h,min,tzOff);
    await csRenderRisultati(data,nome);
  }catch(e){showErr(e.message||'Si è verificato un errore. Riprova.');}
  finally{document.getElementById('cs-loading').style.display='none';document.getElementById('cs-calcola-btn').disabled=false;}
};
</script>
