  const arrowSun=t=>t<=3?'left':'right';
  const dNode=design.find(p=>p.planet_en==='North Node')||{},pNode=personality.find(p=>p.planet_en==='North Node')||{};
  return{type,profile,authority,definition,defined_centers:[...defCenters].sort(),defined_channels:defChannels.map(([a,b])=>[a,b]),gate_colors,personality,design,variables:{digestion:arrowSun(dSun.tone||1),environment:arrowSun(dNode.tone||1),perspective:arrowSun(pSun.tone||1),awareness:arrowSun(pNode.tone||1)},dietary_regime:phsLabel(dSun.color||1,dSun.tone||1),environment_name:envLabel(dNode.color||1,dNode.tone||1)};
}

