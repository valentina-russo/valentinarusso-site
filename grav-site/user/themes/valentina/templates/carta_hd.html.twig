{% extends 'partials/base.html.twig' %}

{% block title %}{{ page.title }} | Valentina Russo{% endblock %}

{% block extra_css %}
<style>
  .hd-carta-wrap {
    max-width: 680px;
    margin: 0 auto;
    padding: var(--space-lg) var(--space-md);
  }
  .hd-carta-intro {
    text-align: center;
    margin-bottom: var(--space-lg);
  }
  .hd-carta-intro h1 {
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    margin-bottom: 0.75rem;
  }
  .hd-carta-intro p {
    color: var(--text-muted, #666);
    font-size: 1rem;
    max-width: 520px;
    margin: 0 auto;
  }
  .hd-form-card {
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.07);
    padding: 2rem;
  }
  .hd-field {
    margin-bottom: 1.25rem;
  }
  .hd-field label {
    display: block;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--primary-color);
    margin-bottom: 0.4rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .hd-field input,
  .hd-field select {
    width: 100%;
    border: 1.5px solid #e0dbd7;
    border-radius: 8px;
    padding: 0.7rem 0.9rem;
    font-family: inherit;
    font-size: 0.95rem;
    color: #333;
    background: #faf9f8;
    transition: border-color 0.2s;
    box-sizing: border-box;
  }
  .hd-field input:focus,
  .hd-field select:focus {
    outline: none;
    border-color: var(--primary-color);
    background: #fff;
  }
  .hd-field-row {
    display: grid;
    gap: 0.75rem;
  }
  .hd-field-row.cols-3 { grid-template-columns: 1fr 2fr 1.5fr; }
  .hd-field-row.cols-2 { grid-template-columns: 1fr 1fr; }
  .hd-field-row .hd-field { margin-bottom: 0; }
  .hd-field-hint {
    font-size: 0.75rem;
    color: #aaa;
    margin-top: 0.3rem;
  }
  .hd-submit-btn {
    width: 100%;
    padding: 0.9rem 1.5rem;
    background: var(--primary-color);
    color: #fff;
    border: none;
    border-radius: 10px;
    font-family: inherit;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.1s;
    margin-top: 0.5rem;
  }
  .hd-submit-btn:hover:not(:disabled) { opacity: 0.88; }
  .hd-submit-btn:active:not(:disabled) { transform: scale(0.99); }
  .hd-submit-btn:disabled { opacity: 0.5; cursor: not-allowed; }

  /* Loading */
  .hd-loading {
    display: none;
    text-align: center;
    padding: 2rem;
    color: var(--primary-color);
    font-style: italic;
  }
  .hd-spinner {
    width: 32px; height: 32px;
    border: 3px solid #e0dbd7;
    border-top-color: var(--primary-color);
    border-radius: 50%;
    animation: hd-spin 0.8s linear infinite;
    margin: 0 auto 1rem;
  }
  @keyframes hd-spin { to { transform: rotate(360deg); } }

  /* Risultati */
  .hd-result {
    display: none;
    margin-top: 2rem;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.4s, transform 0.4s;
  }
  .hd-result.visible {
    display: block;
    opacity: 1;
    transform: translateY(0);
  }

  /* Card Tipo — protagonista */
  .hd-tipo-card {
    background: linear-gradient(135deg, var(--primary-color), var(--secondary-color, #7a5c9e));
    border-radius: 16px;
    padding: 2rem;
    text-align: center;
    color: #fff;
    margin-bottom: 1rem;
  }
  .hd-tipo-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.8;
    margin-bottom: 0.5rem;
  }
  .hd-tipo-name {
    font-size: clamp(1.8rem, 5vw, 2.6rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 0.75rem;
    font-family: var(--font-heading, 'Playfair Display', serif);
  }
  .hd-tipo-strategy {
    font-size: 0.95rem;
    opacity: 0.9;
    font-style: italic;
  }
  .hd-tipo-name-sub {
    font-size: 0.85rem;
    opacity: 0.7;
    margin-top: 0.25rem;
  }

  /* Griglia dati core */
  .hd-core-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }
  .hd-core-card {
    background: #fff;
    border-radius: 12px;
    padding: 1rem 1.25rem;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  }
  .hd-core-card-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--primary-color);
    margin-bottom: 0.3rem;
  }
  .hd-core-card-value {
    font-size: 1rem;
    font-weight: 700;
    color: #222;
    line-height: 1.3;
  }
  .hd-core-card-sub {
    font-size: 0.78rem;
    color: #888;
    margin-top: 0.15rem;
  }

  /* Croce incarnazionale */
  .hd-cross-card {
    background: #f5f0f8;
    border-left: 4px solid var(--secondary-color, #7a5c9e);
    border-radius: 12px;
    padding: 1.25rem;
    margin-bottom: 1rem;
  }
  .hd-cross-card-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--secondary-color, #7a5c9e);
    margin-bottom: 0.4rem;
  }
  .hd-cross-card-value {
    font-size: 0.97rem;
    font-weight: 600;
    color: #333;
    line-height: 1.5;
  }

  /* Centri definiti */
  .hd-centers-card {
    background: #fdf4f0;
    border-left: 4px solid var(--accent-color);
    border-radius: 12px;
    padding: 1.25rem;
    margin-bottom: 1rem;
  }
  .hd-centers-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent-color);
    margin-bottom: 0.6rem;
  }
  .hd-centers-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .hd-center-tag {
    background: var(--accent-color);
    color: #fff;
    border-radius: 20px;
    padding: 0.25rem 0.75rem;
    font-size: 0.8rem;
    font-weight: 600;
  }

  /* Attivazioni planetarie (toggle) */
  .hd-activations-toggle {
    width: 100%;
    background: none;
    border: 1.5px solid #e0dbd7;
    border-radius: 8px;
    padding: 0.65rem 1rem;
    font-family: inherit;
    font-size: 0.88rem;
    font-weight: 600;
    color: #666;
    cursor: pointer;
    text-align: left;
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
    transition: border-color 0.2s;
  }
  .hd-activations-toggle:hover { border-color: var(--primary-color); color: var(--primary-color); }
  .hd-activations-toggle .arrow { transition: transform 0.2s; }
  .hd-activations-toggle.open .arrow { transform: rotate(180deg); }
  .hd-activations-body {
    display: none;
    margin-bottom: 1rem;
  }
  .hd-activations-body.open { display: block; }
  .hd-act-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.82rem;
  }
  .hd-act-table th {
    text-align: left;
    padding: 0.4rem 0.6rem;
    background: #f5f0f8;
    font-weight: 700;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--primary-color);
  }
  .hd-act-table td {
    padding: 0.35rem 0.6rem;
    border-bottom: 1px solid #f0ebe8;
    color: #444;
  }
  .hd-act-table tr:last-child td { border-bottom: none; }
  .hd-act-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

  /* Nascita/Design date */
  .hd-dates-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }
  .hd-date-card {
    background: #f5f5f5;
    border-radius: 10px;
    padding: 0.75rem 1rem;
    font-size: 0.82rem;
    color: #666;
  }
  .hd-date-card strong {
    display: block;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #aaa;
    margin-bottom: 0.2rem;
  }

  /* CTA zone */
  .hd-cta-zone {
    margin-top: 1.25rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(0,0,0,0.06);
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  .hd-cta-section {
    background: linear-gradient(135deg, #fdf4f0, #f8ece8);
    border-left: 4px solid var(--accent-color);
    border-radius: 12px;
    padding: 1.25rem;
    margin-bottom: 0.25rem;
  }
  .hd-cta-section h3 {
    font-size: 0.78rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--accent-color);
    margin: 0 0 0.5rem;
  }
  .hd-cta-section p {
    font-size: 0.95rem;
    color: #444;
    margin: 0 0 0;
    line-height: 1.6;
    font-weight: 500;
  }
  .hd-cta-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.95rem 1.5rem;
    background: var(--primary-color);
    color: #fff;
    border: none;
    border-radius: 10px;
    font-family: inherit;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    text-align: center;
    text-decoration: none;
    transition: opacity 0.2s, transform 0.1s;
    box-sizing: border-box;
  }
  .hd-cta-btn:hover { opacity: 0.88; color: #fff; }
  .hd-cta-btn:active { transform: scale(0.99); }
  .hd-cta-whatsapp { background: #25D366; }
  .hd-cta-whatsapp:hover { opacity: 0.88; color: #fff; }

  /* Reset */
  .hd-reset-btn {
    display: block;
    margin: 0.5rem auto 0;
    background: none;
    border: 1.5px solid #ccc;
    border-radius: 8px;
    padding: 0.5rem 1.2rem;
    font-family: inherit;
    font-size: 0.85rem;
    cursor: pointer;
    color: #666;
    transition: border-color 0.2s;
  }
  .hd-reset-btn:hover { border-color: var(--primary-color); color: var(--primary-color); }

  /* Error */
  .hd-error {
    display: none;
    background: #fff0f0;
    border: 1.5px solid #f5a5a5;
    border-radius: 10px;
    padding: 1rem 1.25rem;
    color: #c0392b;
    font-size: 0.9rem;
    margin-top: 1rem;
  }

  @media (max-width: 480px) {
    .hd-form-card { padding: 1.25rem; }
    .hd-field-row.cols-3 { grid-template-columns: 1fr 1fr; }
    .hd-field-row.cols-3 .hd-field:last-child { grid-column: 1 / -1; }
    .hd-core-grid { grid-template-columns: 1fr; }
    .hd-act-cols { grid-template-columns: 1fr; }
    .hd-dates-row { grid-template-columns: 1fr; }
  }
</style>
{% endblock %}

{% block content %}
<main>
  <div class="hd-carta-wrap">

    <div class="hd-carta-intro" data-animate>
      <p class="eyebrow" style="font-size:0.78rem; text-transform:uppercase; letter-spacing:.08em; color:var(--primary-color); font-weight:700; margin-bottom:.5rem;">Strumento Gratuito</p>
      <h1>{{ page.title }}</h1>
      <p>{{ page.header.description }}</p>
    </div>

    <div class="hd-form-card" data-animate>
      <form id="carta-form" novalidate>

        <div class="hd-field">
          <label for="nome">Il tuo nome <span style="font-weight:400;text-transform:none;font-size:0.8rem;color:#aaa;">(opzionale)</span></label>
          <input type="text" id="nome" name="nome" placeholder="Es. Giulia" autocomplete="given-name">
        </div>

        <div class="hd-field">
          <label>Data di nascita</label>
          <div class="hd-field-row cols-3">
            <div class="hd-field">
              <input type="number" id="giorno" name="giorno" min="1" max="31" placeholder="GG" required>
            </div>
            <div class="hd-field">
              <select id="mese" name="mese" required>
                <option value="" disabled selected>Mese</option>
                <option value="1">Gennaio</option>
                <option value="2">Febbraio</option>
                <option value="3">Marzo</option>
                <option value="4">Aprile</option>
                <option value="5">Maggio</option>
                <option value="6">Giugno</option>
                <option value="7">Luglio</option>
                <option value="8">Agosto</option>
                <option value="9">Settembre</option>
                <option value="10">Ottobre</option>
                <option value="11">Novembre</option>
                <option value="12">Dicembre</option>
              </select>
            </div>
            <div class="hd-field">
              <input type="number" id="anno" name="anno" min="1900" max="2025" placeholder="AAAA" required>
            </div>
          </div>
        </div>

        <div class="hd-field">
          <label>Ora di nascita</label>
          <div class="hd-field-row cols-2">
            <div class="hd-field">
              <input type="number" id="ora" name="ora" min="0" max="23" placeholder="Ore (0–23)" required>
            </div>
            <div class="hd-field">
              <input type="number" id="minuti" name="minuti" min="0" max="59" placeholder="Minuti (0–59)" required>
            </div>
          </div>
          <p class="hd-field-hint">Inserisci l'orario locale del luogo di nascita.</p>
        </div>

        <div class="hd-field">
          <label for="fuso">Fuso orario del luogo di nascita</label>
          <select id="fuso" name="fuso" required>
            <optgroup label="Italia e Europa">
              <option value="Europe/Rome" selected>Italia (Europe/Rome)</option>
              <option value="Europe/London">Regno Unito (Europe/London)</option>
              <option value="Europe/Paris">Francia / Belgio (Europe/Paris)</option>
              <option value="Europe/Berlin">Germania / Austria (Europe/Berlin)</option>
              <option value="Europe/Madrid">Spagna (Europe/Madrid)</option>
              <option value="Europe/Zurich">Svizzera (Europe/Zurich)</option>
              <option value="Europe/Amsterdam">Olanda (Europe/Amsterdam)</option>
              <option value="Europe/Lisbon">Portogallo (Europe/Lisbon)</option>
              <option value="Europe/Athens">Grecia (Europe/Athens)</option>
              <option value="Europe/Warsaw">Polonia (Europe/Warsaw)</option>
              <option value="Europe/Moscow">Russia — Mosca (Europe/Moscow)</option>
            </optgroup>
            <optgroup label="Americhe">
              <option value="America/New_York">USA Est (America/New_York)</option>
              <option value="America/Chicago">USA Centro (America/Chicago)</option>
              <option value="America/Denver">USA Montagna (America/Denver)</option>
              <option value="America/Los_Angeles">USA Ovest (America/Los_Angeles)</option>
              <option value="America/Sao_Paulo">Brasile — São Paulo (America/Sao_Paulo)</option>
              <option value="America/Buenos_Aires">Argentina (America/Buenos_Aires)</option>
              <option value="America/Mexico_City">Messico (America/Mexico_City)</option>
            </optgroup>
            <optgroup label="Asia e Oceania">
              <option value="Asia/Dubai">Emirati Arabi (Asia/Dubai)</option>
              <option value="Asia/Kolkata">India (Asia/Kolkata)</option>
              <option value="Asia/Shanghai">Cina (Asia/Shanghai)</option>
              <option value="Asia/Tokyo">Giappone (Asia/Tokyo)</option>
              <option value="Australia/Sydney">Australia — Sydney (Australia/Sydney)</option>
            </optgroup>
            <optgroup label="Africa">
              <option value="Africa/Johannesburg">Sudafrica (Africa/Johannesburg)</option>
              <option value="Africa/Cairo">Egitto (Africa/Cairo)</option>
            </optgroup>
          </select>
        </div>

        <button type="submit" class="hd-submit-btn" id="submit-btn">
          Calcola la mia Carta Human Design
        </button>
      </form>

      <div class="hd-loading" id="hd-loading">
        <div class="hd-spinner"></div>
        <p>Calcolo in corso…</p>
      </div>

      <div class="hd-error" id="hd-error"></div>
    </div>

    <div class="hd-result" id="hd-result">

      <!-- Tipo HD — protagonista -->
      <div class="hd-tipo-card">
        <div class="hd-tipo-label">Il tuo Tipo Human Design</div>
        <div class="hd-tipo-name" id="res-tipo"></div>
        <div class="hd-tipo-strategy" id="res-strategia"></div>
      </div>

      <!-- Date di calcolo -->
      <div class="hd-dates-row">
        <div class="hd-date-card">
          <strong>Personalità (conscio)</strong>
          <span id="res-date-personality"></span>
        </div>
        <div class="hd-date-card">
          <strong>Design (inconscio)</strong>
          <span id="res-date-design"></span>
        </div>
      </div>

      <!-- Dati core -->
      <div class="hd-core-grid">
        <div class="hd-core-card">
          <div class="hd-core-card-label">Profilo</div>
          <div class="hd-core-card-value" id="res-profilo"></div>
        </div>
        <div class="hd-core-card">
          <div class="hd-core-card-label">Autorità</div>
          <div class="hd-core-card-value" id="res-autorita"></div>
        </div>
        <div class="hd-core-card">
          <div class="hd-core-card-label">Definizione</div>
          <div class="hd-core-card-value" id="res-definizione"></div>
        </div>
        <div class="hd-core-card">
          <div class="hd-core-card-label">Angolo</div>
          <div class="hd-core-card-value" id="res-angolo"></div>
        </div>
      </div>

      <!-- Croce incarnazionale -->
      <div class="hd-cross-card">
        <div class="hd-cross-card-label">Croce Incarnazionale</div>
        <div class="hd-cross-card-value" id="res-croce"></div>
      </div>

      <!-- Centri definiti -->
      <div class="hd-centers-card" id="centers-card" style="display:none">
        <div class="hd-centers-label">Centri Definiti</div>
        <div class="hd-centers-list" id="res-centri"></div>
      </div>

      <!-- Attivazioni planetarie (toggle) -->
      <button class="hd-activations-toggle" id="act-toggle">
        <span>Mostra attivazioni planetarie</span>
        <span class="arrow">▼</span>
      </button>
      <div class="hd-activations-body" id="act-body">
        <div class="hd-act-cols">
          <div>
            <table class="hd-act-table">
              <thead><tr><th colspan="3">Personalità (conscio)</th></tr><tr><th>Pianeta</th><th>Porta</th><th>Linea</th></tr></thead>
              <tbody id="act-personality"></tbody>
            </table>
          </div>
          <div>
            <table class="hd-act-table">
              <thead><tr><th colspan="3">Design (inconscio)</th></tr><tr><th>Pianeta</th><th>Porta</th><th>Linea</th></tr></thead>
              <tbody id="act-design"></tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- CTA -->
      <div class="hd-cta-section">
        <h3>Vuoi capire il tuo Design?</h3>
        <p>Questa carta mostra i dati grezzi. Una sessione con Valentina traduce numeri e simboli in indicazioni concrete per la tua vita, il tuo lavoro, le tue relazioni.</p>
      </div>
      <div class="hd-cta-zone">
        <a href="{{ grav.base_url }}/contatti" class="hd-cta-btn">Prenota una consulenza con Valentina</a>
        <a href="https://wa.me/393791037653?text=Ciao%20Valentina%2C%20ho%20appena%20calcolato%20la%20mia%20Carta%20Human%20Design%20sul%20tuo%20sito%20e%20vorrei%20capire%20meglio%20il%20mio%20Design." class="hd-cta-btn hd-cta-whatsapp" target="_blank" rel="noopener">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Scrivimi su WhatsApp
        </a>
      </div>

      <button class="hd-reset-btn" id="reset-btn">Calcola un'altra carta</button>
    </div>

  </div>
</main>
{% endblock %}

{% block scripts %}
<script>
(function () {
  var API_KEY = "{{ page.header.api_key }}";
  var API_BASE = "https://api.simplechartcalculator.com/v1/calculate";

  var form      = document.getElementById('carta-form');
  var submitBtn = document.getElementById('submit-btn');
  var loading   = document.getElementById('hd-loading');
  var errorBox  = document.getElementById('hd-error');
  var resultBox = document.getElementById('hd-result');
  var resetBtn  = document.getElementById('reset-btn');
  var actToggle = document.getElementById('act-toggle');
  var actBody   = document.getElementById('act-body');

  // Traduzioni
  var TIPI = {
    'Generator': 'Generatore',
    'Manifesting Generator': 'Generatore Manifestante',
    'Projector': 'Proiettore',
    'Manifestor': 'Manifestatore',
    'Reflector': 'Riflettore'
  };
  var STRATEGIE = {
    'Generator': 'Strategia: aspetta di rispondere',
    'Manifesting Generator': 'Strategia: aspetta di rispondere, poi informa',
    'Projector': 'Strategia: aspetta l\'invito',
    'Manifestor': 'Strategia: informa prima di agire',
    'Reflector': 'Strategia: aspetta un ciclo lunare (28 giorni)'
  };
  var AUTORITA = {
    'Sacral': 'Sacrale',
    'Emotional': 'Emotiva',
    'Splenic': 'Splenica',
    'Ego': 'Ego',
    'Ego Manifested': 'Ego Manifestato',
    'Self-Projected': 'Auto-Proiettata',
    'Mental': 'Mentale',
    'Environmental': 'Ambientale',
    'Lunar': 'Lunare',
    'None': 'Nessuna'
  };
  var DEFINIZIONE = {
    'Single Definition': 'Singola',
    'Split Definition': 'Doppia',
    'Triple Split Definition': 'Tripla',
    'Quadruple Split Definition': 'Quadrupla',
    'No Definition': 'Nessuna'
  };
  var ANGOLO = {
    'Right Angle': 'Angolo Destro',
    'Left Angle': 'Angolo Sinistro',
    'Juxtaposition': 'Giustapposizione'
  };
  var PIANETI = {
    'Sun': 'Sole', 'Moon': 'Luna', 'Earth': 'Terra',
    'North Node': 'Nodo Nord', 'South Node': 'Nodo Sud',
    'Mercury': 'Mercurio', 'Venus': 'Venere', 'Mars': 'Marte',
    'Jupiter': 'Giove', 'Saturn': 'Saturno', 'Uranus': 'Urano',
    'Neptune': 'Nettuno', 'Pluto': 'Plutone'
  };
  var CENTRI = {
    'Head': 'Testa', 'Ajna': 'Ajna', 'Throat': 'Gola', 'G': 'G (Identità)',
    'Heart': 'Cuore', 'SolarPlexus': 'Plesso Solare', 'Sacral': 'Sacrale',
    'Spleen': 'Milza', 'Root': 'Radice'
  };

  function tr(map, key) { return map[key] || key; }

  // Toggle attivazioni
  actToggle.addEventListener('click', function () {
    var open = actBody.classList.toggle('open');
    actToggle.classList.toggle('open', open);
    actToggle.querySelector('span:first-child').textContent =
      open ? 'Nascondi attivazioni planetarie' : 'Mostra attivazioni planetarie';
  });

  // Submit
  form.addEventListener('submit', async function (e) {
    e.preventDefault();

    var g   = parseInt(document.getElementById('giorno').value, 10);
    var m   = parseInt(document.getElementById('mese').value, 10);
    var a   = parseInt(document.getElementById('anno').value, 10);
    var h   = parseInt(document.getElementById('ora').value, 10);
    var min = parseInt(document.getElementById('minuti').value, 10);
    var tz  = document.getElementById('fuso').value;

    if (!g || !m || !a || isNaN(h) || isNaN(min) || !tz) {
      showError('Compila tutti i campi obbligatori: data, ora e fuso orario.');
      return;
    }
    if (a < 1900 || a > 2025) { showError('Anno di nascita non valido.'); return; }
    if (g < 1 || g > 31)      { showError('Giorno non valido.'); return; }
    if (h < 0 || h > 23)      { showError('Ora non valida (0–23).'); return; }
    if (min < 0 || min > 59)  { showError('Minuti non validi (0–59).'); return; }

    setLoading(true);

    var url = API_BASE +
      '?y=' + a + '&m=' + m + '&d=' + g +
      '&h=' + h + '&min=' + min +
      '&tz=' + encodeURIComponent(tz) +
      '&key=' + API_KEY;

    var nome = document.getElementById('nome').value.trim();
    if (nome) url += '&name=' + encodeURIComponent(nome);

    try {
      var resp = await fetch(url);
      var data = await resp.json();

      if (!resp.ok || data.status !== 'success') {
        throw new Error(data.error || data.message || 'Errore API (' + resp.status + ')');
      }

      renderResult(data, nome);
    } catch (err) {
      showError('Errore nel calcolo: ' + err.message + '. Controlla i dati inseriti e riprova.');
    } finally {
      setLoading(false);
    }
  });

  function renderResult(data, nome) {
    var core  = data.result.Core;
    var act   = data.result.Activations;
    var info  = data.info;
    var tipo  = core.Type;

    // Tipo
    var tipoIT = tr(TIPI, tipo);
    document.getElementById('res-tipo').textContent = (nome ? nome + ' — ' : '') + tipoIT;
    document.getElementById('res-strategia').textContent = tr(STRATEGIE, tipo);

    // Core
    document.getElementById('res-profilo').textContent    = core.Profile || '—';
    document.getElementById('res-autorita').textContent   = tr(AUTORITA, core.Authority);
    document.getElementById('res-definizione').textContent = tr(DEFINIZIONE, core.Definition);
    document.getElementById('res-angolo').textContent     = tr(ANGOLO, core.Angle);

    // Croce
    document.getElementById('res-croce').textContent = core.IncarnationCross || '—';

    // Date
    document.getElementById('res-date-personality').textContent = info.time_local || '—';
    document.getElementById('res-date-design').textContent      = info.design_local || '—';

    // Centri (dalla sintesi, se disponibili — piano free potrebbe non averli)
    var centri = core.DefinedCenters || (data.result.synthesis && data.result.synthesis.defined_centers);
    var centCard = document.getElementById('centers-card');
    if (centri && centri.length) {
      var centList = document.getElementById('res-centri');
      centList.innerHTML = '';
      centri.forEach(function (c) {
        var tag = document.createElement('span');
        tag.className = 'hd-center-tag';
        tag.textContent = tr(CENTRI, c);
        centList.appendChild(tag);
      });
      centCard.style.display = 'block';
    } else {
      centCard.style.display = 'none';
    }

    // Attivazioni
    renderActivations('act-personality', act.Personality);
    renderActivations('act-design', act.Design);

    // Mostra risultati
    form.style.display = 'none';
    resultBox.style.display = 'block';
    requestAnimationFrame(function () { resultBox.classList.add('visible'); });
    resultBox.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function renderActivations(tbodyId, activations) {
    var tbody = document.getElementById(tbodyId);
    tbody.innerHTML = '';
    if (!activations) return;
    var pianeti = ['Sun','Earth','Moon','North Node','South Node','Mercury','Venus','Mars','Jupiter','Saturn','Uranus','Neptune','Pluto'];
    pianeti.forEach(function (p) {
      var a = activations[p];
      if (!a) return;
      var tr = document.createElement('tr');
      tr.innerHTML = '<td>' + (PIANETI[p] || p) + '</td><td>' + a.Gate + '</td><td>' + a.Line + '</td>';
      tbody.appendChild(tr);
    });
  }

  function setLoading(on) {
    submitBtn.disabled = on;
    loading.style.display = on ? 'block' : 'none';
    errorBox.style.display = 'none';
    if (on) {
      resultBox.classList.remove('visible');
      resultBox.style.display = 'none';
    }
  }

  function showError(msg) {
    errorBox.textContent = msg;
    errorBox.style.display = 'block';
  }

  resetBtn.addEventListener('click', function () {
    resultBox.classList.remove('visible');
    resultBox.style.display = 'none';
    form.reset();
    form.style.display = 'block';
    actBody.classList.remove('open');
    actToggle.classList.remove('open');
    document.querySelector('.hd-form-card').scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
})();
</script>
{% endblock %}
