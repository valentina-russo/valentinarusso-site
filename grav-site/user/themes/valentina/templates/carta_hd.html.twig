async function calcolaCarta() {
  const d = parseInt(document.getElementById('cf-day').value);
  const m = parseInt(document.getElementById('cf-month').value);
  const y = parseInt(document.getElementById('cf-year').value);
  const h = parseInt(document.getElementById('cf-hour').value);
  const min = parseInt(document.getElementById('cf-min').value);
  const tz = document.getElementById('cf-tz').value;
  const nome = document.getElementById('cf-nome').value.trim();
  const city = document.getElementById('cf-city').value.trim();

  if(!city) {
    mostraErrore('Inserisci il luogo di nascita per continuare.');
    document.getElementById('cf-city').focus();
    return;
  }
  if(!d||!m||!y||isNaN(h)||isNaN(min)) {
    mostraErrore('Compila giorno, mese, anno, ora e minuti per continuare.');
    return;
  }
  if(y < 1900 || y > 2050) { mostraErrore('Inserisci un anno tra il 1900 e il 2050.'); return; }

  document.getElementById('carta-error').style.display = 'none';
  document.getElementById('carta-results').style.display = 'none';
  document.getElementById('carta-loading').style.display = 'block';
  document.getElementById('carta-calcola-btn').disabled = true;

  try {
    // Calcolo timezone offset
    const localDt = new Date(y, m - 1, d, h, min);
    const tzDate = new Date(localDt.toLocaleString('en-US', { timeZone: tz }));
    const utcDate = new Date(localDt.toLocaleString('en-US', { timeZone: 'UTC' }));
    const tzOffset = (tzDate - utcDate) / 3600000;

    // Calcolo HD interamente client-side (no API)
    const data = await calculateHDChart(y, m, d, h, min, tzOffset);
    // Fix campo ambiente (il rendering si aspetta 'environment' non 'environment_name')
    if (data.environment_name) { data.environment = data.environment_name; delete data.environment_name; }

    await renderRisultati(data, nome);
  } catch(e) {
    mostraErrore(e.message || 'Si è verificato un errore. Riprova tra qualche istante.');
  } finally {
    document.getElementById('carta-loading').style.display = 'none';
    document.getElementById('carta-calcola-btn').disabled = false;
  }
}

function mostraErrore(msg) {
  document.getElementById('carta-loading').style.display = 'none';
  document.getElementById('carta-calcola-btn').disabled = false;
  const el = document.getElementById('carta-error');
  el.textContent = msg;
  el.style.display = 'block';
}

// ─── Render Results ────────────────────────────────────────────────────────

function normalizzaRisposta(data) {
  // Formato locale (client-side) o API: ha gate_colors — applica traduzione BG5
  if(data.gate_colors) {
    data.type = TIPO_IT[data.type] || data.type;
    data.authority = AUTH_IT[data.authority] || data.authority;
    data.definition = DEF_IT[data.definition] || data.definition;
    return data;
  }

  // Vecchio formato (simplechartcalculator): ha result.Core + result.Activations
  const core = data.result && data.result.Core;
  const acts = data.result && data.result.Activations;
  if(!core || !acts) return null;

  const pArr = Object.entries(acts.Personality).map(([en, v]) => ({
    planet_en: en, planet_it: PLANET_IT[en] || en, gate: v.Gate, line: v.Line, degrees: 0
  }));
  const dArr = Object.entries(acts.Design).map(([en, v]) => ({
    planet_en: en, planet_it: PLANET_IT[en] || en, gate: v.Gate, line: v.Line, degrees: 0
  }));

  const blackGates = new Set(pArr.map(p => p.gate));
  const redGates   = new Set(dArr.map(p => p.gate));
  const allActive  = new Set([...blackGates, ...redGates]);

  const gate_colors = {};
  allActive.forEach(g => {
    const inP = blackGates.has(g), inD = redGates.has(g);
    gate_colors[String(g)] = (inP && inD) ? 'PD' : inP ? 'P' : 'D';
  });

  const defined_channels = CHANNELS
    .filter(([g1,g2]) => allActive.has(g1) && allActive.has(g2))
    .map(([g1,g2]) => [g1,g2]);

  const defined_centers = [];
  defined_channels.forEach(([g1,g2]) => {
    const c1 = GATE_TO_CENTER[g1], c2 = GATE_TO_CENTER[g2];
    if(c1 && !defined_centers.includes(c1)) defined_centers.push(c1);
    if(c2 && !defined_centers.includes(c2)) defined_centers.push(c2);
  });

  return {
    type:       TIPO_IT[core.Type] || core.Type,
    profile:    core.Profile,
    authority:  AUTH_IT[core.Authority] || core.Authority,
    definition: DEF_IT[core.Definition] || core.Definition,
    gate_colors, defined_channels, defined_centers,
    personality: pArr, design: dArr,
  };
}

async function renderRisultati(data, nome) {
  const d = normalizzaRisposta(data);
  if(!d) { mostraErrore('Formato risposta non riconosciuto.'); return; }

  // Name header
  const nh = document.getElementById('carta-name-header');
  if(nome) {
    nh.innerHTML = `<h2>${escHtml(nome)}</h2><p>Carta Human Design</p>`;
    nh.style.display = 'block';
  } else {
    nh.style.display = 'none';
  }

  // Core cards
  const coreEl = document.getElementById('carta-core');
  const coreItems = [
    { label: 'Tipo di Carriera',  value: d.type },
    { label: 'Profilo',           value: d.profile },
    { label: 'Autorità',          value: d.authority },
    { label: 'Definizione',       value: d.definition },
  ];

  if(d.dietary_regime) coreItems.push({ label: 'Regime Alimentare', value: d.dietary_regime });
  if(d.environment) coreItems.push({ label: 'Ambiente', value: d.environment });
  if(d.variables) {
    const arrowSymbol = (dir) => dir === 'left' ? '\u25C4' : '\u25BA';
    const varStr = `${arrowSymbol(d.variables.digestion)} ${arrowSymbol(d.variables.perspective)} ${arrowSymbol(d.variables.environment)} ${arrowSymbol(d.variables.awareness)}`;
    coreItems.push({ label: 'Variabili', value: varStr });
  }

  coreEl.innerHTML = coreItems.map(i =>
    `<div class="core-card">
      <div class="core-card-label">${i.label}</div>
      <div class="core-card-value">${escHtml(i.value)}</div>
    </div>`
  ).join('');

  // Gate sets
  const blackGates = new Set();
  const redGates   = new Set();
  for(const [g, c] of Object.entries(d.gate_colors)) {
    const gn = parseInt(g);
    if(c === 'P' || c === 'PD') blackGates.add(gn);
    if(c === 'D' || c === 'PD') redGates.add(gn);
  }

  // Defined centers and channels
  const definedCenterSet = new Set(d.defined_centers);
  const definedChannels = d.defined_channels.map(([g1, g2]) => {
    const ch = CHANNELS.find(([c1, c2]) => (c1===g1&&c2===g2)||(c1===g2&&c2===g1));
    return ch || [g1, g2, GATE_TO_CENTER[g1]||'', GATE_TO_CENTER[g2]||''];
  });

  // Bodygraph SVG (carica il bodygraph vettoriale reale)
  await loadAndRenderBodygraph(d.gate_colors, definedChannels, definedCenterSet, blackGates, redGates, d.variables);

  // Planet table
  renderPlaneti(d.personality, d.design);

  // Show results
  document.getElementById('carta-results').style.display = 'block';
  document.getElementById('carta-results').scrollIntoView({ behavior: 'smooth', block: 'start' });
}

// ─── Bodygraph SVG reale ────────────────────────────────────────────────────

async function loadAndRenderBodygraph(gateColors, definedChannels, definedCenterSet, blackGates, redGates, variables) {
  const wrap = document.getElementById('carta-bodygraph-wrap');
  const ns = 'http://www.w3.org/2000/svg';

  // 36 canali HD — dati canonici IHDS (public domain)
  const CHANNELS = [
    [1,8],[2,14],[3,60],[4,63],[5,15],[6,59],[7,31],[9,52],
    [10,20],[10,57],[11,56],[12,22],[13,33],[16,48],[17,62],
    [18,58],[19,49],[20,34],[20,57],[21,45],[23,43],[24,61],
    [25,51],[26,44],[27,50],[28,38],[29,46],[30,41],[32,54],
    [34,57],[35,36],[37,40],[39,55],[42,53],[47,64]
  ];

  // Center SVG element IDs
  // Center IDs matching hdkit SVG (renamed in adapt script)
  const CTR_ID = {
    HEAD:'Head', AJNA:'Ajna', THROAT:'Throat', G:'G',
    HEART:'Heart', SPLEEN:'Splenic_Center',
    SACRAL:'Sacral', SOLAR:'Solar_Plexus', ROOT:'Root'
  };
  const CTR_COL = {
    HEAD:'#b4cfe8', AJNA:'#52a363', THROAT:'#b8913e', G:'#d9b82a',
    HEART:'#b83838', SPLEEN:'#957040', SOLAR:'#d47a2e', SACRAL:'#c94e4e', ROOT:'#8a7868'
  };

  try {
    const resp = await fetch('/chart.svg', { cache: 'no-cache' });
    if(!resp.ok) throw new Error('SVG non trovato');
    const svgText = await resp.text();

    const parser = new DOMParser();
    const svgEl = parser.parseFromString(svgText, 'image/svg+xml').documentElement;
    svgEl.setAttribute('style', 'max-width:520px;width:100%;height:auto;display:block;margin:0 auto');
    svgEl.removeAttribute('class');

    const COL_P = '#1a1a2e', COL_D = '#c0392b', COL_EMPTY = '#c8c2bc';

    // ── 1. Costruisci CSS ──────────────────────────────────────────────────────
    const rules = [];
    rules.push(`:root{--color-personality:${COL_P};--color-design:${COL_D};--color-empty:${COL_EMPTY};}`);

    // Colora OGNI gate attivo — hdkit SVG ha id="Gate{n}" per ogni mezza-strip.
    // Gate hanging (partner non attivo) = mezza linea colorata.
    // Gate in canale completo = entrambe le metà colorate.
    // Colore: P solo = nero, D solo = rosso, P+D = strisce bicolore.
    for(let g=1; g<=64; g++) {
      const col = gateColors[g];
      if(!col) continue;
      const fillVal = (col==='P') ? COL_P
                    : (col==='D') ? COL_D
                    : 'url(#splitGatePattern)'; // Both P+D
      rules.push(`#Gate${g}{fill:${fillVal}!important;}`);
    }
    // Integration connectors: color if any integration gate is active
    const intGateIds = [10,20,34,57];
    for(const ig of intGateIds) {
      if(gateColors[ig]) {
        const col = gateColors[ig];
        const fillVal = (col==='P') ? COL_P : (col==='D') ? COL_D : 'url(#splitGatePattern)';
        rules.push(`#GateConnect${ig}{fill:${fillVal}!important;}`);
      }
    }
    if(intGateIds.some(g => gateColors[g])) {
      rules.push(`#GateSpan{fill:${gateColors[20]?((gateColors[20]==='P')?COL_P:(gateColors[20]==='D')?COL_D:'url(#splitGatePattern)'):COL_EMPTY}!important;}`);
    }

    // Centri definiti
    for(const c of definedCenterSet) {
      const svgId = CTR_ID[c], col = CTR_COL[c];
      if(svgId && col) rules.push(`#${svgId} path{fill:${col}!important;}`);
    }

    // Gate attivi: quadrato nero + testo bianco. Inattivi: bianco alpha.
    const activeGates = new Set(Object.keys(gateColors).map(Number));
    for(let g=1; g<=64; g++) {
      if(activeGates.has(g)) {
        rules.push(`#GateText${g}{fill:#fff!important;font-weight:bold!important;opacity:1!important;}`);
        rules.push(`#GateTextBg${g} path,#GateTextBg${g} circle{fill:#1a1a2e!important;rx:3!important;ry:3!important;}`);
      } else {
        rules.push(`#GateText${g}{fill:#fff!important;opacity:0.4!important;}`);
      }
    }

    // Inietta <style> nell'SVG
    let defs = svgEl.querySelector('defs');
    if(!defs){ defs=document.createElementNS(ns,'defs'); svgEl.insertBefore(defs,svgEl.firstChild); }
    const styleEl = document.createElementNS(ns,'style');
    styleEl.textContent = rules.join('\n');
    defs.appendChild(styleEl);

    const gatesGroup = svgEl.querySelector('#Gates');
    if(gatesGroup) gatesGroup.removeAttribute('class');

    // ─── 4 Frecce Variabili (P sinistra, D destra) ───
    if(variables) {
      const toArrow = (dir) => dir === 'left' ? '\u25C4' : '\u25BA';
      const headCenter = 426;
      const arrowY = 30;
      const arrowGap = 35;
      const arrowOffset = 80;
      const mkArrow = (x, y, text, color) => {
        const el = document.createElementNS(ns, 'text');
        el.setAttribute('x', String(x)); el.setAttribute('y', String(y));
        el.setAttribute('text-anchor', 'middle'); el.setAttribute('font-size', '28');
        el.setAttribute('fill', color); el.setAttribute('font-weight', 'bold');
        el.textContent = text; return el;
      };
      const g = document.createElementNS(ns, 'g');
      g.setAttribute('id', 'hd-variables');
      // D (Design/red) LEFT, P (Personality/black) RIGHT
      g.appendChild(mkArrow(headCenter - arrowOffset, arrowY, toArrow(variables.digestion), '#c0392b'));
      g.appendChild(mkArrow(headCenter - arrowOffset, arrowY + arrowGap, toArrow(variables.environment), '#c0392b'));
      g.appendChild(mkArrow(headCenter + arrowOffset, arrowY, toArrow(variables.perspective), '#1a1a2e'));
      g.appendChild(mkArrow(headCenter + arrowOffset, arrowY + arrowGap, toArrow(variables.awareness), '#1a1a2e'));
      svgEl.appendChild(g);
    }

    wrap.innerHTML = '';
    wrap.appendChild(svgEl);

  } catch(e) {
    // Fallback: schema geometrico semplificato
    wrap.innerHTML = buildBodygraph(blackGates, redGates, definedChannels, definedCenterSet);
  }
}

// ─── Bodygraph fallback (schema geometrico) ─────────────────────────────────

const C_PRIMARY = '#7a5c9e';
const C_RED     = '#c0392b';
const C_BLACK   = '#1a1a2e';
const C_UNDEF   = '#f0ece8';
const C_UNDEF_STROKE = '#d5cfc9';

// Center geometry: cx, cy and shape definitions
const CENTER_GEO = {
  HEAD:   { cx:210, cy:35, type:'tri-up',  pts:[[168,62],[252,62],[210,8]] },
  AJNA:   { cx:210, cy:94, type:'tri-dn',  pts:[[168,68],[252,68],[210,120]] },
  THROAT: { cx:210, cy:154, type:'rect',   rx:168, ry:138, rw:84, rh:32 },
  G:      { cx:210, cy:238, type:'diamond',pts:[[210,197],[256,238],[210,279],[164,238]] },
  HEART:  { cx:290, cy:215, type:'tri-dn', pts:[[265,195],[315,195],[290,240]] },
  SPLEEN: { cx:83,  cy:335, type:'tri-rt', pts:[[58,306],[58,364],[108,335]] },
  SOLAR:  { cx:337, cy:335, type:'tri-lt', pts:[[362,306],[362,364],[312,335]] },
  SACRAL: { cx:210, cy:364, type:'rect',   rx:168, ry:350, rw:84, rh:28 },
  ROOT:   { cx:210, cy:462, type:'rect',   rx:168, ry:448, rw:84, rh:28 }
};

// Channel routing: visual connection points between centers
const CHANNEL_PATHS = {
  'HEAD-AJNA':   [[210,62],[210,68]],
  'AJNA-THROAT': [[210,120],[210,138]],
  'THROAT-G':    [[210,170],[210,197]],
  'THROAT-HEART':[[252,154],[265,210]],
  'THROAT-SPLEEN':[[168,154],[108,335]],
  'THROAT-SOLAR': [[252,154],[312,335]],
  'THROAT-SACRAL':[[210,170],[210,350]],
  'G-HEART':     [[256,238],[265,220]],
  'G-SACRAL':    [[210,279],[210,350]],
  'HEART-SPLEEN':[[265,232],[108,320]],
  'HEART-SOLAR': [[315,232],[312,320]],
  'SACRAL-SPLEEN':[[168,364],[108,345]],
  'SACRAL-SOLAR': [[252,364],[312,345]],
  'SACRAL-ROOT':  [[210,378],[210,448]],
  'SPLEEN-ROOT':  [[73,364],[185,448]],
  'SOLAR-ROOT':   [[347,364],[235,448]]
};

function centerPairKey(c1, c2) {
  const order = ['HEAD','AJNA','THROAT','G','HEART','SPLEEN','SOLAR','SACRAL','ROOT'];
  return order.indexOf(c1) < order.indexOf(c2) ? `${c1}-${c2}` : `${c2}-${c1}`;
}

function buildBodygraph(blackGates, redGates, definedChannels, definedCenterSet) {
  const W = 420, H = 510;
  let svg = `<svg viewBox="0 0 ${W} ${H}" width="${W}" height="${H}" xmlns="http://www.w3.org/2000/svg" style="font-family:inherit">`;

  // Draw channel lines first (behind centers)
  const activePairs = new Set();
  definedChannels.forEach(([g1, g2, c1, c2]) => {
    const key = centerPairKey(c1, c2);
    if(!activePairs.has(key) && CHANNEL_PATHS[key]) {
      activePairs.add(key);
      const [[x1,y1],[x2,y2]] = CHANNEL_PATHS[key];
      // Determine color based on gate types
      const g1b = blackGates.has(g1), g1r = redGates.has(g1);
      const g2b = blackGates.has(g2), g2r = redGates.has(g2);
      const bothBlack = g1b && !g1r && g2b && !g2r;
      const bothRed   = !g1b && g1r && !g2b && g2r;
      const color = bothBlack ? C_BLACK : bothRed ? C_RED : C_PRIMARY;
      svg += `<line x1="${x1}" y1="${y1}" x2="${x2}" y2="${y2}" stroke="${color}" stroke-width="4" stroke-linecap="round"/>`;
    }
  });

  // Also draw undefined channel outlines (faint) for defined-but-inactive pairs
  for(const [key, [[x1,y1],[x2,y2]]] of Object.entries(CHANNEL_PATHS)) {
    if(!activePairs.has(key)) {
      svg += `<line x1="${x1}" y1="${y1}" x2="${x2}" y2="${y2}" stroke="${C_UNDEF_STROKE}" stroke-width="2" stroke-linecap="round"/>`;
    }
  }

  // Draw centers
  for(const [name, geo] of Object.entries(CENTER_GEO)) {
    const isDef = definedCenterSet.has(name);
    const fill = isDef ? C_PRIMARY : C_UNDEF;
    const stroke = isDef ? C_PRIMARY : C_UNDEF_STROKE;
    const textColor = isDef ? '#fff' : '#aaa';

    if(geo.type === 'rect') {
      svg += `<rect x="${geo.rx}" y="${geo.ry}" width="${geo.rw}" height="${geo.rh}" rx="5" fill="${fill}" stroke="${stroke}" stroke-width="1.5"/>`;
    } else {
      const pts = geo.pts.map(p=>p.join(',')).join(' ');
      svg += `<polygon points="${pts}" fill="${fill}" stroke="${stroke}" stroke-width="1.5"/>`;
    }

    // Center label
    svg += `<text x="${geo.cx}" y="${geo.cy+5}" text-anchor="middle" fill="${textColor}" font-size="9" font-weight="700" letter-spacing="0.5">${CENTER_IT[name].toUpperCase()}</text>`;
  }

  svg += '</svg>';
  return svg;
}

// ─── Planet Table ──────────────────────────────────────────────────────────

const PLANET_ORDER = [
  'Sun','Earth','Moon','North Node','South Node',
  'Mercury','Venus','Mars','Jupiter','Saturn',
  'Uranus','Neptune','Pluto'
];

function renderPlaneti(personality, design) {
  const designMap = {};
  design.forEach(p => { designMap[p.planet_en] = p; });
  const persMap = {};
  personality.forEach(p => { persMap[p.planet_en] = p; });

  let rows = '';
  for(const key of PLANET_ORDER) {
    const p = persMap[key];
    if(!p) continue;
    const d = designMap[p.planet_en] || {};
    const bg5 = PLANET_BG5[p.planet_en] || p.planet_it;
    rows += `<tr>
      <td><span class="planet-bg5">${escHtml(bg5)}</span><span class="planet-name">(${escHtml(p.planet_it)})</span></td>
      <td class="gate-black">${p.gate}.${p.line}</td>
      <td class="gate-red">${d.gate || '–'}.${d.line || ''}</td>
    </tr>`;
  }
  document.getElementById('carta-planets').innerHTML = `
    <h3>Attivazioni Planetarie</h3>
    <table class="planets-table">
      <thead><tr>
        <th>Pianeta BG5</th>
        <th style="color:#1a1a2e">Personalità (cosciente)</th>
        <th style="color:#c0392b">Design (inconscio)</th>
      </tr></thead>
      <tbody>${rows}</tbody>
    </table>`;
}

// ─── Utils ─────────────────────────────────────────────────────────────────

function escHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// ─── PDF Download ─────────────────────────────────────────────────────────

function scaricaPDF() {
  const results = document.getElementById('carta-results');
  const btn = document.getElementById('carta-pdf-btn');
  const cta = document.querySelector('.carta-cta');
  const form = document.querySelector('.carta-form');
  const header = document.querySelector('header');
  const footer = document.querySelector('footer');
  const intro = document.querySelector('.carta-intro');

  // Hide non-print elements
  if(btn) btn.style.display = 'none';
  if(cta) cta.style.display = 'none';
  if(form) form.style.display = 'none';
  if(header) header.style.display = 'none';
  if(footer) footer.style.display = 'none';
  if(intro) intro.style.display = 'none';

  // Force single column for print
  const layout = document.querySelector('.carta-desktop-layout');
  if(layout) layout.style.flexDirection = 'column';
  const colLeft = document.querySelector('.carta-col-left');
  if(colLeft) { colLeft.style.flex = '1'; colLeft.style.maxWidth = '100%'; colLeft.style.position = 'static'; }

  window.print();

  // Restore
  if(btn) btn.style.display = '';
  if(cta) cta.style.display = '';
  if(form) form.style.display = '';
  if(header) header.style.display = '';
  if(footer) footer.style.display = '';
  if(intro) intro.style.display = '';
  if(layout) layout.style.flexDirection = '';
  if(colLeft) { colLeft.style.flex = ''; colLeft.style.maxWidth = ''; colLeft.style.position = ''; }
}

// Allow Enter key
document.addEventListener('keydown', e => {
  if(e.key === 'Enter') calcolaCarta();
});
</script>
