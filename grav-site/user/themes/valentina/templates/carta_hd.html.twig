{% extends 'partials/base.html.twig' %}

{% block title %}Calcola la tua Carta Human Design Gratis | Valentina Russo{% endblock %}

{% block extra_css %}
<style>
  .carta-wrap {
    max-width: 860px;
    margin: 0 auto;
    padding: var(--space-lg) var(--space-md);
  }
  .carta-intro {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .carta-intro h1 { font-size: clamp(1.6rem, 4vw, 2.2rem); margin-bottom: 0.75rem; }
  .carta-intro p { color: var(--text-muted, #666); font-size: 1rem; max-width: 560px; margin: 0 auto; line-height: 1.6; }

  /* Form */
  .carta-form-card {
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.07);
    padding: 2rem;
    margin-bottom: 2rem;
  }
  .cf-row { display: grid; gap: 1rem; margin-bottom: 1rem; }
  .cf-row.cols-3 { grid-template-columns: 1fr 1fr 1.5fr; }
  .cf-row.cols-2 { grid-template-columns: 1fr 1fr; }
  .cf-row.cols-1 { grid-template-columns: 1fr; }
  .cf-field label {
    display: block;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--primary-color);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.35rem;
  }
  .cf-field input,
  .cf-field select {
    width: 100%;
    border: 1.5px solid #e0dbd7;
    border-radius: 8px;
    padding: 0.65rem 0.85rem;
    font-family: inherit;
    font-size: 0.95rem;
    color: #333;
    background: #faf9f8;
    box-sizing: border-box;
    transition: border-color 0.2s;
  }
  .cf-field input:focus,
  .cf-field select:focus { outline: none; border-color: var(--primary-color); background: #fff; }
  .cf-hint { font-size: 0.73rem; color: #aaa; margin-top: 0.25rem; }
  .carta-btn {
    width: 100%;
    padding: 0.9rem 1.5rem;
    background: var(--primary-color);
    color: #fff;
    border: none;
    border-radius: 10px;
    font-family: inherit;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    margin-top: 0.5rem;
    transition: opacity 0.2s, transform 0.1s;
  }
  .carta-btn:hover:not(:disabled) { opacity: 0.88; }
  .carta-btn:active:not(:disabled) { transform: scale(0.99); }
  .carta-btn:disabled { opacity: 0.5; cursor: not-allowed; }

  /* Loading */
  .carta-loading {
    display: none;
    text-align: center;
    padding: 2.5rem;
    color: var(--primary-color);
  }
  .carta-loading-dots span {
    display: inline-block;
    width: 8px; height: 8px;
    background: var(--primary-color);
    border-radius: 50%;
    margin: 0 3px;
    animation: dotPulse 1.2s ease-in-out infinite;
  }
  .carta-loading-dots span:nth-child(2) { animation-delay: 0.2s; }
  .carta-loading-dots span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes dotPulse { 0%,80%,100%{opacity:0.2;transform:scale(0.8)} 40%{opacity:1;transform:scale(1)} }

  /* Error */
  .carta-error {
    display: none;
    background: #fff0f0;
    border: 1.5px solid #ffcccc;
    border-radius: 10px;
    padding: 1rem 1.25rem;
    color: #c0392b;
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  /* Results */
  .carta-results { display: none; }
  .carta-name-header {
    text-align: center;
    margin-bottom: 1.5rem;
  }
  .carta-name-header h2 {
    font-size: 1.4rem;
    color: var(--primary-color);
    margin: 0 0 0.2rem;
  }
  .carta-name-header p { color: #888; font-size: 0.85rem; margin: 0; }

  /* Core cards */
  .carta-core {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
    gap: 0.6rem;
    margin-bottom: 1.5rem;
  }
  .core-card {
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    padding: 1rem 0.9rem;
    text-align: center;
  }
  .core-card-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--primary-color);
    margin-bottom: 0.3rem;
  }
  .core-card-value {
    font-size: 0.95rem;
    font-weight: 700;
    color: #2c2c2c;
    line-height: 1.3;
  }

  /* Bodygraph */
  .carta-bodygraph-wrap {
    display: flex;
    justify-content: center;
    margin-bottom: 2rem;
  }
  .carta-bodygraph-wrap svg { max-width: 100%; height: auto; }

  /* Planet table */
  .carta-planets {
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    padding: 1.25rem;
    margin-bottom: 2rem;
    overflow-x: auto;
  }
  .carta-planets h3 {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--primary-color);
    margin: 0 0 1rem;
  }
  .planets-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.78rem;
  }
  .planets-table th {
    text-align: left;
    padding: 0.25rem 0.4rem;
    font-weight: 700;
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #999;
    border-bottom: 1.5px solid #f0ece8;
  }
  .planets-table td {
    padding: 0.25rem 0.4rem;
    border-bottom: 1px solid #f5f2ef;
    color: #444;
    line-height: 1.2;
  }
  .planets-table tr:last-child td { border-bottom: none; }
  .gate-black { color: #1a1a2e; font-weight: 700; }
  .gate-red   { color: #c0392b; font-weight: 700; }
  .planet-bg5 { font-weight: 600; color: #333; font-size: 0.78rem; }
  .planet-name { font-size: 0.65rem; color: #aaa; margin-left: 0.3rem; }

  /* Desktop 2-col layout */
  .carta-desktop-layout {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  @media (min-width: 900px) {
    .carta-desktop-layout {
      flex-direction: row;
      gap: 2rem;
      align-items: flex-start;
    }
    .carta-col-left {
      flex: 0 0 45%;
      max-width: 45%;
      position: sticky;
      top: 1rem;
    }
    .carta-col-right {
      flex: 1;
      min-width: 0;
    }
  }

  /* PDF button */
  .carta-pdf-btn {
    display: block;
    width: 100%;
    padding: 0.85rem 1.5rem;
    margin-top: 2rem;
    background: var(--primary-color);
    color: #fff;
    border: none;
    border-radius: 10px;
    font-weight: 700;
    font-size: 0.95rem;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  .carta-pdf-btn:hover { opacity: 0.88; }

  /* CTA */
  .carta-cta {
    background: #f5f0f8;
    border-radius: 16px;
    padding: 2rem;
    text-align: center;
    margin-top: 2.5rem;
  }
  .carta-cta p { color: #555; font-size: 0.95rem; margin-bottom: 1.25rem; line-height: 1.6; }
  .carta-cta a {
    display: inline-block;
    padding: 0.9rem 2rem;
    background: var(--primary-color);
    color: #fff;
    border-radius: 10px;
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .carta-cta a:hover { opacity: 0.88; }

  /* City autocomplete */
  .cf-autocomplete-wrap { position: relative; }
  .cf-autocomplete-list {
    position: absolute;
    top: calc(100% + 2px);
    left: 0; right: 0;
    background: #fff;
    border: 1.5px solid var(--primary-color);
    border-radius: 8px;
    box-shadow: 0 6px 20px rgba(0,0,0,0.12);
    z-index: 200;
    max-height: 220px;
    overflow-y: auto;
    display: none;
  }
  .cf-autocomplete-list li {
    padding: 0.6rem 0.85rem;
    cursor: pointer;
    font-size: 0.9rem;
    color: #333;
    border-bottom: 1px solid #f5f2ef;
    list-style: none;
  }
  .cf-autocomplete-list li:last-child { border-bottom: none; }
  .cf-autocomplete-list li:hover { background: #f8f4ff; }
  .cf-tz-detected { font-size: 0.73rem; color: #7c5cbf; margin-top: 0.25rem; display: none; }

  @media (max-width: 600px) {
    .cf-row.cols-3 { grid-template-columns: 1fr 1fr; }
    .cf-row.cols-2 { grid-template-columns: 1fr; }
    .carta-core { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 601px) and (max-width: 899px) {
    .carta-core { grid-template-columns: repeat(4, 1fr); }
  }

  @media print {
    header, footer, .carta-intro, .carta-form, .carta-cta,
    .carta-pdf-btn, .cf-autocomplete-list, nav { display: none !important; }
    .carta-results { display: block !important; }
    .carta-desktop-layout { flex-direction: column !important; }
    .carta-col-left { flex: 1 !important; max-width: 100% !important; position: static !important; }
    .carta-bodygraph-wrap svg { max-width: 500px; margin: 0 auto; }
    .core-card { box-shadow: none; border: 1px solid #eee; }
    .carta-planets { box-shadow: none; border: 1px solid #eee; }
    body { background: #fff; }
  }
</style>
{% endblock %}

{% block content %}
<div class="carta-wrap">

  <div class="carta-intro">
    <h1>{{ page.header.title }}</h1>
    <p>{{ page.header.description }}</p>
  </div>

  <div class="carta-form-card">
    <div class="cf-row cols-1">
      <div class="cf-field">
        <label>Nome (opzionale)</label>
        <input type="text" id="cf-nome" placeholder="Il tuo nome">
      </div>
    </div>
    <div class="cf-row cols-3">
      <div class="cf-field">
        <label>Giorno</label>
        <input type="number" id="cf-day" min="1" max="31" placeholder="15">
      </div>
      <div class="cf-field">
        <label>Mese</label>
        <input type="number" id="cf-month" min="1" max="12" placeholder="6">
      </div>
      <div class="cf-field">
        <label>Anno</label>
        <input type="number" id="cf-year" min="1900" max="2050" placeholder="1990">
      </div>
    </div>
    <div class="cf-row cols-2">
      <div class="cf-field">
        <label>Ora</label>
        <input type="number" id="cf-hour" min="0" max="23" placeholder="10">
      </div>
      <div class="cf-field">
        <label>Minuti</label>
        <input type="number" id="cf-min" min="0" max="59" placeholder="30">
      </div>
    </div>
    <div class="cf-row cols-1">
      <div class="cf-field">
        <label>Luogo di nascita *</label>
        <div class="cf-autocomplete-wrap">
          <input type="text" id="cf-city" placeholder="Es: Milano, Roma, Napoli…" autocomplete="off" required>
          <ul class="cf-autocomplete-list" id="cf-city-list"></ul>
        </div>
        <div class="cf-hint">Inserisci la città — il fuso orario verrà rilevato automaticamente</div>
      </div>
    </div>
    <div class="cf-row cols-1">
      <div class="cf-field">
        <label>Fuso orario</label>
        <select id="cf-tz">
          <option value="Europe/Rome" selected>Italia (Europe/Rome)</option>
          <option value="Europe/London">Regno Unito (Europe/London)</option>
          <option value="Europe/Paris">Francia / Belgio (Europe/Paris)</option>
          <option value="Europe/Berlin">Germania / Austria (Europe/Berlin)</option>
          <option value="Europe/Madrid">Spagna (Europe/Madrid)</option>
          <option value="Europe/Zurich">Svizzera (Europe/Zurich)</option>
          <option value="America/New_York">USA Est (America/New_York)</option>
          <option value="America/Chicago">USA Centrale (America/Chicago)</option>
          <option value="America/Los_Angeles">USA Ovest (America/Los_Angeles)</option>
          <option value="America/Argentina/Buenos_Aires">Argentina</option>
          <option value="America/Sao_Paulo">Brasile (America/Sao_Paulo)</option>
          <option value="Asia/Dubai">Emirati Arabi (Asia/Dubai)</option>
          <option value="Asia/Kolkata">India (Asia/Kolkata)</option>
          <option value="Asia/Tokyo">Giappone (Asia/Tokyo)</option>
          <option value="Australia/Sydney">Australia (Australia/Sydney)</option>
        </select>
        <div class="cf-hint">Selezionato automaticamente dalla città</div>
        <div class="cf-tz-detected" id="cf-tz-detected"></div>
      </div>
    </div>
    <button class="carta-btn" id="carta-calcola-btn" onclick="calcolaCarta()">Calcola la mia Carta</button>
  </div>

  <div class="carta-loading" id="carta-loading">
    <div class="carta-loading-dots"><span></span><span></span><span></span></div>
    <p style="margin-top:0.75rem;color:#888;font-size:0.9rem;">Calcolo in corso…</p>
  </div>

  <div class="carta-error" id="carta-error"></div>

  <div class="carta-results" id="carta-results">
    <div class="carta-name-header" id="carta-name-header"></div>
    <div class="carta-core" id="carta-core"></div>
    <div class="carta-desktop-layout">
      <div class="carta-col-left">
        <div class="carta-bodygraph-wrap" id="carta-bodygraph-wrap"></div>
      </div>
      <div class="carta-col-right">
        <div class="carta-planets" id="carta-planets"></div>
        <button class="carta-pdf-btn" id="carta-pdf-btn" onclick="scaricaPDF()">Scarica PDF</button>
      </div>
    </div>
    <div class="carta-cta">
      <p>Il tuo grafico mostra la struttura energetica di base. Una consulenza con Valentina trasforma questi dati in indicazioni pratiche per le tue relazioni, il lavoro e le decisioni quotidiane.</p>
      <a href="/contatti">Prenota una consulenza con Valentina</a>
    </div>
  </div>

</div>

<script src="/user/themes/valentina/js/swe-hd.js"></script>
<script>

// ─── HD Calculator Client-Side (no API) ──────────────────────────────────────
let _sweMod = null;
let _sweCalc = null;
let _sweJulday = null;
async function initSwe() {
  if (_sweMod) return;
  const SweClass = window.SwissEphemeris;
  if (!SweClass) throw new Error('SwissEphemeris non caricato');
  const inst = new SweClass();
  await inst.init();
  // Load JPL ephemeris files from CDN for sub-arcsecond precision (required for Tone accuracy)
  try { await inst.loadStandardEphemeris(); } catch(e) { console.warn('JPL ephemeris not loaded, using Moshier fallback'); }
  _sweMod = inst.module;
  // Load JPL ephemeris files directly into WASM filesystem for sub-arcsecond precision
  try {
    const CDN = 'https://cdn.jsdelivr.net/gh/aloistr/swisseph/ephe';
    try { _sweMod.FS.mkdir('/ephe'); } catch(e) {}
    const files = ['sepl_18.se1', 'semo_18.se1'];
    await Promise.all(files.map(async f => {
      const resp = await fetch(`${CDN}/${f}`);
      if (resp.ok) _sweMod.FS.writeFile(`/ephe/${f}`, new Uint8Array(await resp.arrayBuffer()));
    }));
    _sweMod.cwrap('swe_set_ephe_path_wrap', null, ['string'])('/ephe');
  } catch(e) {
    console.warn('JPL files not loaded, using Moshier fallback');
    _sweMod.cwrap('swe_set_ephe_path_wrap', null, ['string'])('');
  }
  _sweCalc = (jd, planet, flags) => {
    const ptr = _sweMod.ccall('swe_calc_ut_wrap', 'number', ['number','number','number'], [jd, planet, flags]);
    return _sweMod.getValue(ptr, 'double');
  };
  _sweJulday = _sweMod.cwrap('swe_julday_wrap', 'number', ['number','number','number','number','number']);
}

const HD_GATE_WHEEL = [
  41,19,13,49,30,55,37,63,22,36,25,17,21,51,42,3,27,24,2,23,
  8,20,16,35,45,12,15,52,39,53,62,56,31,33,7,4,29,59,40,64,
  47,6,46,18,48,57,32,50,28,44,1,43,14,34,9,5,26,11,10,58,
  38,54,61,60
];
const HD_GATE_SIZE = 360.0/64, HD_LINE_SIZE = HD_GATE_SIZE/6, HD_COLOR_SIZE = HD_LINE_SIZE/6, HD_TONE_SIZE = HD_COLOR_SIZE/6;
const HD_RAVE_OFFSET = 58.0;

const HD_CHANNELS = [
  [64,47],[61,24],[63,4],[17,62],[43,23],[11,56],[16,48],[20,57],
  [31,7],[8,1],[33,13],[10,20],[45,21],[35,36],[12,22],[20,34],
  [26,44],[51,25],[40,37],[2,14],[5,15],[29,46],[27,50],[34,57],
  [59,6],[3,60],[9,52],[42,53],[18,58],[28,38],[32,54],[30,41],
  [39,55],[19,49]
];

const HD_GATE_CENTER = {};
[64,61,63].forEach(g => HD_GATE_CENTER[g]='HEAD');
[47,24,4,17,43,11].forEach(g => HD_GATE_CENTER[g]='AJNA');
[62,23,56,16,31,8,33,45,35,12,20].forEach(g => HD_GATE_CENTER[g]='THROAT');
[7,13,1,10,25,15,2,46].forEach(g => HD_GATE_CENTER[g]='G');
[21,51,26,40].forEach(g => HD_GATE_CENTER[g]='HEART');
[48,57,44,50,32,28,18].forEach(g => HD_GATE_CENTER[g]='SPLEEN');
[36,22,37,6,30,55,49].forEach(g => HD_GATE_CENTER[g]='SOLAR');
[34,5,14,29,3,42,9,27,59].forEach(g => HD_GATE_CENTER[g]='SACRAL');
[53,60,52,54,58,38,41,39,19].forEach(g => HD_GATE_CENTER[g]='ROOT');

const HD_PLANETS = [
  {id: 0,  it:'Sole',      en:'Sun'},       // SE_SUN
  {id:-2,  it:'Terra',      en:'Earth'},     // calculated
  {id: 1,  it:'Luna',       en:'Moon'},      // SE_MOON
  {id:11,  it:'Nodo Nord',  en:'North Node'},// SE_TRUE_NODE
  {id:-1,  it:'Nodo Sud',   en:'South Node'},// calculated
  {id: 2,  it:'Mercurio',   en:'Mercury'},
  {id: 3,  it:'Venere',     en:'Venus'},
  {id: 4,  it:'Marte',      en:'Mars'},
  {id: 5,  it:'Giove',      en:'Jupiter'},
  {id: 6,  it:'Saturno',    en:'Saturn'},
  {id: 7,  it:'Urano',      en:'Uranus'},
  {id: 8,  it:'Nettuno',    en:'Neptune'},
  {id: 9,  it:'Plutone',    en:'Pluto'},
];

// PHS: Color → base name, Tone 1-3 → sub A, Tone 4-6 → sub B
const HD_PHS = {
  1: {name:'Appetito', a:'Consecutivo', b:'Alternato'},
  2: {name:'Gusto', a:'Chiuso', b:'Aperto'},
  3: {name:'Sete', a:'Caldo', b:'Freddo'},
  4: {name:'Tatto', a:'Calmo', b:'Nervoso'},
  5: {name:'Suono', a:'Basso', b:'Alto'},
  6: {name:'Luce', a:'Diretta', b:'Indiretta'},
};
const HD_ENV = {
  1: {name:'Grotte', a:'Selettivo', b:'Aperto'},
  2: {name:'Mercati', a:'Esterno', b:'Interno'},
  3: {name:'Cucine', a:'Umido', b:'Secco'},
  4: {name:'Montagne', a:'Attivo', b:'Passivo'},
  5: {name:'Valli', a:'Stretto', b:'Largo'},
  6: {name:'Rive', a:'Naturale', b:'Artificiale'},
};
function phsLabel(color, tone) {
  const p = HD_PHS[color]; if(!p) return '?';
  // Sub-type determined by COLOR odd/even (verified on 3 profiles)
  return `${p.name} (${color % 2 === 0 ? p.a : p.b})`;
}
function envLabel(color, arrowDir) {
  const e = HD_ENV[color]; if(!e) return '?';
  // Sub-type follows arrow direction: left (strategic) = a, right (receptive) = b
  return `${e.name} (${arrowDir === 'left' ? e.a : e.b})`;
}

function hdDegreesToGateLineColor(deg) {
  // MicFell multiplication chain method (matches reference HD software)
  const angle = ((deg + HD_RAVE_OFFSET) % 360 + 360) % 360;
  const pct = angle / 360;
  const gate = HD_GATE_WHEEL[Math.min(Math.floor(pct * 64), 63)];
  const line = Math.floor((pct * 64 * 6) % 6) + 1;
  const color = Math.floor((pct * 64 * 6 * 6) % 6) + 1;
  const tone = Math.floor((pct * 64 * 6 * 6 * 6) % 6) + 1;
  return { gate, line, color, tone };
}

function dateToJD(y, m, d, h, min, tzOffset) {
  // Use Swiss Ephemeris julday for precision
  const utcH = h + min / 60.0 - tzOffset;
  return _sweJulday(y, m, d, utcH, 1); // 1 = Gregorian
}

async function calcPlanets(jd) {
  await initSwe();
  const results = [];
  let nnLon = null, sunLon = null;
  const SWIEPH = 0; // SEFLG_SWIEPH (JPL precision)

  for (const p of HD_PLANETS) {
    let lon;
    if (p.id === -1) {
      lon = nnLon !== null ? (nnLon + 180) % 360 : 0;
    } else if (p.id === -2) {
      lon = sunLon !== null ? (sunLon + 180) % 360 : 0;
    } else {
      lon = _sweCalc(jd, p.id, SWIEPH);
      if (p.id === 0) sunLon = lon;
      if (p.id === 11) nnLon = lon;
    }

    const glc = hdDegreesToGateLineColor(lon);
    results.push({
      planet_it: p.it, planet_en: p.en,
      gate: glc.gate, line: glc.line, color: glc.color, tone: glc.tone,
      degrees: Math.round(lon * 10000) / 10000
    });
  }
  return results;
}

function hdGetDefinedChannels(activeGates) {
  return HD_CHANNELS.filter(([g1,g2]) => activeGates.has(g1) && activeGates.has(g2));
}

function hdGetDefinedCenters(activeGates) {
  const def = new Set();
  for (const [g1,g2] of HD_CHANNELS) {
    if (activeGates.has(g1) && activeGates.has(g2)) {
      if (HD_GATE_CENTER[g1]) def.add(HD_GATE_CENTER[g1]);
      if (HD_GATE_CENTER[g2]) def.add(HD_GATE_CENTER[g2]);
    }
  }
  return def;
}

function hdCalcType(defCenters, defChannels) {
  const motors = new Set(['SACRAL','HEART','SOLAR','ROOT']);
  const hasMotor = [...defCenters].some(c => motors.has(c));
  if (!defCenters.size || !hasMotor) return 'Reflector';

  function motorToThroat(start, visited = new Set()) {
    if (visited.has(start)) return false;
    visited.add(start);
    if (start === 'THROAT') return true;
    const adj = new Set();
    for (const [g1,g2] of defChannels) {
      const c1 = HD_GATE_CENTER[g1]||'', c2 = HD_GATE_CENTER[g2]||'';
      if (c1 === start) adj.add(c2);
      else if (c2 === start) adj.add(c1);
    }
    return [...adj].some(c => motorToThroat(c, new Set(visited)));
  }

  const hasSacral = defCenters.has('SACRAL');
  const sacralToThroat = hasSacral && motorToThroat('SACRAL');
  const otherMotorToThroat = [...motors].filter(m => m !== 'SACRAL' && defCenters.has(m)).some(m => motorToThroat(m));

  if (hasSacral) return sacralToThroat ? 'Manifesting Generator' : 'Generator';
  return otherMotorToThroat ? 'Manifestor' : 'Projector';
}

function hdCalcProfile(personality, design) {
  const sunP = personality.find(p => p.planet_en === 'Sun');
  const sunD = design.find(p => p.planet_en === 'Sun');
  if (!sunP || !sunD) return '?/?';
  return `${sunP.line}/${sunD.line}`;
}

function hdCalcAuthority(defCenters) {
  const order = [['SOLAR','Emotional'],['SACRAL','Sacral'],['SPLEEN','Splenic'],['HEART','Ego Manifested'],['G','Self Projected']];
  for (const [c, auth] of order) {
    if (defCenters.has(c)) return auth;
  }
  return defCenters.size ? 'Mental Projector' : 'Lunar';
}

function hdCalcDefinition(defCenters, defChannels) {
  if (!defCenters.size) return 'No Definition';
  const adj = {};
  for (const c of defCenters) adj[c] = new Set();
  for (const [g1,g2] of defChannels) {
    const c1 = HD_GATE_CENTER[g1]||'', c2 = HD_GATE_CENTER[g2]||'';
    if (adj[c1] && adj[c2]) { adj[c1].add(c2); adj[c2].add(c1); }
  }
  const visited = new Set();
  let components = 0;
  for (const c of defCenters) {
    if (visited.has(c)) continue;
    components++;
    const stack = [c];
    while (stack.length) {
      const n = stack.pop();
      if (visited.has(n)) continue;
      visited.add(n);
      for (const nb of (adj[n]||[])) { if (!visited.has(nb)) stack.push(nb); }
    }
  }
  return {1:'Single Definition',2:'Split Definition',3:'Triple Split',4:'Quadruple Split'}[components] || 'Quadruple Split';
}

async function calculateHDChart(y, m, d, h, min, tzOffset) {
  await initSwe();
  const jdBirth = dateToJD(y, m, d, h, min, tzOffset);

  // Design date: bisection to find exact JD when Sun was 88° before natal Sun
  // (matches humandesignhub reference algo and MicFell's swe.solcross_ut)
  const SWIEPH = 0;
  const natalSunLon = _sweCalc(jdBirth, 0, SWIEPH);
  const targetLon = ((natalSunLon - 88.0) % 360 + 360) % 360;
  let lo = jdBirth - 95.0, hi = jdBirth - 80.0;
  for (let i = 0; i < 50; i++) {
    const mid = (lo + hi) / 2;
    const midLon = _sweCalc(mid, 0, SWIEPH);
    let diff = (midLon - targetLon + 180) % 360 - 180;
    if (Math.abs(diff) < 1e-6) { lo = hi = mid; break; }
    if (diff < 0) lo = mid; else hi = mid;
  }
  let jdDesign = (lo + hi) / 2;

  const personality = await calcPlanets(jdBirth);
  const design = await calcPlanets(jdDesign);

  const activeGates = new Set();
  [...personality, ...design].forEach(p => activeGates.add(p.gate));

  const defChannels = hdGetDefinedChannels(activeGates);
  const defCenters = hdGetDefinedCenters(activeGates);

  const type = hdCalcType(defCenters, defChannels);
  const profile = hdCalcProfile(personality, design);
  const authority = hdCalcAuthority(defCenters);
  const definition = hdCalcDefinition(defCenters, defChannels);

  const pGates = new Set(personality.map(p => p.gate));
  const dGates = new Set(design.map(p => p.gate));
  const gate_colors = {};
  for (const g of new Set([...pGates, ...dGates])) {
    gate_colors[String(g)] = (pGates.has(g) && dGates.has(g)) ? 'PD' : pGates.has(g) ? 'P' : 'D';
  }

  const pSun = personality.find(p => p.planet_en === 'Sun') || {};
  const dSun = design.find(p => p.planet_en === 'Sun') || {};

  // Variables: determined by TONE (not Color). Tone 1-3=left, 4-6=right
  // Source: MicFell/human_design_engine (verified open-source HD engine)
  const arrow = t => t <= 3 ? 'left' : 'right';
  const dNode = design.find(p => p.planet_en === 'North Node') || {};
  const pNode = personality.find(p => p.planet_en === 'North Node') || {};

  return {
    type, profile, authority, definition,
    defined_centers: [...defCenters].sort(),
    defined_channels: defChannels.map(([a,b]) => [a,b]),
    gate_colors, personality, design,
    variables: {
      digestion: arrow(dSun.tone||1),
      environment: arrow(dNode.tone||1),
      perspective: arrow(pSun.tone||1),
      awareness: arrow(pNode.tone||1),
    },
    dietary_regime: phsLabel(dSun.color||1, dSun.tone||1),
    environment_name: envLabel(dNode.color||1, arrow(dNode.tone||1)),
  };
}

