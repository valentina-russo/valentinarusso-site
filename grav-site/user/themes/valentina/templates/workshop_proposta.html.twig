{% extends 'partials/base.html.twig' %}

{% block title %}Workshop Scopri il tuo Disegno | Valentina Russo{% endblock %}

{% block content %}
<style>
@media (max-width: 768px) {
    /* Chi conduce: colonna singola, foto sotto */
    .ws-bio-grid {
        grid-template-columns: 1fr !important;
        gap: 2rem !important;
    }
    .ws-bio-grid h2 { font-size: 2.2rem !important; }

    /* Win-Win: colonna singola */
    .ws-pricing-grid {
        grid-template-columns: 1fr !important;
        gap: 2rem !important;
    }

    /* Sezione vantaggi: meno margine e border-radius */
    .ws-vantaggi {
        border-radius: 24px !important;
        margin: 1rem 0.5rem !important;
        padding: 3rem 1.25rem !important;
    }
    .ws-vantaggi h2 { font-size: 2rem !important; margin-bottom: 2rem !important; }

    /* Card padding ridotto */
    .ws-card-inner { padding: 1.75rem !important; }

    /* Certificazione: padding ridotto */
    .ws-cert-box { padding: 2rem 1.5rem !important; }

    /* Sezioni padding */
    .ws-section-v { padding-bottom: 3rem !important; }
}
</style>
<main style="background-color: var(--bg-color);">
    <!-- HERO -->
    <section class="section-padding" style="background: linear-gradient(135deg, rgba(182, 131, 151, 0.05) 0%, rgba(93, 174, 177, 0.05) 100%); padding-top: 5rem; padding-bottom: 5rem; text-align: center;">
        <div class="container" style="max-width: 900px;">
            <p class="text-uppercase" style="color: var(--primary-color); font-weight: 700; font-size: 0.85rem; letter-spacing: 2px; margin-bottom: 1.5rem;">
                Per Centri Olistici
            </p>
            <h1 class="serif" style="font-size: clamp(2.5rem, 8vw, 4.5rem); line-height: 1.1; margin-bottom: 1.5rem;">
                Scopri il tuo<br><em style="font-style: italic; color: var(--primary-color);">Disegno</em>
            </h1>
            <p class="serif italic" style="font-size: 1.5rem; color: #555; margin-bottom: 2.5rem; max-width: 800px; margin-left: auto; margin-right: auto; line-height: 1.6;">
                Un approccio pratico e operativo: al termine del workshop, ogni persona avrà le basi esatte per capire come operare e muoversi correttamente nel mondo secondo il proprio disegno individuale.
            </p>
            <div style="padding: 1rem 2rem; background: rgba(182, 131, 151, 0.08); display: inline-block; border-radius: 50px; font-weight: 600;">
                Format: <strong>Masterclass Interattiva</strong> | Durata: <strong>90-120 min</strong>
            </div>
        </div>
    </section>

    <!-- VIDEO -->
    <section class="ws-section-v" style="padding-bottom: 5rem;">
        <div class="container" style="max-width: 960px;">
            <div style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; border-radius: 24px; box-shadow: 0 40px 80px -20px rgba(0, 0, 0, 0.15); border: 1px solid var(--soft-gray); background: #000;">
                <iframe style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: 0;"
                    src="https://www.youtube-nocookie.com/embed/WPieOX8GoO0?rel=0"
                    title="Workshop Scopri il tuo Disegno - Valentina Russo"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                    allowfullscreen>
                </iframe>
            </div>
        </div>
    </section>

    <!-- CERTIFICAZIONE -->
    <section class="ws-section-v" style="padding-bottom: 5rem;">
        <div class="container" style="max-width: 900px; text-align: center;">
            <div class="ws-cert-box" style="display: inline-flex; flex-direction: column; align-items: center; gap: 1.5rem; background: white; border: 1px solid var(--soft-gray); border-radius: 32px; padding: 3rem; box-shadow: 0 10px 30px rgba(0,0,0,0.03);">
                <img src="{{ grav.base_url }}/user/themes/valentina/images/bg5-certified.png"
                     alt="BG5 Certified — Jovian Archive"
                     style="height: 90px; width: auto;">
                <p style="font-size: 1.05rem; line-height: 1.7; color: #555; max-width: 640px; margin: 0;">
                    Questo è l'<strong>unico logo ufficiale</strong> rilasciato da Jovian Archive — la casa madre del sistema BG5® e Human Design. 
                    Qualunque proposta priva di questa certificazione non garantisce l'accuratezza del metodo originale.
                </p>
            </div>
        </div>
    </section>

    <!-- IL CONCETTO -->
    <section class="section-padding" style="background: white;">
        <div class="container" style="max-width: 1000px;">
            <div class="blog-card" style="box-shadow: 0 20px 50px rgba(0,0,0,0.04); border-radius: 32px; overflow: hidden; border: 1px solid var(--soft-gray);">
                <div style="padding: 4rem 3rem; text-align: center;">
                    <h2 class="serif" style="color: var(--primary-color); margin-bottom: 2.5rem; font-size: clamp(2rem, 5vw, 2.75rem);">
                        Più di un oroscopo,<br>più di un test di personalità
                    </h2>
                    <p style="font-size: 1.3rem; line-height: 1.8; color: #444; margin-bottom: 3rem; max-width: 800px; margin-left: auto; margin-right: auto;">
                        I frequentatori dei centri olistici cercano risposte a domande profonde: <em>"Perché ripeto sempre gli stessi schemi?"</em>, <em>"Perché mi mancano le energie?"</em>, <em>"Come posso prendere decisioni migliori?"</em>
                    </p>
                    <div style="background: var(--bg-color); padding: 2.5rem; border-radius: 24px; border-left: 6px solid var(--primary-color); text-align: left;">
                        <p style="font-size: 1.15rem; line-height: 1.8; margin: 0;">
                            <strong>Lo Human Design</strong> sintetizza saggezze antiche (Astrologia, I-Ching, Sistema dei Chakra e <em>Cabala Ebraica</em>) e scienza moderna (Genetica e Fisica Quantistica). È lo strumento più avanzato per l'auto-conoscenza oggi disponibile.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CONTENUTO DELL'EVENTO -->
    <section class="section-padding" style="background: #fafafa;">
        <div class="container">
            <h2 class="serif text-center" style="color: var(--primary-color); margin-bottom: 4rem; font-size: 2.5rem;">
                Il contenuto dell'evento
            </h2>
            <div class="blog-grid">
                <div class="blog-card" style="border-radius: 24px; border: 1px solid var(--soft-gray); background: white;">
                    <div class="ws-card-inner" style="padding: 2.5rem;">
                        <div style="display: flex; align-items: center; gap: 1.25rem; margin-bottom: 1.25rem;">
                            <span style="font-size: 2.5rem; line-height: 1; color: var(--primary-color);">✦</span>
                            <h3 style="margin: 0; font-family: var(--font-heading); color: var(--primary-color); font-size: 1.5rem;">I Vantaggi dello Human Design</h3>
                        </div>
                        <p style="color: #666; line-height: 1.7; margin: 0;">Applicazioni pratiche e benefici reali nella vita quotidiana. Come utilizzare questa mappa meccanica per migliorare le proprie relazioni e capire le proprie dinamiche comportamentali.</p>
                    </div>
                </div>
                <div class="blog-card" style="border-radius: 24px; border: 1px solid var(--soft-gray); background: white;">
                    <div class="ws-card-inner" style="padding: 2.5rem;">
                        <div style="display: flex; align-items: center; gap: 1.25rem; margin-bottom: 1.25rem;">
                            <span style="font-size: 2.5rem; line-height: 1; color: var(--secondary-color);">❂</span>
                            <h3 style="margin: 0; font-family: var(--font-heading); color: var(--secondary-color); font-size: 1.5rem;">I Quattro Tipi Energetici</h3>
                        </div>
                        <p style="color: #666; line-height: 1.7; margin: 0;">Analisi delle diverse nature energetiche: Generatori, Proiettori, Manifestatori e Riflettori. Imparare a comprendere il modo corretto per processare l'energia senza resistenza e frustrazione.</p>
                    </div>
                </div>
                <div class="blog-card" style="border-radius: 24px; border: 1px solid var(--soft-gray); background: white;">
                    <div class="ws-card-inner" style="padding: 2.5rem;">
                        <div style="display: flex; align-items: center; gap: 1.25rem; margin-bottom: 1.25rem;">
                            <span style="font-size: 2.5rem; line-height: 1; color: var(--accent-color);">✧</span>
                            <h3 style="margin: 0; font-family: var(--font-heading); color: var(--accent-color); font-size: 1.5rem;">Strategia e Autorità</h3>
                        </div>
                        <p style="color: #666; line-height: 1.7; margin: 0;">Gli strumenti fondamentali e meccanici per il processo decisionale. Scoprire dove risiede la propria vera bussola per fare scelte corrette e pienamente allineate.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CHI CONDUCE -->
    <section class="section-padding">
        <div class="container">
            <div class="ws-bio-grid" style="display: grid; grid-template-columns: 1fr 1fr; align-items: center; gap: 4rem;">
                <div>
                    <h2 class="serif" style="font-size: 3.5rem; margin-bottom: 1rem;">Chi conduce</h2>
                    <p class="serif italic" style="color: var(--primary-color); font-size: 1.5rem; margin-bottom: 2rem;">Human Design Analyst & Mental Advisor</p>
                    <p style="line-height: 1.8; font-size: 1.15rem; margin-bottom: 1.5rem; color: #444;">
                        Valentina traduce la complessità del sistema BG5® in <strong>istruzioni pratiche</strong> per la vita quotidiana, con un approccio logico e diretto.
                    </p>
                    <p style="line-height: 1.8; font-size: 1.15rem; color: #444;">
                        Il suo obiettivo è fornire una chiave di lettura strutturale della propria natura per eliminare le frizioni energetiche e vivere con chiarezza.
                    </p>
                </div>
                <div style="border-radius: 40px; overflow: hidden; box-shadow: 0 40px 80px -15px rgba(0,0,0,0.12);">
                    <img src="{{ grav.base_url }}/user/pages/assets/valentina.jpg"
                         alt="Valentina Russo"
                         style="width: 100%; height: auto; display: block;">
                </div>
            </div>
        </div>
    </section>

    <!-- VANTAGGI PER IL CENTRO -->
    <section class="ws-vantaggi" style="background: linear-gradient(145deg, #B68397 0%, #7a5c6e 100%); color: white; border-radius: 40px; margin: 2rem 1rem; padding: 5rem 2rem;">
        <div class="container">
            <h2 class="serif text-center" style="color: white; font-size: 3rem; margin-bottom: 4rem;">
                Perché ospitare questo workshop?
            </h2>
            <div class="blog-grid">
                <div class="blog-card" style="background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.2); color: white; border-radius: 24px;">
                    <div class="ws-card-inner" style="padding: 2.5rem;">
                        <h3 style="color: white; margin-bottom: 1rem; font-family: var(--font-heading); font-size: 1.5rem;">Trend Attuale</h3>
                        <p style="line-height: 1.7; opacity: 0.95; margin: 0;">Lo Human Design è un argomento di fortissimo richiamo attualmente nel mondo olistico e della crescita personale.</p>
                    </div>
                </div>
                <div class="blog-card" style="background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.2); color: white; border-radius: 24px;">
                    <div class="ws-card-inner" style="padding: 2.5rem;">
                        <h3 style="color: white; margin-bottom: 1rem; font-family: var(--font-heading); font-size: 1.5rem;">Nuova Acquisizione</h3>
                        <p style="line-height: 1.7; opacity: 0.95; margin: 0;">L'evento funge da magnete. È uno strumento eccellente per attirare e generare nuova clientela per la struttura ospitante.</p>
                    </div>
                </div>
                <div class="blog-card" style="background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.2); color: white; border-radius: 24px;">
                    <div class="ws-card-inner" style="padding: 2.5rem;">
                        <h3 style="color: white; margin-bottom: 1rem; font-family: var(--font-heading); font-size: 1.5rem;">Pionierismo</h3>
                        <p style="line-height: 1.7; opacity: 0.95; margin: 0;">In Italia è ancora un approccio nuovo e incontaminato. Ospitarlo ora offre un netto vantaggio competitivo rispetto agli altri centri della zona.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- PROPOSTA ECONOMICA -->
    <section class="section-padding">
        <div class="container" style="max-width: 960px;">
            <h2 class="serif text-center" style="color: var(--primary-color); margin-bottom: 5rem; font-size: 2.75rem;">
                Un modello Win-Win
            </h2>
            <div class="ws-pricing-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 3rem;">
                <!-- CARD A -->
                <div class="blog-card" style="border: 2.5px solid var(--primary-color); position: relative; background: white; border-radius: 32px; box-shadow: 0 20px 40px rgba(0,0,0,0.05);">
                    <div class="ws-card-inner" style="padding: 2.5rem; padding-top: 3rem;">
                        <div style="display: inline-block; background: var(--primary-color); color: white; padding: 0.6rem 1.5rem; border-radius: 50px; font-size: 0.85rem; font-weight: 800; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 1.75rem; box-shadow: 0 5px 15px rgba(182,131,151,0.3);">
                            ★ Modello Consigliato
                        </div>
                        <h3 style="color: var(--primary-color); margin-bottom: 0.5rem; font-size: 1.4rem;">Opzione A</h3>
                        <p style="font-weight: 800; font-size: 1.75rem; margin-bottom: 1.25rem; color: var(--text-color); line-height: 1;">Revenue Share</p>
                        <p style="line-height: 1.8; color: #555; margin: 0;">Il Centro trattiene il <strong>30%</strong> sull'intero incasso. <strong>Nessun costo fisso o rischio imprenditoriale.</strong></p>
                    </div>
                </div>
                <!-- CARD B -->
                <div class="blog-card" style="border-radius: 32px; border: 1px solid var(--soft-gray); background: white;">
                    <div style="padding: 2.5rem; padding-top: 3.5rem;">
                        <h3 style="color: #666; margin-bottom: 0.5rem; font-size: 1.4rem;">Opzione B</h3>
                        <p style="font-weight: 800; font-size: 1.75rem; margin-bottom: 1.25rem; color: var(--text-color); line-height: 1;">Flat Fee</p>
                        <p style="line-height: 1.8; color: #555; margin: 0;">Il gettone per la masterclass è da concordare e verrà quantificato di volta in volta in base alla location e alla capienza. Il Centro gestisce autonomamente il prezzo del biglietto, trattenendo il surplus.</p>
                    </div>
                </div>
            </div>
            <p style="margin-top: 4rem; font-style: italic; color: #999; text-align: center; font-size: 1rem; max-width: 700px; margin-left: auto; margin-right: auto;">
                * È possibile prevedere giornate di Letture Individuali Human Design nei giorni successivi, portando traffico ricorrente al Centro.
            </p>
        </div>
    </section>

    <!-- CTA FINALE -->
    <section class="section-padding" style="background: white; border-top: 1px solid var(--soft-gray); text-align: center;">
        <div class="container" style="max-width: 800px;">
            <h2 class="serif" style="font-size: clamp(2rem, 5vw, 3.5rem); margin-bottom: 2rem;">
                Collaboriamo?
            </h2>
            <p style="font-size: 1.35rem; line-height: 1.6; opacity: 0.9; margin-bottom: 3.5rem; max-width: 650px; margin-left: auto; margin-right: auto;">
                Prenota una call interlocutoria di 15 minuti per valutare fattibilità e date per il tuo centro.
            </p>
            <div style="display: flex; flex-direction: column; gap: 2rem; align-items: center;">
                <a href="https://calendly.com/valentinarusso-studioyouniverse" target="_blank" rel="noopener noreferrer" class="btn btn-primary" style="padding: 1.4rem 4rem; font-size: 1.25rem; border-radius: 60px; box-shadow: 0 15px 30px rgba(182,131,151,0.25);">
                    Prenota Call Conoscitiva
                </a>
                <div style="font-size: 1.2rem; color: var(--text-color);">
                    Email: <a href="mailto:valentina@studioyouniverse.it" style="color: var(--primary-color); font-weight: 600; text-decoration: none;">valentina@studioyouniverse.it</a>
                </div>
            </div>
        </div>
    </section>

</main>
{% endblock %}
