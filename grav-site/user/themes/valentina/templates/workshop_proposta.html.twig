{% extends 'partials/base.html.twig' %}

{% block title %}Workshop Scopri il tuo Disegno | Valentina Russo{% endblock %}

{% block content %}
<style>
/* ── Mobile-first overrides ─────────────────────────────────── */

/* Touch-action su tutti gli elementi interattivi */
button, input, select, label, a {
    touch-action: manipulation;
}

/* Bottone full-width + tappo ottimale su mobile */
#ws-submit {
    width: 100%;
    min-height: 52px;
}

/* Day-label touch target minimo 44px */
.ws-day-label {
    min-height: 44px;
    padding: 0.6rem 1.1rem;
    align-items: center;
}

/* Focus ring accessibile (keyboard + a11y) */
input:focus-visible, select:focus-visible, button:focus-visible {
    outline: 3px solid var(--primary-color);
    outline-offset: 2px;
}

/* ── 768px ──────────────────────────────────────────────────── */
@media (max-width: 768px) {
    /* Chi conduce: colonna singola, foto sotto */
    .ws-bio-grid {
        grid-template-columns: 1fr !important;
        gap: 2rem !important;
    }
    .ws-bio-grid h2 {
        font-size: clamp(1.9rem, 7vw, 2.5rem) !important;
        line-height: 1.15 !important;
    }

    /* Win-Win: colonna singola */
    .ws-pricing-grid {
        grid-template-columns: 1fr !important;
        gap: 2rem !important;
    }

    /* Sezione vantaggi */
    .ws-vantaggi {
        border-radius: 24px !important;
        margin: 1rem 0.75rem !important;
        padding: 3rem 1.5rem !important;
    }
    .ws-vantaggi h2 { font-size: 2rem !important; margin-bottom: 2rem !important; }

    /* Card padding ridotto */
    .ws-card-inner { padding: 1.75rem !important; }

    /* Certificazione */
    .ws-cert-box { padding: 2rem 1.5rem !important; }

    /* Sezioni padding verticale */
    .ws-section-v { padding-bottom: 3rem !important; }

    /* "Il Concetto" card interna */
    .ws-concetto-inner { padding: 2.5rem 1.5rem !important; }

    /* Hero: meno padding verticale */
    .ws-hero { padding-top: 3.5rem !important; padding-bottom: 3.5rem !important; }

    /* Format badge: wrap su 2 righe se necessario */
    .ws-format-badge {
        display: flex !important;
        flex-wrap: wrap !important;
        justify-content: center !important;
        gap: 0.35rem 0.75rem !important;
        padding: 0.85rem 1.25rem !important;
        text-align: center !important;
    }
}

/* ── 480px — piccoli phone (iPhone SE, 375px) ───────────────── */
@media (max-width: 480px) {
    .ws-bio-grid h2 {
        font-size: 1.85rem !important;
    }
    .ws-vantaggi {
        margin: 0.75rem 0.5rem !important;
        padding: 2.5rem 1.25rem !important;
    }
    .ws-vantaggi h2 { font-size: 1.75rem !important; }
    .ws-card-inner { padding: 1.4rem !important; }
    .ws-cert-box { padding: 1.75rem 1.1rem !important; }
    .ws-concetto-inner { padding: 2rem 1.1rem !important; }

    /* Day checkboxes: full-width su phone piccoli */
    .ws-days-wrap { flex-direction: column !important; }
    .ws-day-label { width: 100% !important; justify-content: flex-start !important; }

    /* Prezzi: testo più compatto */
    .ws-pricing-grid .ws-price-title { font-size: 1.4rem !important; }
}

/* Desktop: bottone auto-width */
@media (min-width: 769px) {
    #ws-submit { width: auto; min-width: 260px; }
}
</style>
<main style="background-color: var(--bg-color);">
    <!-- HERO -->
    <section class="section-padding ws-hero" style="background: linear-gradient(135deg, rgba(182, 131, 151, 0.05) 0%, rgba(93, 174, 177, 0.05) 100%); padding-top: 5rem; padding-bottom: 5rem; text-align: center;">
        <div class="container" style="max-width: 900px;">
            <p class="text-uppercase" style="color: var(--primary-color); font-weight: 700; font-size: 0.85rem; letter-spacing: 2px; margin-bottom: 1.5rem;">
                Per Centri Olistici
            </p>
            <h1 class="serif" style="font-size: clamp(2.5rem, 8vw, 4.5rem); line-height: 1.1; margin-bottom: 1.5rem;">
                Scopri il tuo<br><em style="font-style: italic; color: var(--primary-color);">Disegno</em>
            </h1>
            <p class="serif italic" style="font-size: 1.5rem; color: #555; margin-bottom: 2.5rem; max-width: 800px; margin-left: auto; margin-right: auto; line-height: 1.6;">
                Un approccio pratico e operativo: al termine del workshop, ogni persona avrà le basi esatte per capire come operare e muoversi correttamente nel mondo secondo il proprio disegno individuale.
            </p>
            <div class="ws-format-badge" style="padding: 1rem 2rem; background: rgba(182, 131, 151, 0.08); display: inline-block; border-radius: 50px; font-weight: 600;">
                Format: <strong>Masterclass Interattiva</strong> | Durata: <strong>90-120 min</strong>
            </div>
        </div>
    </section>

    <!-- VIDEO -->
    <section class="ws-section-v" style="padding-bottom: 5rem;">
        <div class="container" style="max-width: 960px;">
            <div style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; border-radius: 24px; box-shadow: 0 40px 80px -20px rgba(0, 0, 0, 0.15); border: 1px solid var(--soft-gray); background: #000;">
                <iframe style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: 0;"
                    src="https://www.youtube-nocookie.com/embed/WPieOX8GoO0?rel=0"
                    title="Workshop Scopri il tuo Disegno - Valentina Russo"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                    allowfullscreen>
                </iframe>
            </div>
        </div>
    </section>

    <!-- CERTIFICAZIONE -->
    <section class="ws-section-v" style="padding-bottom: 5rem;">
        <div class="container" style="max-width: 900px; text-align: center;">
            <div class="ws-cert-box" style="display: inline-flex; flex-direction: column; align-items: center; gap: 1.5rem; background: white; border: 1px solid var(--soft-gray); border-radius: 32px; padding: 3rem; box-shadow: 0 10px 30px rgba(0,0,0,0.03);">
                <img src="{{ grav.base_url }}/user/themes/valentina/images/bg5-certified.png"
                     alt="BG5 Certified — Jovian Archive"
                     style="height: 90px; width: auto;">
                <p style="font-size: 1.05rem; line-height: 1.7; color: #555; max-width: 640px; margin: 0;">
                    Questo è l'<strong>unico logo ufficiale</strong> rilasciato da Jovian Archive — la casa madre del sistema BG5® e Human Design. 
                    Qualunque proposta priva di questa certificazione non garantisce l'accuratezza del metodo originale.
                </p>
            </div>
        </div>
    </section>

    <!-- IL CONCETTO -->
    <section class="section-padding" style="background: white;">
        <div class="container" style="max-width: 1000px;">
            <div class="blog-card" style="box-shadow: 0 20px 50px rgba(0,0,0,0.04); border-radius: 32px; overflow: hidden; border: 1px solid var(--soft-gray);">
                <div class="ws-concetto-inner" style="padding: 4rem 3rem; text-align: center;">
                    <h2 class="serif" style="color: var(--primary-color); margin-bottom: 2.5rem; font-size: clamp(2rem, 5vw, 2.75rem);">
                        Più di un oroscopo,<br>più di un test di personalità
                    </h2>
                    <p style="font-size: 1.3rem; line-height: 1.8; color: #444; margin-bottom: 3rem; max-width: 800px; margin-left: auto; margin-right: auto;">
                        I frequentatori dei centri olistici cercano risposte a domande profonde: <em>"Perché ripeto sempre gli stessi schemi?"</em>, <em>"Perché mi mancano le energie?"</em>, <em>"Come posso prendere decisioni migliori?"</em>
                    </p>
                    <div style="background: var(--bg-color); padding: 2.5rem; border-radius: 24px; border-left: 6px solid var(--primary-color); text-align: left;">
                        <p style="font-size: 1.15rem; line-height: 1.8; margin: 0;">
                            <strong>Lo Human Design</strong> sintetizza saggezze antiche (Astrologia, I-Ching, Sistema dei Chakra e <em>Cabala Ebraica</em>) e scienza moderna (Genetica e Fisica Quantistica). È lo strumento più avanzato per l'auto-conoscenza oggi disponibile.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CONTENUTO DELL'EVENTO -->
    <section class="section-padding" style="background: #fafafa;">
        <div class="container">
            <h2 class="serif text-center" style="color: var(--primary-color); margin-bottom: 4rem; font-size: 2.5rem;">
                Il contenuto dell'evento
            </h2>
            <div class="blog-grid">
                <div class="blog-card" style="border-radius: 24px; border: 1px solid var(--soft-gray); background: white;">
                    <div class="ws-card-inner" style="padding: 2.5rem;">
                        <div style="display: flex; align-items: center; gap: 1.25rem; margin-bottom: 1.25rem;">
                            <span style="font-size: 2.5rem; line-height: 1; color: var(--primary-color);">✦</span>
                            <h3 style="margin: 0; font-family: var(--font-heading); color: var(--primary-color); font-size: 1.5rem;">I Vantaggi dello Human Design</h3>
                        </div>
                        <p style="color: #666; line-height: 1.7; margin: 0;">Applicazioni pratiche e benefici reali nella vita quotidiana. Come utilizzare questa mappa meccanica per migliorare le proprie relazioni e capire le proprie dinamiche comportamentali.</p>
                    </div>
                </div>
                <div class="blog-card" style="border-radius: 24px; border: 1px solid var(--soft-gray); background: white;">
                    <div class="ws-card-inner" style="padding: 2.5rem;">
                        <div style="display: flex; align-items: center; gap: 1.25rem; margin-bottom: 1.25rem;">
                            <span style="font-size: 2.5rem; line-height: 1; color: var(--secondary-color);">❂</span>
                            <h3 style="margin: 0; font-family: var(--font-heading); color: var(--secondary-color); font-size: 1.5rem;">I Quattro Tipi Energetici</h3>
                        </div>
                        <p style="color: #666; line-height: 1.7; margin: 0;">Analisi delle diverse nature energetiche: Generatori, Proiettori, Manifestatori e Riflettori. Imparare a comprendere il modo corretto per processare l'energia senza resistenza e frustrazione.</p>
                    </div>
                </div>
                <div class="blog-card" style="border-radius: 24px; border: 1px solid var(--soft-gray); background: white;">
                    <div class="ws-card-inner" style="padding: 2.5rem;">
                        <div style="display: flex; align-items: center; gap: 1.25rem; margin-bottom: 1.25rem;">
                            <span style="font-size: 2.5rem; line-height: 1; color: var(--accent-color);">✧</span>
                            <h3 style="margin: 0; font-family: var(--font-heading); color: var(--accent-color); font-size: 1.5rem;">Strategia e Autorità</h3>
                        </div>
                        <p style="color: #666; line-height: 1.7; margin: 0;">Gli strumenti fondamentali e meccanici per il processo decisionale. Scoprire dove risiede la propria vera bussola per fare scelte corrette e pienamente allineate.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CHI CONDUCE -->
    <section class="section-padding">
        <div class="container">
            <div class="ws-bio-grid" style="display: grid; grid-template-columns: 1fr 1fr; align-items: center; gap: 4rem;">
                <div>
                    <h2 class="serif ws-bio-h2" style="font-size: clamp(2rem, 6vw, 3.5rem); margin-bottom: 1rem;">Chi conduce</h2>
                    <p class="serif italic" style="color: var(--primary-color); font-size: 1.5rem; margin-bottom: 2rem;">Human Design Analyst & Mental Advisor</p>
                    <p style="line-height: 1.8; font-size: 1.15rem; margin-bottom: 1.5rem; color: #444;">
                        Valentina traduce la complessità del sistema BG5® in <strong>istruzioni pratiche</strong> per la vita quotidiana, con un approccio logico e diretto.
                    </p>
                    <p style="line-height: 1.8; font-size: 1.15rem; color: #444;">
                        Il suo obiettivo è fornire una chiave di lettura strutturale della propria natura per eliminare le frizioni energetiche e vivere con chiarezza.
                    </p>
                </div>
                <div style="border-radius: 40px; overflow: hidden; box-shadow: 0 40px 80px -15px rgba(0,0,0,0.12);">
                    <img src="{{ grav.base_url }}/user/pages/assets/valentina.jpg"
                         alt="Valentina Russo"
                         style="width: 100%; height: auto; display: block;">
                </div>
            </div>
        </div>
    </section>

    <!-- VANTAGGI PER IL CENTRO -->
    <section class="ws-vantaggi" style="background: linear-gradient(145deg, #B68397 0%, #7a5c6e 100%); color: white; border-radius: 40px; margin: 2rem 1rem; padding: 5rem 2rem;">
        <div class="container">
            <h2 class="serif text-center" style="color: white; font-size: 3rem; margin-bottom: 4rem;">
                Perché ospitare questo workshop?
            </h2>
            <div class="blog-grid">
                <div class="blog-card" style="background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.2); color: white; border-radius: 24px;">
                    <div class="ws-card-inner" style="padding: 2.5rem;">
                        <h3 style="color: white; margin-bottom: 1rem; font-family: var(--font-heading); font-size: 1.5rem;">Trend Attuale</h3>
                        <p style="line-height: 1.7; opacity: 0.95; margin: 0;">Lo Human Design è un argomento di fortissimo richiamo attualmente nel mondo olistico e della crescita personale.</p>
                    </div>
                </div>
                <div class="blog-card" style="background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.2); color: white; border-radius: 24px;">
                    <div class="ws-card-inner" style="padding: 2.5rem;">
                        <h3 style="color: white; margin-bottom: 1rem; font-family: var(--font-heading); font-size: 1.5rem;">Nuova Acquisizione</h3>
                        <p style="line-height: 1.7; opacity: 0.95; margin: 0;">L'evento funge da magnete. È uno strumento eccellente per attirare e generare nuova clientela per la struttura ospitante.</p>
                    </div>
                </div>
                <div class="blog-card" style="background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.2); color: white; border-radius: 24px;">
                    <div class="ws-card-inner" style="padding: 2.5rem;">
                        <h3 style="color: white; margin-bottom: 1rem; font-family: var(--font-heading); font-size: 1.5rem;">Pionierismo</h3>
                        <p style="line-height: 1.7; opacity: 0.95; margin: 0;">In Italia è ancora un approccio nuovo e incontaminato. Ospitarlo ora offre un netto vantaggio competitivo rispetto agli altri centri della zona.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- PROPOSTA ECONOMICA -->
    <section class="section-padding">
        <div class="container" style="max-width: 960px;">
            <h2 class="serif text-center" style="color: var(--primary-color); margin-bottom: 5rem; font-size: 2.75rem;">
                Un modello Win-Win
            </h2>
            <div class="ws-pricing-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 3rem;">
                <!-- CARD A -->
                <div class="blog-card" style="border: 2.5px solid var(--primary-color); position: relative; background: white; border-radius: 32px; box-shadow: 0 20px 40px rgba(0,0,0,0.05);">
                    <div class="ws-card-inner" style="padding: 2.5rem; padding-top: 3rem;">
                        <div style="display: inline-block; background: var(--primary-color); color: white; padding: 0.6rem 1.5rem; border-radius: 50px; font-size: 0.85rem; font-weight: 800; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 1.75rem; box-shadow: 0 5px 15px rgba(182,131,151,0.3);">
                            ★ Modello Consigliato
                        </div>
                        <h3 style="color: var(--primary-color); margin-bottom: 0.5rem; font-size: 1.4rem;">Opzione A</h3>
                        <p class="ws-price-title" style="font-weight: 800; font-size: 1.75rem; margin-bottom: 1.25rem; color: var(--text-color); line-height: 1;">Revenue Share</p>
                        <p style="line-height: 1.8; color: #555; margin: 0;">Il Centro trattiene il <strong>30%</strong> sull'intero incasso. <strong>Nessun costo fisso o rischio imprenditoriale.</strong></p>
                    </div>
                </div>
                <!-- CARD B -->
                <div class="blog-card" style="border-radius: 32px; border: 1px solid var(--soft-gray); background: white;">
                    <div style="padding: 2.5rem; padding-top: 3.5rem;">
                        <h3 style="color: #666; margin-bottom: 0.5rem; font-size: 1.4rem;">Opzione B</h3>
                        <p class="ws-price-title" style="font-weight: 800; font-size: 1.75rem; margin-bottom: 1.25rem; color: var(--text-color); line-height: 1;">Flat Fee</p>
                        <p style="line-height: 1.8; color: #555; margin: 0;">Il gettone per la masterclass è da concordare e verrà quantificato di volta in volta in base alla location e alla capienza. Il Centro gestisce autonomamente il prezzo del biglietto, trattenendo il surplus.</p>
                    </div>
                </div>
            </div>
            <p style="margin-top: 4rem; font-style: italic; color: #999; text-align: center; font-size: 1rem; max-width: 700px; margin-left: auto; margin-right: auto;">
                * È possibile prevedere giornate di Letture Individuali Human Design nei giorni successivi, portando traffico ricorrente al Centro.
            </p>
        </div>
    </section>

    <!-- CTA FINALE — FORM RICHIESTA INFORMAZIONI -->
    <section class="section-padding" style="background: white; border-top: 1px solid var(--soft-gray);">
        <div class="container" style="max-width: 700px;">
            <h2 class="serif text-center" style="font-size: clamp(2rem, 5vw, 3.5rem); margin-bottom: 1.25rem;">
                Collaboriamo?
            </h2>
            <p style="font-size: 1.2rem; line-height: 1.6; color: #666; margin-bottom: 3rem; text-align: center; max-width: 580px; margin-left: auto; margin-right: auto;">
                Lascia i tuoi dati e ti ricontatteremo nelle fasce orarie che preferisci.
            </p>

            <!-- Form -->
            <form id="ws-contact-form" novalidate style="display: flex; flex-direction: column; gap: 1.25rem;">

                <div style="display: flex; flex-direction: column; gap: 0.4rem;">
                    <label for="ws-centro" style="font-weight: 700; font-size: 0.9rem; color: #444; letter-spacing: 0.03em;">Nome del centro <span style="color: var(--primary-color);">*</span></label>
                    <input id="ws-centro" name="centro" type="text" required autocomplete="organization"
                        placeholder="Centro Olistico Esempio"
                        style="padding: 0.9rem 1.2rem; border: 1.5px solid #ddd; border-radius: 12px; font-size: 1rem; font-family: var(--font-body); transition: border-color 0.2s; outline: none; width: 100%; box-sizing: border-box;">
                </div>

                <div style="display: flex; flex-direction: column; gap: 0.4rem;">
                    <label for="ws-referente" style="font-weight: 700; font-size: 0.9rem; color: #444; letter-spacing: 0.03em;">Nome del referente <span style="color: var(--primary-color);">*</span></label>
                    <input id="ws-referente" name="referente" type="text" required autocomplete="name"
                        placeholder="Nome e Cognome"
                        style="padding: 0.9rem 1.2rem; border: 1.5px solid #ddd; border-radius: 12px; font-size: 1rem; font-family: var(--font-body); transition: border-color 0.2s; outline: none; width: 100%; box-sizing: border-box;">
                </div>

                <div style="display: flex; flex-direction: column; gap: 0.4rem;">
                    <label for="ws-telefono" style="font-weight: 700; font-size: 0.9rem; color: #444; letter-spacing: 0.03em;">Numero di telefono <span style="color: var(--primary-color);">*</span></label>
                    <input id="ws-telefono" name="telefono" type="tel" required autocomplete="tel"
                        placeholder="+39 000 000 0000"
                        style="padding: 0.9rem 1.2rem; border: 1.5px solid #ddd; border-radius: 12px; font-size: 1rem; font-family: var(--font-body); transition: border-color 0.2s; outline: none; width: 100%; box-sizing: border-box;">
                </div>

                <div style="display: flex; flex-direction: column; gap: 0.4rem;">
                    <label for="ws-fascia" style="font-weight: 700; font-size: 0.9rem; color: #444; letter-spacing: 0.03em;">Fascia oraria preferita</label>
                    <select id="ws-fascia" name="fascia"
                        style="padding: 0.9rem 1.2rem; border: 1.5px solid #ddd; border-radius: 12px; font-size: 1rem; font-family: var(--font-body); background: white; outline: none; width: 100%; box-sizing: border-box; appearance: none; background-image: url('data:image/svg+xml,<svg xmlns=&quot;http://www.w3.org/2000/svg&quot; viewBox=&quot;0 0 24 24&quot; fill=&quot;none&quot; stroke=&quot;%23888&quot; stroke-width=&quot;2&quot;><path d=&quot;M6 9l6 6 6-6&quot;/></svg>'); background-repeat: no-repeat; background-position: right 1rem center; background-size: 1.2em; cursor: pointer;">
                        <option value="">— Seleziona —</option>
                        <option value="Mattina (9:00–12:00)">Mattina (9:00–12:00)</option>
                        <option value="Primo pomeriggio (12:00–15:00)">Primo pomeriggio (12:00–15:00)</option>
                        <option value="Pomeriggio (15:00–18:00)">Pomeriggio (15:00–18:00)</option>
                        <option value="Sera (18:00–20:00)">Sera (18:00–20:00)</option>
                    </select>
                </div>

                <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                    <span style="font-weight: 700; font-size: 0.9rem; color: #444; letter-spacing: 0.03em;">Giorni preferiti</span>
                    <div class="ws-days-wrap" style="display: flex; flex-wrap: wrap; gap: 0.6rem;">
                        {% for giorno in ["Lunedì","Martedì","Mercoledì","Giovedì","Venerdì","Sabato"] %}
                        <label style="display: flex; align-items: center; gap: 0.5rem; padding: 0.5rem 1rem; border: 1.5px solid #ddd; border-radius: 50px; cursor: pointer; font-size: 0.95rem; user-select: none; transition: all 0.15s;" class="ws-day-label">
                            <input type="checkbox" name="giorni[]" value="{{ giorno }}" style="accent-color: var(--primary-color); width: 1rem; height: 1rem;">
                            {{ giorno }}
                        </label>
                        {% endfor %}
                    </div>
                </div>

                <div id="ws-error" style="display:none; padding: 0.9rem 1.2rem; background: #fff0f0; border: 1px solid #f5c6c6; border-radius: 12px; color: #c0392b; font-size: 0.95rem;"></div>

                <button type="submit" id="ws-submit"
                    style="margin-top: 0.5rem; padding: 1.2rem 2.5rem; background: var(--primary-color); color: white; border: none; border-radius: 60px; font-size: 1.1rem; font-weight: 800; cursor: pointer; font-family: var(--font-body); letter-spacing: 0.02em; box-shadow: 0 10px 25px rgba(182,131,151,0.3); transition: opacity 0.2s, transform 0.15s;">
                    Richiedi informazioni
                </button>
            </form>

            <!-- Stato success -->
            <div id="ws-success" style="display:none; text-align:center; padding: 3rem 2rem; background: rgba(93,174,177,0.08); border: 1px solid rgba(93,174,177,0.3); border-radius: 24px; margin-top: 1rem;">
                <div style="font-size: 2.5rem; margin-bottom: 1rem;">✓</div>
                <h3 style="font-family: var(--font-heading); color: var(--secondary-color); margin-bottom: 0.75rem;">Richiesta inviata!</h3>
                <p style="color: #555; line-height: 1.7; margin: 0;">Il team di Valentina ti contatterà a breve nelle fasce orarie indicate.</p>
            </div>
        </div>
    </section>

    <script>
    (function () {
        var form    = document.getElementById('ws-contact-form');
        var success = document.getElementById('ws-success');
        var errBox  = document.getElementById('ws-error');
        var btn     = document.getElementById('ws-submit');

        // Focus style per i campi
        form.querySelectorAll('input[type="text"],input[type="tel"],select').forEach(function (el) {
            el.addEventListener('focus',  function () { this.style.borderColor = 'var(--primary-color)'; });
            el.addEventListener('blur',   function () { this.style.borderColor = '#ddd'; });
        });

        // Hover/tap style per i checkbox-giorno
        form.querySelectorAll('.ws-day-label').forEach(function (lbl) {
            var cb = lbl.querySelector('input[type="checkbox"]');
            function applyChecked() {
                lbl.style.background  = cb.checked ? 'rgba(182,131,151,0.08)' : '';
                lbl.style.borderColor = cb.checked ? 'var(--primary-color)' : '#ddd';
                lbl.style.fontWeight  = cb.checked ? '700' : '';
            }
            lbl.addEventListener('mouseenter', function () { lbl.style.borderColor = 'var(--primary-color)'; });
            lbl.addEventListener('mouseleave', function () { lbl.style.borderColor = cb.checked ? 'var(--primary-color)' : '#ddd'; });
            cb.addEventListener('change', applyChecked);
        });

        form.addEventListener('submit', function (e) {
            e.preventDefault();
            errBox.style.display = 'none';

            var centro    = form.querySelector('[name="centro"]').value.trim();
            var referente = form.querySelector('[name="referente"]').value.trim();
            var telefono  = form.querySelector('[name="telefono"]').value.trim();

            if (!centro || !referente || !telefono) {
                errBox.textContent = 'Compila i campi obbligatori: nome del centro, referente e telefono.';
                errBox.style.display = 'block';
                return;
            }

            btn.disabled = true;
            btn.textContent = 'Invio in corso…';

            var data = new FormData(form);

            fetch('/workshop-contact.php', {
                method: 'POST',
                body: data
            })
            .then(function (r) { return r.json(); })
            .then(function (json) {
                if (json.ok) {
                    form.style.display    = 'none';
                    success.style.display = 'block';
                } else {
                    errBox.textContent  = 'Si è verificato un errore. Scrivi direttamente a staff@valentinarussobg5.com';
                    errBox.style.display = 'block';
                    btn.disabled    = false;
                    btn.textContent = 'Richiedi informazioni';
                }
            })
            .catch(function () {
                errBox.textContent  = 'Problema di connessione. Scrivi direttamente a staff@valentinarussobg5.com';
                errBox.style.display = 'block';
                btn.disabled    = false;
                btn.textContent = 'Richiedi informazioni';
            });
        });
    })();
    </script>

</main>
{% endblock %}
