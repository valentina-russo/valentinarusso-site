{% extends 'partials/base.html.twig' %}

{% block title %}{{ page.title }} | Valentina Russo{% endblock %}

{% block extra_css %}
<style>
  .hd-tool-wrap {
    max-width: 680px;
    margin: 0 auto;
    padding: var(--space-lg) var(--space-md);
  }
  .hd-tool-intro {
    text-align: center;
    margin-bottom: var(--space-lg);
  }
  .hd-tool-intro h1 {
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    margin-bottom: 0.75rem;
  }
  .hd-tool-intro p {
    color: var(--text-muted, #666);
    font-size: 1rem;
    max-width: 520px;
    margin: 0 auto;
  }
  .hd-form-card {
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.07);
    padding: 2rem;
  }
  .hd-field {
    margin-bottom: 1.25rem;
  }
  .hd-field label {
    display: block;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--primary-color);
    margin-bottom: 0.4rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .hd-field select,
  .hd-field textarea {
    width: 100%;
    border: 1.5px solid #e0dbd7;
    border-radius: 8px;
    padding: 0.7rem 0.9rem;
    font-family: inherit;
    font-size: 0.95rem;
    color: #333;
    background: #faf9f8;
    transition: border-color 0.2s;
    box-sizing: border-box;
  }
  .hd-field select:focus,
  .hd-field textarea:focus {
    outline: none;
    border-color: var(--primary-color);
    background: #fff;
  }
  .hd-field textarea {
    resize: vertical;
    min-height: 100px;
  }
  .hd-char-counter {
    font-size: 0.75rem;
    color: #aaa;
    text-align: right;
    margin-top: 0.3rem;
  }
  .hd-char-counter.over { color: #e55; }
  .hd-submit-btn {
    width: 100%;
    padding: 0.9rem 1.5rem;
    background: var(--primary-color);
    color: #fff;
    border: none;
    border-radius: 10px;
    font-family: inherit;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.1s;
    margin-top: 0.5rem;
  }
  .hd-submit-btn:hover:not(:disabled) { opacity: 0.88; }
  .hd-submit-btn:active:not(:disabled) { transform: scale(0.99); }
  .hd-submit-btn:disabled { opacity: 0.5; cursor: not-allowed; }

  /* Loading */
  .hd-loading {
    display: none;
    text-align: center;
    padding: 2rem;
    color: var(--primary-color);
    font-style: italic;
  }
  .hd-spinner {
    width: 32px; height: 32px;
    border: 3px solid #e0dbd7;
    border-top-color: var(--primary-color);
    border-radius: 50%;
    animation: hd-spin 0.8s linear infinite;
    margin: 0 auto 1rem;
  }
  @keyframes hd-spin { to { transform: rotate(360deg); } }

  /* Risultato */
  .hd-result {
    display: none;
    margin-top: 2rem;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.4s, transform 0.4s;
  }
  .hd-result.visible {
    display: block;
    opacity: 1;
    transform: translateY(0);
  }
  .hd-result-card {
    border-radius: 14px;
    padding: 1.5rem;
    margin-bottom: 1rem;
  }
  .hd-result-card h3 {
    font-size: 0.78rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    margin: 0 0 0.75rem;
  }
  .hd-result-card p {
    margin: 0;
    line-height: 1.7;
    font-size: 0.97rem;
  }
  .hd-card-pillola  { background: #f0ebe8; border-left: 4px solid var(--primary-color); }
  .hd-card-pillola h3 { color: var(--primary-color); }
  .hd-card-diagnosi { background: #f5f0f8; border-left: 4px solid var(--secondary-color, #7a5c9e); }
  .hd-card-diagnosi h3 { color: var(--secondary-color, #7a5c9e); }
  .hd-card-upsell   { background: linear-gradient(135deg, #fdf4f0, #f8ece8); border-left: 4px solid var(--accent-color); }
  .hd-card-upsell h3 { color: var(--accent-color); }
  .hd-card-upsell p { font-weight: 500; }

  .hd-reset-btn {
    display: block;
    margin: 0.5rem auto 0;
    background: none;
    border: 1.5px solid #ccc;
    border-radius: 8px;
    padding: 0.5rem 1.2rem;
    font-family: inherit;
    font-size: 0.85rem;
    cursor: pointer;
    color: #666;
    transition: border-color 0.2s;
  }
  .hd-reset-btn:hover { border-color: var(--primary-color); color: var(--primary-color); }

  /* CTA zone — inside upsell card */
  .hd-cta-zone {
    margin-top: 1.25rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(0,0,0,0.06);
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  .hd-cta-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.95rem 1.5rem;
    background: var(--primary-color);
    color: #fff;
    border: none;
    border-radius: 10px;
    font-family: inherit;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    text-align: center;
    text-decoration: none;
    transition: opacity 0.2s, transform 0.1s;
    box-sizing: border-box;
  }
  .hd-cta-btn:hover { opacity: 0.88; color: #fff; }
  .hd-cta-btn:active { transform: scale(0.99); }

  .hd-cta-whatsapp {
    background: #25D366;
  }
  .hd-cta-whatsapp:hover { opacity: 0.88; color: #fff; }
  .hd-cta-whatsapp svg { flex-shrink: 0; }

  /* Social proof */
  .hd-social-proof {
    text-align: center;
    font-size: 0.8rem;
    color: #999;
    margin-top: 0.5rem;
    letter-spacing: 0.01em;
  }
  .hd-social-proof span {
    font-weight: 700;
    color: var(--primary-color);
  }

  .hd-error {
    display: none;
    background: #fff0f0;
    border: 1.5px solid #f5a5a5;
    border-radius: 10px;
    padding: 1rem 1.25rem;
    color: #c0392b;
    font-size: 0.9rem;
    margin-top: 1rem;
  }

  @media (max-width: 480px) {
    .hd-form-card { padding: 1.25rem; }
  }
</style>
{% endblock %}

{% block content %}
<main>
  <div class="hd-tool-wrap">

    <div class="hd-tool-intro" data-animate>
      <p class="eyebrow" style="font-size:0.78rem; text-transform:uppercase; letter-spacing:.08em; color:var(--primary-color); font-weight:700; margin-bottom:.5rem;">Strumento Gratuito</p>
      <h1>{{ page.title }}</h1>
      <p>{{ page.header.description ?? 'Inserisci i dati qui sotto e ricevi un\'analisi immediata della dinamica tra voi.' }}</p>
    </div>

    <div class="hd-form-card" data-animate>
      <form id="hd-form" novalidate>

        <div class="hd-field">
          <label for="tipo_utente">Il tuo Tipo</label>
          <select id="tipo_utente" name="tipo_utente" required>
            <option value="" disabled selected>Seleziona il tuo Tipo…</option>
            <option>Generatore</option>
            <option>Generatore Manifestante</option>
            <option>Proiettore</option>
            <option>Manifestatore</option>
            <option>Riflettore</option>
          </select>
        </div>

        <div class="hd-field">
          <label for="tipo_altro">Il Tipo dell'altra persona</label>
          <select id="tipo_altro" name="tipo_altro" required>
            <option value="" disabled selected>Seleziona il Tipo dell'altra persona…</option>
            <option>Generatore</option>
            <option>Generatore Manifestante</option>
            <option>Proiettore</option>
            <option>Manifestatore</option>
            <option>Riflettore</option>
          </select>
        </div>

        <div class="hd-field">
          <label for="relazione">Che tipo di relazione è?</label>
          <select id="relazione" name="relazione" required>
            <option value="" disabled selected>Seleziona il tipo di relazione…</option>
            <option>Partner Sentimentale</option>
            <option>Genitore/Figlio</option>
            <option>Colleghi/Lavoro</option>
            <option>Amicizia</option>
          </select>
        </div>

        <div class="hd-field">
          <label for="problema">Qual è il problema o la dinamica da risolvere?</label>
          <textarea id="problema" name="problema" maxlength="300" placeholder="Descrivi brevemente la situazione o il problema relazionale (max 300 caratteri)…" required></textarea>
          <div class="hd-char-counter"><span id="char-count">0</span>/300</div>
        </div>

        <button type="submit" class="hd-submit-btn" id="submit-btn">
          Genera la tua Analisi Relazionale
        </button>
      </form>

      <div class="hd-loading" id="hd-loading">
        <div class="hd-spinner"></div>
        <p>Il nostro oracolo sta consultando gli archivi…</p>
      </div>

      <div class="hd-error" id="hd-error"></div>
    </div>

    <div class="hd-result" id="hd-result">
      <div class="hd-result-card hd-card-pillola" id="card-pillola">
        <h3>La Pillola</h3>
        <p id="text-pillola"></p>
      </div>
      <div class="hd-result-card hd-card-diagnosi" id="card-diagnosi">
        <h3>La Diagnosi</h3>
        <p id="text-diagnosi"></p>
      </div>
      <div class="hd-result-card hd-card-upsell" id="card-upsell">
        <h3>Vuoi capire tutto?</h3>
        <p id="text-upsell"></p>
        <div class="hd-cta-zone">
          <a href="{{ grav.base_url }}/contatti" class="hd-cta-btn">Prenota una consulenza con Valentina</a>
          <a href="https://wa.me/393791037653?text=Ciao%20Valentina%2C%20ho%20appena%20fatto%20l%27analisi%20relazionale%20sul%20tuo%20sito%20e%20vorrei%20approfondire%20la%20mia%20situazione." class="hd-cta-btn hd-cta-whatsapp" target="_blank" rel="noopener">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Scrivimi su WhatsApp
          </a>
          <p class="hd-social-proof"><span id="analisi-count">380</span> analisi generate questo mese</p>
        </div>
      </div>
      <button class="hd-reset-btn" id="reset-btn">Fai una nuova analisi</button>
    </div>

  </div>
</main>
{% endblock %}

{% block scripts %}
<script>
(function () {
  const API_URL = "{{ page.header.api_url ?? 'http://localhost:8000' }}";

  const form = document.getElementById('hd-form');
  const submitBtn = document.getElementById('submit-btn');
  const loading = document.getElementById('hd-loading');
  const errorBox = document.getElementById('hd-error');
  const resultBox = document.getElementById('hd-result');
  const resetBtn = document.getElementById('reset-btn');
  const charCount = document.getElementById('char-count');
  const textarea = document.getElementById('problema');

  // Warm-up: ping silenzioso a /health per svegliare Render prima che l'utente invii
  fetch(API_URL + '/health', { method: 'GET' }).catch(() => {});

  // Social proof: carica contatore salvato
  var savedCount = localStorage.getItem('hd_analisi_count');
  if (savedCount) {
    document.getElementById('analisi-count').textContent = savedCount;
  }

  // Contatore caratteri
  textarea.addEventListener('input', function () {
    const n = this.value.length;
    charCount.textContent = n;
    charCount.parentElement.classList.toggle('over', n > 300);
  });

  // Submit
  form.addEventListener('submit', async function (e) {
    e.preventDefault();

    const payload = {
      tipo_utente: document.getElementById('tipo_utente').value,
      tipo_altro: document.getElementById('tipo_altro').value,
      relazione: document.getElementById('relazione').value,
      problema: textarea.value.trim(),
    };

    if (!payload.tipo_utente || !payload.tipo_altro || !payload.relazione || !payload.problema) {
      showError('Compila tutti i campi prima di procedere.');
      return;
    }

    setLoading(true);

    try {
      const resp = await fetch(API_URL + '/analisi', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      if (!resp.ok) {
        if (resp.status === 429) {
          throw new Error('Hai inviato troppe richieste. Attendi qualche minuto e riprova.');
        }
        const err = await resp.json().catch(() => ({}));
        throw new Error(err.detail || 'Errore del server (' + resp.status + ')');
      }

      const data = await resp.json();
      renderResult(data.result);

      // Incrementa contatore social proof (locale, parte da 380)
      var cnt = parseInt(localStorage.getItem('hd_analisi_count') || '380', 10) + 1;
      localStorage.setItem('hd_analisi_count', String(cnt));
      document.getElementById('analisi-count').textContent = cnt;
    } catch (err) {
      showError('Si è verificato un errore: ' + err.message + '. Riprova tra qualche istante.');
    } finally {
      setLoading(false);
    }
  });

  // Helpers
  function setLoading(on) {
    submitBtn.disabled = on;
    loading.style.display = on ? 'block' : 'none';
    errorBox.style.display = 'none';
    if (on) {
      resultBox.classList.remove('visible');
      resultBox.style.display = 'none';
    }
  }

  function showError(msg) {
    errorBox.textContent = msg;
    errorBox.style.display = 'block';
  }

  function renderResult(text) {
    const pillola = extractSection(text, '[LA PILLOLA]', '[LA DIAGNOSI]');
    const diagnosi = extractSection(text, '[LA DIAGNOSI]', "[L'UPSELL]");
    const upsell   = extractSection(text, "[L'UPSELL]", null);

    document.getElementById('text-pillola').textContent = pillola || text;
    document.getElementById('text-diagnosi').textContent = diagnosi;
    document.getElementById('text-upsell').textContent = upsell;

    // Mostra/nascondi sezioni vuote
    document.getElementById('card-diagnosi').style.display = diagnosi ? 'block' : 'none';
    document.getElementById('card-upsell').style.display = upsell ? 'block' : 'none';

    // Nascondi il form, mostra solo i risultati
    form.style.display = 'none';

    resultBox.style.display = 'block';
    requestAnimationFrame(() => resultBox.classList.add('visible'));
    resultBox.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // Reset: torna al form per una nuova analisi
  resetBtn.addEventListener('click', function () {
    resultBox.classList.remove('visible');
    resultBox.style.display = 'none';
    form.reset();
    form.style.display = 'block';
    charCount.textContent = '0';
    document.querySelector('.hd-form-card').scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  function extractSection(text, startTag, endTag) {
    const start = text.indexOf(startTag);
    if (start === -1) return '';
    const content = text.slice(start + startTag.length);
    const end = endTag ? content.indexOf(endTag) : -1;
    return (end === -1 ? content : content.slice(0, end)).trim();
  }
})();
</script>
{% endblock %}
