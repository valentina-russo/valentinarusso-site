{% extends 'partials/base.html.twig' %}

{% block title %}Valentina Russo | Corporate BG5&reg; Consulting{% endblock %}

{% block extra_css %}
<link rel="stylesheet" href="{{ theme_url }}/css/hero-aziende.css?v=20260311">
{% endblock %}

{% block content %}
<main>
    <!-- NEW HERO V2 AZIENDE -->
    <section class="hero-v2">
        <div class="hero-text">
            <p class="eyebrow">Consulenza Strategica per Aziende e Leader</p>
            <h1 class="headline">
                Eccellenza<br>
                <em>meccanica</em><br>
                per il tuo team
            </h1>
            <p class="subline">
                L&rsquo;allineamento perfetto tra talento individuale e fatturato aziendale.
                Trasformiamo l&rsquo;energia del capitale umano in risultati finanziari misurabili.
            </p>
            <div class="benefits">
                <div class="benefit-pill"><span>&uarr;</span> Aumento del fatturato</div>
                <div class="benefit-pill"><span>&#11041;</span> Team engineering</div>
                <div class="benefit-pill"><span>&#9672;</span> Leadership efficace</div>
            </div>
            <div class="cta-group">
                <a href="{{ grav.base_url }}/aziende/servizi" class="btn-primary-v2">Richiedi una consulenza &rarr;</a>
                <a href="{{ grav.base_url }}/genera-carta" class="btn-secondary-v2">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10" />
                        <polygon points="10 8 16 12 10 16 10 8" />
                    </svg>
                    <span style="font-size:.78rem;">Analizza la tua carta qui</span>
                </a>
            </div>
            <div class="cert-pill">
                <img src="{{ theme_url }}/images/bg5-certified.png" alt="BG5 Certified" style="height: 40px; width: auto; object-fit: contain;">
                Certified Career &amp; Business Professional
            </div>
        </div>

        <div class="hero-visual">
            <div class="image-wrapper">
                <div class="dot-grid"></div>
                <img src="{{ grav.base_url }}/user/pages/assets/valentina-aziende-hero2.png" alt="Valentina Russo &ndash; BG5 Corporate Consultant" class="photo-blob" />
            </div>
        </div>
    </section>

    <!-- Funnel Corporate -->
    <section class="section-padding" style="background: transparent;">
        <div class="container">
            <div class="text-center" style="margin-bottom: var(--space-lg); max-width: 800px; margin-inline: auto;">
                <h2 data-animate style="margin-bottom: 1rem; color: var(--primary-color);">Il Vantaggio Competitivo del BG5&reg;</h2>
                <p data-animate style="margin-bottom: 2rem;">
                    Il sistema BG5&reg; analizza le dinamiche nascoste che limitano la crescita del tuo business.
                    Trasformiamo le inefficienze in metriche oggettive per costruire team ad alte performance e leader carismatici.
                </p>
            </div>

            <div class="footer-grid" style="grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));">
                <div class="blog-card" data-animate>
                    <div class="blog-card-content text-center">
                        <h3 style="color: var(--primary-color);">Vuoi aumentare il fatturato?</h3>
                        <p class="text-small">Team engineering, allineamento chimico delle risorse e rimozione dei colli di bottiglia operativi.</p>
                        <a href="{{ grav.base_url }}/aziende/servizi" class="btn btn-primary" style="margin-top: 1rem; background-color: var(--accent-color); font-size: 0.8rem; padding: 0.8rem 1.2rem;">S&igrave;, lo voglio</a>
                    </div>
                </div>
                <div class="blog-card" data-animate>
                    <div class="blog-card-content text-center">
                        <h3 style="color: var(--primary-color);">Vorresti essere un buon leader?</h3>
                        <p class="text-small">Strumenti per C-Levels e Founder per prendere decisioni strategiche corrette secondo il proprio disegno.</p>
                        <a href="{{ grav.base_url }}/aziende/servizi" class="btn btn-primary" style="margin-top: 1rem; background-color: var(--secondary-color); font-size: 0.8rem; padding: 0.8rem 1.2rem;">S&igrave;, voglio essere un buon leader</a>
                    </div>
                </div>
                <div class="blog-card" data-animate>
                    <div class="blog-card-content text-center">
                        <h3 style="color: var(--primary-color);">Vuoi migliorare la vita del tuo team?</h3>
                        <p class="text-small">Corporate analysis per mappare talenti e conflitti dormienti, riducendo drasticamente il turnover.</p>
                        <a href="{{ grav.base_url }}/aziende/servizi" class="btn btn-primary" style="margin-top: 1rem; background-color: var(--primary-color); font-size: 0.8rem; padding: 0.8rem 1.2rem;">S&igrave;, voglio migliorare la vita del mio team</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="section-padding text-center hero-cta-band" style="color: var(--white); margin-top: 0;">
        <div class="container">
            <h2 style="margin-bottom: var(--space-md); color: var(--white);" data-animate>Soluzioni su misura per la tua realt&agrave;</h2>
            <p style="margin-bottom: var(--space-lg);" data-animate>Prenota una call esplorativa per capire come le metriche BG5&reg; possono ottimizzare il tuo business.</p>
            <a href="{{ grav.base_url }}/aziende/contatti" class="btn btn-outline" style="border-color: var(--white); color: var(--white);" data-animate>Richiedi una consulenza</a>
        </div>
    </section>
</main>
{% endblock %}
