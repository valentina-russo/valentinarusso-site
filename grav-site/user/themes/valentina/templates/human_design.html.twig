{% extends 'partials/base.html.twig' %}

{% block title %}{{ page.header.seo_title ?? page.title }} | Valentina Russo{% endblock %}

{% block extra_css %}
<style>
/* ── Human Design intro page ── */
.hd-hero {
    background:
        url("data:image/svg+xml,<svg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/><feColorMatrix type='saturate' values='0'/><feComponentTransfer><feFuncA type='linear' slope='0.06'/></feComponentTransfer></filter><rect width='100%25' height='100%25' filter='url(%23n)'/></svg>"),
        radial-gradient(ellipse at 15% 20%, rgba(182,131,151,0.22) 0%, transparent 55%),
        radial-gradient(ellipse at 85% 15%, rgba(45,106,139,0.14) 0%, transparent 50%),
        radial-gradient(ellipse at 70% 85%, rgba(182,131,151,0.12) 0%, transparent 45%),
        radial-gradient(ellipse at 10% 80%, rgba(45,106,139,0.10) 0%, transparent 50%),
        #FAF7F5;
    padding: 4rem 1.25rem;
}
.hd-hero-inner {
    max-width: 860px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 2rem;
    align-items: center;
}
.hd-hero-text { }
.hd-hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 4vw, 2.8rem);
    color: #222;
    margin: 0 0 1.25rem;
    line-height: 1.2;
}
.hd-hero .hero-lead {
    font-size: 1.05rem;
    color: #555;
    max-width: 520px;
    margin: 0 0 2.25rem;
    line-height: 1.75;
}
.hd-hero-visual {
    position: relative;
}
/* ── Carousel bodygraph ── */
.hd-demo-carousel {
    position: relative;
    width: 100%;
    max-width: 280px;
    margin: 0 auto;
    aspect-ratio: 851 / 1309;
}
.hd-demo-slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    opacity: 0;
    animation: hd-fade 28s infinite;
    filter: drop-shadow(0 6px 24px rgba(45,106,139,0.15));
}
/* Ogni immagine è visibile per 2.8s su 28s totali (10%) */
@keyframes hd-fade {
    0%   { opacity: 0; }
    2%   { opacity: 1; }
    8%   { opacity: 1; }
    10%  { opacity: 0; }
    100% { opacity: 0; }
}
.hd-demo-slide:nth-child(1)  { animation-delay:  0.0s; }
.hd-demo-slide:nth-child(2)  { animation-delay:  2.8s; }
.hd-demo-slide:nth-child(3)  { animation-delay:  5.6s; }
.hd-demo-slide:nth-child(4)  { animation-delay:  8.4s; }
.hd-demo-slide:nth-child(5)  { animation-delay: 11.2s; }
.hd-demo-slide:nth-child(6)  { animation-delay: 14.0s; }
.hd-demo-slide:nth-child(7)  { animation-delay: 16.8s; }
.hd-demo-slide:nth-child(8)  { animation-delay: 19.6s; }
.hd-demo-slide:nth-child(9)  { animation-delay: 22.4s; }
.hd-demo-slide:nth-child(10) { animation-delay: 25.2s; }
.hd-type-label {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    margin-top: 0.9rem;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #999;
    min-height: 1.4em;
}
.hd-type-dot {
    display: inline-block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #ccc;
    flex-shrink: 0;
    transition: background 0.9s ease;
}
.hd-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--primary-color, #B68397);
    border: 1px solid var(--primary-color, #B68397);
    border-radius: 20px;
    padding: 0.3rem 1rem;
    margin-bottom: 1.5rem;
}

/* ── Valentina box (BG5 section) ── */
.valentina-box {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 2rem;
    align-items: start;
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(45,106,139,0.15);
}
.valentina-photo {
    width: 160px;
    height: 160px;
    object-fit: cover;
    border-radius: 50%;
    border: 3px solid rgba(45,106,139,0.2);
}
.valentina-box-text p {
    font-size: 0.92rem;
    color: #444;
    line-height: 1.7;
    margin-bottom: 1rem;
}
.valentina-box-text strong { color: #222; }
.bg5-badge {
    height: 48px;
    width: auto;
    opacity: 0.85;
    margin-top: 0.5rem;
}

/* ── Sezioni ── */
.hd-prose-wrap {
    max-width: 800px;
    margin: 0 auto;
    padding: 4rem 1.25rem;
}
.hd-wide-wrap {
    max-width: 1100px;
    margin: 0 auto;
    padding: 4rem 1.25rem;
}
.hd-tinted { background: rgba(182,131,151,0.05); }
.hd-teal-tinted { background: rgba(45,106,139,0.04); }

.hd-prose-wrap h2,
.hd-wide-wrap h2 {
    font-family: 'Playfair Display', serif;
    font-size: 1.7rem;
    color: #222;
    margin-bottom: 1.25rem;
}
.hd-wide-wrap h2 { text-align: center; margin-bottom: 0.75rem; }
.hd-wide-wrap .section-lead {
    text-align: center;
    color: #666;
    font-size: 0.95rem;
    max-width: 580px;
    margin: 0 auto 2.5rem;
    line-height: 1.65;
}

.hd-prose p {
    font-size: 1rem;
    line-height: 1.85;
    color: #444;
    margin-bottom: 1.25rem;
}
.hd-prose strong { color: #222; }
.hd-prose a { color: var(--primary-color, #B68397); font-weight: 600; text-decoration: none; }
.hd-prose a:hover { text-decoration: underline; }

/* ── AEO box ── */
.aeo-box {
    background: rgba(182,131,151,0.08);
    border-left: 3px solid var(--primary-color, #B68397);
    padding: 1rem 1.5rem;
    border-radius: 0 8px 8px 0;
    margin-bottom: 2.5rem;
}
.aeo-box p {
    margin: 0;
    font-size: 0.95rem;
    font-style: italic;
    color: #444;
    line-height: 1.7;
}

/* ── Tipi grid ── */
.types-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
}
.type-card {
    background: #fff;
    border-radius: 16px;
    padding: 1.5rem 1.1rem 1.25rem;
    border: 1px solid #ece8e3;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
}
.type-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 28px rgba(0,0,0,0.08);
}
.type-accent-bar {
    width: 32px;
    height: 4px;
    border-radius: 2px;
    margin-bottom: 1rem;
}
.type-card h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    color: #222;
    margin-bottom: 0.2rem;
    line-height: 1.3;
}
.type-hd { font-size: 0.72rem; color: #aaa; font-style: italic; margin-bottom: 0.75rem; }
.type-pct {
    font-size: 1.75rem;
    font-weight: 800;
    font-family: 'Outfit', sans-serif;
    line-height: 1;
    margin-bottom: 0.75rem;
}
.type-label {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: #bbb;
    margin-bottom: 0.2rem;
    margin-top: 0.6rem;
}
.type-strategy { font-size: 0.82rem; color: #555; line-height: 1.5; }
.type-shadow { font-size: 0.78rem; color: #888; font-style: italic; }

/* ── Gerarchia ── */
.hierarchy-steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 0.5rem;
}
.h-step {
    background: #FEFCFB;
    border-radius: 16px;
    border: 1px solid rgba(182,131,151,0.14);
    padding: 2.25rem 1.5rem;
    text-align: center;
}
.h-step-num {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: var(--primary-color, #B68397);
    color: #fff;
    font-weight: 800;
    font-size: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.1rem;
    box-shadow: 0 0 0 4px rgba(182,131,151,0.15), 0 4px 16px rgba(182,131,151,0.20);
}
.h-step h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    color: #222;
    margin-bottom: 0.75rem;
}
.h-step p {
    font-size: 0.88rem;
    color: #555;
    line-height: 1.65;
    margin: 0;
}

/* ── Centri grid ── */
.centers-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 0.75rem;
    margin-top: 1.5rem;
}
.center-chip {
    background: #FAF7F5;
    border: 1px solid rgba(182,131,151,0.16);
    border-radius: 10px;
    padding: 0.85rem 1rem;
    transition: border-color 0.2s ease, transform 0.2s ease;
}
.center-chip:hover {
    border-color: rgba(182,131,151,0.42);
    transform: translateY(-2px);
}
.center-chip .cn { font-weight: 700; font-size: 0.88rem; color: #333; margin-bottom: 0.2rem; }
.center-chip .cd { font-size: 0.75rem; color: #999; }

/* ── FAQ ── */
.hd-faq { margin-top: 0.5rem; }
.faq-hd-item {
    border-bottom: 1px solid #ece8e3;
    padding: 1.25rem 0;
}
.faq-hd-item:first-child { border-top: 1px solid #ece8e3; }
.faq-hd-item h4 {
    font-size: 0.98rem;
    font-weight: 700;
    color: #333;
    margin-bottom: 0.5rem;
}
.faq-hd-item p {
    font-size: 0.9rem;
    color: #555;
    line-height: 1.7;
    margin: 0;
}

/* ── CTA finale ── */
.hd-cta {
    background:
        url("data:image/svg+xml,<svg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.70' numOctaves='3' stitchTiles='stitch'/><feColorMatrix type='saturate' values='0'/><feComponentTransfer><feFuncA type='linear' slope='0.05'/></feComponentTransfer></filter><rect width='100%25' height='100%25' filter='url(%23n)'/></svg>"),
        radial-gradient(ellipse at 50% 0%, rgba(182,131,151,0.20) 0%, transparent 60%),
        #FAF7F5;
    padding: 4.5rem 1.25rem;
    text-align: center;
}
.hd-cta h2 {
    font-family: 'Playfair Display', serif;
    font-size: 1.7rem;
    color: var(--primary-color, #B68397);
    margin-bottom: 1rem;
}
.hd-cta p {
    color: #666;
    font-size: 0.95rem;
    max-width: 500px;
    margin: 0 auto 2rem;
    line-height: 1.65;
}
.cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
    align-items: center;
}

/* ── HD vs BG5 confronto ── */
.hd-vs-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 1.5rem;
    align-items: start;
    margin-top: 0.5rem;
}
.hd-vs-card {
    background: #fff;
    border-radius: 16px;
    border: 1px solid #ece8e3;
    overflow: hidden;
}
.hd-vs-bg5 { border-color: rgba(45,106,139,0.3); }
.hd-vs-header {
    padding: 1rem 1.5rem;
    background: rgba(182,131,151,0.06);
    border-bottom: 1px solid #ece8e3;
}
.hd-vs-bg5 .hd-vs-header { background: rgba(45,106,139,0.05); border-color: rgba(45,106,139,0.15); }
.hd-vs-label {
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: rgba(182,131,151,0.12);
    color: var(--primary-color, #B68397);
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
}
.hd-vs-list {
    list-style: none;
    margin: 0;
    padding: 0.5rem 0;
}
.hd-vs-list li {
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: 0.75rem;
    padding: 0.75rem 1.5rem;
    border-bottom: 1px solid #f5f2ef;
    align-items: start;
}
.hd-vs-list li:last-child { border-bottom: none; }
.hd-vs-key {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #bbb;
    padding-top: 0.1rem;
}
.hd-vs-val { font-size: 0.87rem; color: #444; line-height: 1.5; }
.hd-vs-divider {
    font-size: 0.8rem;
    font-weight: 800;
    color: #ccc;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    align-self: center;
    text-align: center;
    padding-top: 3rem;
}

/* ── CTA mid-page sticky bar ── */
.hd-cta-bar {
    background: var(--primary-color, #B68397);
    padding: 1.25rem 1.25rem;
    text-align: center;
}
.hd-cta-bar p {
    display: inline;
    color: rgba(255,255,255,0.9);
    font-size: 0.95rem;
    margin-right: 1.25rem;
}
.hd-cta-bar .btn-white {
    display: inline-flex;
    align-items: center;
    padding: 0.65rem 1.5rem;
    background: #fff;
    color: var(--primary-color, #B68397);
    border-radius: 8px;
    font-weight: 700;
    font-size: 0.9rem;
    text-decoration: none;
    transition: opacity 0.2s;
}
.hd-cta-bar .btn-white:hover { opacity: 0.88; }

/* ── Wave dividers ── */
.wave-divider { display: block; width: 100%; overflow: hidden; line-height: 0; margin: 0; padding: 0; }
.wave-divider svg { display: block; width: 100%; }

/* ── Sezione Tipi: navy scuro ── */
.hd-types-section {
    background:
        url("data:image/svg+xml,<svg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/><feColorMatrix type='saturate' values='0'/><feComponentTransfer><feFuncA type='linear' slope='0.04'/></feComponentTransfer></filter><rect width='100%25' height='100%25' filter='url(%23n)'/></svg>"),
        radial-gradient(ellipse at 90% 10%, rgba(45,106,139,0.35) 0%, transparent 50%),
        radial-gradient(ellipse at 5% 90%, rgba(182,131,151,0.25) 0%, transparent 45%),
        #1A2D3F;
}
.hd-types-section h2 { color: #FAF7F5 !important; }
.hd-types-section .section-lead { color: rgba(250,247,245,0.72) !important; }
.hd-types-section .hd-wide-wrap > p { color: rgba(250,247,245,0.42) !important; }

/* ── Sezione BG5: teal ── */
.hd-bg5-section {
    background:
        url("data:image/svg+xml,<svg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.80' numOctaves='3' stitchTiles='stitch'/><feColorMatrix type='saturate' values='0'/><feComponentTransfer><feFuncA type='linear' slope='0.05'/></feComponentTransfer></filter><rect width='100%25' height='100%25' filter='url(%23n)'/></svg>"),
        radial-gradient(ellipse at 85% 15%, rgba(182,131,151,0.20) 0%, transparent 50%),
        radial-gradient(ellipse at 10% 80%, rgba(250,247,245,0.06) 0%, transparent 45%),
        #2D6A8B;
}
.hd-bg5-section h2 { color: #FAF7F5 !important; }
.hd-bg5-section .section-lead { color: rgba(250,247,245,0.75) !important; }
.hd-bg5-section .hd-vs-card { background: rgba(250,247,245,0.08); border-color: rgba(250,247,245,0.15); }
.hd-bg5-section .hd-vs-header { background: rgba(250,247,245,0.06) !important; border-color: rgba(250,247,245,0.10) !important; }
.hd-bg5-section .hd-vs-key { color: rgba(250,247,245,0.45); }
.hd-bg5-section .hd-vs-val { color: rgba(250,247,245,0.88); }
.hd-bg5-section .hd-vs-list li { border-bottom-color: rgba(250,247,245,0.07); }
.hd-bg5-section .hd-vs-divider { color: rgba(250,247,245,0.30); }
.hd-bg5-section .hd-vs-label { background: rgba(250,247,245,0.14) !important; color: #FAF7F5 !important; }
.hd-bg5-section .hd-vs-bg5 .hd-vs-label { background: rgba(182,131,151,0.35) !important; color: #FAF7F5 !important; }
.hd-bg5-section p[style] { color: rgba(250,247,245,0.80) !important; }
.hd-bg5-section .valentina-box { border-top-color: rgba(250,247,245,0.15); background: rgba(250,247,245,0.06); border-radius: 16px; padding: 2rem; }
.hd-bg5-section .valentina-box-text p { color: rgba(250,247,245,0.82); }
.hd-bg5-section .valentina-box-text strong { color: #FAF7F5; }
.hd-bg5-section .valentina-photo { border-color: rgba(250,247,245,0.25); }
.hd-bg5-section .bg5-badge { opacity: 0.90; filter: brightness(10); }

/* ── Responsive ── */
@media (max-width: 900px) {
    .types-grid { grid-template-columns: repeat(2, 1fr); }
    .hd-vs-grid { grid-template-columns: 1fr; }
    .hd-vs-divider { padding: 0; }
}
@media (max-width: 768px) {
    /* Hero: stack verticale, testo sopra, bodygraph sotto */
    .hd-hero-inner {
        grid-template-columns: 1fr;
        text-align: center;
        gap: 2rem;
    }
    .hd-hero .hero-lead { max-width: 100%; }
    .hd-hero .cta-row { justify-content: center; }
    /* Valentina box: stack verticale */
    .valentina-box {
        grid-template-columns: 1fr;
        text-align: center;
    }
    .valentina-photo { margin: 0 auto; }
}
@media (max-width: 640px) {
    .hierarchy-steps { grid-template-columns: 1fr; }
    .hd-hero { padding: 2.5rem 1rem 2rem; }
    .hd-prose-wrap { padding: 2.5rem 1rem; }
    .hd-wide-wrap { padding: 2.5rem 1rem; }
    .hd-cta { padding: 3rem 1rem; }
    .hd-cta-bar p { display: block; margin: 0 0 1rem; }
}
@media (max-width: 480px) {
    .types-grid { grid-template-columns: 1fr; }
    .hd-demo-carousel { max-width: 220px; }
}
</style>
{% endblock %}

{% block schema %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": {{ page.header.seo_title|json_encode|raw }},
  "description": {{ (page.header.seo_desc ?? '')|json_encode|raw }},
  "abstract": {{ (page.header.aeo_answer ?? '')|json_encode|raw }},
  "url": "{{ page.url(true) }}",
  "author": {
    "@type": "Person",
    "name": "Valentina Russo",
    "url": "{{ grav.base_url_absolute }}/chi-sono",
    "jobTitle": "Consulente Certificata BG5® e Human Design",
    "sameAs": ["https://www.instagram.com/valentinarussobg5/", "{{ grav.base_url_absolute }}"]
  },
  "publisher": {
    "@type": "Organization",
    "name": "Valentina Russo",
    "url": "{{ grav.base_url_absolute }}"
  },
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": [".aeo-box", "h1"]
  }
}
</script>

{% if page.header.faq is defined and page.header.faq %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for faq in page.header.faq %}
    {
      "@type": "Question",
      "name": {{ (faq.question ?? faq.q)|json_encode|raw }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ (faq.answer ?? faq.a)|json_encode|raw }}
      }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
{% endif %}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "{{ grav.base_url_absolute }}" },
    { "@type": "ListItem", "position": 2, "name": "Cos'è l'Human Design", "item": "{{ page.url(true) }}" }
  ]
}
</script>
{% endblock %}

{% block content %}
<main>

  {# ══ HERO ══ #}
  <section class="hd-hero">
    <div class="hd-hero-inner">
      <div class="hd-hero-text">
        <span class="hd-badge">Guida per chi inizia</span>
        <h1>Cos'è l'Human Design?</h1>
        <p class="hero-lead">Una mappa del tuo funzionamento unico: come prendi decisioni, dove metti energia, perché certe situazioni ti esauriscono e altre ti ricaricano.</p>
        <div class="cta-row">
          <a href="{{ grav.base_url }}/genera-carta" class="btn btn-primary">Calcola gratis la tua carta</a>
        </div>
      </div>
      <div class="hd-hero-visual">
        <div class="hd-demo-carousel" aria-label="Esempi di bodygraph Human Design">
          <img src="{{ grav.base_url }}/user/pages/assets/hd-demo/hd01.png" alt="Generatore — 22 lug 1988" class="hd-demo-slide">
          <img src="{{ grav.base_url }}/user/pages/assets/hd-demo/hd02.png" alt="Proiettore — 3 nov 1975" class="hd-demo-slide">
          <img src="{{ grav.base_url }}/user/pages/assets/hd-demo/hd03.png" alt="Riflettore — 14 feb 1992" class="hd-demo-slide">
          <img src="{{ grav.base_url }}/user/pages/assets/hd-demo/hd04.png" alt="Proiettore — 8 set 1969" class="hd-demo-slide">
          <img src="{{ grav.base_url }}/user/pages/assets/hd-demo/hd05.png" alt="Proiettore — 30 apr 2001" class="hd-demo-slide">
          <img src="{{ grav.base_url }}/user/pages/assets/hd-demo/hd06.png" alt="Generatore — 25 dic 1983" class="hd-demo-slide">
          <img src="{{ grav.base_url }}/user/pages/assets/hd-demo/hd07.png" alt="Proiettore — 18 giu 1997" class="hd-demo-slide">
          <img src="{{ grav.base_url }}/user/pages/assets/hd-demo/hd08.png" alt="Proiettore — 4 ago 1961" class="hd-demo-slide">
          <img src="{{ grav.base_url }}/user/pages/assets/hd-demo/hd09.png" alt="Proiettore — 11 ott 2004" class="hd-demo-slide">
