# Grav CMS .htaccess — valentinarussobg5.com
# Questo file va rinominato in .htaccess nella root di public_html
# NOTA: sostituisce quello installato da Grav. Aggiunge redirect www → non-www.

# Disabilita visualizzazione directory
Options -Indexes

# Abilita mod_rewrite
<IfModule mod_rewrite.c>
    RewriteEngine On

    ## REDIRECT www → non-www
    RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
    RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

    ## REDIRECT HTTP → HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

    ## REDIRECT vecchi URL WordPress → Grav equivalenti (301)
    RewriteRule ^2025/02/03/relazioni-e-bisogni-emotivi/?$ /blog/relazioni-bisogni-emotivi [R=301,L]
    RewriteRule ^2025/03/24/la-mente-innamorata1/?$ /blog/la-mente-innamorata-1 [R=301,L]
    RewriteRule ^category/la-mente-innamorata/?$ /blog [R=301,L]
    RewriteRule ^info-contatti/?$ /contatti [R=301,L]
    RewriteRule ^sistema-mentecorpo/?$ /servizi [R=301,L]
    RewriteRule ^wp-admin/?$ / [R=301,L]
    RewriteRule ^wp-login\.php$ / [R=301,L]
    RewriteRule ^feed/?$ / [R=301,L]

    ## REDIRECT admin.php → /admin (Grav Admin)
    RewriteRule ^admin\.php$ /admin [R=301,L]

    ## Sitemap dinamica
    RewriteRule ^sitemap\.xml$ sitemap.xml.php [L]

    ## Blocca accesso a file sensibili (non system/assets né themes/plugins — contengono CSS/JS)
    RewriteRule ^(\.git|cache|bin|logs|backup|vendor|webserver-configs)(/|$) [F,L]
    RewriteRule ^user/(config|data|accounts)(/|$) [F,L]
    RewriteRule ^(system/src|system/vendor)(/|$) [F,L]
    RewriteRule \.(?:yaml|twig|md)$ [F,L]

    ## Servi file statici direttamente
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ /index.php [QSA,L]
</IfModule>

# Tipi MIME utili
<IfModule mod_mime.c>
    AddType application/javascript .js
    AddType text/css .css
    AddType image/svg+xml .svg
    AddType image/webp .webp
    AddType font/woff2 .woff2
</IfModule>

# Compressione gzip
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json text/xml
</IfModule>

# Browser caching
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
</IfModule>
